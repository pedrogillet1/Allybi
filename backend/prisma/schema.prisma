generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                   String                 @id @default(uuid())
  email                String                 @unique
  firstName            String?
  lastName             String?
  profileImage         String?
  passwordHash         String?
  salt                 String?
  googleId             String?                @unique
  appleId              String?                @unique
  phoneNumber          String?                @unique
  isEmailVerified      Boolean                @default(false)
  isPhoneVerified      Boolean                @default(false)
  subscriptionTier     String                 @default("free")
  role                 String                 @default("user")
  storageUsedBytes     BigInt                 @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  recoveryKeyHash      String?
  masterKeyEncrypted   String?
  tenantKeyEncrypted   String?
  tenantKeyProvider    String?
  tenantKeyMeta        Json?
  auditLogs            AuditLog[]
  conversationFeedback ConversationFeedback[]
  conversations        Conversation[]
  documents            Document[]
  folders              Folder[]
  ragQueryMetrics      RAGQueryMetrics[]
  sessions             Session[]
  twoFactorAuth        TwoFactorAuth?
  userLifetimeValue    UserLifetimeValue?
  verificationCodes    VerificationCode[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  tokenVersion     Int       @default(1)
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastActivityAt   DateTime  @default(now())
  revokedAt        DateTime?
  ipAddress        String?
  lastIpAddress    String?
  userAgent        String?
  deviceId         String?
  deviceType       String?
  deviceName       String?
  isActive         Boolean   @default(true)
  isSuspicious     Boolean   @default(false)
  suspicionReason  String?
  country          String?
  city             String?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([isActive])
  @@map("sessions")
}

model TwoFactorAuth {
  id                   String   @id @default(uuid())
  userId               String   @unique
  secret               String?
  secretEncrypted      String?
  backupCodes          String?
  backupCodesEncrypted String?
  isEnabled            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_auth")
}

model Folder {
  id                String     @id @default(uuid())
  userId            String
  name              String?
  description       String?
  emoji             String?
  color             String?
  parentFolderId    String?
  path              String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  nameEncrypted     String?
  dataKeyEncrypted  String?
  dataKeyMeta       Json?
  encryptionSalt    String?
  encryptionIV      String?
  encryptionAuthTag String?
  isDeleted         Boolean    @default(false)
  deletedAt         DateTime?
  documents         Document[]
  parentFolder      Folder?    @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: Cascade)
  subfolders        Folder[]   @relation("FolderHierarchy")
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentFolderId])
  @@index([path])
  @@index([userId, parentFolderId])
  @@index([parentFolderId, name])
  @@index([userId, isDeleted])
  @@index([userId, parentFolderId, name]) // For folder existence lookup during bulk upload
  @@map("folders")
}

model Document {
  id                         String                     @id @default(uuid())
  userId                     String
  folderId                   String?
  filename                   String?
  encryptedFilename          String
  fileSize                   Int
  mimeType                   String
  fileHash                   String
  status                     String                     @default("uploaded")
  parentVersionId            String?
  isEncrypted                Boolean                    @default(false)
  encryptionSalt             String?
  encryptionIV               String?
  encryptionAuthTag          String?
  filenameEncrypted          String?
  extractedTextEncrypted     String?
  previewTextEncrypted       String?
  renderableContentEncrypted String?
  displayTitleEncrypted      String?
  dataKeyEncrypted           String?
  dataKeyMeta                Json?
  renderableContent          String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  language                   String                     @default("en")
  chunksCount                Int?                       @default(0)
  embeddingsGenerated        Boolean                    @default(false)
  error                      String?
  displayTitle               String?
  rawText                    String?
  previewText                String?
  uploadSessionId            String?
  chunks                     DocumentChunk[]
  embeddings                 DocumentEmbedding[]
  metadata                   DocumentMetadata?
  processingMetrics          DocumentProcessingMetrics?
  folder                     Folder?                    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  parentVersion              Document?                  @relation("DocumentVersions", fields: [parentVersionId], references: [id])
  versions                   Document[]                 @relation("DocumentVersions")
  user                       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folderId])
  @@index([parentVersionId])
  @@index([userId, status])
  @@index([status])
  @@index([mimeType])
  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([folderId, status])
  @@index([userId, folderId, status])
  @@index([filename])
  @@index([userId, filename])
  @@index([fileHash])
  @@index([userId, fileHash, filename])
  @@index([language])
  @@index([userId, language])
  @@index([uploadSessionId])
  @@map("documents")
}

model DocumentMetadata {
  id                       String    @id @default(uuid())
  documentId               String    @unique
  extractedText            String?
  extractedTextEncrypted   String?
  entitiesEncrypted        String?
  classificationEncrypted  String?
  ocrConfidence            Float?
  pageCount                Int?
  wordCount                Int?
  characterCount           Int?
  thumbnailUrl             String?
  entities                 String?
  classification           String?
  summary                  String?
  author                   String?
  creationDate             DateTime?
  modificationDate         DateTime?
  language                 String?
  topics                   String?
  keyEntities              String?
  hasSignature             Boolean   @default(false)
  hasTables                Boolean   @default(false)
  hasImages                Boolean   @default(false)
  markdownContent          String?
  markdownUrl              String?
  markdownStructure        String?
  sheetCount               Int?
  slideCount               Int?
  slidesData               String?
  pptxMetadata             String?
  slideGenerationStatus    String?   @default("pending")
  slideGenerationError     String?
  previewPdfStatus         String?   @default("pending")
  previewPdfKey            String?
  previewPdfError          String?
  previewPdfAttempts       Int?      @default(0)
  previewPdfUpdatedAt      DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  classificationConfidence Float?
  domain                   String?
  domainConfidence         Float?
  document                 Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_metadata")
}

model DocumentChunk {
  id            String   @id @default(uuid())
  documentId    String
  chunkIndex    Int
  text          String?
  textEncrypted String?
  page          Int?
  startChar     Int?
  endChar       Int?
  embedding     Bytes?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([documentId, chunkIndex])
  @@index([documentId, page])
  @@map("document_chunks")
}

model VerificationCode {
  id          String   @id @default(uuid())
  userId      String
  type        String
  code        String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("verification_codes")
}

model PendingUser {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  salt               String
  firstName          String?
  lastName           String?
  phoneNumber        String?
  emailCode          String?
  phoneCode          String?
  emailVerified      Boolean  @default(false)
  phoneVerified      Boolean  @default(false)
  expiresAt          DateTime
  createdAt          DateTime @default(now())
  recoveryKeyHash    String?
  masterKeyEncrypted String?

  @@index([email])
  @@map("pending_users")
}

model Conversation {
  id                String                 @id @default(uuid())
  userId            String
  title             String?                @default("New Chat")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  titleEncrypted    String?
  encryptionSalt    String?
  encryptionIV      String?
  encryptionAuthTag String?
  dataKeyEncrypted  String?
  dataKeyMeta       Json?
  contextType       String?
  contextId         String?
  contextName       String?
  contextMeta       Json?
  scopeDescription  String?
  scopeDocumentIds  String[]               @default([])
  summary           String?
  isPinned          Boolean                @default(false)
  isDeleted         Boolean                @default(false)
  deletedAt         DateTime?
  documentList      Json?
  lastDocumentId    String?
  feedback          ConversationFeedback[]
  metrics           ConversationMetrics?
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          Message[]
  ragQueries        RAGQueryMetrics[]

  @@index([userId])
  @@index([contextType, contextId])
  @@index([userId, updatedAt])
  @@index([userId, isDeleted, isPinned, updatedAt])
  @@map("conversations")
}

model Message {
  id                String                 @id @default(uuid())
  conversationId    String
  role              String
  content           String?
  contentEncrypted  String?
  metadata          String?
  createdAt         DateTime               @default(now())
  isEncrypted       Boolean                @default(false)
  encryptionSalt    String?
  encryptionIV      String?
  encryptionAuthTag String?
  isDocument        Boolean                @default(false)
  documentTitle     String?
  documentFormat    String?
  markdownContent   String?
  calculationResult Json?
  contextEntities   Json?
  feedback          ConversationFeedback[]
  conversation      Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  ragMetrics        RAGQueryMetrics?

  @@index([conversationId])
  @@index([isDocument])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String?
  ipAddress String?
  userAgent String?
  status    String
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model DocumentEmbedding {
  id                String                   @id @default(uuid())
  documentId        String
  chunkIndex        Int
  content           String
  embedding         String
  metadata          String
  createdAt         DateTime                 @default(now())
  contentTsv        Unsupported("tsvector")?
  userId            String?                  @map("user_id")
  pageNumber        Int?                     @map("page_number")
  sectionName       String?                  @map("section_name")
  chunkText         String?                  @map("chunk_text")
  microSummary      String?                  @map("micro_summary")
  chunkType         String?                  @map("chunk_type")
  pineconeNamespace String?                  @map("pinecone_namespace")
  embeddingModel    String?                  @map("embedding_model")
  searchVector      Unsupported("tsvector")? @map("search_vector")
  updatedAt         DateTime?                @map("updated_at")
  document          Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([documentId, chunkIndex])
  @@index([userId])
  @@index([chunkType])
  @@index([documentId, sectionName])
  @@index([documentId, pageNumber])
  @@index([pineconeNamespace])
  @@index([userId, documentId])
  @@map("document_embeddings")
}

model AnalyticsUserActivity {
  id                   String    @id @default(uuid())
  userId               String
  date                 DateTime
  sessionsCount        Int       @default(0)
  messagesSent         Int       @default(0)
  documentsUploaded    Int       @default(0)
  conversationsCreated Int       @default(0)
  ragQueriesCount      Int       @default(0)
  totalActiveMinutes   Int       @default(0)
  lastActiveAt         DateTime?
  featuresUsed         String[]  @default([])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@map("analytics_user_activity")
}

model AnalyticsSystemHealth {
  id                  String   @id @default(uuid())
  timestamp           DateTime @default(now())
  databaseConnections Int      @default(0)
  databaseSizeBytes   BigInt   @default(0)
  slowQueryCount      Int      @default(0)
  requestsPerMinute   Int      @default(0)
  avgResponseTimeMs   Int      @default(0)
  errorRate           Float    @default(0)
  cpuUsagePercent     Float    @default(0)
  memoryUsagePercent  Float    @default(0)
  diskUsagePercent    Float    @default(0)
  pineconeLatencyMs   Int      @default(0)
  geminiLatencyMs     Int      @default(0)
  s3LatencyMs         Int      @default(0)

  @@index([timestamp])
  @@map("analytics_system_health")
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  adminUserId String
  timestamp   DateTime @default(now())
  action      String
  resource    String?
  resourceId  String?
  ipAddress   String?
  userAgent   String?
  details     Json?

  @@index([adminUserId])
  @@index([timestamp])
  @@index([action])
  @@map("admin_audit_logs")
}

model ConversationFeedback {
  id             String       @id @default(cuid())
  conversationId String
  messageId      String?
  userId         String
  feedbackType   String
  rating         Int?
  sentiment      String?
  comment        String?
  categories     String[]
  wasHelpful     Boolean?
  hadSources     Boolean      @default(false)
  sourceCount    Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message?     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([userId])
  @@index([feedbackType])
  @@index([createdAt])
  @@map("conversation_feedback")
}

model ConversationMetrics {
  id                String       @id @default(cuid())
  conversationId    String       @unique
  startedAt         DateTime
  endedAt           DateTime?
  duration          Int?
  totalMessages     Int          @default(0)
  userMessages      Int          @default(0)
  assistantMessages Int          @default(0)
  completed         Boolean      @default(false)
  abandoned         Boolean      @default(false)
  hadFallback       Boolean      @default(false)
  fallbackCount     Int          @default(0)
  ragQueriesCount   Int          @default(0)
  sourcesUsedCount  Int          @default(0)
  avgRelevanceScore Float?
  userRating        Int?
  userFeedback      String?
  updatedAt         DateTime     @updatedAt
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([startedAt])
  @@index([completed])
  @@map("conversation_metrics")
}

model DocumentProcessingMetrics {
  id                    String    @id @default(cuid())
  documentId            String    @unique
  uploadStartedAt       DateTime
  uploadCompletedAt     DateTime?
  uploadDuration        Int?
  uploadFailed          Boolean   @default(false)
  uploadError           String?
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  processingDuration    Int?
  processingFailed      Boolean   @default(false)
  processingError       String?
  textExtractionMethod  String?
  textExtractionSuccess Boolean   @default(false)
  textExtractionTime    Int?
  textLength            Int?
  ocrUsed               Boolean   @default(false)
  ocrSuccess            Boolean   @default(false)
  ocrConfidence         Float?
  ocrTime               Int?
  embeddingStartedAt    DateTime?
  embeddingCompletedAt  DateTime?
  embeddingDuration     Int?
  embeddingsCreated     Int       @default(0)
  chunksCreated         Int       @default(0)
  timesQueried          Int       @default(0)
  lastQueriedAt         DateTime?
  updatedAt             DateTime  @updatedAt
  document              Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([uploadStartedAt])
  @@map("document_processing_metrics")
}

model RAGQueryMetrics {
  id                String        @id @default(cuid())
  conversationId    String?
  messageId         String?       @unique
  userId            String
  query             String
  queryLanguage     String?
  retrievalMethod   String
  usedBM25          Boolean       @default(false)
  usedPinecone      Boolean       @default(false)
  startedAt         DateTime      @default(now())
  completedAt       DateTime?
  totalLatency      Int?
  embeddingLatency  Int?
  bm25Latency       Int?
  pineconeLatency   Int?
  llmLatency        Int?
  chunksRetrieved   Int           @default(0)
  bm25Results       Int           @default(0)
  pineconeResults   Int           @default(0)
  documentsUsed     Int           @default(0)
  topScore          Float?
  avgScore          Float?
  minRelevanceScore Float?
  passedThreshold   Boolean       @default(false)
  needsRefinement   Boolean       @default(false)
  refinementReason  String?
  hadFallback       Boolean       @default(false)
  responseGenerated Boolean       @default(false)
  uniqueDocuments   Int           @default(0)
  sourceCoverage    Float?
  conversation      Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message           Message?      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([startedAt])
  @@index([retrievalMethod])
  @@map("rag_query_metrics")
}

model APIPerformanceLog {
  id             String    @id @default(cuid())
  service        String
  endpoint       String
  method         String
  requestSize    Int?
  requestData    Json?
  responseSize   Int?
  statusCode     Int
  success        Boolean
  errorMessage   String?
  errorCode      String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  latency        Int?
  rateLimitHit   Boolean   @default(false)
  retryCount     Int       @default(0)
  tokensUsed     Int?
  estimatedCost  Float?
  userId         String?
  conversationId String?

  @@index([service])
  @@index([startedAt])
  @@index([success])
  @@index([rateLimitHit])
  @@map("api_performance_logs")
}

model UserLifetimeValue {
  id                  String    @id @default(cuid())
  userId              String    @unique
  totalSessions       Int       @default(0)
  totalMessages       Int       @default(0)
  totalDocuments      Int       @default(0)
  totalConversations  Int       @default(0)
  totalTimeSpent      Int       @default(0)
  avgSessionDuration  Float?
  daysSinceSignup     Int?
  lastActiveAt        DateTime?
  isActive            Boolean   @default(true)
  isChurned           Boolean   @default(false)
  churnedAt           DateTime?
  churnReason         String?
  subscriptionTier    String?
  lifetimeRevenue     Float?    @default(0)
  estimatedValue      Float?
  featuresUsed        String[]
  featureAdoptionRate Float?
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([isChurned])
  @@map("user_lifetime_value")
}

model TokenUsage {
  id             String   @id @default(cuid())
  userId         String?
  conversationId String?
  messageId      String?
  model          String
  provider       String
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  totalTokens    Int      @default(0)
  inputCost      Float    @default(0)
  outputCost     Float    @default(0)
  totalCost      Float    @default(0)
  requestType    String
  latencyMs      Int?
  success        Boolean  @default(true)
  errorMessage   String?
  wasCached      Boolean  @default(false)
  cacheHit       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([conversationId])
  @@index([model])
  @@index([provider])
  @@index([requestType])
  @@index([createdAt])
  @@map("token_usage")
}

model DailyAnalyticsAggregate {
  id                         String   @id @default(cuid())
  date                       DateTime @unique @db.Date
  totalUsers                 Int      @default(0)
  newUsers                   Int      @default(0)
  activeUsers                Int      @default(0)
  returningUsers             Int      @default(0)
  totalSessions              Int      @default(0)
  avgSessionDuration         Int      @default(0)
  bounceRate                 Float    @default(0)
  totalConversations         Int      @default(0)
  newConversations           Int      @default(0)
  avgMessagesPerConversation Float    @default(0)
  totalMessages              Int      @default(0)
  userMessages               Int      @default(0)
  assistantMessages          Int      @default(0)
  avgResponseTime            Int      @default(0)
  totalDocuments             Int      @default(0)
  newDocuments               Int      @default(0)
  documentsProcessed         Int      @default(0)
  totalStorageBytes          BigInt   @default(0)
  totalRagQueries            Int      @default(0)
  avgRagLatency              Int      @default(0)
  ragSuccessRate             Float    @default(0)
  fallbackRate               Float    @default(0)
  totalInputTokens           Int      @default(0)
  totalOutputTokens          Int      @default(0)
  totalTokenCost             Float    @default(0)
  geminiCalls                Int      @default(0)
  embeddingCalls             Int      @default(0)
  totalErrors                Int      @default(0)
  errorRate                  Float    @default(0)
  topFeatures                Json?
  positiveRatings            Int      @default(0)
  negativeRatings            Int      @default(0)
  satisfactionRate           Float    @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([date])
  @@map("daily_analytics_aggregates")
}

model ErrorLog {
  id             String    @id @default(cuid())
  userId         String?
  service        String
  errorType      String
  errorMessage   String
  errorStack     String?
  severity       String    @default("error")
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  conversationId String?
  requestPath    String?
  httpMethod     String?
  statusCode     Int?
  metadata       Json?
  createdAt      DateTime  @default(now())

  @@index([service])
  @@index([errorType])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
  @@map("error_logs")
}

model SystemHealthMetric {
  id         String   @id @default(cuid())
  metricType String
  metricName String
  value      Float
  unit       String?
  status     String   @default("healthy")
  threshold  Float?
  metadata   Json?
  recordedAt DateTime @default(now())

  @@index([metricType])
  @@index([metricName])
  @@index([recordedAt])
  @@map("system_health_metrics")
}

model QueryTelemetry {
  id                   String   @id @default(cuid())
  queryId              String   @unique
  userId               String
  conversationId       String?
  messageId            String?
  environment          String   @default("prod")
  timestamp            DateTime @default(now())
  queryText            String?  @db.Text
  intent               String
  intentConfidence     Float
  questionType         String?
  queryScope           String?
  domain               String?
  depth                String?
  family               String?
  subIntent            String?
  isMultiIntent        Boolean  @default(false)
  segmentCount         Int      @default(1)
  matchedPatterns      String[] @default([])
  matchedKeywords      String[] @default([])
  blockedByNegatives   Boolean  @default(false)
  overrideReason       String?
  classificationTimeMs Int?
  chunksReturned       Int      @default(0)
  bm25Results          Int      @default(0)
  vectorResults        Int      @default(0)
  distinctDocs         Int      @default(0)
  documentIds          String[] @default([])
  topRelevanceScore    Float?
  avgRelevanceScore    Float?
  minRelevanceScore    Float?
  totalSnippetChars    Int      @default(0)
  retrievalAdequate    Boolean  @default(false)
  retrievalMethod      String?
  mergeStrategy        String?
  expansionAttempts    Int      @default(0)
  meetsAllFloors       Boolean  @default(false)
  retrievalBudgets     Json?
  evidenceGateAction   String?
  evidenceGateMessage  String?
  evidenceShouldProceed Boolean @default(true)
  formatMode           String?
  formattingPassed     Boolean  @default(true)
  formattingViolations String[] @default([])
  bulletPolicy         Json?
  constraints          Json?
  resolvedLang         String   @default("en")
  languageSource       String   @default("default")
  detectedLang         String?
  languageMismatch     Boolean  @default(false)
  enforcementApplied   Boolean  @default(false)
  bannedPhrasesFound   String[] @default([])
  isUseful             Boolean  @default(true)
  failureCategory      String?
  hadFallback          Boolean  @default(false)
  fallbackScenario     String?
  citationCount        Int      @default(0)
  sourcesMissing       Boolean  @default(false)
  answerLength         Int      @default(0)
  ungroundedClaims     Boolean  @default(false)
  underinformative     Boolean  @default(false)
  metadataOnly         Boolean  @default(false)
  thinRetrieval        Boolean  @default(false)
  incompleteSummary    Boolean  @default(false)
  compareSingleDoc     Boolean  @default(false)
  wasTruncated         Boolean  @default(false)
  ttft                 Int?
  retrievalMs          Int?
  llmMs                Int?
  embeddingMs          Int?
  pineconeMs           Int?
  bm25Ms               Int?
  formattingMs         Int?
  totalMs              Int?
  model                String?
  inputTokens          Int      @default(0)
  outputTokens         Int      @default(0)
  totalTokens          Int      @default(0)
  estimatedCostUsd     Float    @default(0)
  contextUsed          Int      @default(0)
  contextMax           Int      @default(0)
  streamStarted        Boolean  @default(false)
  firstTokenReceived   Boolean  @default(false)
  streamEnded          Boolean  @default(false)
  clientDisconnected   Boolean  @default(false)
  sseErrors            String[] @default([])
  chunksSent           Int      @default(0)
  streamDurationMs     Int?
  wasAborted           Boolean  @default(false)
  pipelineSignature    String?
  handler              String?
  pipelineFamily       String?
  ragEnabled           Boolean  @default(false)
  hybridSearchUsed     Boolean  @default(false)
  productHelpUsed      Boolean  @default(false)
  mathUsed             Boolean  @default(false)
  routingReason        String?
  answerMode           String?
  outputShape          String?
  operatorFamily       String?
  userAskedForBullets  Boolean  @default(false)
  userAskedForTable    Boolean  @default(false)
  userAskedForQuote    Boolean  @default(false)
  userAskedForSteps    Boolean  @default(false)
  userAskedForShort    Boolean  @default(false)
  navOpenRequested     Boolean  @default(false)
  navWhereRequested    Boolean  @default(false)
  navDiscoverRequested Boolean  @default(false)
  preferredNavType     String?
  errors               Json?
  warnings             String[] @default([])
  hasErrors            Boolean  @default(false)

  @@index([userId])
  @@index([conversationId])
  @@index([timestamp])
  @@index([intent])
  @@index([questionType])
  @@index([domain])
  @@index([isUseful])
  @@index([failureCategory])
  @@index([resolvedLang])
  @@index([hasErrors])
  @@index([userId, timestamp])
  @@index([environment, timestamp])
  @@map("query_telemetry")
}

model ModelCall {
  id               String   @id @default(cuid())
  userId           String
  tenantId         String?
  traceId          String
  turnId           String?
  provider         String
  model            String
  stage            String
  status           String
  errorCode        String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  firstTokenMs     Int?
  durationMs       Int?
  retries          Int?
  at               DateTime
  meta             Json?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([traceId])
  @@index([provider])
  @@index([model])
  @@index([stage])
  @@index([status])
  @@index([at])
  @@map("model_calls")
}

model UsageEvent {
  id             String   @id @default(cuid())
  userId         String
  tenantId       String?
  eventType      String
  at             DateTime
  conversationId String?
  documentId     String?
  folderId       String?
  locale         String?
  deviceType     String?
  meta           Json?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([at])
  @@map("usage_events")
}

model RetrievalEvent {
  id                 String   @id @default(cuid())
  userId             String
  tenantId           String?
  traceId            String
  turnId             String?
  conversationId     String?
  operator           String
  intent             String
  domain             String
  docLockEnabled     Boolean  @default(false)
  strategy           String
  candidates         Int?
  selected           Int?
  evidenceStrength   Float?
  refined            Boolean?
  wrongDocPrevented  Boolean?
  sourcesCount       Int?
  navPillsUsed       Boolean?
  fallbackReasonCode String?
  at                 DateTime
  meta               Json?
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([traceId])
  @@index([at])
  @@map("retrieval_events")
}

model IngestionEvent {
  id                  String   @id @default(cuid())
  userId              String
  tenantId            String?
  documentId          String?
  filename            String?
  mimeType            String?
  sizeBytes           Int?
  status              String
  errorCode           String?
