}

model Admin {
  id           String         @id @default(uuid())
  username     String         @unique
  passwordHash String
  name         String?
  role         String         @default("admin")
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lastLoginAt  DateTime?
  sessions     AdminSession[]

  @@index([username])
  @@map("admins")
}

model AdminSession {
  id               String   @id @default(uuid())
  adminId          String
  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  lastActivityAt   DateTime @default(now())
  ipAddress        String?
  userAgent        String?
  isActive         Boolean  @default(true)
  admin            Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([isActive])
  @@map("admin_sessions")
}

model HourlyMetrics {
  id                String   @id @default(cuid())
  bucketHour        DateTime @unique
  activeUsers       Int      @default(0)
  messages          Int      @default(0)
  queries           Int      @default(0)
  documentsUploaded Int      @default(0)
  weakEvidenceCount Int      @default(0)
  weakEvidenceRate  Float    @default(0)
  apiRequests       Int      @default(0)
  apiErrorCount     Int      @default(0)
  apiErrorRate      Float    @default(0)
  p50LatencyMs      Int?
  p95LatencyMs      Int?
  avgLatencyMs      Int?
  ttftAvgMs         Int?
  llmCostUsd        Float    @default(0)
  llmTokensIn       Int      @default(0)
  llmTokensOut      Int      @default(0)
  llmCalls          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([bucketHour])
  @@map("hourly_metrics")
}

