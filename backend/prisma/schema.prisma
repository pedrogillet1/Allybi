  uploaded
  available
  enriching
  indexed
  ready
  failed
  skipped
}

// ============================================================================
// Enterprise Observability Tables
// ============================================================================

model TraceSpan {
  id        String    @id @default(cuid())
  traceId   String    @db.VarChar(64)
  stepName  String    @db.VarChar(50) // DOC_INDEX_LOAD, QUERY_NORMALIZE, INTENT_RESOLVE, etc.
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  durationMs Int?
  status    String    @db.VarChar(20) // ok, error, skipped
  errorCode String?   @db.VarChar(50)
  metadata  Json?     // Step-specific data (redacted)

  @@index([traceId])
  @@index([startedAt])
  @@index([stepName])
  @@map("trace_spans")
}

model BankUsageEvent {
  id          String   @id @default(cuid())
  traceId     String   @db.VarChar(64)
  bankType    String   @db.VarChar(30) // domain_bank, operator_bank, policy_bank, formatting_bank
  bankId      String   @db.VarChar(100) // Bank filename or stable ID
  bankVersion String?  @db.VarChar(64) // SHA256 of file contents
  stageUsed   String   @db.VarChar(30) // ROUTER, PROMPT_BUILD, POSTPROCESS
  createdAt   DateTime @default(now())

  @@index([traceId])
  @@index([bankId])
  @@index([bankType])
  @@map("bank_usage_events")
}

model QueryKeyword {
  id        String   @id @default(cuid())
  traceId   String   @db.VarChar(64)
  keyword   String   @db.VarChar(100)
  weight    Float?
  createdAt DateTime @default(now())

  @@index([traceId])
  @@index([keyword])
  @@map("query_keywords")
}

model QueryEntity {
  id         String   @id @default(cuid())
  traceId    String   @db.VarChar(64)
  entityType String   @db.VarChar(50) // company, date, amount, person, etc.
  value      String   @db.VarChar(200)
  confidence Float?
  createdAt  DateTime @default(now())

  @@index([traceId])
  @@index([entityType])
  @@map("query_entities")
}

model SocialSnapshot {
  id         String   @id @default(cuid())
  platform   String   @db.VarChar(30) // instagram, youtube, linkedin, twitter, tiktok
  followers  Int
  posts      Int?
  engagement Float?   // engagement rate if available
  capturedAt DateTime @default(now())

  @@index([platform, capturedAt])
  @@map("social_snapshots")
}

model UserAcquisition {
  id          String   @id @default(cuid())
  userId      String   @unique
  source      String   @db.VarChar(50) // instagram, facebook, google, youtube, tiktok, direct, organic
  campaign    String?  @db.VarChar(100)
  medium      String?  @db.VarChar(50)
  referrerUrl String?  @db.VarChar(500)
  landingPage String?  @db.VarChar(500)
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([createdAt])
  @@map("user_acquisitions")
}
