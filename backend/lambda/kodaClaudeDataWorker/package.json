{
  "name": "koda-claude-data-worker",
  "version": "2.0.0",
  "description": "Tier 2 Dataset Generator - Lambda + Orchestrator",
  "main": "index.mjs",
  "type": "module",
  "scripts": {
    "orchestrate": "node orchestrator.mjs",
    "orchestrate:dry": "node orchestrator.mjs --dry-run",
    "orchestrate:docs": "node documentsOrchestrator.mjs --lambda",
    "orchestrate:docs:local": "node documentsOrchestrator.mjs",
    "orchestrate:docs:dry": "node documentsOrchestrator.mjs --dry-run",
    "postprocess": "node postprocessor.mjs",
    "package": "powershell Compress-Archive -Path index.mjs,documentsSchema.mjs,documentsPrompts.mjs,rateLimiter.mjs,package.json,node_modules -DestinationPath function.zip -Force"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@upstash/redis": "^1.34.3",
    "dotenv": "^17.2.3"
  }
}
