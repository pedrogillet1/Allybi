      "role": "corporation",
      "notes": "US corporation with Inc suffix",
      "normalizationContract": {
        "type": "party",
        "localeSensitivity": "medium",
        "ambiguityPolicy": "normalize_if_confident",
        "confidenceModel": "strict_regex",
        "requiresContextKeys": [],
        "curationReason": "signals:stable_pattern+typed_party"
