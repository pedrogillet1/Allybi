{
  "_meta": {
    "id": "layout_signals",
    "version": "2.1.0",
    "description": "Layout and structure signals for Koda extraction + retrieval. Normalizes signals from PDF/DOCX/PPTX/XLSX/OCR to inform chunk scoring, evidence packaging, and locate_content breadcrumbs. Includes heuristics to detect headers/footers, tables, lists, key-value blocks, and scanned/OCR dominance.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "caseInsensitive": true,
    "stripDiacritics": true,
    "useRegex": true,
    "maxSignalsPerChunk": 12,
    "emitFooterHeaderCandidates": true,
    "emitTableSignals": true,
    "emitListSignals": true,
    "emitKVSignals": true,
    "emitOCRSignals": true
  },
  "signals": {
    "header_footer_detection": {
      "_comment": "Detect repeated lines across pages that are likely headers/footers. Used to downrank noise and avoid false headings.",
      "enabled": true,
      "thresholds": {
        "minRepeatCount": 3,
        "minSimilarity": 0.86,
        "maxLineChars": 120
      },
      "patterns": {
        "likelyPageNumber": [
          "^\\s*(page|p[aûÀ]gina)\\s*\\d+\\s*(of|de)\\s*\\d+\\s*$",
          "^\\s*\\d+\\s*/\\s*\\d+\\s*$"
        ],
        "likelyConfidential": [
          "^\\s*(confidential|proprietary|internal use only|do not distribute)\\s*$",
          "^\\s*(confidencial|uso interno|n[aûÈ]o distribuir)\\s*$",
          "^\\s*(confidencial|uso interno|no distribuir)\\s*$"
        ]
      }
    },
    "table_detection": {
      "_comment": "Table signals for markdown tables, spreadsheet-like rows, or OCR tables.",
      "enabled": true,
      "patterns": {
        "markdownTableRow": "^\\s*\\|.*\\|\\s*$",
        "markdownSeparator": "^\\s*\\|[\\s:-]+\\|\\s*$",
        "delimitedRow": "^\\s*[^\\n]+\\s*(\\t|\\s{2,}|\\|)\\s*[^\\n]+\\s*(\\t|\\s{2,}|\\|)\\s*[^\\n]+\\s*$"
      },
      "thresholds": {
        "minRowsToTagTableBlock": 2,
        "minColumnsToConsider": 2
      },
      "tags": ["table", "tabular"]
    },
    "list_detection": {
      "_comment": "Detect bullet and numbered list structures.",
      "enabled": true,
      "patterns": {
        "bullet": "^\\s*[-ãÂ*+]\\s+.+$",
        "numbered": "^\\s*\\d+\\.\\s+.+$",
        "roman": "^\\s*[IVXLCDM]{1,6}\\.\\s+.+$"
      },
      "tags": ["list"]
    },
    "kv_detection": {
      "_comment": "Detect key-value lines like 'Total investment: R$ 900,000'.",
      "enabled": true,
      "patterns": {
        "kvColon": "^\\s*([A-Za-zû-ûû-ûÑû¡-û¢0-9][A-Za-zû-ûû-ûÑû¡-û¢0-9\\s/()\\-]{2,50})\\s*:\\s*(.+)$",
        "kvDash": "^\\s*([A-Za-zû-ûû-ûÑû¡-û¢0-9][A-Za-zû-ûû-ûÑû¡-û¢0-9\\s/()\\-]{2,50})\\s*[ãã-]\\s*(.+)$"
      },
      "thresholds": {
        "minValueChars": 2,
        "maxKeyChars": 60
      },
      "tags": ["kv"]
    },
    "heading_detection": {
      "_comment": "Lightweight heading hints (full heading extraction uses section_heading_patterns).",
      "enabled": true,
      "patterns": {
        "allCapsLine": "^\\s*[A-Z0-9][A-Z0-9\\s/&()\\-]{6,140}\\s*$",
        "titleCaseLike": "^\\s*[A-Z][a-z].{3,120}$"
      },
      "tags": ["heading_hint"]
    },
    "numeric_density": {
      "_comment": "Detect numeric-heavy chunks to boost table preference and numeric grounding checks.",
      "enabled": true,
      "thresholds": {
        "numericCharRatioGte": 0.20,
        "currencyTokenCountGte": 1,
        "minChars": 80
      },
      "currencyPatterns": [
        "R\\$\\s*\\d",
        "\\$\\s*\\d",
        "ã˜\\s*\\d",
        "ôÈ\\s*\\d"
      ],
      "tags": ["numeric_heavy"]
    },
    "ocr_quality": {
      "_comment": "Tag OCR-dominant / low-confidence chunks for scoring penalties and retrieval profile switching.",
      "enabled": true,
      "thresholds": {
        "ocrDominantIfRatioGte": 0.55,
        "lowConfidenceIfLt": 0.70
      },
      "noisePatterns": [
        "[\\uFFFD]",
        "(?:\\b[a-zA-Z]\\b\\s*){10,}",
        "(?:[|/\\\\_\\-]{6,})"
      ],
      "tags": ["ocr", "ocr_low_confidence", "ocr_dominant"]
    },
    "page_region_hints": {
      "_comment": "Optional: tag top/bottom-of-page text if extractor provides y-position.",
      "enabled": true,
      "requires": ["chunk.bbox"],
      "thresholds": {
        "topRegionMaxY": 0.12,
        "bottomRegionMinY": 0.88
      },
      "tags": ["top_of_page", "bottom_of_page"]
    }
  },
  "outputContract": {
    "_comment": "Signals attached to evidence chunks for scoring and packaging.",
    "shape": {
      "tags": "string[]",
      "headerFooterCandidate": "boolean|optional",
      "tableCandidate": "boolean|optional",
      "listCandidate": "boolean|optional",
      "kvCandidate": "boolean|optional",
      "numericHeavy": "boolean|optional",
      "ocrDominant": "boolean|optional",
      "ocrLowConfidence": "boolean|optional"
    }
  },
  "tests": {
    "cases": [
      {
        "id": "LS_0001_kv_detect",
        "input": "Investimento total: R$ 900.000,00",
        "expect": { "tagsIncludeAny": ["kv", "numeric_heavy"] }
      },
      {
        "id": "LS_0002_table_detect_markdown",
        "input": "| Item | Value |\n| --- | --- |\n| Total | R$ 900.000,00 |",
        "expect": { "tagsIncludeAny": ["table"] }
      },
      {
        "id": "LS_0003_list_detect",
        "input": "- Assumption one\n- Assumption two",
        "expect": { "tagsIncludeAny": ["list"] }
      },
      {
        "id": "LS_0004_header_footer_page",
        "input": "Page 1 of 10",
        "expect": { "headerFooterCandidate": true }
      }
    ]
  }
}
