  },
  "alwaysConfirmOperators": [
    "DOCX_FIND_REPLACE",
    "DOCX_TRANSLATE_SCOPE",
    "DOCX_DELETE_PARAGRAPH",
    "DOCX_MERGE_PARAGRAPHS",
    "DOCX_REWRITE_SECTION",
    "XLSX_SET_RANGE_VALUES",
    "XLSX_SET_RANGE_FORMULAS",
    "XLSX_CHART_CREATE",
    "XLSX_CHART_SET_SERIES",
    "XLSX_TABLE_CREATE",
    "XLSX_SORT_RANGE",
    "XLSX_FILTER_APPLY"
  ],
  "viewerModeRules": {
    "blockConnectorFallback": true,
    "allowExplicitConnectorOnly": true
  }
}
