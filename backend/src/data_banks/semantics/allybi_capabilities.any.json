    "XLSX_CHART_SET_TITLES":     { "supported": true,  "filetype": "xlsx", "runtimeOperator": "CREATE_CHART",   "engine": "sheets_bridge_required", "renderCard": "xlsx_chart_diff" },
    "XLSX_CHART_SET_AXES":       { "supported": true,  "filetype": "xlsx", "runtimeOperator": "CREATE_CHART",   "engine": "sheets_bridge_required", "renderCard": "xlsx_chart_diff" },
    "XLSX_CHART_MOVE_RESIZE":    { "supported": true,  "filetype": "xlsx", "runtimeOperator": "CREATE_CHART",   "engine": "sheets_bridge_required", "renderCard": "xlsx_chart_diff" },
