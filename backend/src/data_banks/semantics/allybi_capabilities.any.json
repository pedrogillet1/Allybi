    "XLSX_MERGE_CELLS":          { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
    "XLSX_WRAP_TEXT":             { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_format_diff" },
    "XLSX_AUTO_FIT":             { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
    "XLSX_COND_FORMAT_DATA_BARS":{ "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_format_diff" },
    "XLSX_COND_FORMAT_COLOR_SCALE":{ "supported": true,"filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_format_diff" },
    "XLSX_COND_FORMAT_TOP_N":    { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_format_diff" },
    "XLSX_SORT_RANGE":           { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
    "XLSX_FILTER_APPLY":         { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
    "XLSX_FILTER_CLEAR":         { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
    "XLSX_TABLE_CREATE":         { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
    "XLSX_DATA_VALIDATION_SET":  { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_format_diff" },
    "XLSX_FREEZE_PANES":         { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
    "XLSX_HIDE_ROWS_COLS":       { "supported": true,  "filetype": "xlsx", "runtimeOperator": "COMPUTE_BUNDLE", "engine": "local", "renderCard": "xlsx_structural_diff" },
