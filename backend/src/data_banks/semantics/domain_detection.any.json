{
  "_meta": {
    "id": "domain_detection",
    "version": "3.0.0",
    "description": "Hierarchical domain detection for Koda (US + Brazil). Scores parent families and child subdomains using high-signal vocabulary from query text, doc titles, and extracted snippets. Emits topParentDomain + topSubDomain + confidence + match evidence. Designed for ChatGPT-like routing + retrieval profiles without wrong-domain drift.",
    "languages": [
      "any",
      "en",
      "pt"
    ],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "matching": {
      "useRegex": true,
      "caseInsensitive": true,
      "stripDiacritics": true,
      "collapseWhitespace": true,
      "treatHyphenUnderscoreAsSpace": true
    },
    "scoring": {
      "maxDomainsToReturn": 3,
      "minConfidenceToEmit": 0.55,
      "strongMatchWeight": 0.16,
      "mediumMatchWeight": 0.09,
      "weakMatchWeight": 0.05,
      "titleBoost": 0.1,
      "docTextBoost": 0.07,
      "parentAggregation": {
        "method": "sum_of_children_capped",
        "cap": 0.92,
        "parentBoostIfMultipleChildrenHit": 0.06,
        "minDistinctChildrenForBoost": 2
      },
      "capMaxConfidence": 0.98,
      "tieBreakers": [
        "mostStrongMatches",
        "titleBoost",
        "docTextBoost",
        "mostDistinctSignals",
        "mostDistinctChildren"
      ]
    },
    "lexiconBankId": "terminology_domains",
    "output": {
      "emitTopParentDomain": true,
      "emitTopSubDomain": true,
      "emitSupportingMatches": true,
      "maxSupportingMatches": 10
    }
  },
  "inputs": {
    "queryText": true,
    "docTitle": true,
    "docSnippets": true
  },
