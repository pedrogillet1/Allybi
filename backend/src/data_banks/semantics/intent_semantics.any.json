{
  "_meta": {
    "id": "intent_semantics",
    "version": "1.0.0",
    "description": "Deterministic intent semantics rules for Koda. Tags high-level semantic intent (discovery, inside-doc navigation, extraction, quote, compute, compare, file inventory, scope lock/unlock, time/numeric constraints) to stabilize routing and prevent wrong-mode responses without duplicating intent_patterns.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-semantics",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "preferExplicitCues": true,
    "neverForceClarificationIfAutopickSafe": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_specific_then_merge_tags",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": false,
        "redirectPreferencePriority": "over_tagging"
      },
      "thresholds": {
        "minSemanticConfidence": 0.75,
        "autopickTopConfidence": 0.85,
        "autopickGap": 0.25
      },
      "conflictResolution": {
        "ifQuoteAndSummarize": "prefer_quote",
        "ifOpenAndLocateContent": "prefer_locate_content",
        "ifDiscoveryAndDocLock": "prefer_doc_lock"
      }
    }
  },
  "rules": [
    {
      "id": "intent_file_inventory",
      "scope": "global",
      "description": "Tag file inventory intent (list/filter/sort/group/count files).",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(list my files|show my files|all files|my uploads|count files)\\b", "\\b(filter|sort|group by)\\b"],
        "pt": ["\\b(listar meus arquivos|mostrar meus arquivos|todos os arquivos|meus uploads|contar arquivos)\\b", "\\b(filtrar|ordenar|agrupar por)\\b"],
        "es": ["\\b(listar mis archivos|mostrar mis archivos|todos los archivos|mis subidas|contar archivos)\\b", "\\b(filtrar|ordenar|agrupar por)\\b"]
      },
      "action": {
        "type": "tag_intent_semantics",
        "intent": "file_inventory",
        "confidence": 0.85,
        "suggestedAnswerMode": "general_answer"
      },
      "reasonCode": "intent_file_inventory",
      "severity": "low"
    },
    {
      "id": "intent_open_vs_locate_content",
      "scope": "cross_family",
      "description": "Disambiguate open/preview intent from inside-document navigation intent.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(open|preview|view|pull it up)\\b", "\\b(where is|on which (page|slide|section)|find all mentions)\\b"],
        "pt": ["\\b(abrir|previsualizar|visualizar|mostra)\\b", "\\b(onde|em qual (p[aá]gina|slide|se[cç][aã]o)|encontre todas as men[cç][oõ]es)\\b"],
        "es": ["\\b(abrir|previsualizar|ver|mu[eé]strame)\\b", "\\b(d[oó]nde|en qu[eé] (p[aá]gina|diapositiva|secci[oó]n)|encuentra todas las menciones)\\b"]
      },
      "action": {
        "type": "tag_intent_semantics",
        "intent": "open_or_locate_content",
        "confidence": 0.8,
        "emitSignals": ["needs_collision_resolution"]
      },
      "reasonCode": "intent_open_locate_collision",
      "severity": "medium"
    },
    {
      "id": "intent_quote",
      "scope": "global",
      "description": "Tag explicit quote/verbatim intent (must override summarize).",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(quote|verbatim|exact words|word for word)\\b"],
        "pt": ["\\b(citar|literalmente|palavras exatas)\\b"],
        "es": ["\\b(citar|textualmente|palabras exactas)\\b"]
      },
      "action": {
        "type": "tag_intent_semantics",
        "intent": "quote",
        "confidence": 0.9,
        "suggestedOperator": "quote",
        "suggestedAnswerMode": "doc_grounded_quote"
      },
      "reasonCode": "intent_quote",
      "severity": "high"
    },
    {
      "id": "intent_summarize",
      "scope": "global",
      "description": "Tag summarization intent when abstraction keywords appear and no quote intent is present.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(summarize|summary|overview|key takeaways)\\b"],
        "pt": ["\\b(resum(o|ir)|resumo|vis[aã]o geral|pontos principais)\\b"],
        "es": ["\\b(resumen|resumir|visi[oó]n general|puntos clave)\\b"]
      },
      "when": {
        "all": [
          { "path": "signals.isQuoteIntent", "op": "neq", "value": true }
        ]
      },
      "action": {
        "type": "tag_intent_semantics",
        "intent": "summarize",
        "confidence": 0.8,
        "suggestedOperator": "summarize",
        "suggestedAnswerMode": "doc_grounded_single"
      },
      "reasonCode": "intent_summarize",
      "severity": "low"
    },
    {
      "id": "intent_extract_compute_compare",
      "scope": "global",
      "description": "Tag extract/compute/compare intents using explicit verbs and comparative cues.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(extract|pull|what is the)\\b", "\\b(calculate|compute|margin|variance|percent)\\b", "\\b(compare|vs|versus|difference between)\\b"],
        "pt": ["\\b(extrair|mostra|qual [eé])\\b", "\\b(calcular|margem|varia[cç][aã]o|percent)\\b", "\\b(comparar|vs|diferen[cç]a entre)\\b"],
        "es": ["\\b(extraer|mostrar|cu[aá]l es)\\b", "\\b(calcular|margen|variaci[oó]n|porcentaje)\\b", "\\b(comparar|vs|diferencia entre)\\b"]
      },
      "action": {
        "type": "tag_intent_semantics",
        "intent": "extract_compute_compare",
        "confidence": 0.75,
        "emitSignals": ["may_need_table"]
      },
      "reasonCode": "intent_extract_compute_compare",
      "severity": "medium"
    },
    {
      "id": "intent_scope_lock_unlock",
      "scope": "global",
      "description": "Tag explicit scope lock/pin or unlock/switch directives.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(lock|pin|keep this|stay on this|don't switch)\\b", "\\b(unlock|switch docs|change file|use another file)\\b"],
        "pt": ["\\b(travar|fixar|manter ativo|fica nesse|n[aã]o troque)\\b", "\\b(destravar|trocar (de )?documento|mudar arquivo)\\b"],
        "es": ["\\b(bloquear|fijar|mant[eé]nlo|no cambies)\\b", "\\b(desbloquear|cambiar documento|cambiar archivo)\\b"]
      },
      "action": {
        "type": "tag_intent_semantics",
        "intent": "scope_control",
        "confidence": 0.85,
        "emitSignals": ["scope_change_requested"]
      },
      "reasonCode": "intent_scope_control",
      "severity": "high"
    },
    {
      "id": "intent_time_filtering",
      "scope": "cross_family",
      "description": "Tag time filtering intent when explicit year/quarter/month/range cues are present.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(19\\d{2}|20\\d{2}|Q[1-4]|last year|this year|next year)\\b"],
        "pt": ["\\b(19\\d{2}|20\\d{2}|T[1-4]|ano passado|este ano|pr[oó]ximo ano)\\b"],
        "es": ["\\b(19\\d{2}|20\\d{2}|T[1-4]|a[oñ]o pasado|este a[oñ]o|pr[oó]ximo a[oñ]o)\\b"]
      },
      "action": {
        "type": "tag_intent_semantics",
        "intent": "time_filter",
        "confidence": 0.8,
        "emitSignals": ["time_constraints_present"]
      },
      "reasonCode": "intent_time_filter",
      "severity": "medium"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "IS_001_quote_over_summarize_collision",
        "context": { "signals": { "isQuoteIntent": true } },
        "input": "Summarize and quote the exact words",
        "expect": { "preferredIntent": "quote" }
      },
      {
        "id": "IS_002_open_vs_locate_content_collision",
        "input": "Open it — where is ROI mentioned?",
        "expect": { "emitSignals": ["needs_collision_resolution"] }
      },
      {
        "id": "IS_003_file_inventory_en",
        "input": "List my files",
        "expect": { "intent": "file_inventory" }
      },
      {
        "id": "IS_004_scope_lock_pt",
        "input": "mantém esse documento ativo",
        "expect": { "intent": "scope_control" }
      },
      {
        "id": "IS_005_time_filter_es",
        "input": "comparar T2 2023 vs T2 2024",
        "expect": { "intent": "time_filter" }
      },
      {
        "id": "IS_006_extract_compute_compare_en",
        "input": "Calculate the margin and compare it vs last year",
        "expect": { "intent": "extract_compute_compare" }
      }
    ]
  }
}
