        "pt": ["quem\\s+assinou", "(?:nome|identifique)\\s+(?:o(?:s)?\\s+)?(?:signatário|assinante)", "(?:liste|mostre)\\s+(?:o(?:s)?\\s+)?(?:signatário|assinante)"]
      },
