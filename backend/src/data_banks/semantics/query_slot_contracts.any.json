        "pt": ["quem\\s+(?:é|são)\\s+(?:o(?:s)?\\s+)?(?:inquilino|locatário|arrendatário)", "(?:nome|identifique)\\s+(?:o(?:s)?\\s+)?(?:inquilino|locatário|arrendatário)"]
      },
