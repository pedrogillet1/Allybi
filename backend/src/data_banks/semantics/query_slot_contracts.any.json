{
  "_meta": { "id": "query_slot_contracts", "version": "1.0.0", "description": "Maps query patterns to entity-role slot targets with forbidden confusion roles for extraction precision.", "languages": ["any", "en", "pt"], "lastUpdated": "2026-02-20", "owner": "koda-retrieval", "compat": ">=1.0.0" },
  "config": { "enabled": true, "minPatternConfidence": 0.75 },
  "slots": [
    {
      "id": "contract_owner_names",
      "patterns": {
        "en": ["who\\s+(?:is|are)\\s+(?:the\\s+)?owners?", "(?:name|identify)\\s+(?:the\\s+)?owners?", "(?:list|show)\\s+(?:the\\s+)?owners?", "owner(?:s)?\\s+(?:of|for)\\s+(?:the|this)"],
        "pt": ["quem\\s+(?:é|são)\\s+(?:o(?:s)?\\s+)?(?:proprietário|dono|locador)", "(?:nome|identifique)\\s+(?:o(?:s)?\\s+)?(?:proprietário|dono|locador)", "(?:liste|mostre)\\s+(?:o(?:s)?\\s+)?(?:proprietário|dono|locador)"]
      },
      "targetRoleId": "owner",
      "extractionMode": "STRICT_EXTRACT",
      "forbidden": ["signatory", "witness", "guarantor", "representative"],
      "confusionPenalties": [
        { "role": "signatory", "penalty": 0.40 },
        { "role": "witness", "penalty": 0.30 },
        { "role": "guarantor", "penalty": 0.35 },
        { "role": "representative", "penalty": 0.25 }
      ],
      "anchorLabels": { "en": ["owner", "proprietor", "landlord", "lessor"], "pt": ["proprietário", "dono", "locador", "senhorio"] }
    },
    {
      "id": "contract_signatory_names",
