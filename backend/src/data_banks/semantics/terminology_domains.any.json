{
  "_meta": {
    "id": "terminology_domains",
    "version": "3.0.0",
    "description": "High-signal, non-templated lexicon for Koda domain detection + doc understanding (US + Brazil). This is NOT user-facing microcopy. It powers: domain_detection, synonym_expansion, retrieval boosting, and extraction labeling. Organized by domain families (parent) with child subdomains inheriting shared vocabulary + adding specialized terms.",
    "languages": ["en", "pt"],
    "lastUpdated": "2026-01-26"
  },

  "config": {
    "enabled": true,
    "normalizationHints": {
      "stripDiacritics": true,
      "caseInsensitive": true,
      "collapseWhitespace": true,
      "treatHyphenUnderscoreAsSpace": true,
      "punctuationFolding": true
    },
    "runtimeNotes": [
      "This lexicon should be compiled to regex at runtime using word boundaries where appropriate.",
      "Prefer exact field labels (as seen on documents) as STRONG signals; general words are WEAK signals.",
      "Title matches should be boosted slightly; docSnippet matches should be boosted slightly.",
      "Avoid using these strings as answer templates. They are detection + grounding vocabulary only."
    ],
    "limits": {
      "maxTermsPerTier": 250,
      "maxPhrasesPerDomain": 180,
      "maxIssuersPerDomain": 80
    }
  },

  "outputContract": {
    "_comment": "Downstream banks should treat these as term lists that can be converted to patterns.",
    "tiers": ["strong", "medium", "weak"],
    "fields": [
      "docTypeTerms",
      "issuerTerms",
      "artifactTerms",
      "fieldLabelTerms",
      "actionVerbTerms",
      "conceptTerms",
      "commonPhrases"
    ]
  },

