{
  "_meta": {
    "id": "domain_ontology",
    "version": "3.0.0",
    "description": "Canonical domain taxonomy + behavior contract for Koda. Defines stable parent/child domain ids, alias coverage, related-domain graph, doc-type affinities, retrieval/formatting profiles, and terminology hooks. Must stay aligned with domain_detection + terminology_domains.",
    "languages": [
      "any",
      "en",
      "pt"
    ],
    "lastUpdated": "2026-01-26",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ],
    "ssotRole": "root_taxonomy"
  },
  "config": {
    "enabled": true,
    "strictDomainIds": true,
    "failOnUnknownDomain": true,
    "defaultParentDomain": "general",
    "defaultSubDomain": "general",
    "maxRelatedDomains": 4,
    "maxAliasesPerDomain": 120,
    "normalizationHints": {
      "stripDiacritics": true,
      "caseInsensitive": true,
      "collapseWhitespace": true,
      "treatHyphenUnderscoreAsSpace": true
    }
  },
  "terminologyHooks": {
    "_comment": "Keys into terminology_domains.any.json (lexicon) and synonym_expansion.any.json (expansion).",
    "lexiconBankId": "terminology_domains",
    "synonymsBankId": "synonym_expansion",
    "abbreviationsBankId": "abbreviations"
  },
  "retrievalProfiles": {
    "_comment": "Matches semantic_search_config profiles; used as a hint to retrieval engine.",
    "balanced": {
      "weights": {
        "lexical": 0.45,
        "semantic": 0.45,
        "structure": 0.1
      }
    },
    "numbers_first": {
      "weights": {
        "lexical": 0.55,
        "semantic": 0.3,
        "structure": 0.15
      }
    },
    "numeric_strict": {
      "weights": {
        "lexical": 0.58,
        "semantic": 0.27,
        "structure": 0.15
      }
    },
    "structure_first": {
      "weights": {
        "lexical": 0.5,
        "semantic": 0.25,
        "structure": 0.25
      }
    },
    "ocr_tolerant": {
      "weights": {
        "lexical": 0.55,
        "semantic": 0.35,
        "structure": 0.1
      }
    },
    "field_extraction": {
      "weights": {
        "lexical": 0.58,
        "semantic": 0.3,
        "structure": 0.12
      }
    },
    "quote_friendly": {
      "weights": {
        "lexical": 0.5,
        "semantic": 0.4,
        "structure": 0.1
      }
    },
    "payments_lexical": {
      "weights": {
        "lexical": 0.6,
        "semantic": 0.28,
        "structure": 0.12
      }
    }
  },
  "formattingProfiles": {
    "_comment": "Hints for answer_style_policy / render_policy selection.",
    "default": {
      "prefer": [
        "short_paragraphs"
      ],
      "tables": "allow",
      "quotes": "allow"
    },
    "fields_first": {
      "prefer": [
        "bullets",
        "key_value"
      ],
      "tables": "allow",
      "quotes": "avoid_if_not_requested"
    },
    "numbers_first": {
      "prefer": [
        "table",
        "bullets"
      ],
      "tables": "prefer",
      "quotes": "allow"
    },
    "tables_first": {
      "prefer": [
        "table"
      ],
      "tables": "prefer",
      "quotes": "avoid_if_not_requested"
    },
    "bullets_first": {
      "prefer": [
        "bullets"
      ],
      "tables": "allow",
      "quotes": "allow"
    }
  },
