{
  "_meta": {
    "id": "section_heading_patterns",
    "version": "2.0.0",
    "description": "High-coverage multilingual patterns for detecting section headings in extracted document text (PDF/DOCX/OCR). Used by chunking, locate_content, and evidence packaging to create stable breadcrumbs (section → page/slide/sheet). Optimized for business/finance/legal/accounting/medical/personal-doc documents and avoids false positives from table rows and bullet lines.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "useRegex": true,
    "caseInsensitive": true,
    "stripDiacritics": true,
    "collapseWhitespace": true,
    "maxHeadingChars": 140,
    "minHeadingChars": 3,
    "maxLeadingWhitespace": 6,
    "rejectIfLooksLikeTableRow": true,
    "rejectIfLooksLikeBulletLine": true,
    "rejectIfMostlyNumeric": true,
    "allowAllCaps": true,
    "scoreThresholds": {
      "emitAsHeadingGte": 0.70,
      "emitAsSubheadingGte": 0.55
    }
  },
  "filters": {
    "rejectPatterns": {
      "_comment": "Common false positives: table separators, repeated punctuation, bullet-only lines, page footers, and numeric-only lines.",
      "any": [
        "^\\s*\\|.*\\|\\s*$",
        "^\\s*[-_—–]{3,}\\s*$",
        "^\\s*\\d+\\s*$",
        "^\\s*(page|p[aá]gina)\\s*\\d+\\s*(of|de)\\s*\\d+\\s*$",
        "^\\s*(confidential|proprietary|internal use only)\\s*$",
        "^\\s*[-•*+]\\s+.+$",
        "^\\s*\\d+\\.\\s+.+$"
      ]
    },
    "rejectIfContains": {
      "_comment": "Avoid mistaking repeated column headers for headings.",
      "any": [
        "\\bqty\\b",
        "\\bsku\\b",
        "\\bunit price\\b",
        "\\bsubtotal\\b",
        "\\btotal\\b",
        "\\bamount\\b"
      ]
    }
  },
  "detectors": {
    "_comment": "Heading detectors produce scores. Multiple detectors can fire; highest score wins.",
    "numbered": {
      "weight": 0.40,
      "patterns": {
        "any": [
          "^\\s*(\\d{1,2})([.)])\\s+(.{3,140})$",
          "^\\s*(\\d{1,2}\\.\\d{1,2})([.)])\\s+(.{3,140})$",
          "^\\s*(\\d{1,2}\\.\\d{1,2}\\.\\d{1,2})([.)])\\s+(.{3,140})$"
        ]
      },
      "notes": "Matches 1) Title, 1.1) Subsection, 1.1.1) Sub-subsection."
    },
    "roman": {
      "weight": 0.28,
      "patterns": {
        "any": [
          "^\\s*([IVXLCDM]{1,6})([.)])\\s+(.{3,140})$"
        ]
      },
      "notes": "Matches Roman numeral headings like I. Overview."
    },
    "keyword_labels": {
      "weight": 0.34,
      "patterns": {
        "en": [
          "^\\s*(overview|summary|introduction|background|scope|assumptions|methodology|findings|results|analysis|discussion|recommendations|next steps|conclusion|appendix|definitions)\\s*:?\\s*$",
          "^\\s*(executive summary)\\s*:?\\s*$",
          "^\\s*(risk(s)?|constraints|limitations)\\s*:?\\s*$"
        ],
        "pt": [
          "^\\s*(vis[aã]o geral|resumo|introdu[cç][aã]o|contexto|escopo|premissas|suposi[cç][oõ]es|metodologia|resultados|an[aá]lise|discuss[aã]o|recomenda[cç][oõ]es|pr[oó]ximos passos|conclus[aã]o|ap[eê]ndice|defini[cç][oõ]es)\\s*:?\\s*$",
          "^\\s*(resumo executivo)\\s*:?\\s*$",
          "^\\s*(riscos|restri[cç][oõ]es|limita[cç][oõ]es)\\s*:?\\s*$"
        ],
        "es": [
          "^\\s*(visi[oó]n general|resumen|introducci[oó]n|antecedentes|alcance|suposiciones|metodolog[ií]a|hallazgos|resultados|an[aá]lisis|discusi[oó]n|recomendaciones|pr[oó]ximos pasos|conclusi[oó]n|ap[eé]ndice|definiciones)\\s*:?\\s*$",
          "^\\s*(resumen ejecutivo)\\s*:?\\s*$",
          "^\\s*(riesgos|restricciones|limitaciones)\\s*:?\\s*$"
        ]
      },
      "notes": "Matches common standalone section label lines."
    },
    "colon_headings": {
      "weight": 0.26,
      "patterns": {
        "any": [
          "^\\s*([A-Za-zÀ-ÖØ-öø-ÿ0-9][A-Za-zÀ-ÖØ-öø-ÿ0-9\\s/&()\\-]{2,80})\\s*:\\s*$"
        ]
      },
      "notes": "Matches lines like 'Break-even Point:' or 'Custo de Investimento:'."
    },
    "all_caps": {
      "weight": 0.22,
      "patterns": {
        "any": [
          "^\\s*([A-Z0-9][A-Z0-9\\s/&()\\-]{4,120})\\s*$"
        ]
      },
      "notes": "Matches ALL CAPS headings; requires additional heuristics to avoid false positives."
    },
    "legal_structures": {
      "weight": 0.30,
      "patterns": {
        "en": [
          "^\\s*(section|article|clause)\\s+\\d{1,3}\\s*[:.-]?\\s+(.{3,140})$",
          "^\\s*(definitions|governing law|termination|liability|indemnification|confidentiality)\\s*:?\\s*$"
        ],
        "pt": [
          "^\\s*(se[cç][aã]o|artigo|cl[aá]usula)\\s+\\d{1,3}\\s*[:.-]?\\s+(.{3,140})$",
          "^\\s*(defini[cç][oõ]es|lei aplic[aá]vel|rescis[aã]o|responsabilidade|indeniza[cç][aã]o|confidencialidade)\\s*:?\\s*$"
        ],
        "es": [
          "^\\s*(secci[oó]n|art[ií]culo|cl[aá]usula)\\s+\\d{1,3}\\s*[:.-]?\\s+(.{3,140})$",
          "^\\s*(definiciones|ley aplicable|terminaci[oó]n|responsabilidad|indemnizaci[oó]n|confidencialidad)\\s*:?\\s*$"
        ]
      },
      "notes": "Legal contract style headings."
    },
    "finance_structures": {
      "weight": 0.30,
      "patterns": {
        "en": [
          "^\\s*(income statement|balance sheet|cash flow statement|assumptions|scenario(s)?|sensitivity|break[- ]?even|payback|roi|irr|npv)\\s*:?\\s*$"
        ],
        "pt": [
          "^\\s*(dre|demonstra[cç][aã]o de resultado|balan[cç]o patrimonial|fluxo de caixa|premissas|cen[aá]rios|sensibilidade|break[- ]?even|ponto de equil[ií]brio|payback|retorno|roi|tir|vpl)\\s*:?\\s*$"
        ],
        "es": [
          "^\\s*(estado de resultados|balance general|flujo de caja|suposiciones|escenarios|sensibilidad|break[- ]?even|punto de equilibrio|payback|retorno|roi|tir|vpn)\\s*:?\\s*$"
        ]
      },
      "notes": "Finance analysis headings."
    },
    "medical_structures": {
      "weight": 0.28,
      "patterns": {
        "en": [
          "^\\s*(history of present illness|assessment|plan|impression|medications|allergies|diagnosis|findings)\\s*:?\\s*$"
        ],
        "pt": [
          "^\\s*(hist[oó]ria|avalia[cç][aã]o|plano|impress[aã]o|medica[cç][oõ]es|alergias|diagn[oó]stico|achados)\\s*:?\\s*$"
        ],
        "es": [
          "^\\s*(historia|evaluaci[oó]n|plan|impresi[oó]n|medicaciones|alergias|diagn[oó]stico|hallazgos)\\s*:?\\s*$"
        ]
      },
      "notes": "Common clinical report headings."
    }
  },
  "heuristics": {
    "_comment": "Additional scoring signals when a detector matches.",
    "scoreBoosts": {
      "endsWithColon": 0.10,
      "hasNumberingPrefix": 0.12,
      "isAllCaps": 0.06,
      "titleCaseLike": 0.05,
      "surroundedByBlankLines": 0.10,
      "shortLine": 0.05
    },
    "scorePenalties": {
      "containsManyDigits": 0.10,
      "containsCurrencyAndLooksLikeRow": 0.15,
      "looksLikeTableHeader": 0.10
    },
    "tableHeaderLikeTokens": [
      "qty",
      "sku",
      "unit",
      "price",
      "subtotal",
      "total",
      "amount",
      "date"
    ]
  },
  "outputContract": {
    "_comment": "Emitted heading objects for chunking/layout.",
    "shape": {
      "text": "string",
      "kind": "heading|subheading",
      "score": "number",
      "detectorId": "string",
      "numbering": "string|optional",
      "normalized": "string",
      "pageHint": "number|optional"
    }
  },
  "tests": {
    "cases": [
      {
        "id": "SHP_0001_numbered_heading",
        "input": "4. Break-even Point",
        "expect": { "kind": "heading", "scoreGte": 0.70 }
      },
      {
        "id": "SHP_0002_colon_heading",
        "input": "Custo de Investimento:",
        "expect": { "kind": "heading", "scoreGte": 0.65 }
      },
      {
        "id": "SHP_0003_reject_table_row",
        "input": "| Item | Value | Note |",
        "expect": { "rejected": true }
      },
      {
        "id": "SHP_0004_legal_heading",
        "input": "Clause 12 - Termination",
        "expect": { "kindAny": ["heading", "subheading"], "scoreGte": 0.60 }
      }
    ]
  }
}
