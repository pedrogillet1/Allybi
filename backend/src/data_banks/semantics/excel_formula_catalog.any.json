{
  "_meta": {
    "id": "excel_formula_catalog",
    "version": "1.0.0",
    "description": "Excel formula intent catalog with EN/PT aliases and validation hints.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-13",
    "owner": "allybi-editing"
  },
  "config": {
    "enabled": true,
    "requireFormulaPrefix": true
  },
  "functions": [
    {
      "name": "SUM",
      "aliases_en": ["sum", "total"],
      "aliases_pt": ["soma", "total"],
      "example_en": "=SUM(D5:D20)",
      "example_pt": "=SUM(D5:D20)"
    },
    {
      "name": "SUMIFS",
      "aliases_en": ["sumifs", "sum with conditions"],
      "aliases_pt": ["somases", "somar com condi\u00e7\u00f5es"],
      "example_en": "=SUMIFS(F:F,C:C,\"CABINS\")",
      "example_pt": "=SUMIFS(F:F,C:C,\"CABINS\")"
    },
    {
      "name": "IFERROR",
      "aliases_en": ["iferror", "if error"],
      "aliases_pt": ["seerro", "se erro"],
      "example_en": "=IFERROR(A1/B1,0)",
      "example_pt": "=IFERROR(A1/B1,0)"
    },
    {
      "name": "XLOOKUP",
      "aliases_en": ["xlookup", "lookup by key"],
      "aliases_pt": ["xlookup", "procurar por chave"],
      "example_en": "=XLOOKUP(A2,Table1[Key],Table1[Value])",
      "example_pt": "=XLOOKUP(A2,Table1[Key],Table1[Value])"
    },
    {
      "name": "LET",
      "aliases_en": ["let", "named expression"],
      "aliases_pt": ["let", "express\u00e3o nomeada"],
      "example_en": "=LET(x,D5:D20,SUM(x))",
      "example_pt": "=LET(x,D5:D20,SUM(x))"
    }
  ],
  "validation": {
    "errors": {
      "en": {
        "MISSING_PREFIX": "Formula must start with '='.",
        "UNKNOWN_FUNCTION": "Unknown formula function. Try one of: SUM, SUMIFS, IFERROR, XLOOKUP, LET."
      },
      "pt": {
        "MISSING_PREFIX": "A f\u00f3rmula deve come\u00e7ar com '='.",
        "UNKNOWN_FUNCTION": "Fun\u00e7\u00e3o de f\u00f3rmula desconhecida. Tente: SUM, SUMIFS, IFERROR, XLOOKUP, LET."
      }
    }
  }
}
