      "typicalContent": ["Paragraph group heading", "Minor heading"],
      "expectedChildren": [6],
      "tocDepthDefault": false
    },
    {
      "level": 6,
      "styleNames": ["Heading 6", "heading 6", "Heading6"],
      "xmlStyleIds": ["Heading6"],
      "outlineLevel": 5,
      "semanticRole": "minor_heading",
      "typicalContent": ["Minor heading", "Run-in heading"],
      "expectedChildren": [7],
      "tocDepthDefault": false
    },
    {
      "level": 7,
      "styleNames": ["Heading 7", "heading 7", "Heading7"],
      "xmlStyleIds": ["Heading7"],
      "outlineLevel": 6,
      "semanticRole": "deep_heading",
      "typicalContent": ["Deep nested heading", "Outline detail level"],
      "expectedChildren": [8],
      "tocDepthDefault": false
    },
    {
      "level": 8,
      "styleNames": ["Heading 8", "heading 8", "Heading8"],
      "xmlStyleIds": ["Heading8"],
      "outlineLevel": 7,
      "semanticRole": "deep_heading",
      "typicalContent": ["Deep nested heading", "Technical sub-detail"],
      "expectedChildren": [9],
      "tocDepthDefault": false
    },
    {
      "level": 9,
      "styleNames": ["Heading 9", "heading 9", "Heading9"],
      "xmlStyleIds": ["Heading9"],
      "outlineLevel": 8,
      "semanticRole": "deepest_heading",
      "typicalContent": ["Deepest heading level", "Fine-grained outline node"],
      "expectedChildren": [],
      "tocDepthDefault": false
