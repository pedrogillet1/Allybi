{
  "_meta": {
    "id": "docx_heading_levels_en",
    "version": "1.0.0",
    "description": "English heading level conventions for DOCX structural parsing — maps style names, numbering patterns, and font heuristics to semantic levels.",
    "languages": ["en"],
    "lastUpdated": "2026-02-27"
  },
  "config": { "enabled": true },
  "levels": [
    {
      "level": 1,
      "styleNames": ["Heading 1", "heading 1", "Heading1", "Title", "TITLE"],
      "xmlStyleIds": ["Heading1", "Title"],
      "outlineLevel": 0,
      "semanticRole": "document_title_or_major_section",
      "typicalContent": ["Document title", "Major section heading"],
      "expectedChildren": [2],
      "tocDepthDefault": true
    },
    {
      "level": 2,
      "styleNames": ["Heading 2", "heading 2", "Heading2", "Subtitle", "SUBTITLE"],
      "xmlStyleIds": ["Heading2", "Subtitle"],
      "outlineLevel": 1,
      "semanticRole": "section",
      "typicalContent": ["Section heading", "Chapter heading"],
      "expectedChildren": [3],
      "tocDepthDefault": true
    },
    {
      "level": 3,
      "styleNames": ["Heading 3", "heading 3", "Heading3"],
      "xmlStyleIds": ["Heading3"],
      "outlineLevel": 2,
      "semanticRole": "subsection",
      "typicalContent": ["Subsection heading", "Topic heading"],
