{
  "_meta": {
    "id": "chunking_rules",
    "version": "1.0.0",
    "description": "Chunking rules for document ingestion (size, overlap, splitting heuristics, and boundary preservation).",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-02-07"
  },
  "config": {
    "enabled": true
  },
  "maxChunkSize": 1000,
  "minChunkSize": 100,
  "overlapSize": 100,
  "splitOn": ["paragraph", "sentence", "header"],
  "preserveBoundaries": ["table", "codeBlock", "list"],
  "tests": { "cases": [] }
}
