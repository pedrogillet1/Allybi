{
  "_meta": {
    "id": "feature_flags",
    "version": "1.0.0",
    "description": "Central feature flag control plane for Koda. Flags gate behavior across routing, retrieval, composition, and UX rendering so changes can be rolled out safely without hardcoding. Supports per-env defaults and optional runtime overrides.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-02",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "src/services/core/banks/bankRollout.service.test.ts",
      "src/services/core/banks/featureFlagResolver.service.test.ts",
      "src/services/core/banks/canaryHealthCheck.service.test.ts",
      "src/tests/certification/rollout-safety.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "_comment": "If a flag is referenced but missing, fail in prod/staging to avoid silent drift.",
    "failOnUnknownFlagByEnv": {
      "production": true,
      "staging": true,
      "dev": false,
      "local": false
    },
    "_comment2": "Runtime overrides can be supplied by env vars or DB; this bank defines which are allowed.",
    "runtimeOverrides": {
      "enabled": true,
      "allowList": [
        "ff.nav_pills_sources_ui_contract",
        "ff.enable_multi_provider",
        "ff.adaptive_failure_fallbacks",
        "ff.regen_variation_seed",
        "ff.bold_keywords_from_query",
        "ff.short_paragraph_enforcement",
        "ff.doc_title_keyword_discovery",
        "ff.provenance_user_failopen_with_evidence",
        "ff.provenance_thresholds_v3",
        "ff.provenance_telemetry_dual_channel",
        "ff.viewer_qa_locked_default",
        "ff.viewer_source_navigation_animation",
        "ff.viewer_cross_document_source_jump"
      ]
    },
    "rolloutSafety": {
      "enabled": true,
      "thresholds": {
        "minSampleSize": 20,
        "maxErrorRate": 0.02,
        "maxP95LatencyMs": 12000,
        "maxWeakEvidenceRate": 0.15
      }
    }
  },
  "flags": [
    {
      "id": "ff.nav_pills_sources_ui_contract",
      "description": "Enforce nav_pills UI contract: pills-only (no Sources label/divider), no message actions, and intro line + pills only.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "render_policy",
        "answer_mode_router",
        "frontend_sources_ui"
      ],
      "riskLevel": "low"
    },
    {
      "id": "ff.enable_multi_provider",
      "description": "Allow cross-provider fallback between Gemini and OpenAI for high availability in routing.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "llm_router",
        "provider_fallbacks",
        "llm_gateway"
      ],
      "riskLevel": "high",
      "rollout": {
        "requiresCanary": true,
        "maxPercentByEnv": {
          "production": 10,
          "staging": 25,
          "dev": 100,
          "local": 100
        }
      }
    },
    {
      "id": "ff.adaptive_failure_fallbacks",
      "description": "Replace generic 'no relevant information found' with adaptive fallbacks (processing/extraction/scope empty/scoped not found) + one next best action.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "quality_gates",
        "fallback_engine",
        "microcopy"
      ],
      "riskLevel": "medium"
    },
    {
      "id": "ff.regen_variation_seed",
      "description": "Enable deterministic regeneration variation via (conversationId, turnId, regenCount) seed so regenerated answers differ in wording/structure while preserving facts.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "answer_composer",
        "microcopy_picker",
        "prompt_templates"
      ],
      "riskLevel": "medium"
    },
    {
      "id": "ff.bold_keywords_from_query",
      "description": "Bold key query terms (non-stopwords) in doc-grounded answers for scanability; still respect maxBoldItems and never bold inside tables unless allowed.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "bolding_normalizer",
        "answer_composer"
      ],
      "riskLevel": "low"
    },
    {
      "id": "ff.short_paragraph_enforcement",
      "description": "Enforce ChatGPT-like short paragraphs (1–2 sentences, ≤260 chars) with automatic paragraph splitting in markdown normalization.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "markdown_normalizer",
        "answer_style_policy"
      ],
      "riskLevel": "low"
    },
    {
      "id": "ff.doc_title_keyword_discovery",
      "description": "Allow file discovery by title keywords (e.g., 'mezanino document') even when user does not type the exact filename. Uses normalized title token matching + boosts.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "file_inventory",
        "retrieval_ranker",
        "intent_patterns"
      ],
      "riskLevel": "high",
      "rollout": {
        "requiresCanary": true,
        "maxPercentByEnv": {
          "production": 10,
          "staging": 25,
          "dev": 100,
          "local": 100
        }
      }
    },
    {
      "id": "ff.strict_provenance_v2",
      "description": "Enable strict provenance v2 enforcement (per-ref thresholds, mode thresholds, no seeded provenance refs).",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "provenance",
        "response_contract_enforcer"
      ],
      "riskLevel": "high",
      "rollout": {
        "requiresCanary": true,
        "maxPercentByEnv": {
          "production": 10,
          "staging": 25,
          "dev": 100,
          "local": 100
        }
      }
    },
    {
      "id": "ff.provenance_user_failopen_with_evidence",
      "description": "When provenance refs are missing but scoped evidence exists, keep user response path and emit hedge telemetry instead of hard fallback.",
      "type": "boolean",
      "defaultByEnv": {
        "production": false,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "provenance",
        "answer_finalization",
        "telemetry"
      ],
      "riskLevel": "high",
      "rollout": {
        "requiresCanary": true,
        "maxPercentByEnv": {
          "production": 10,
          "staging": 25,
          "dev": 100,
          "local": 100
        }
      }
    },
    {
      "id": "ff.provenance_thresholds_v3",
      "description": "Use calibrated provenance lexical/anchor thresholds with normalization for diacritics and localized numeric formatting.",
      "type": "boolean",
      "defaultByEnv": {
        "production": false,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "provenance",
        "retrieval_evidence_matching"
      ],
      "riskLevel": "medium"
    },
    {
      "id": "ff.provenance_telemetry_dual_channel",
      "description": "Emit provenance reason/action telemetry even when user-facing failure is suppressed.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "telemetry",
        "trace_debug",
        "retrieval_events"
      ],
      "riskLevel": "low"
    },
    {
      "id": "ff.quality_gates_enforcing",
      "description": "Allow configured blocking quality gate failures to fail-close answer finalization.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "quality_gates",
        "answer_finalization"
      ],
      "riskLevel": "high",
      "rollout": {
        "requiresCanary": true,
        "maxPercentByEnv": {
          "production": 10,
          "staging": 25,
          "dev": 100,
          "local": 100
        }
      }
    },
    {
      "id": "ff.language_contract_v2",
      "description": "Enable language contract v2 heuristic detection + fail-closed fallback replacement on confident mismatch only.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "language_contract",
        "answer_finalization"
      ],
      "riskLevel": "medium"
    },
    {
      "id": "ff.recent_history_order_v2",
      "description": "Use most recent conversation turns for LLM context window (descending query + chronological restore).",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "conversation_memory",
        "chat_runtime"
      ],
      "riskLevel": "medium"
    },
    {
      "id": "ff.prompt_mode_coverage_strict",
      "description": "Fail compose prompt construction when strict document modes do not map to explicit task templates.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "prompt_registry",
        "answer_composition"
      ],
      "riskLevel": "high",
      "rollout": {
        "requiresCanary": true,
        "maxPercentByEnv": {
          "production": 10,
          "staging": 25,
          "dev": 100,
          "local": 100
        }
      }
    },
    {
      "id": "ff.emit_gate_trace",
      "description": "Emit quality gate trace to logs for debugging; never user-visible.",
      "type": "boolean",
      "defaultByEnv": {
        "production": false,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "quality_gates"
      ],
      "riskLevel": "low"
    },
    {
      "id": "ff.allow_prompt_debug",
      "description": "Allow debug printing of prompts in logs (redacted).",
      "type": "boolean",
      "defaultByEnv": {
        "production": false,
        "staging": false,
        "dev": true,
        "local": true
      },
      "impacts": [
        "prompt_registry",
        "orchestrator"
      ],
      "riskLevel": "high",
      "rollout": {
        "requiresCanary": true,
        "maxPercentByEnv": {
          "production": 10,
          "staging": 25,
          "dev": 100,
          "local": 100
        }
      }
    },
    {
      "id": "ff.viewer_qa_locked_default",
      "description": "Default Ask Allybi in document viewer to qa_locked intent so responses remain scoped to the active document.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "editor_session_routes",
        "viewer_chat"
      ],
      "riskLevel": "medium"
    },
    {
      "id": "ff.viewer_source_navigation_animation",
      "description": "Enable animated in-document navigation for source pill clicks (pdf page spotlight, sheet selection, slide jump, paragraph jump).",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "viewer_sources_ui",
        "document_viewer"
      ],
      "riskLevel": "low"
    },
    {
      "id": "ff.viewer_cross_document_source_jump",
      "description": "Allow viewer source clicks to open a different document while preserving qa_locked context.",
      "type": "boolean",
      "defaultByEnv": {
        "production": true,
        "staging": true,
        "dev": true,
        "local": true
      },
      "impacts": [
        "viewer_sources_ui",
        "routing"
      ],
      "riskLevel": "medium"
    }
  ],
  "tests": {
    "_comment": "Boot-time validation.",
    "cases": [
      {
        "id": "FF_0001_unique_flag_ids",
        "assert": "all flags[].id are unique"
      },
      {
        "id": "FF_0002_core_flags_present",
        "assert": "ff.nav_pills_sources_ui_contract, ff.adaptive_failure_fallbacks, ff.regen_variation_seed exist"
      },
      {
        "id": "FF_0003_prod_safe_defaults",
        "assert": "production defaults do not enable debug-only flags (ff.emit_gate_trace=false AND ff.allow_prompt_debug=false)"
      }
    ]
  }
}
