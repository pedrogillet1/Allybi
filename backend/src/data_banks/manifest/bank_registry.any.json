{
  "_meta": {
    "id": "bank_registry",
    "version": "3.6.0",
    "description": "Canonical, exhaustive registry for all Koda data banks. Single source of truth for loading, validation, dependency resolution, environment gating, schema enforcement, and ChatGPT-parity behavioral guarantees.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },

  "config": {
    "enabled": true,

    "strictLoad": true,
    "failOnMissingRequired": true,

    "enforceUniqueIds": true,
    "enforceUniquePaths": true,

    "validateSchemasAtBoot": true,
    "validateDependenciesAtBoot": true,

    "envOverridesEnabled": true,
    "allowOptionalBanks": true,

    "allowFutureUnknownCategories": false,

    "checksumPolicy": {
      "enabled": false,
      "algorithm": "sha256",
      "failOnMissingChecksumInProd": false
    }
  },

  "loadOrder": [
    "manifest",
    "schemas",
    "normalizers",
    "negatives",
    "routing",
    "operators",
    "semantics",
    "scope",
    "retrieval",
    "formatting",
    "microcopy",
    "overlays",
    "prompts",
    "quality",
    "tests",
    "triggers",
    "ambiguity",
    "state",
    "probes"
  ],

  "schemaMap": {
    "manifest": "bank_schema",
