{
  "_meta": {
    "id": "bank_registry",
    "version": "3.1.0",
    "description": "Canonical, exhaustive registry for all Koda data banks. Single source of truth for loading, validation, dependency resolution, environment gating, schema enforcement, and ChatGPT-parity behavioral guarantees.",
    "languages": ["any"],
    "lastUpdated": "2026-01-25"
  },

  "config": {
    "enabled": true,

    "strictLoad": true,
    "failOnMissingRequired": true,

    "enforceUniqueIds": true,
    "enforceUniquePaths": true,

    "validateSchemasAtBoot": true,
    "validateDependenciesAtBoot": true,

    "envOverridesEnabled": true,
    "allowOptionalBanks": true,

    "allowFutureUnknownCategories": false,

    "checksumPolicy": {
      "enabled": false,
      "algorithm": "sha256",
      "failOnMissingChecksumInProd": false
    }
  },

  "loadOrder": [
    "manifest",
    "schemas",
    "normalizers",
    "negatives",
    "routing",
    "operators",
    "semantics",
    "scope",
    "retrieval",
    "formatting",
    "microcopy",
    "overlays",
    "prompts",
    "quality",
    "triggers",
    "ambiguity",
    "state",
    "probes"
  ],

  "schemaMap": {
    "manifest": "bank_schema",
    "schemas": "bank_schema",
    "normalizers": "bank_schema",
    "negatives": "bank_schema",
    "routing": "bank_schema",
    "operators": "bank_schema",
    "semantics": "bank_schema",
    "scope": "bank_schema",
    "retrieval": "bank_schema",
    "formatting": "bank_schema",
    "microcopy": "bank_schema",
    "overlays": "bank_schema",
    "prompts": "bank_schema",
    "quality": "bank_schema",
    "triggers": "bank_schema",
    "ambiguity": "bank_schema",
    "state": "bank_schema",
    "probes": "bank_schema"
  },

