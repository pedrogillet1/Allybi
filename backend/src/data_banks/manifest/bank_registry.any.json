  "tests": [
    { "id": "unique_path", "assert": "no two banks share the same path" },
    { "id": "unique_id", "assert": "no two banks share the same id" },
    { "id": "dependency_dag", "assert": "dependsOn graph is acyclic" },
    { "id": "required_env_coverage", "assert": "all banks requiredByEnv.production=true are present and enabled" },
    { "id": "schema_coverage", "assert": "every enabled bank has a valid schemaId" },
    { "id": "load_order_respected", "assert": "no bank depends on a category loaded after its own" }
  ]
