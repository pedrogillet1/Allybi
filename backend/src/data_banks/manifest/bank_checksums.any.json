{
  "_meta": {
    "id": "bank_checksums",
    "version": "1.0.0",
    "description": "Integrity map for data banks. Stores expected SHA-256 checksums per bank path and optional per-env overrides. Used at boot (and optionally in CI) to detect drift, partial restores, or accidental edits.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "algorithm": "sha256",
    "strict": {
      "production": true,
      "staging": true,
      "dev": false,
      "local": false
    },
    "onMismatch": {
      "production": "fail_boot",
      "staging": "fail_boot",
      "dev": "warn",
      "local": "warn"
    },
    "onMissingChecksumEntry": {
      "production": "fail_boot",
      "staging": "fail_boot",
      "dev": "warn",
      "local": "warn"
    },
    "allowChecksumEmptyInDev": true,
    "notes": [
      "Populate checksums via CI script after bank generation.",
      "Checksum is for file content only (excluding file path).",
      "Use bank_registry.path as the canonical key."
    ]
  },
