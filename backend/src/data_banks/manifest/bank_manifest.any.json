{
  "_meta": {
    "id": "bank_manifest",
    "version": "1.1.0",
    "description": "Top-level manifest describing Koda data bank categories, their purpose, strictness, environment behavior, and dependency/load guarantees. This file defines what categories exist and how they must behave across environments.",
    "languages": ["any"],
    "lastUpdated": "2026-01-25"
  },

  "config": {
    "enabled": true,

    "strictCategories": true,
    "failOnUnknownCategory": true,

    "envOverridesEnabled": true,

    "defaults": {
      "defaultSchemaId": "bank_schema",
      "defaultCategoryPolicy": {
        "strictLoad": true,
        "failOnMissingRequired": true,
        "allowOptionalSkip": true
      }
    }
  },

  "allowedCategoryIds": [
    "manifest",
    "schemas",
    "normalizers",
    "negatives",
    "routing",
    "operators",
    "semantics",
    "scope",
    "retrieval",
    "formatting",
    "microcopy",
    "overlays",
    "prompts",
    "quality",
    "triggers",
    "ambiguity",
    "state",
    "probes"
  ],

  "loadOrder": [
    "manifest",
    "schemas",
    "normalizers",
    "negatives",
    "routing",
    "operators",
    "semantics",
    "scope",
    "retrieval",
    "formatting",
    "microcopy",
    "overlays",
    "prompts",
    "quality",
    "triggers",
    "ambiguity",
    "state",
    "probes"
  ],

  "categories": [
    {
      "id": "manifest",
      "folder": "manifest",
      "description": "Bootstrapping control plane: registry, load order, dependency resolution, schema mapping, checksums, versions, and environment flags.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": false },
      "dependsOnCategories": [],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "schemas",
      "folder": "schemas",
      "description": "JSON schema contracts for bank validation and for router/scope/retrieval/evidence/attachments outputs.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "normalizers",
      "folder": "normalizers",
      "description": "Normalization for user queries and doc names: language indicators, month/number/unit normalization, filename normalization, aliases.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "negatives",
      "folder": "negatives",
      "description": "Negation/exclusion rules and denylist terms to prevent wrong scope, unsafe matches, and routing hijacks.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "normalizers"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "routing",
      "folder": "routing",
      "description": "Intent/operator routing and tie-breakers. Determines WHAT the user is trying to do and sets routing signals.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "normalizers", "negatives"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "operators",
      "folder": "operators",
      "description": "Operator contracts: allowed outputs, constraints, signals, discovery rules, and nav_pills operator list.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "semantics",
      "folder": "semantics",
      "description": "Semantic signals: domain, time, numeric intent, synonyms, tokenization, layout, chunking, table extraction, section headings.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "normalizers", "negatives", "routing", "operators"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "scope",
      "folder": "scope",
      "description": "Hard/soft scope resolution and candidate filtering to prevent wrong-doc drift and enforce locks.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators", "semantics", "negatives"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "retrieval",
      "folder": "retrieval",
      "description": "Retrieval config + ranking boosts (keyword/title/type/recency/diversification) + evidence packaging contracts.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "scope", "semantics"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "formatting",
      "folder": "formatting",
      "description": "Answer structure + render policy + paragraph/bullet/table rules + bolding + banned phrases + followup templates.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "microcopy",
      "folder": "microcopy",
      "description": "User-facing messages (conversation, nav, no-docs, scoped-not-found, adaptive fallbacks). Must support anti-repetition/variety.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators", "formatting"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "overlays",
      "folder": "overlays",
      "description": "Soft hints + UI contracts that modify behavior without changing core logic (optional runtime layer).",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": false, "failOnMissingRequired": false, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas"],
      "requiredInEnv": { "production": false, "staging": false, "dev": false, "local": false }
    },
    {
      "id": "prompts",
      "folder": "prompts",
      "description": "Prompt registry + templates for system/compose/retrieval/disambiguation/fallback/tool prompts.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators", "retrieval", "formatting"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "quality",
      "folder": "quality",
      "description": "Quality gates and guards (grounding, hallucination, dedupe, numeric integrity, privacy). Blocks bad fallbacks and wrong-doc output.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators", "retrieval", "formatting", "microcopy"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "triggers",
      "folder": "triggers",
      "description": "Trigger banks for intent/operator/format/nav/domain/language signals (optional, but recommended for parity).",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": false, "failOnMissingRequired": false, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators", "normalizers"],
      "requiredInEnv": { "production": false, "staging": false, "dev": false, "local": false }
    },
    {
      "id": "ambiguity",
      "folder": "ambiguity",
      "description": "Disambiguation policies + ranking features + clarification routing for blocking ambiguity cases.",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators", "retrieval", "microcopy"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "state",
      "folder": "state",
      "description": "Conversation state schema, update rules, decay rules, and debug policy (keeps doc locks stable across turns).",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": true, "failOnMissingRequired": true, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas", "routing", "operators"],
      "requiredInEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "probes",
      "folder": "probes",
      "description": "Regression/parity probes for CI/dev to prevent regressions (optional in prod runtime).",
      "schemaId": "bank_schema",
      "policy": { "strictLoad": false, "failOnMissingRequired": false, "allowOptionalSkip": true },
      "dependsOnCategories": ["manifest", "schemas"],
      "requiredInEnv": { "production": false, "staging": false, "dev": false, "local": false }
    }
  ],

  "requiredCategorySet": [
    "manifest",
    "schemas",
    "normalizers",
    "negatives",
    "routing",
    "operators",
    "semantics",
    "scope",
    "retrieval",
    "formatting",
    "microcopy",
    "prompts",
    "quality",
    "ambiguity",
    "state"
  ],

  "tests": {
    "cases": [
      {
        "id": "BM_0001_categories_unique",
        "assert": "all categories[].id are unique AND all categories[].folder are unique"
      },
      {
        "id": "BM_0002_allowed_category_ids_match",
        "assert": "allowedCategoryIds contains exactly the set of categories[].id"
      },
      {
        "id": "BM_0003_load_order_matches_allowed",
        "assert": "loadOrder contains exactly the set of categories[].id in allowedCategoryIds (no missing, no extras)"
      },
      {
        "id": "BM_0004_required_categories_exist",
        "assert": "every id in requiredCategorySet exists in categories[].id"
      },
      {
        "id": "BM_0005_dependency_dag",
        "assert": "dependsOnCategories graph is acyclic AND every dependsOnCategories entry exists in categories[].id"
      },
      {
        "id": "BM_0006_load_order_respects_dependencies",
        "assert": "for each category, all dependsOnCategories appear earlier in loadOrder"
      },
      {
        "id": "BM_0007_env_required_respects_policy",
        "assert": "for production/staging: categories requiredInEnv.<env>==true must have policy.failOnMissingRequired==true"
      },
      {
        "id": "BM_0008_strict_categories_enforced",
        "assert": "if config.strictCategories==true AND failOnUnknownCategory==true then unknown categories are rejected at boot"
      }
    ]
  }
}
