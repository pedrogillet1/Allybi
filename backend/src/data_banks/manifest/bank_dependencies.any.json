{
  "_meta": {
    "id": "bank_dependencies",
    "version": "1.0.0",
    "description": "Explicit dependency graph for Koda data banks. Use when you prefer central dependency declaration instead of (or in addition to) per-bank dependsOn in bank_registry. Enables boot-time validation and stable load ordering.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failOnMissingNode": true,
    "failOnCycle": true,
    "defaultDependencyPolicy": {
      "allowMissingOptional": true,
      "allowCrossCategory": true
    }
  },
  "categories": {
    "_comment": "Category-level dependencies used to validate loadOrder. Individual bank deps may be stricter.",
    "manifest": [],
    "schemas": [
      "manifest"
    ],
    "normalizers": [
      "schemas"
    ],
    "routing": [
      "normalizers"
    ],
    "operators": [
      "routing"
    ],
    "retrieval": [
      "routing",
      "operators",
      "normalizers"
    ],
    "formatting": [
      "routing",
      "operators"
    ],
    "microcopy": [
      "formatting"
    ],
    "overlays": [
      "routing",
      "retrieval",
      "formatting",
      "microcopy"
    ],
    "prompts": [
      "routing",
      "operators",
      "formatting"
    ],
    "policies": [
      "routing",
      "operators",
      "formatting",
      "prompts"
    ],
    "fallbacks": [
      "policies",
      "microcopy"
    ],
    "quality": [
      "routing",
      "retrieval",
      "formatting",
      "microcopy",
      "prompts"
    ],
    "triggers": [
      "routing",
      "operators",
      "normalizers"
    ],
    "ambiguity": [
      "routing",
      "retrieval",
      "operators"
    ],
    "probes": [
      "routing",
      "retrieval",
      "formatting",
      "quality"
    ]
  },
  "banks": [
    {
      "id": "bank_registry",
      "dependsOn": [
        "manifest"
      ],
      "notes": [
        "Registry loads after base manifest category is available."
      ]
    },
    {
      "id": "bank_aliases",
      "dependsOn": [
        "bank_registry"
      ]
    },
    {
      "id": "environments",
      "dependsOn": [
        "bank_registry"
      ]
    },
    {
      "id": "feature_flags",
      "dependsOn": [
        "environments"
      ]
    },
    {
      "id": "bank_schema",
      "dependsOn": [
        "bank_registry"
      ]
    },
    {
      "id": "language_indicators",
      "dependsOn": []
    },
    {
      "id": "synonym_expansion",
      "dependsOn": []
    },
    {
      "id": "doc_aliases",
      "dependsOn": []
    },
    {
      "id": "ambiguous_terms",
      "dependsOn": [],
      "optional": true
    },
    {
      "id": "intent_patterns",
      "dependsOn": []
    },
    {
      "id": "operator_families",
      "dependsOn": [
        "intent_patterns"
      ]
    },
    {
      "id": "operator_contracts",
      "dependsOn": [
        "operator_families"
      ]
    },
    {
      "id": "operator_output_shapes",
      "dependsOn": [
        "operator_contracts"
      ]
    },
    {
      "id": "scope_resolution",
      "dependsOn": [
        "doc_aliases"
      ]
    },
    {
      "id": "semantic_search_config",
      "dependsOn": []
    },
    {
      "id": "retrieval_ranker_config",
      "dependsOn": [
        "semantic_search_config"
      ]
    },
    {
      "id": "evidence_packaging",
      "dependsOn": [
        "retrieval_ranker_config"
      ]
    },
    {
      "id": "answer_style_policy",
      "dependsOn": [
        "banned_phrases",
        "truncation_and_limits"
      ]
    },
    {
      "id": "render_policy",
      "dependsOn": [
        "answer_style_policy"
      ]
    },
    {
      "id": "quality_gates",
      "dependsOn": [
        "fallback_processing",
        "fallback_extraction_recovery",
        "fallback_scope_empty",
        "fallback_not_found_scope",
        "no_docs_messages",
        "clarification_phrases",
        "refusal_phrases"
      ]
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "BDEP_0001_no_cycles",
        "assert": "dependency graph is acyclic"
      },
      {
        "id": "BDEP_0002_category_order_valid",
        "assert": "category dependencies do not require later categories"
      }
    ]
  }
}
