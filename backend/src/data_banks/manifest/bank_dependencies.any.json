{
  "_meta": {
    "id": "bank_dependencies",
    "version": "1.0.0",
    "description": "Explicit dependency graph for Koda data banks. Use when you prefer central dependency declaration instead of (or in addition to) per-bank dependsOn in bank_registry. Enables boot-time validation and stable load ordering.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-27"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failOnMissingNode": true,
    "failOnCycle": true,
    "defaultDependencyPolicy": {
      "allowMissingOptional": true,
      "allowCrossCategory": true
    }
  },
  "categories": {
    "_comment": "Category-level dependencies used to validate loadOrder. Individual bank deps may be stricter.",
    "manifest": [],
    "schemas": [
      "manifest"
    ],
    "normalizers": [
      "schemas"
    ],
