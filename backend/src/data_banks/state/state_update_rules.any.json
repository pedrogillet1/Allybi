{
  "_meta": {
    "id": "state_update_rules",
    "version": "1.0.0",
    "description": "Deterministic state update rules for Koda. Defines how conversation state evolves per turn: scope locks, follow-up continuity, language preferences, formatting preferences, ambiguity resolution outcomes, and fallback anti-repetition tracking. Prevents state drift, wrong-doc carryover, and clarification loops.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-state",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added strict precedence for explicit references over continuity",
      "Added anti-repetition tracking for fallbacks and prompts",
      "Added safe persistence boundaries between persistent and ephemeral state"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "end_of_turn",
    "preservePersistentAcrossTurns": true,
    "resetEphemeralEachTurn": true,
    "maxHistoryDepth": {
      "recentOperators": 12,
      "recentReasonCodes": 48,
      "recentFallbacks": 12,
      "recentTokens": 24
    },
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_in_precedence_order_then_commit",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "maxStateBytesSoft": 120000,
        "maxStateBytesHard": 240000,
        "fallbackCooldownTurns": 3,
        "tokenEntropyWindow": 6
      },
      "conflictResolution": {
        "ifExplicitRefAndContinuity": "explicit_wins",
        "ifLockAndUnlockSameTurn": "prefer_latest_user_directive",
        "ifInvalidUpdate": "reject_update_keep_prior"
      }
    },
    "precedenceOrder": [
      "apply_turn_reset",
      "apply_language_update",
      "apply_explicit_scope_lock_or_unlock",
      "apply_explicit_doc_ref_set_active",
      "apply_sheet_and_range_lock",
      "apply_followup_continuity",
      "apply_format_preferences",
      "record_reason_codes_and_tokens",
      "record_fallbacks_and_cooldowns",
      "enforce_history_caps"
    ],
    "integrationHooks": {
      "expectsSignals": [
        "explicitDocRef",
        "explicitDocLock",
        "scope_change_requested",
        "sheetHintPresent",
        "rangeExplicit",
        "isFollowup",
        "followupStrength",
        "languageSelected",
        "userAskedForBullets",
        "userAskedForTable",
        "userAskedForShort",
        "fallbackTriggered"
      ],
      "emitsSignals": ["stateUpdated", "stateResetEphemeral", "scopeLocked", "scopeUnlocked"]
    }
  },
  "rules": [
    {
      "id": "apply_turn_reset",
      "scope": "global",
      "description": "Reset ephemeral state at start of each new turn while preserving persistent and history.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "action": { "type": "reset_ephemeral", "preserve": ["persistent", "history", "session", "version"] },
      "reasonCode": "state_reset_ephemeral",
      "severity": "high"
    },
    {
      "id": "apply_language_update",
      "scope": "global",
      "description": "Persist language preference when an explicit language selection signal is present.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.languageSelected", "op": "in", "value": ["en", "pt", "es"] }
        ]
      },
      "action": {
        "type": "set_persistent",
        "path": "persistent.preferences.language",
        "valueFrom": "signals.languageSelected"
      },
      "reasonCode": "state_language_set",
      "severity": "medium"
    },
    {
      "id": "apply_explicit_scope_lock",
      "scope": "cross_family",
      "description": "If user requests doc lock/pin, persist hardDocLock and lock metadata.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.explicitDocLock", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "set_persistent_multi",
        "updates": [
          { "path": "persistent.scope.hardDocLock", "value": true },
          { "path": "persistent.locks.lockSetTurn", "valueFrom": "ephemeral.turn.turnId" },
          { "path": "persistent.locks.lockReasonCodes", "appendUniqueFrom": "ephemeral.routing.reasonCodes" }
        ]
      },
      "reasonCode": "state_doc_lock_set",
      "severity": "high"
    },
    {
      "id": "apply_explicit_scope_unlock",
      "scope": "cross_family",
      "description": "If user explicitly requests unlock/switch scope, clear hard locks and related scope fields safely.",
      "appliesTo": ["state_update"],
      "triggerPatterns": {
        "en": ["\\b(unlock|switch docs|change file|use another file)\\b"],
        "pt": ["\\b(destravar|trocar documento|mudar arquivo|usar outro arquivo)\\b"],
        "es": ["\\b(desbloquear|cambiar documento|cambiar archivo|usar otro archivo)\\b"]
      },
      "action": {
        "type": "set_persistent_multi",
        "updates": [
          { "path": "persistent.scope.hardDocLock", "value": false },
          { "path": "persistent.scope.hardSheetLock", "value": false },
          { "path": "persistent.scope.activeSheetName", "value": null },
          { "path": "persistent.scope.activeRangeA1", "value": null },
          { "path": "persistent.locks.lockReasonCodes", "value": [] },
          { "path": "persistent.locks.lockSetTurn", "value": null }
        ]
      },
      "reasonCode": "state_scope_unlocked",
      "severity": "high"
    },
    {
      "id": "apply_explicit_doc_ref_set_active",
      "scope": "global",
      "description": "When an explicit doc reference resolves, set active doc fields persistently; explicit ref wins over follow-up continuity.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.explicitDocRef", "op": "eq", "value": true },
          { "path": "signals.resolvedDocId", "op": "neq", "value": null }
        ]
      },
      "action": {
        "type": "set_persistent_multi",
        "updates": [
          { "path": "persistent.scope.activeDocId", "valueFrom": "signals.resolvedDocId" },
          { "path": "persistent.scope.activeDocTitle", "valueFrom": "signals.resolvedDocTitle" },
          { "path": "persistent.scope.activeFilename", "valueFrom": "signals.resolvedFilename" }
        ]
      },
      "reasonCode": "state_active_doc_set",
      "severity": "critical"
    },
    {
      "id": "apply_sheet_and_range_lock",
      "scope": "cross_family",
      "description": "If explicit sheet/range references exist, persist within-doc sheet/range lock hints (hardSheetLock).",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "any": [
          { "path": "signals.sheetHintPresent", "op": "eq", "value": true },
          { "path": "signals.rangeExplicit", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "set_persistent_multi",
        "updates": [
          { "path": "persistent.scope.hardSheetLock", "value": true },
          { "path": "persistent.scope.activeSheetName", "valueFrom": "signals.resolvedSheetName" },
          { "path": "persistent.scope.activeRangeA1", "valueFrom": "signals.resolvedRangeA1" }
        ]
      },
      "reasonCode": "state_sheet_range_lock_set",
      "severity": "high"
    },
    {
      "id": "apply_followup_continuity",
      "scope": "global",
      "description": "On follow-ups, keep active scope unless explicit new doc reference appears.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.isFollowup", "op": "eq", "value": true },
          { "path": "signals.explicitDocRef", "op": "neq", "value": true }
        ]
      },
      "action": {
        "type": "preserve_persistent",
        "paths": ["persistent.scope.activeDocId", "persistent.scope.activeSheetName", "persistent.scope.activeRangeA1"]
      },
      "reasonCode": "state_followup_continuity",
      "severity": "medium"
    },
    {
      "id": "apply_format_preferences",
      "scope": "global",
      "description": "Persist light formatting preferences (bullets/tables/concise) when user explicitly requests them.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "any": [
          { "path": "signals.userAskedForBullets", "op": "eq", "value": true },
          { "path": "signals.userAskedForTable", "op": "eq", "value": true },
          { "path": "signals.userAskedForShort", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "set_persistent_multi",
        "updates": [
          { "path": "persistent.preferences.formatBias.preferBullets", "valueFrom": "signals.userAskedForBullets" },
          { "path": "persistent.preferences.formatBias.preferTables", "valueFrom": "signals.userAskedForTable" },
          { "path": "persistent.preferences.formatBias.preferConcise", "valueFrom": "signals.userAskedForShort" }
        ]
      },
      "reasonCode": "state_format_bias_set",
      "severity": "low"
    },
    {
      "id": "record_reason_codes_and_tokens",
      "scope": "global",
      "description": "Append routing reason codes and UI tokens to history with uniqueness and caps.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "action": {
        "type": "append_history",
        "updates": [
          { "path": "history.recentOperators", "appendUniqueFrom": "ephemeral.routing.operator", "maxItems": 12 },
          { "path": "history.recentReasonCodes", "appendUniqueFrom": "ephemeral.routing.reasonCodes", "maxItems": 48 },
          { "path": "history.recentTokens", "appendUniqueFrom": "signals.uiTokensUsed", "maxItems": 24 }
        ]
      },
      "reasonCode": "state_history_recorded",
      "severity": "medium"
    },
    {
      "id": "record_fallbacks_and_cooldowns",
      "scope": "global",
      "description": "Record fallback events for anti-repetition (reasonCode/type/strategy) with capped history.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.fallbackTriggered", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "append_history_object",
        "path": "history.recentFallbacks",
        "object": {
          "reasonCodeFrom": "signals.fallbackReasonCode",
          "fallbackTypeFrom": "signals.fallbackType",
          "strategyFrom": "signals.fallbackStrategy",
          "turnIdFrom": "ephemeral.turn.turnId"
        },
        "maxItems": 12
      },
      "reasonCode": "state_fallback_recorded",
      "severity": "high"
    },
    {
      "id": "enforce_history_caps",
      "scope": "global",
      "description": "Enforce max lengths on history arrays to keep state bounded.",
      "appliesTo": ["state_update"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "action": {
        "type": "cap_history",
        "caps": { "recentOperators": 12, "recentReasonCodes": 48, "recentFallbacks": 12, "recentTokens": 24 }
      },
      "reasonCode": "state_history_capped",
      "severity": "low"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "SUR_0001_ephemeral_resets_each_turn",
        "context": { "priorState": { "ephemeral": { "routing": { "operator": "summarize", "answerMode": "doc_grounded_single", "reasonCodes": ["x"] } } }, "signals": {} },
        "expect": { "ephemeralReset": true }
      },
      {
        "id": "SUR_0002_explicit_doc_ref_sets_active",
        "context": { "signals": { "explicitDocRef": true, "resolvedDocId": "doc_A", "resolvedDocTitle": "A", "resolvedFilename": "a.pdf" } },
        "expect": { "persistent.scope.activeDocId": "doc_A" }
      },
      {
        "id": "SUR_0003_followup_preserves_scope",
        "context": { "signals": { "isFollowup": true, "explicitDocRef": false }, "priorState": { "persistent": { "scope": { "activeDocId": "doc_A" } } } },
        "expect": { "persistent.scope.activeDocId": "doc_A" }
      },
      {
        "id": "SUR_0004_unlock_clears_locks",
        "input": "unlock",
        "expect": { "persistent.scope.hardDocLock": false, "persistent.scope.hardSheetLock": false }
      },
      {
        "id": "SUR_0005_record_fallback_event",
        "context": { "signals": { "fallbackTriggered": true, "fallbackReasonCode": "scope_hard_constraints_empty", "fallbackType": "scope_empty", "fallbackStrategy": "offer_scope_relaxation" }, "ephemeral": { "turn": { "turnId": 5 } } },
        "expect": { "history.recentFallbacksCountMin": 1 }
      },
      {
        "id": "SUR_0006_history_caps_enforced",
        "context": { "history": { "recentReasonCodesCount": 200 } },
        "expect": { "history.recentReasonCodesCountMax": 48 }
      }
    ]
  }
}
