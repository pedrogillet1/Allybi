{
  "_meta": {
    "id": "conversation_state_schema",
    "version": "1.0.0",
    "description": "Canonical conversation state schema for Koda. Defines the minimal, production-safe state contract shared across routing, scope, retrieval, formatting, fallbacks, and probes. Prevents state drift by enforcing stable field names, allowed enums, and persistence boundaries (what may persist vs what must not).",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-state",
    "compat": ">=1.0.0",
    "changeLog": [
      "Introduced a strict but extensible state contract with namespaces",
      "Separated persistent state from ephemeral per-turn state",
      "Added constraints to prevent leaking internal IDs to user-visible layers"
    ]
  },
  "config": {
    "enabled": true,
    "schemaFlavor": "json_schema_like",
    "strict": true,
    "allowAdditionalProperties": false,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_all",
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "maxStateBytesSoft": 120000,
        "maxStateBytesHard": 240000
      },
      "conflictResolution": {
        "ifInvalidState": "hard_block_and_reset_ephemeral"
      }
    }
  },
  "rules": [
    {
      "id": "define_conversation_state_schema",
      "scope": "global",
      "description": "Defines the canonical state shape and constraints.",
      "appliesTo": ["state_schema"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "define_schema",
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "session", "persistent", "ephemeral", "history"],
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "session": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sessionId", "createdAt", "env"],
              "properties": {
                "sessionId": { "type": "string", "minLength": 6, "maxLength": 128 },
                "createdAt": { "type": "string" },
                "env": { "type": "string", "enum": ["production", "staging", "dev", "local"] },
                "userLocale": { "type": ["string", "null"] },
                "userLanguage": { "type": "string", "enum": ["any", "en", "pt", "es"] }
              }
            },
            "persistent": {
              "type": "object",
              "additionalProperties": false,
              "required": ["scope", "preferences", "locks"],
              "properties": {
                "scope": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["activeDocId", "activeDocTitle", "activeFilename", "hardDocLock", "hardSheetLock"],
                  "properties": {
                    "activeDocId": { "type": ["string", "null"], "maxLength": 256 },
                    "activeDocTitle": { "type": ["string", "null"], "maxLength": 256 },
                    "activeFilename": { "type": ["string", "null"], "maxLength": 256 },
                    "hardDocLock": { "type": "boolean" },
                    "hardSheetLock": { "type": "boolean" },
                    "activeSheetName": { "type": ["string", "null"], "maxLength": 128 },
                    "activeRangeA1": { "type": ["string", "null"], "maxLength": 32 },
                    "activePageHint": { "type": ["integer", "null"], "minimum": 1 },
                    "activeSlideHint": { "type": ["integer", "null"], "minimum": 1 }
                  }
                },
                "preferences": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["language", "formatBias"],
                  "properties": {
                    "language": { "type": "string", "enum": ["any", "en", "pt", "es"] },
                    "formatBias": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["preferBullets", "preferTables", "preferConcise"],
                      "properties": {
                        "preferBullets": { "type": "boolean" },
                        "preferTables": { "type": "boolean" },
                        "preferConcise": { "type": "boolean" }
                      }
                    }
                  }
                },
                "locks": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["lockReasonCodes", "lockSetTurn"],
                  "properties": {
                    "lockReasonCodes": { "type": "array", "items": { "type": "string" }, "maxItems": 12 },
                    "lockSetTurn": { "type": ["integer", "null"], "minimum": 0 }
                  }
                }
              }
            },
            "ephemeral": {
              "type": "object",
              "additionalProperties": false,
              "required": ["turn", "signals", "routing", "retrieval", "formatting"],
              "properties": {
                "turn": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["turnId", "timestamp"],
                  "properties": {
                    "turnId": { "type": "integer", "minimum": 0 },
                    "timestamp": { "type": "string" }
                  }
                },
                "signals": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "isFollowup": { "type": ["boolean", "null"] },
                    "followupStrength": { "type": ["string", "null"], "enum": ["weak", "medium", "strong", null] },
                    "explicitDocRef": { "type": ["boolean", "null"] },
                    "explicitDocLock": { "type": ["boolean", "null"] },
                    "intentFamily": { "type": ["string", "null"] },
                    "unsafeGate": { "type": ["boolean", "null"] },
                    "allowExpansion": { "type": ["boolean", "null"] },
                    "userAskedForTable": { "type": ["boolean", "null"] },
                    "userAskedForQuote": { "type": ["boolean", "null"] }
                  }
                },
                "routing": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["operator", "answerMode", "reasonCodes"],
                  "properties": {
                    "operator": { "type": ["string", "null"], "maxLength": 64 },
                    "answerMode": {
                      "type": ["string", "null"],
                      "enum": [
                        "nav_pills",
                        "doc_grounded_single",
                        "doc_grounded_multi",
                        "doc_grounded_quote",
                        "doc_grounded_table",
                        "general_answer",
                        "help_steps",
                        "rank_disambiguate",
                        "rank_autopick",
                        null
                      ]
                    },
                    "reasonCodes": { "type": "array", "items": { "type": "string" }, "maxItems": 24 }
                  }
                },
                "retrieval": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["retrievedChunks", "evidenceDocs", "topScore"],
                  "properties": {
                    "retrievedChunks": { "type": "integer", "minimum": 0 },
                    "evidenceDocs": { "type": "array", "items": { "type": "string" }, "maxItems": 32 },
                    "topScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
                    "scoreGap": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
                  }
                },
                "formatting": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["outputShape", "clarificationQuestionCount"],
                  "properties": {
                    "outputShape": { "type": ["string", "null"], "maxLength": 32 },
                    "clarificationQuestionCount": { "type": "integer", "minimum": 0 }
                  }
                }
              }
            },
            "history": {
              "type": "object",
              "additionalProperties": false,
              "required": ["recentOperators", "recentReasonCodes", "recentFallbacks", "recentTokens"],
              "properties": {
                "recentOperators": { "type": "array", "items": { "type": "string" }, "maxItems": 12 },
                "recentReasonCodes": { "type": "array", "items": { "type": "string" }, "maxItems": 48 },
                "recentFallbacks": {
                  "type": "array",
                  "maxItems": 12,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["reasonCode", "fallbackType", "strategy", "turnId"],
                    "properties": {
                      "reasonCode": { "type": "string" },
                      "fallbackType": { "type": "string" },
                      "strategy": { "type": "string" },
                      "turnId": { "type": "integer", "minimum": 0 }
                    }
                  }
                },
                "recentTokens": { "type": "array", "items": { "type": "string" }, "maxItems": 24 }
              }
            }
          }
        }
      },
      "reasonCode": "state_schema_defined",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "CSS_0001_required_top_level_fields",
        "input": {
          "version": "1.0.0",
          "session": { "sessionId": "abc123", "createdAt": "now", "env": "dev", "userLocale": null, "userLanguage": "any" },
          "persistent": {
            "scope": { "activeDocId": null, "activeDocTitle": null, "activeFilename": null, "hardDocLock": false, "hardSheetLock": false, "activeSheetName": null, "activeRangeA1": null, "activePageHint": null, "activeSlideHint": null },
            "preferences": { "language": "any", "formatBias": { "preferBullets": false, "preferTables": false, "preferConcise": false } },
            "locks": { "lockReasonCodes": [], "lockSetTurn": null }
          },
          "ephemeral": {
            "turn": { "turnId": 0, "timestamp": "now" },
            "signals": {},
            "routing": { "operator": null, "answerMode": null, "reasonCodes": [] },
            "retrieval": { "retrievedChunks": 0, "evidenceDocs": [], "topScore": null, "scoreGap": null },
            "formatting": { "outputShape": null, "clarificationQuestionCount": 0 }
          },
          "history": { "recentOperators": [], "recentReasonCodes": [], "recentFallbacks": [], "recentTokens": [] }
        },
        "expect": { "valid": true }
      },
      {
        "id": "CSS_0002_env_enum_enforced",
        "input": {
          "version": "1.0.0",
          "session": { "sessionId": "abc123", "createdAt": "now", "env": "development", "userLocale": null, "userLanguage": "any" },
          "persistent": { "scope": { "activeDocId": null, "activeDocTitle": null, "activeFilename": null, "hardDocLock": false, "hardSheetLock": false, "activeSheetName": null, "activeRangeA1": null, "activePageHint": null, "activeSlideHint": null }, "preferences": { "language": "any", "formatBias": { "preferBullets": false, "preferTables": false, "preferConcise": false } }, "locks": { "lockReasonCodes": [], "lockSetTurn": null } },
          "ephemeral": { "turn": { "turnId": 0, "timestamp": "now" }, "signals": {}, "routing": { "operator": null, "answerMode": null, "reasonCodes": [] }, "retrieval": { "retrievedChunks": 0, "evidenceDocs": [], "topScore": null, "scoreGap": null }, "formatting": { "outputShape": null, "clarificationQuestionCount": 0 } },
          "history": { "recentOperators": [], "recentReasonCodes": [], "recentFallbacks": [], "recentTokens": [] }
        },
        "expect": { "valid": false }
      },
      {
        "id": "CSS_0003_no_additional_properties",
        "input": {
          "version": "1.0.0",
          "session": { "sessionId": "abc123", "createdAt": "now", "env": "dev", "userLocale": null, "userLanguage": "any" },
          "persistent": { "scope": { "activeDocId": null, "activeDocTitle": null, "activeFilename": null, "hardDocLock": false, "hardSheetLock": false, "activeSheetName": null, "activeRangeA1": null, "activePageHint": null, "activeSlideHint": null }, "preferences": { "language": "any", "formatBias": { "preferBullets": false, "preferTables": false, "preferConcise": false } }, "locks": { "lockReasonCodes": [], "lockSetTurn": null } },
          "ephemeral": { "turn": { "turnId": 0, "timestamp": "now" }, "signals": {}, "routing": { "operator": null, "answerMode": null, "reasonCodes": [] }, "retrieval": { "retrievedChunks": 0, "evidenceDocs": [], "topScore": null, "scoreGap": null }, "formatting": { "outputShape": null, "clarificationQuestionCount": 0 } },
          "history": { "recentOperators": [], "recentReasonCodes": [], "recentFallbacks": [], "recentTokens": [] },
          "unexpected": 123
        },
        "expect": { "valid": false }
      }
    ]
  }
}
