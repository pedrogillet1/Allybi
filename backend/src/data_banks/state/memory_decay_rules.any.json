{
  "_meta": {
    "id": "memory_decay_rules",
    "version": "1.1.0",
    "description": "Deterministic memory decay rules for Koda conversation state. Controls how persistent preferences, locks, and history signals decay over time/turns to prevent stale scope, repetitive fallbacks, and incorrect follow-up carryover. Ensures ChatGPT-like continuity without 'sticky' wrong context.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-02-19",
    "owner": "koda-state",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added turn-based decay for locks, follow-up continuity, and anti-repetition histories",
      "Added safeguards so explicit user locks persist until explicit unlock",
      "Added bounded history pruning rules to keep state stable"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "start_of_turn",
    "decayModel": "turn_based_with_safeguards",
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_in_precedence_order_then_commit",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "followupContinuityTtlTurns": 6,
        "softPreferenceTtlTurns": 24,
        "fallbackCooldownTtlTurns": 6,
        "maxHistoryDepth": 64,
        "staleTopicTtlTurns": 18,
        "staleScopeTtlTurns": 14
      },
      "conflictResolution": {
        "ifExplicitLock": "preserve",
        "ifDecayAndNewSignal": "new_signal_wins",
        "ifOverPruneRisk": "prune_least_recent"
      }
    },
    "integrationHooks": {
      "expectsStatePaths": [
        "persistent.scope.hardDocLock",
        "persistent.locks.lockSetTurn",
        "history.recentFallbacks",
        "history.recentReasonCodes",
        "history.recentOperators",
        "ephemeral.signals.isFollowup"
      ],
      "emitsSignals": [
        "memoryDecayed",
        "followupContinuityExpired",
        "fallbackCooldownExpired"
      ]
    },
    "decayPolicies": {
      "followupContinuity": {
        "ttlTurns": 6,
        "decaysWhenNoActiveDoc": true
      },
      "formatPreferences": {
        "ttlTurns": 24,
        "fields": [
          "persistent.preferences.formatBias.preferBullets",
          "persistent.preferences.formatBias.preferTables",
          "persistent.preferences.formatBias.preferConcise"
        ]
      },
      "fallbackAntiRepetition": {
        "ttlTurns": 6,
        "fields": [
          "history.recentFallbacks"
        ]
      },
      "reasonCodeHistory": {
        "maxItems": 48
      },
      "operatorHistory": {
        "maxItems": 12
      },
      "tokenHistory": {
        "maxItems": 24
      },
      "topicContinuity": {
        "ttlTurns": 18,
        "clearWhenNoFollowup": true,
        "fields": [
          "persistent.scope.activeDocTitle",
          "persistent.scope.activeFilename"
        ]
      },
      "scopeHints": {
        "ttlTurns": 14,
        "fields": [
          "persistent.scope.activeSheetName",
          "persistent.scope.activeRangeA1"
        ]
      }
    }
  },
  "rules": [
    {
      "id": "preserve_explicit_doc_lock_indefinitely",
      "scope": "global",
      "description": "Never decay explicit hard doc lock; it must persist until user explicitly unlocks.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "when": {
        "all": [
          {
            "path": "persistent.scope.hardDocLock",
            "op": "eq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "preserve_path",
        "paths": [
          "persistent.scope.hardDocLock",
          "persistent.scope.activeDocId",
          "persistent.scope.activeFilename",
          "persistent.locks.lockSetTurn",
          "persistent.locks.lockReasonCodes"
        ]
      },
      "reasonCode": "memory_preserve_explicit_lock",
      "severity": "high"
    },
    {
      "id": "expire_followup_continuity_soft",
      "scope": "global",
      "description": "Expire follow-up continuity hints after TTL when no explicit lock is active, to prevent stale carryover.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "when": {
        "all": [
          {
            "path": "persistent.scope.hardDocLock",
            "op": "neq",
            "value": true
          },
          {
            "path": "metrics.turnsSinceLastContentTurn",
            "op": "gt",
            "value": 6
          }
        ]
      },
      "action": {
        "type": "clear_ephemeral_signal",
        "signals": [
          "isFollowup",
          "followupStrength"
        ]
      },
      "reasonCode": "memory_followup_continuity_expired",
      "severity": "medium"
    },
    {
      "id": "decay_format_preferences",
      "scope": "global",
      "description": "Decay soft format preferences over time to avoid sticky formatting across unrelated tasks.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "when": {
        "all": [
          {
            "path": "metrics.turnsSinceLastFormatPreference",
            "op": "gt",
            "value": 24
          }
        ]
      },
      "action": {
        "type": "set_paths",
        "updates": [
          {
            "path": "persistent.preferences.formatBias.preferBullets",
            "value": false
          },
          {
            "path": "persistent.preferences.formatBias.preferTables",
            "value": false
          },
          {
            "path": "persistent.preferences.formatBias.preferConcise",
            "value": false
          }
        ]
      },
      "reasonCode": "memory_format_prefs_decayed",
      "severity": "low"
    },
    {
      "id": "prune_fallback_history_by_ttl",
      "scope": "global",
      "description": "Prune fallback anti-repetition history beyond TTL to prevent unbounded growth and stale cooldown behavior.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "action": {
        "type": "prune_history_objects",
        "path": "history.recentFallbacks",
        "keepIf": [
          {
            "path": "turnId",
            "op": "gte",
            "valueFrom": "metrics.currentTurnIdMinusTtlFallback"
          }
        ],
        "maxItems": 12
      },
      "reasonCode": "memory_fallback_history_pruned",
      "severity": "medium"
    },
    {
      "id": "cap_reason_code_history",
      "scope": "global",
      "description": "Cap reason code history to keep state bounded and deterministic.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "action": {
        "type": "cap_history_array",
        "path": "history.recentReasonCodes",
        "maxItems": 48
      },
      "reasonCode": "memory_reason_codes_capped",
      "severity": "low"
    },
    {
      "id": "cap_operator_history",
      "scope": "global",
      "description": "Cap recent operator history to keep state bounded.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "action": {
        "type": "cap_history_array",
        "path": "history.recentOperators",
        "maxItems": 12
      },
      "reasonCode": "memory_operators_capped",
      "severity": "low"
    },
    {
      "id": "cap_token_history",
      "scope": "global",
      "description": "Cap recent UI token history for anti-repetition controls.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "action": {
        "type": "cap_history_array",
        "path": "history.recentTokens",
        "maxItems": 24
      },
      "reasonCode": "memory_tokens_capped",
      "severity": "low"
    },
    {
      "id": "decay_stale_scope_hints",
      "scope": "global",
      "description": "Decay stale sheet/range scope hints when follow-up continuity expires.",
      "appliesTo": [
        "memory_decay"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "when": {
        "all": [
          {
            "path": "persistent.scope.hardDocLock",
            "op": "neq",
            "value": true
          },
          {
            "path": "metrics.turnsSinceLastScopedHint",
            "op": "gt",
            "value": 14
          }
        ]
      },
      "action": {
        "type": "set_paths",
        "updates": [
          {
            "path": "persistent.scope.activeSheetName",
            "value": null
          },
          {
            "path": "persistent.scope.activeRangeA1",
            "value": null
          }
        ]
      },
      "reasonCode": "memory_scope_hints_decayed",
      "severity": "medium"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "MDR_0001_explicit_lock_not_decayed",
        "context": {
          "persistent": {
            "scope": {
              "hardDocLock": true,
              "activeDocId": "doc_A",
              "activeFilename": "a.pdf"
            },
            "locks": {
              "lockSetTurn": 1,
              "lockReasonCodes": [
                "explicit_doc_lock"
              ]
            }
          },
          "metrics": {
            "turnsSinceLastContentTurn": 100
          }
        },
        "expect": {
          "preservedPathsAny": [
            "persistent.scope.hardDocLock",
            "persistent.scope.activeDocId"
          ]
        }
      },
      {
        "id": "MDR_0002_followup_continuity_expires_without_lock",
        "context": {
          "persistent": {
            "scope": {
              "hardDocLock": false
            }
          },
          "ephemeral": {
            "signals": {
              "isFollowup": true,
              "followupStrength": "strong"
            }
          },
          "metrics": {
            "turnsSinceLastContentTurn": 7
          }
        },
        "expect": {
          "followupContinuityExpired": true
        }
      },
      {
        "id": "MDR_0003_format_prefs_decay",
        "context": {
          "metrics": {
            "turnsSinceLastFormatPreference": 30
          },
          "persistent": {
            "preferences": {
              "formatBias": {
                "preferBullets": true,
                "preferTables": true,
                "preferConcise": true
              }
            }
          }
        },
        "expect": {
          "formatBiasReset": true
        }
      },
      {
        "id": "MDR_0004_prune_fallback_history",
        "context": {
          "history": {
            "recentFallbacks": [
              {
                "reasonCode": "x",
                "fallbackType": "y",
                "strategy": "z",
                "turnId": 1
              },
              {
                "reasonCode": "x2",
                "fallbackType": "y2",
                "strategy": "z2",
                "turnId": 100
              }
            ]
          },
          "metrics": {
            "currentTurnIdMinusTtlFallback": 95
          }
        },
        "expect": {
          "recentFallbacksCountMax": 12,
          "oldEntriesPruned": true
        }
      },
      {
        "id": "MDR_0005_reason_codes_capped",
        "context": {
          "history": {
            "recentReasonCodesCount": 200
          }
        },
        "expect": {
          "recentReasonCodesCountMax": 48
        }
      },
      {
        "id": "MDR_0006_scope_hints_decay_after_ttl",
        "context": {
          "persistent": {
            "scope": {
              "hardDocLock": false,
              "activeSheetName": "Revenue",
              "activeRangeA1": "B2:F18"
            }
          },
          "metrics": {
            "turnsSinceLastScopedHint": 18
          }
        },
        "expect": {
          "scopeHintsCleared": true
        }
      },
      {
        "id": "MDR_0007_scope_hints_preserved_with_hard_lock",
        "context": {
          "persistent": {
            "scope": {
              "hardDocLock": true,
              "activeSheetName": "Revenue",
              "activeRangeA1": "B2:F18"
            }
          },
          "metrics": {
            "turnsSinceLastScopedHint": 30
          }
        },
        "expect": {
          "scopeHintsCleared": false
        }
      }
    ]
  }
}
