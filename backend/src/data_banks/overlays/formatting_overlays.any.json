{
  "_meta": {
    "id": "formatting_overlays",
    "version": "1.0.0",
    "description": "Deterministic formatting overlays for Koda. Applies post-routing formatting constraints based on answerMode, operator family, evidence type, and user format requests. Ensures ChatGPT-like structure: short paragraphs, controlled bullets/tables/quotes, and strict nav_pills behavior without hardcoded copy.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-overlays",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added overlay precedence for nav_pills vs doc-grounded formatting",
      "Added deterministic gating for tables/quotes/bullets based on intent and evidence",
      "Added tests for regressions: wall-of-text, bullet spam, tables without request, quotes too long"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "post_retrieval_pre_render",
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_most_restrictive",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "maxParagraphSentencesSoft": 2,
        "maxParagraphSentencesHard": 4,
        "maxBulletsSoft": 5,
        "maxBulletsHard": 7,
        "maxRowsSoft": 8,
        "maxRowsHard": 12,
        "maxQuoteCharsHard": 800
      },
      "conflictResolution": {
        "ifNavPillsAndAnything": "nav_pills_wins",
        "ifQuoteAndSummary": "prefer_quote",
        "ifTableAndNoTableIntent": "degrade_to_bullets"
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "paragraph_rules",
        "bullet_rules",
        "table_styles",
        "quote_styles",
        "bolding_rules",
        "banned_phrases",
        "boilerplate_phrases",
        "answer_openers"
      ],
      "emitsSignals": [
        "formatOverrideApplied",
        "tableSuppressed",
        "quoteTruncated",
        "bulletsSuppressed",
        "paragraphSplitApplied"
      ]
    },
    "precedenceOrder": [
      "nav_pills_strict",
      "quote_mode_strict",
      "table_mode_guard",
      "bullet_density_guard",
      "paragraph_split_guard",
      "banned_phrase_enforcement"
    ]
  },
  "rules": [
    {
      "id": "nav_pills_strict",
      "scope": "operator_specific",
      "description": "In nav_pills mode, allow only a single intro sentence and source buttons; suppress body formatting entirely.",
      "appliesTo": ["format_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": {
        "type": "enforce_nav_pills_format",
        "introOnly": true,
        "maxIntroSentences": 1,
        "suppress": ["bullets", "tables", "quotes", "sources_header", "actions"]
      },
      "reasonCode": "format_nav_pills_strict",
      "severity": "critical"
    },
    {
      "id": "quote_mode_strict",
      "scope": "operator_specific",
      "description": "In quote mode, enforce quote length caps and require exact evidence snippets; suppress tables unless explicitly requested.",
      "appliesTo": ["format_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "doc_grounded_quote" }
        ]
      },
      "action": {
        "type": "enforce_quote_format",
        "maxQuoteCharsHard": 800,
        "truncateIfOver": true,
        "suppressIfNoQuoteIntent": false
      },
      "reasonCode": "format_quote_strict",
      "severity": "high"
    },
    {
      "id": "table_mode_guard",
      "scope": "cross_family",
      "description": "Allow tables only for comparison/computation/multi-row metrics; otherwise degrade to bullets/paragraphs.",
      "appliesTo": ["format_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.userAskedForTable", "op": "neq", "value": true },
          { "path": "signals.isComparisonIntent", "op": "neq", "value": true },
          { "path": "signals.isComputationIntent", "op": "neq", "value": true },
          { "path": "metrics.factCount", "op": "lt", "value": 3 }
        ]
      },
      "action": {
        "type": "suppress_tables",
        "fallback": "bullets",
        "emitSignals": ["tableSuppressed"]
      },
      "reasonCode": "format_table_guard",
      "severity": "high"
    },
    {
      "id": "bullet_density_guard",
      "scope": "global",
      "description": "Cap bullet count and per-bullet density; suppress bullets when single-fact answers.",
      "appliesTo": ["format_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "enforce_bullet_limits",
        "maxBulletsSoft": 5,
        "maxBulletsHard": 7,
        "maxBulletSentencesHard": 3,
        "maxBulletCharsHard": 320
      },
      "reasonCode": "format_bullet_density",
      "severity": "medium"
    },
    {
      "id": "paragraph_split_guard",
      "scope": "global",
      "description": "Split long paragraphs into short paragraphs and enforce sentence caps for ChatGPT-like readability.",
      "appliesTo": ["format_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "enforce_paragraph_limits",
        "maxSentencesSoft": 2,
        "maxSentencesHard": 4,
        "autoSplit": true,
        "emitSignals": ["paragraphSplitApplied"]
      },
      "reasonCode": "format_paragraph_limits",
      "severity": "high"
    },
    {
      "id": "banned_phrase_enforcement",
      "scope": "global",
      "description": "Enforce banned phrase removal/blocking prior to final render.",
      "appliesTo": ["format_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "enforce_banned_phrases"
      },
      "reasonCode": "format_banned_phrases",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "FO_001_nav_pills_strict_intro_only",
        "context": { "answerMode": "nav_pills" },
        "expect": { "introOnly": true, "maxIntroSentences": 1 }
      },
      {
        "id": "FO_002_table_guard_degrades",
        "context": { "metrics": { "factCount": 1 }, "signals": { "userAskedForTable": false } },
        "expect": { "tableSuppressed": true }
      },
      {
        "id": "FO_003_quote_truncate",
        "context": { "answerMode": "doc_grounded_quote", "metrics": { "quoteChars": 1200 } },
        "expect": { "quoteTruncated": true }
      },
      {
        "id": "FO_004_paragraph_split_applied",
        "context": { "metrics": { "paragraphSentences": 6 } },
        "expect": { "paragraphSplitApplied": true }
      },
      {
        "id": "FO_005_banned_phrase_blocked",
        "input": "No relevant information found.",
        "expect": { "blockedOrRemoved": true }
      }
    ]
  }
}
