{
  "_meta": {
    "id": "scope_hints",
    "version": "1.0.0",
    "description": "Deterministic scope hint overlays for Koda. Extracts and prioritizes scope constraints from user input (explicit doc/file refs, active doc locks, doc types, sheets/tabs, pages/slides/sections, ranges, and domain anchors). Prevents wrong-doc drift and over-broad retrieval by converting natural language into explicit scope signals used by scope_resolution and retrieval.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-overlays",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added deterministic actionsContract for scope-hint precedence and collision handling",
      "Added guarded extraction of file/sheet/page/section/range scope signals",
      "Expanded tests for multilingual, collision, and regression (doc drift, nav pills, over-scope)"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "pre_scope_resolution",
    "preferExplicitOverImplicit": true,
    "neverInventDocScope": true,
    "neverOverrideExplicitLocks": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_in_precedence_order_then_merge",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "minHintConfidence": 0.75,
        "autopickConfidence": 0.88,
        "autopickGap": 0.25,
        "maxHintsPerTypeSoft": 3,
        "maxHintsPerTypeHard": 6
      },
      "conflictResolution": {
        "ifExplicitDocAndActiveDocConflict": "explicit_wins",
        "ifMultipleDocRefs": "require_disambiguation_unless_autopick_safe",
        "ifDiscoveryIntentAndHardLock": "discovery_ignores_lock",
        "ifRangeAndNoRangeConflict": "prefer_explicit_range"
      }
    },
    "precedenceOrder": [
      "explicit_filename",
      "explicit_doc_title_or_alias",
      "explicit_sheet_or_tab",
      "explicit_page_or_slide",
      "explicit_section_heading",
      "explicit_cell_range",
      "doc_type_hint",
      "domain_hint",
      "implicit_reference_pronouns"
    ],
    "hintTypes": [
      "doc_ref",
      "doc_type",
      "sheet_ref",
      "page_ref",
      "slide_ref",
      "section_ref",
      "range_ref",
      "domain_ref",
      "pronoun_ref"
    ],
    "integrationHooks": {
      "normalizers": [
        "language_indicators",
        "stopwords_docnames",
        "doc_aliases",
        "document_intelligence_bank_map"
      ],
      "semantics": [
        "spreadsheet_semantics",
        "domain_ontology",
        "document_intelligence_bank_map"
      ]
    }
  },
  "rules": [
    {
      "id": "explicit_filename_hint",
      "scope": "global",
      "description": "Extract explicit filename references (with extension) as hard doc scope hints.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b\\w[\\w\\-_. ]{0,160}\\.(pdf|docx?|xlsx?|pptx?|txt|csv|png|jpe?g|webp)\\b"],
        "pt": ["\\b\\w[\\w\\-_. ]{0,160}\\.(pdf|docx?|xlsx?|pptx?|txt|csv|png|jpe?g|webp)\\b"],
        "es": ["\\b\\w[\\w\\-_. ]{0,160}\\.(pdf|docx?|xlsx?|pptx?|txt|csv|png|jpe?g|webp)\\b"]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "doc_ref",
        "hard": true,
        "confidence": 0.95,
        "source": "explicit_filename",
        "emitSignals": ["explicitDocRef", "explicitDocLockCandidate"]
      },
      "reasonCode": "scope_hint_filename",
      "severity": "critical"
    },
    {
      "id": "explicit_doc_title_or_alias_hint",
      "scope": "global",
      "description": "Extract explicit doc title/alias references and emit doc scope hints via doc_aliases resolution (guarded).",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(this file|this document|the document called|the file named)\\b", "\\bopen\\b.{0,60}"],
        "pt": ["\\b(este arquivo|este documento|o documento chamado|o arquivo chamado)\\b", "\\babrir\\b.{0,60}"],
        "es": ["\\b(este archivo|este documento|el documento llamado|el archivo llamado)\\b", "\\babrir\\b.{0,60}"]
      },
      "when": {
        "all": [
          { "path": "signals.docAliasesAvailable", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "doc_ref",
        "hard": true,
        "confidence": 0.85,
        "source": "doc_aliases",
        "emitSignals": ["explicitDocRef"]
      },
      "reasonCode": "scope_hint_doc_alias",
      "severity": "high"
    },
    {
      "id": "sheet_or_tab_hint",
      "scope": "global",
      "description": "Extract explicit spreadsheet sheet/tab references as sheet scope hints.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(sheet|tab)\\s*[:#]?\\s*([A-Za-z0-9 _\\-]{1,40})\\b"],
        "pt": ["\\b(aba|guia|folha)\\s*[:#]?\\s*([A-Za-z0-9 _\\-]{1,40})\\b"],
        "es": ["\\b(hoja|pestaña)\\s*[:#]?\\s*([A-Za-z0-9 _\\-]{1,40})\\b"]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "sheet_ref",
        "hard": true,
        "confidence": 0.85,
        "source": "explicit_sheet",
        "emitSignals": ["explicitSheetRef"]
      },
      "reasonCode": "scope_hint_sheet",
      "severity": "high"
    },
    {
      "id": "page_reference_hint",
      "scope": "global",
      "description": "Extract explicit PDF page references and emit page scope hints without guessing page numbers.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\bpage\\s*(\\d{1,5})\\b", "\\bp\\.\\s*(\\d{1,5})\\b"],
        "pt": ["\\b(p[aá]gina|p[aá]g\\.)\\s*(\\d{1,5})\\b"],
        "es": ["\\b(p[aá]gina|p[áa]g\\.)\\s*(\\d{1,5})\\b"]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "page_ref",
        "hard": false,
        "confidence": 0.9,
        "source": "explicit_page",
        "emitSignals": ["pageRefPresent"]
      },
      "reasonCode": "scope_hint_page",
      "severity": "medium"
    },
    {
      "id": "slide_reference_hint",
      "scope": "global",
      "description": "Extract explicit slide references and emit slide scope hints.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\bslide\\s*(\\d{1,5})\\b"],
        "pt": ["\\bslide\\s*(\\d{1,5})\\b"],
        "es": ["\\b(diapositiva|slide)\\s*(\\d{1,5})\\b"]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "slide_ref",
        "hard": false,
        "confidence": 0.85,
        "source": "explicit_slide",
        "emitSignals": ["slideRefPresent"]
      },
      "reasonCode": "scope_hint_slide",
      "severity": "medium"
    },
    {
      "id": "section_heading_hint",
      "scope": "global",
      "description": "Extract explicit section/heading references and emit structural scope hints (does not assume the section exists).",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(section|heading|chapter|appendix)\\b\\s*[:#]?\\s*([A-Za-z0-9 _\\-]{1,60})\\b"],
        "pt": ["\\b(se[cç][aã]o|t[ií]tulo|cap[ií]tulo|anexo)\\b\\s*[:#]?\\s*([A-Za-z0-9 _\\-]{1,60})\\b"],
        "es": ["\\b(secci[oó]n|t[ií]tulo|cap[ií]tulo|anexo)\\b\\s*[:#]?\\s*([A-Za-z0-9 _\\-]{1,60})\\b"]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "section_ref",
        "hard": false,
        "confidence": 0.8,
        "source": "explicit_section",
        "emitSignals": ["sectionRefPresent"]
      },
      "reasonCode": "scope_hint_section",
      "severity": "medium"
    },
    {
      "id": "explicit_cell_range_hint",
      "scope": "global",
      "description": "Extract explicit spreadsheet A1 ranges and emit range scope hints; do not infer ranges.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b[A-Z]{1,3}\\d{1,7}\\s*:\\s*[A-Z]{1,3}\\d{1,7}\\b"],
        "pt": ["\\b[A-Z]{1,3}\\d{1,7}\\s*:\\s*[A-Z]{1,3}\\d{1,7}\\b"],
        "es": ["\\b[A-Z]{1,3}\\d{1,7}\\s*:\\s*[A-Z]{1,3}\\d{1,7}\\b"]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "range_ref",
        "hard": true,
        "confidence": 0.9,
        "source": "explicit_range",
        "emitSignals": ["rangeExplicit"]
      },
      "reasonCode": "scope_hint_range",
      "severity": "high"
    },
    {
      "id": "doc_type_hint",
      "scope": "global",
      "description": "Extract doc type hints (pdf/spreadsheet/slides/image) to guide retrieval type boosting without excluding other types.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(pdf|spreadsheet|xlsx|csv|slides|pptx|image|png|jpg|jpeg)\\b"],
        "pt": ["\\b(pdf|planilha|xlsx|csv|slides|pptx|imagem|png|jpg|jpeg)\\b"],
        "es": ["\\b(pdf|hoja|xlsx|csv|diapositivas|pptx|imagen|png|jpg|jpeg)\\b"]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "doc_type",
        "hard": false,
        "confidence": 0.8,
        "source": "explicit_doc_type",
        "emitSignals": ["docTypeHintPresent"]
      },
      "reasonCode": "scope_hint_doc_type",
      "severity": "low"
    },
    {
      "id": "implicit_pronoun_reference_soft",
      "scope": "global",
      "description": "Tag pronoun-based references (it/this/that) as soft scope hints to maintain continuity, without overriding explicit refs.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(it|this|that|here)\\b"],
        "pt": ["\\b(isso|isto|esse|essa|aqui)\\b"],
        "es": ["\\b(eso|esto|ese|esa|aqu[ií])\\b"]
      },
      "when": {
        "all": [
          { "path": "signals.hasActiveDoc", "op": "eq", "value": true },
          { "path": "signals.explicitDocRef", "op": "neq", "value": true }
        ]
      },
      "action": {
        "type": "emit_scope_hint",
        "hintType": "pronoun_ref",
        "hard": false,
        "confidence": 0.75,
        "source": "pronoun_continuity",
        "emitSignals": ["followupContinuity"]
      },
      "reasonCode": "scope_hint_pronoun",
      "severity": "low"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "SH_001_filename_hard_scope",
        "input": "Open report_Q4_2023.pdf",
        "expect": { "hintType": "doc_ref", "hard": true, "emitSignalsAny": ["explicitDocRef"] }
      },
      {
        "id": "SH_002_sheet_hint_pt",
        "input": "Na aba Caixa, some os valores",
        "expect": { "hintType": "sheet_ref", "hard": true }
      },
      {
        "id": "SH_003_page_hint_es",
        "input": "En la página 10, ¿dónde se menciona NOI?",
        "expect": { "hintType": "page_ref", "hard": false }
      },
      {
        "id": "SH_004_range_hint",
        "input": "Sum A1:B20",
        "expect": { "hintType": "range_ref", "hard": true }
      },
      {
        "id": "SH_005_pronoun_continuity_only_when_active_doc",
        "context": { "signals": { "hasActiveDoc": true, "explicitDocRef": false } },
        "input": "Summarize it",
        "expect": { "hintType": "pronoun_ref", "emitSignalsAny": ["followupContinuity"] }
      },
      {
        "id": "SH_006_collision_explicit_doc_wins_over_pronoun",
        "context": { "signals": { "hasActiveDoc": true } },
        "input": "Summarize it — in report_Q4_2023.pdf",
        "expect": { "explicitDocRefPreferred": true }
      },
      {
        "id": "SH_007_regression_no_wrong_doc_drift_after_lock",
        "context": { "signals": { "explicitDocLock": true, "intentFamily": "documents" } },
        "input": "Now summarize it",
        "expect": { "scopeRestrictedToLockedDoc": true }
      }
    ]
  }
}
