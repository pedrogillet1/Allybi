{
  "_meta": {
    "id": "creative_operators",
    "version": "1.0.0",
    "description": "Operator catalog for creative generation (visuals/diagrams/assets). Defines safe creative requests, style constraints, deck matching rules, and EN/PT patterns + examples. User-facing copy must never mention model names.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07",
    "owner": "koda-creative"
  },
  "config": {
    "enabled": true,
    "defaults": {
      "confirmationPolicy": {
        "silentExecuteConfidence": 0.9,
        "disambiguationMargin": 0.12,
        "blockedIfAmbiguous": true,
        "blockedIfMissingEntities": true,
        "allowOverrideWithExplicitUserConfirmation": true
      },
      "outputContract": {
        "requiredBlocks": ["preview", "why", "actions"],
        "stages": ["preview", "applied", "blocked"],
        "proofRequired": false
      },
      "stylePolicy": {
        "defaultStyleMode": "match_deck",
        "defaultPalettePolicy": "use_deck_colors",
        "defaultTextInImagePolicy": "none",
        "safeZones": {
          "16:9": { "marginPct": 0.06 },
          "1:1": { "marginPct": 0.08 }
        }
      },
      "safety": {
        "noLogPromptsWithSensitiveData": true,
        "noGeneratingPersonalData": true
      }
    },
    "normalization": {
      "supportedLocales": ["en", "pt"],
      "supportedFileTypes": ["slides", "pptx"],
      "supportedDomains": ["finance", "legal", "medical", "research", "comp_sci", "tax_us", "tax_br", "insurance", "general", "other"]
    }
  },
