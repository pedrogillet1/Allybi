{
  "_meta": {
    "id": "operator_examples",
    "version": "2.0.0",
    "description": "High-fidelity operator intent corpus for Koda. Encodes positive, negative, ambiguous, and discourse-continuation examples to preserve ChatGPT-class routing behavior across turns and contexts.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-routing",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "requirePositive": true,
    "requireNegative": true,
    "requireAmbiguous": true,
    "requireFollowups": true,
    "maxExamplesPerClass": 10
  },
  "entries": [
    {
      "operator": "summarize",
      "intentProfile": "doc_abstraction",
      "positive": [
        "Summarize this document",
        "Give me a high-level overview",
        "What are the main takeaways?"
      ],
      "negative": [
        "Quote the exact wording",
        "Where is this mentioned?",
        "List my files"
      ],
      "ambiguous": [
        "Explain this",
        "What does this say?"
      ],
      "followups": [
        {
          "prior": "Summarize this document",
          "next": "Now do it in bullet points"
        }
      ]
    },
    {
      "operator": "extract",
      "intentProfile": "fact_retrieval",
      "positive": [
        "What is the total revenue?",
        "Extract the NOI",
        "List the operating expenses"
      ],
      "negative": [
        "Summarize the report",
        "Where is revenue mentioned?"
      ],
      "ambiguous": [
        "Tell me about revenue",
        "Show me the numbers"
      ],
      "followups": [
        {
          "prior": "What is the total revenue?",
          "next": "And what about last year?"
        }
      ]
    },
    {
      "operator": "locate_content",
      "intentProfile": "inside_doc_navigation",
      "positive": [
        "Where is ROI mentioned?",
        "On which page does it discuss capex?",
        "Find all mentions of depreciation"
      ],
      "negative": [
        "Open the document",
        "Which folder is this in?"
      ],
      "ambiguous": [
        "Where is it?",
        "Find this"
      ],
      "followups": [
        {
          "prior": "Where is ROI mentioned?",
          "next": "Show me the first occurrence"
        }
      ]
    },
    {
      "operator": "list",
      "intentProfile": "file_inventory",
      "positive": [
        "List my files",
        "Show all uploaded documents"
      ],
      "negative": [
        "List the top 5 risks",
        "List the assumptions in the report"
      ],
      "ambiguous": [
        "What do I have?",
        "Show me everything"
      ],
      "followups": [
        {
          "prior": "List my files",
          "next": "Only PDFs"
        }
      ]
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "EX_001_inventory_not_conceptual",
        "input": "List the top 5 assumptions",
        "expect": { "operatorNot": "list" }
      },
      {
        "id": "EX_002_followup_resolution",
        "inputSequence": ["Summarize this document", "Now show me where it's mentioned"],
        "expect": { "operator": "locate_content", "isFollowup": true }
      },
      {
        "id": "EX_003_pt_ambiguity",
        "input": "mostra isso",
        "expect": { "ambiguous": true }
      },
      {
        "id": "EX_004_es_negative",
        "input": "cita textualmente",
        "expect": { "operator": "quote" }
      }
    ]
  }
}
