  "entityExtractionPatterns": {
    "filelike_pattern": {
      "_comment": "Matches filenames with extensions OR quoted filenames. The executor should prefer quoted matches when present.",
      "patterns": [
        "[\"']([^\"']+\\.(?:pdf|xlsx?|docx?|pptx?|csv|txt|png|jpe?g|gif|webp|svg|mp4|mov|mp3|wav|zip|rar))[\"']",
        "([\\w\\-\\.\\s]+\\.(?:pdf|xlsx?|docx?|pptx?|csv|txt|png|jpe?g|gif|webp|svg|mp4|mov|mp3|wav|zip|rar))"
      ]
    },
    "quoted_or_trailing": {
      "_comment": "Matches quoted string or trailing noun phrase after 'folder/pasta'.",
      "patterns": [
        "[\"']([^\"']+)[\"']",
        "(?:folder|pasta|directory|diret[oó]rio)\\s+([\\p{L}\\p{N}\\s\\-_.]+?)(?:\\s*$|\\s+(?:to|para|inside|dentro|in|em|under|sob))"
      ]
    },
    "first_quoted_or_noun": {
      "_comment": "Matches first quoted string, else first noun phrase after folder/pasta token.",
      "patterns": [
        "^[^\"']*[\"']([^\"']+)[\"']",
        "(?:folder|pasta)\\s+([\\p{L}\\p{N}\\s\\-_.]+?)(?:\\s+(?:to|para|as|como)|\\s*$)"
      ]
    },
    "after_keyword": {
      "_comment": "Executor should build a dynamic regex using keywords list per operator (to/as/para/como) and capture following phrase.",
      "patterns": [
        "(?:\\bto\\b|\\bas\\b|\\bpara\\b|\\bcomo\\b)\\s+[\"']?([^\"'\\n]+)[\"']?",
        "(?:\\binto\\b|\\bin\\b|\\binside\\b|\\bem\\b|\\bna\\b|\\bno\\b)\\s+[\"']?([^\"'\\n]+)[\"']?"
      ]
    },
    "after_preposition": {
      "_comment": "Executor should build a dynamic regex using prepositions list per operator (inside/in/under/dentro/em/sob) and capture following phrase.",
      "patterns": [
        "(?:\\binside\\b|\\bwithin\\b|\\bunder\\b|\\bin\\b)\\s+[\"']?([^\"'\\n]+)[\"']?",
        "(?:\\bdentro\\s+de\\b|\\bem\\b|\\bsob\\b|\\bna\\b|\\bno\\b)\\s+[\"']?([^\"'\\n]+)[\"']?"
      ]
    },
    "multiple_filelike": {
      "_comment": "Matches multiple filenames separated by commas or 'and'/'e'. Executor handles the extraction in extractMultipleFilenames().",
      "patterns": [
        "([\\w\\-\\.\\s]+\\.(?:pdf|xlsx?|docx?|pptx?|csv|txt|png|jpe?g|gif|webp|svg))(?:\\s*(?:,|and|e)\\s*([\\w\\-\\.\\s]+\\.(?:pdf|xlsx?|docx?|pptx?|csv|txt|png|jpe?g|gif|webp|svg)))+",
        "[\"']([^\"']+\\.(?:pdf|xlsx?|docx?|pptx?|csv|txt))[\"'](?:\\s*(?:,|and|e)\\s*[\"']([^\"']+\\.(?:pdf|xlsx?|docx?|pptx?|csv|txt))[\"'])+"
      ]
    }
  },
