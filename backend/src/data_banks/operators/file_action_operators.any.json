{
  "_meta": {
    "id": "file_action_operators",
    "version": "1.2.0",
    "description": "Databank-driven configuration for file/folder write operators and navigation operators. Executor MUST read detection + entity extraction from here (no hardcoded patterns in TypeScript). Supports EN/PT natural language, confirmation prompts, undo, and safe disambiguation. Includes open operator (non-destructive).",
    "languages": [
      "any",
      "en",
      "pt"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "koda-file-actions",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "undoTtlSeconds": 300,
    "maxBulkItems": 50,
    "confirmBulkAbove": 10,
    "_comment": "Answer-class behavior: file actions are NAVIGATION/GENERAL (no RAG sources). If executor emits actionSources, UI should render as action attachments, not doc-grounded sources.",
    "operatorDetection": {
      "enabled": true,
      "useRegex": true,
      "caseInsensitive": true,
      "stripDiacritics": true,
      "collapseWhitespace": true,
      "multipleMatchPolicy": "pick_highest_priority",
      "maxCandidatesPerMessage": 3,
      "minConfidence": 0.55,
      "highConfidence": 0.82,
      "guards": {
        "_comment": "Global guards to avoid false positives with content questions.",
        "mustNotMatchWholeMessage": {
          "en": [
            "^\\s*(hi|hello|hey|thanks|thank you|ok|okay|cool)\\s*[!.?]*\\s*$"
          ],
          "pt": [
            "^\\s*(oi|ol[aá]|obrigado|obrigada|valeu|ok|beleza|certo)\\s*[!.?]*\\s*$"
          ]
        },
        "mustNotContain": {
          "_comment": "Avoid interpreting doc-content questions as file actions.",
          "en": [
            "\\b(summarize|summary|explain|what does it say|quote|verbatim|find all mentions|on which page|where in the document)\\b"
          ],
          "pt": [
            "\\b(resumir|resumo|explique|o que diz|citar|literal|encontre|em qual p[aá]gina|onde no documento)\\b"
          ]
        }
      }
    }
  },
  "detectionRules": [
    {
      "id": "DET_0001_undo",
      "operator": "undo",
      "priority": 100,
      "confidence": 0.92,
      "patterns": {
        "en": [
          "^\\s*(undo|revert|roll\\s*back|go\\s*back|take\\s*that\\s*back|cancel\\s*that)\\s*[!.?]*\\s*$",
          "\\bundo\\b",
          "\\brevert\\b",
          "\\broll\\s*back\\b"
        ],
        "pt": [
          "^\\s*(desfazer|reverter|voltar\\s*atr[aá]s|anular|cancelar\\s*isso|desfaz)\\s*[!.?]*\\s*$",
          "\\bdesfazer\\b",
          "\\breverter\\b",
          "\\bvoltar\\s*atr[aá]s\\b"
        ]
      }
    },
    {
      "id": "DET_0010_folder_create",
      "operator": "folder_create",
      "priority": 95,
      "confidence": 0.86,
      "patterns": {
        "en": [
          "\\b(create|make|add|start)\\b.{0,25}\\b(folder|directory)\\b",
          "\\bnew\\b.{0,10}\\b(folder|directory)\\b",
          "\\bcreate\\b.{0,10}\\b(a\\s+)?folder\\b.{0,15}\\b(called|named|titled)\\b"
        ],
        "pt": [
          "\\b(criar|crie|cria|novo|nova|adicionar)\\b.{0,25}\\b(pasta|diret[oó]rio)\\b",
          "\\b(criar)\\b.{0,10}\\b(uma\\s+)?pasta\\b.{0,15}\\b(chamada|chamado|nomeada|nomeado|com\\s+nome)\\b",
          "\\b(nova)\\b.{0,10}\\b(pasta)\\b"
        ]
      },
      "mustNotContain": {
        "_comment": "Avoid collision with document open requests like 'open folder' in a viewer context.",
        "en": [
          "\\bopen\\b.{0,10}\\bfolder\\b"
        ],
        "pt": [
          "\\babrir\\b.{0,10}\\bpasta\\b"
        ]
      }
    },
    {
      "id": "DET_0011_folder_rename",
      "operator": "folder_rename",
      "priority": 90,
      "confidence": 0.82,
      "patterns": {
        "en": [
          "\\b(rename|change\\s+name\\s+of)\\b.{0,40}\\b(folder|directory)\\b",
          "\\brename\\b.{0,20}\\bfolder\\b.{0,50}\\b(to|as)\\b"
        ],
        "pt": [
          "\\b(renomear|mudar\\s+o\\s+nome|trocar\\s+o\\s+nome)\\b.{0,40}\\b(pasta|diret[oó]rio)\\b",
          "\\brenomear\\b.{0,20}\\bpasta\\b.{0,50}\\b(para|como)\\b"
        ]
      }
    },
    {
      "id": "DET_0012_folder_delete",
      "operator": "folder_delete",
      "priority": 89,
      "confidence": 0.8,
      "patterns": {
        "en": [
          "\\b(delete|remove|trash)\\b.{0,40}\\b(folder|directory)\\b",
          "\\bdelete\\b.{0,20}\\bfolder\\b"
        ],
        "pt": [
          "\\b(excluir|deletar|remover|apagar)\\b.{0,40}\\b(pasta|diret[oó]rio)\\b",
          "\\bexcluir\\b.{0,20}\\bpasta\\b"
        ]
      }
    },
    {
      "id": "DET_0013_folder_move",
      "operator": "folder_move",
      "priority": 88,
      "confidence": 0.78,
      "patterns": {
        "en": [
          "\\b(move|transfer)\\b.{0,25}\\b(folder|directory)\\b.{0,80}\\b(to|into|inside|under)\\b",
          "\\bmove\\b.{0,20}\\bfolder\\b.{0,80}\\bto\\b"
        ],
        "pt": [
          "\\b(mover|transferir|colocar)\\b.{0,25}\\b(pasta|diret[oó]rio)\\b.{0,80}\\b(para|em|dentro\\s+de|sob)\\b",
          "\\bmover\\b.{0,20}\\bpasta\\b.{0,80}\\bpara\\b"
        ]
      }
    },
    {
      "id": "DET_0020_file_bulk_move",
      "operator": "file_bulk_move",
      "priority": 87,
      "confidence": 0.8,
      "patterns": {
        "en": [
          "\\b(move|transfer)\\b.{0,10}\\b(all|these|those)\\b.{0,30}\\b(files|documents|pdfs|spreadsheets|slides)\\b.{0,80}\\b(to|into|in)\\b",
          "\\bmove\\b.{0,10}\\beverything\\b.{0,60}\\bto\\b"
        ],
        "pt": [
          "\\b(mover|transferir|colocar)\\b.{0,10}\\b(todos|todas|esses|essas)\\b.{0,30}\\b(arquivos|documentos|pdfs|planilhas|slides)\\b.{0,80}\\b(para|em|dentro\\s+de)\\b",
          "\\bmover\\b.{0,10}\\btudo\\b.{0,60}\\bpara\\b"
        ]
      },
      "mustContain": {
        "_comment": "Bulk requires a plural indicator.",
        "en": [
          "\\b(all|these|those|everything)\\b"
        ],
        "pt": [
          "\\b(todos|todas|esses|essas|tudo)\\b"
        ]
      }
    },
    {
      "id": "DET_0021_file_bulk_delete",
      "operator": "file_bulk_delete",
      "priority": 86,
      "confidence": 0.78,
      "patterns": {
        "en": [
          "\\b(delete|remove|trash)\\b.{0,10}\\b(all|these|those)\\b.{0,30}\\b(files|documents)\\b",
          "\\bdelete\\b.{0,10}\\beverything\\b"
        ],
        "pt": [
          "\\b(excluir|deletar|remover|apagar)\\b.{0,10}\\b(todos|todas|esses|essas)\\b.{0,30}\\b(arquivos|documentos)\\b",
          "\\bexcluir\\b.{0,10}\\btudo\\b"
        ]
      }
    },
    {
      "id": "DET_0022_file_bulk_copy",
      "operator": "file_bulk_copy",
      "priority": 85,
      "confidence": 0.72,
      "patterns": {
        "en": [
          "\\b(copy|duplicate)\\b.{0,10}\\b(all|these|those)\\b.{0,30}\\b(files|documents)\\b.{0,80}\\b(to|into|in)\\b"
        ],
        "pt": [
          "\\b(copiar|duplicar)\\b.{0,10}\\b(todos|todas|esses|essas)\\b.{0,30}\\b(arquivos|documentos)\\b.{0,80}\\b(para|em|dentro\\s+de)\\b"
        ]
      }
    },
    {
      "id": "DET_0030_file_copy",
      "operator": "file_copy",
      "priority": 80,
      "confidence": 0.7,
      "patterns": {
        "en": [
          "\\b(copy|duplicate|make\\s+a\\s+copy\\s+of|clone)\\b",
          "\\bduplicate\\b.{0,40}\\b(file|document)\\b"
        ],
        "pt": [
          "\\b(copiar|duplicar|fazer\\s+uma\\s+c[oó]pia|clonar)\\b",
          "\\bduplicar\\b.{0,40}\\b(arquivo|documento)\\b"
        ]
      },
      "mustNotContain": {
        "_comment": "Avoid collision with copy/paste text operations.",
        "en": [
          "\\bclipboard\\b",
          "\\bcopy\\s+this\\s+text\\b"
        ],
        "pt": [
          "\\b[aá]rea\\s+de\\s+transfer[eê]ncia\\b",
          "\\bcopiar\\s+este\\s+texto\\b"
        ]
      }
    },
    {
      "id": "DET_0031_file_rename",
      "operator": "file_rename",
      "priority": 79,
      "confidence": 0.74,
      "patterns": {
        "en": [
          "\\brename\\b.{0,80}\\b(to|as)\\b",
          "\\bchange\\s+the\\s+name\\s+of\\b.{0,80}\\bto\\b"
        ],
        "pt": [
          "\\brenomear\\b.{0,80}\\b(para|como)\\b",
          "\\bmudar\\s+o\\s+nome\\s+de\\b.{0,80}\\bpara\\b"
        ]
      },
      "mustNotContain": {
        "_comment": "If message contains folder keywords, prefer folder_rename.",
        "en": [
          "\\bfolder\\b",
          "\\bdirectory\\b"
        ],
        "pt": [
          "\\bpasta\\b",
          "\\bdiret[oó]rio\\b"
        ]
      }
    },
    {
      "id": "DET_0023_file_multi_move",
      "operator": "file_multi_move",
      "priority": 84,
      "confidence": 0.82,
      "_comment": "Detects multiple named files like 'move file1.pdf and file2.xlsx to folder X'",
      "patterns": {
        "en": [
          "\\b(move|transfer)\\b.{0,60}\\.(pdf|xlsx?|docx?|pptx?).{0,60}\\b(and|,)\\b.{0,60}\\.(pdf|xlsx?|docx?|pptx?).{0,60}\\b(to|into|in)\\b",
          "\\b(move|transfer)\\b.{0,60}\\.(pdf|xlsx?|docx?|pptx?).{0,60}\\b(to|into|in)\\b.{0,40}\\.(pdf|xlsx?|docx?|pptx?)"
        ],
        "pt": [
          "\\b(mover|transferir)\\b.{0,60}\\.(pdf|xlsx?|docx?|pptx?).{0,60}\\b(e|,)\\b.{0,60}\\.(pdf|xlsx?|docx?|pptx?).{0,60}\\b(para|em)\\b"
        ]
      },
      "mustNotContain": {
        "en": [
          "\\bfolder\\b",
          "\\bdirectory\\b"
        ],
        "pt": [
          "\\bpasta\\b",
          "\\bdiret[oó]rio\\b"
        ]
      }
    },
    {
      "id": "DET_0032_file_move",
      "operator": "file_move",
      "priority": 78,
      "confidence": 0.74,
      "patterns": {
        "en": [
          "\\b(move|transfer|put|place)\\b.{0,80}\\b(to|into|in|inside|under)\\b",
          "\\bmove\\b.{0,120}\\bto\\b"
        ],
        "pt": [
          "\\b(mover|transferir|colocar|p[oó]r)\\b.{0,80}\\b(para|em|na|no|dentro\\s+de|sob)\\b",
          "\\bmover\\b.{0,120}\\bpara\\b"
        ]
      },
      "mustNotContain": {
        "_comment": "If message contains folder keywords, prefer folder_move.",
        "en": [
          "\\bfolder\\b",
          "\\bdirectory\\b"
        ],
        "pt": [
          "\\bpasta\\b",
          "\\bdiret[oó]rio\\b"
        ]
      }
    },
    {
      "id": "DET_0033_file_delete",
      "operator": "file_delete",
      "priority": 77,
      "confidence": 0.72,
      "patterns": {
        "en": [
          "\\b(delete|remove|trash)\\b.{0,80}\\b(file|document)\\b",
          "\\b(delete|remove|trash)\\b.{0,80}\\b\\.([a-z0-9]{2,5})\\b"
        ],
        "pt": [
          "\\b(excluir|deletar|remover|apagar)\\b.{0,80}\\b(arquivo|documento)\\b",
          "\\b(excluir|deletar|remover|apagar)\\b.{0,80}\\b\\.([a-z0-9]{2,5})\\b"
        ]
      },
      "mustNotContain": {
        "_comment": "If message contains folder keywords, prefer folder_delete.",
        "en": [
          "\\bfolder\\b",
          "\\bdirectory\\b"
        ],
        "pt": [
          "\\bpasta\\b",
          "\\bdiret[oó]rio\\b"
        ]
      }
    },
    {
      "id": "DET_0040_open",
      "operator": "open",
      "priority": 70,
      "confidence": 0.78,
      "patterns": {
        "en": [
          "\\bopen\\b",
          "\\bpreview\\b",
          "\\bview\\b.{0,20}\\b(file|document|pdf|spreadsheet|presentation)\\b",
          "\\bpull\\s+up\\b",
          "\\bbring\\s+up\\b"
        ],
        "pt": [
          "\\babrir\\b",
          "\\bvisualizar\\b",
          "\\bver\\b.{0,20}\\b(arquivo|documento|pdf|planilha|apresenta[cç][aã]o)\\b",
          "\\bmostra\\b.{0,10}\\b(para\\s+mim|isso)\\b",
          "\\bpuxar\\b.{0,10}\\b(arquivo|documento)\\b"
        ]
      },
      "mustNotContain": {
        "_comment": "Avoid mapping inside-doc location questions to open.",
        "en": [
          "\\bwhere\\s+in\\b.{0,40}\\b(document|file)\\b",
          "\\bon\\s+which\\s+page\\b"
        ],
        "pt": [
          "\\bonde\\s+no\\b.{0,40}\\b(documento|arquivo)\\b",
          "\\bem\\s+qual\\s+p[aá]gina\\b"
        ]
      }
    }
  ],
  "operators": {
    "folder_create": {
      "service": "folderService",
      "method": "create",
      "destructive": false,
      "requiresConfirmation": false,
      "canUndo": true,
      "undoAction": "delete",
      "entityExtraction": {
        "folderName": {
          "type": "quoted_or_trailing",
          "required": true,
          "afterKeywords": {
            "en": [
              "called",
              "named",
              "titled"
            ],
            "pt": [
              "chamada",
              "chamado",
              "nomeada",
              "nomeado",
              "com nome"
            ]
          }
        },
        "parentFolder": {
          "type": "after_preposition",
          "required": false,
          "prepositions": {
            "en": [
              "inside",
              "in",
              "under",
              "within"
            ],
            "pt": [
              "dentro de",
              "em",
              "sob",
              "na",
              "no"
            ]
          }
        }
      },
      "microcopy": {
        "success": {
          "en": "Done — I created the folder **{folderName}**.",
          "pt": "Pronto — criei a pasta **{folderName}**."
        },
        "successWithParent": {
          "en": "Done — I created **{folderName}** inside **{parentFolder}**.",
          "pt": "Pronto — criei **{folderName}** dentro de **{parentFolder}**."
        },
        "alreadyExists": {
          "en": "A folder named **{folderName}** already exists.",
          "pt": "Já existe uma pasta chamada **{folderName}**."
        },
        "error": {
          "en": "Failed to create folder: {error}",
          "pt": "Falha ao criar pasta: {error}"
        },
        "missingEntity": {
          "en": "Please specify a folder name.",
          "pt": "Por favor, especifique o nome da pasta."
        }
      }
    },
    "folder_rename": {
      "service": "folderService",
      "method": "rename",
      "destructive": false,
      "requiresConfirmation": false,
      "canUndo": true,
      "undoAction": "rename_back",
      "entityExtraction": {
        "folderName": {
          "type": "first_quoted_or_noun",
          "required": true
        },
        "newName": {
          "type": "after_keyword",
          "required": true,
          "keywords": {
            "en": [
              "to",
              "as"
            ],
            "pt": [
              "para",
              "como"
            ]
          }
        }
      },
      "microcopy": {
        "success": {
          "en": "Done — renamed **{folderName}** to **{newName}**.",
          "pt": "Pronto — renomeei **{folderName}** para **{newName}**."
        },
        "notFound": {
          "en": "I couldn't find a folder named **{folderName}**.",
          "pt": "Não encontrei uma pasta chamada **{folderName}**."
        },
        "error": {
          "en": "Failed to rename folder: {error}",
          "pt": "Falha ao renomear pasta: {error}"
        },
        "missingEntity": {
          "en": "Please specify the folder name and the new name.",
          "pt": "Por favor, especifique o nome da pasta e o novo nome."
        }
      }
    },
    "folder_delete": {
      "service": "folderService",
      "method": "delete",
      "destructive": true,
      "requiresConfirmation": true,
      "canUndo": false,
      "entityExtraction": {
        "folderName": {
          "type": "quoted_or_trailing",
          "required": true
        }
      },
      "confirmation": {
        "prompt": {
          "en": "Are you sure you want to delete the folder **{folderName}**? This will also delete all files inside.",
          "pt": "Tem certeza que deseja excluir a pasta **{folderName}**? Isso também excluirá todos os arquivos dentro."
        },
        "confirmLabel": {
          "en": "Delete",
          "pt": "Excluir"
        },
        "cancelLabel": {
          "en": "Cancel",
          "pt": "Cancelar"
        },
        "confirmStyle": "danger"
      },
      "microcopy": {
        "success": {
          "en": "Done — deleted the folder **{folderName}** and moved its files to the root.",
          "pt": "Pronto — excluí a pasta **{folderName}** e movi os arquivos para a raiz."
        },
        "notFound": {
          "en": "I couldn't find a folder named **{folderName}**.",
          "pt": "Não encontrei uma pasta chamada **{folderName}**."
        },
        "error": {
          "en": "Failed to delete folder: {error}",
          "pt": "Falha ao excluir pasta: {error}"
        },
        "missingEntity": {
          "en": "Please specify which folder to delete.",
          "pt": "Por favor, especifique qual pasta excluir."
        }
      }
    },
    "folder_move": {
      "service": "folderService",
      "method": "move",
      "destructive": false,
      "requiresConfirmation": false,
      "canUndo": true,
      "undoAction": "move_back",
      "entityExtraction": {
        "folderName": {
          "type": "first_quoted_or_noun",
          "required": true
        },
        "targetFolder": {
          "type": "after_keyword",
          "required": true,
          "keywords": {
            "en": [
              "to",
              "into",
              "inside",
              "under"
            ],
            "pt": [
              "para",
              "em",
              "dentro de",
              "sob"
            ]
          },
          "specialValues": {
            "en": [
              "root",
              "top level",
              "top-level"
            ],
            "pt": [
              "raiz",
              "nível principal"
            ]
          }
        }
      },
      "microcopy": {
        "success": {
          "en": "Done — moved **{folderName}** to **{targetFolder}**.",
          "pt": "Pronto — movi **{folderName}** para **{targetFolder}**."
        },
        "successToRoot": {
          "en": "Done — moved **{folderName}** to the top level.",
          "pt": "Pronto — movi **{folderName}** para o nível principal."
        },
        "notFound": {
          "en": "I couldn't find a folder named **{folderName}**.",
          "pt": "Não encontrei uma pasta chamada **{folderName}**."
        },
        "targetNotFound": {
          "en": "I couldn't find the target folder **{targetFolder}**.",
          "pt": "Não encontrei a pasta de destino **{targetFolder}**."
        },
        "error": {
          "en": "Failed to move folder: {error}",
          "pt": "Falha ao mover pasta: {error}"
        },
        "missingEntity": {
          "en": "Please specify the folder to move and the destination.",
          "pt": "Por favor, especifique a pasta a mover e o destino."
        }
      }
    },
    "file_move": {
      "service": "documentService",
      "method": "move",
      "destructive": false,
      "requiresConfirmation": false,
      "canUndo": true,
      "undoAction": "move_back",
      "bulkSupport": true,
      "entityExtraction": {
        "filename": {
          "type": "filelike_pattern",
          "required": true
        },
        "targetFolder": {
          "type": "after_keyword",
          "required": true,
          "keywords": {
            "en": [
              "to",
              "into",
              "in",
              "inside",
              "under"
            ],
            "pt": [
              "para",
              "em",
              "na",
              "no",
              "dentro de",
              "sob"
            ]
          }
        }
      },
      "microcopy": {
        "success": {
          "en": "Done — moved **{filename}** to **{targetFolder}**.",
          "pt": "Pronto — movi **{filename}** para **{targetFolder}**."
        },
        "notFound": {
          "en": "I couldn't find **{filename}** in your documents.",
          "pt": "Não encontrei **{filename}** nos seus documentos."
        },
        "folderNotFound": {
          "en": "I couldn't find a folder named **{targetFolder}**.",
          "pt": "Não encontrei uma pasta chamada **{targetFolder}**."
        },
        "error": {
          "en": "Failed to move document: {error}",
          "pt": "Falha ao mover documento: {error}"
        },
        "missingEntity": {
          "en": "Please specify the file to move and the destination folder.",
          "pt": "Por favor, especifique o arquivo a mover e a pasta de destino."
        }
      }
    },
    "file_multi_move": {
      "_comment": "Move multiple named files to a folder (e.g., 'move file1.pdf and file2.xlsx to Archive')",
      "service": "documentService",
      "method": "multiMove",
      "destructive": false,
      "requiresConfirmation": false,
      "canUndo": true,
      "undoAction": "move_back",
      "entityExtraction": {
        "filenames": {
          "type": "multiple_filelike",
          "required": true
        },
        "targetFolder": {
          "type": "after_keyword",
          "required": true,
          "keywords": {
            "en": [
              "to",
              "into",
              "in",
              "inside",
              "under"
            ],
            "pt": [
              "para",
              "em",
              "na",
              "no",
              "dentro de",
              "sob"
            ]
          }
