{
  "_meta": {
    "id": "operator_playbook_compare_finance",
    "version": "1.0.0",
    "description": "compare operator playbook for finance documents with deterministic behavior and domain guardrails.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "operator": "compare",
    "domain": "finance",
    "runtimeIntent": "operator_handler_and_prompt_builder",
    "deterministic": true,
    "outputPolicy": {
      "navPillsOnly": false,
      "allowSourceRequests": true,
      "askSingleQuestionOnly": true
    }
  },
  "operator": "compare",
  "domain": "finance",
  "lookFor": [
    "keyword: revenue",
    "keyword: sales",
    "keyword: gross margin",
    "keyword: operating margin",
    "keyword: ebitda",
    "keyword: noi",
    "keyword: revpar",
    "keyword: yoy",
    "keyword: qoq",
    "keyword: variance",
    "keyword: budget vs actual",
    "keyword: forecast",
    "keyword: run rate",
    "keyword: dscr",
    "keyword: covenant",
    "heading: executive summary",
    "heading: management discussion",
    "heading: assumptions",
    "heading: financial highlights",
    "heading: notes to accounts",
    "table header: revenue",
    "table header: gross profit",
    "table header: operating expenses",
    "table header: ebitda",
    "table header: noi",
    "table header: revpar",
    "table header: occupancy",
    "table header: adr",
    "doc type: budget report",
    "doc type: income statement",
    "doc type: forecast model",
    "doc type: covenant report",
    "intent phrase: compare",
    "intent phrase: versus",
    "intent phrase: differences",
    "intent phrase: side by side",
    "signal: two or more documents referenced",
    "signal: asks for gap analysis"
  ],
  "outputStructure": {
    "requiredBlocks": [
      "Scope",
      "Comparison Basis",
      "Differences",
      "Verdict",
      "Next Steps"
    ],
    "optionalBlocks": [
      "Similarity List",
      "Mismatch Table",
      "Materiality Note",
      "Warnings",
      "Assumptions",
      "Open Questions"
    ]
  },
  "validationChecks": [
    {
      "id": "check_01_domain_match",
      "condition": "always",
      "check": "Request domain must resolve to finance.",
      "onFail": "Ask one domain disambiguation question."
    },
    {
      "id": "check_02_operator_match",
      "condition": "always",
      "check": "Resolved operator must stay compare.",
      "onFail": "Return one operator disambiguation question."
    },
    {
      "id": "check_03_evidence_presence",
      "condition": "missing direct anchor evidence",
      "check": "At least one matching anchor from lookFor is required before final answer.",
      "onFail": "Ask one clarification question."
    },
    {
      "id": "check_04_period_consistency",
      "condition": "query includes time period",
      "check": "Compared or reported periods must be explicitly aligned.",
      "onFail": "Ask one period clarification question."
    },
    {
      "id": "check_05_units_consistency",
      "condition": "numeric values present",
      "check": "Units and scales must be consistent before computing or comparing.",
      "onFail": "Ask one units clarification question."
    },
    {
      "id": "check_06_scope_clarity",
      "condition": "multiple docs or sections match",
      "check": "Scope must be explicit before final output.",
      "onFail": "Ask one scope disambiguation question."
    },
    {
      "id": "check_07_missing_required_input",
      "condition": "required input field missing",
      "check": "Required input fields for operator must be present.",
      "onFail": "Ask one missing-input question."
    },
    {
      "id": "check_08_term_consistency",
      "condition": "defined term appears",
      "check": "Defined terms must remain consistent in wording and capitalization.",
      "onFail": "Ask one term clarification question."
    },
    {
      "id": "check_09_no_vague_block",
      "condition": "always",
      "check": "Output must only use deterministic named blocks from outputStructure.",
      "onFail": "Regenerate with required blocks only."
    },
    {
      "id": "check_10_single_question_rule",
      "condition": "clarification needed",
      "check": "Ask exactly one crisp question, not a questionnaire.",
      "onFail": "Trim to one question."
    },
    {
      "id": "domain_01",
      "condition": "domain specific",
      "check": "currency code consistency across compared values",
      "onFail": "Ask one domain-specific clarification question."
    },
    {
      "id": "domain_02",
      "condition": "domain specific",
      "check": "period alignment by month quarter or year",
      "onFail": "Ask one domain-specific clarification question."
    },
    {
      "id": "domain_03",
      "condition": "domain specific",
      "check": "percentage versus absolute value mismatch",
      "onFail": "Ask one domain-specific clarification question."
    },
    {
      "id": "domain_04",
      "condition": "domain specific",
      "check": "totals equal sum of line items when provided",
      "onFail": "Ask one domain-specific clarification question."
    },
    {
      "id": "domain_05",
      "condition": "domain specific",
      "check": "negative values not accidentally stripped",
      "onFail": "Ask one domain-specific clarification question."
    },
    {
      "id": "domain_06",
      "condition": "domain specific",
      "check": "formula denominator not zero",
      "onFail": "Ask one domain-specific clarification question."
    },
    {
      "id": "domain_07",
      "condition": "domain specific",
      "check": "yoY baseline period exists before computing",
      "onFail": "Ask one domain-specific clarification question."
    },
    {
      "id": "domain_08",
      "condition": "domain specific",
      "check": "variance sign convention explicit favorable or unfavorable",
      "onFail": "Ask one domain-specific clarification question."
    }
  ],
  "askQuestionWhen": [
    {
      "id": "ask_01_missing_scope",
      "condition": "multiple candidate docs and no explicit scope",
      "questionTemplate": "Which document should I use?"
    },
    {
      "id": "ask_02_missing_period",
      "condition": "time period required but not explicit",
      "questionTemplate": "Which period should I use?"
    },
    {
      "id": "ask_03_missing_units",
      "condition": "numeric request with ambiguous units",
      "questionTemplate": "Which units should I use?"
    },
    {
      "id": "ask_04_missing_doc_type",
      "condition": "doc type required to retrieve correct section",
      "questionTemplate": "Which document type should I prioritize?"
    },
    {
      "id": "ask_05_conflicting_inputs",
      "condition": "inputs conflict across provided evidence",
      "questionTemplate": "Which value should I treat as authoritative?"
    },
    {
      "id": "ask_06_format_preference",
      "condition": "user did not specify output granularity",
      "questionTemplate": "Do you want a concise answer or detailed output?"
    },
    {
      "id": "ask_07_precision_preference",
      "condition": "numeric output requested without precision preference",
      "questionTemplate": "How many decimals should I use?"
    },
    {
      "id": "ask_08_compare_scope",
      "condition": "compare requested with fewer than two explicit docs",
      "questionTemplate": "Which two documents should I compare?"
    },
    {
      "id": "ask_09_missing_anchor",
      "condition": "no matching anchors found for requested field",
      "questionTemplate": "Which section should I search first?"
    },
    {
      "id": "ask_10_next_step",
      "condition": "answer completed and follow-up path unclear",
      "questionTemplate": "Do you want me to proceed to the next step?"
    },
    {
      "id": "ask_domain_01",
      "condition": "domain-specific ambiguity",
      "questionTemplate": "Which period should I use for this calculation?"
    },
    {
      "id": "ask_domain_02",
      "condition": "domain-specific ambiguity",
      "questionTemplate": "Should I return this in USD or local currency?"
    },
    {
      "id": "ask_domain_03",
      "condition": "domain-specific ambiguity",
      "questionTemplate": "Do you want absolute variance, percentage variance, or both?"
    },
    {
      "id": "ask_domain_04",
      "condition": "domain-specific ambiguity",
      "questionTemplate": "Should I compare against budget, forecast, or prior year?"
    }
  ]
}
