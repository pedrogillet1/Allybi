{
  "_meta": {
    "id": "email_action_operators",
    "version": "1.0.0",
    "description": "Databank-driven extraction rules for email drafting/sending fields (to/subject/body/provider) and email attachment name hints. Used by PrismaChat email executor (no hardcoded regexes).",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-09",
    "owner": "koda-email"
  },
  "config": {
    "enabled": true,
    "composeExtraction": {
      "maxFieldChars": {
        "subject": 160,
        "body": 6000
      },
      "provider": {
        "allowed": ["gmail", "outlook", "email"],
        "aliases": {
          "google mail": "gmail",
          "microsoft outlook": "outlook",
          "office365": "outlook",
          "office 365": "outlook"
        }
      },
      "fields": {
        "to": {
          "patterns": {
            "any": [
              "([\\w.+-]+@[\\w.-]+\\.[A-Za-z]{2,})"
            ]
          }
        },
        "subject": {
          "patterns": {
            "any": [
              "\\\\b(?:subject|subj)\\\\b\\\\s*[:=]\\\\s*([^\\n]{1,160})",
              "\\\\b(?:with|and)\\\\s+subject\\\\s+[\\\"“]?(.{1,160}?)[\\\"”]?(?:\\\\s+\\\\b(?:with|and)\\\\s+\\\\b(?:body|message|text)\\\\b|$)",
              "\\\\b(?:about|regarding|re:?)\\\\s+(.{3,160}?)(?:\\\\s+\\\\b(?:with|and)\\\\s+\\\\b(?:body|message|text)\\\\b|$)"
            ]
          }
        },
        "body": {
          "patterns": {
            "any": [
              "\\\\b(?:body|message|text)\\\\b\\\\s*[:=]\\\\s*([\\\u005cs\\\u005cS]{3,})$",
              "\\\\b(?:saying|that says|tell them|tell him|tell her)\\\\b\\\\s+([\\\u005cs\\\u005cS]{3,})$",
              "\\\\b(?:with|and)\\\\s+\\\\b(?:body|message|text)\\\\b\\\\s+([\\\u005cs\\\u005cS]{3,})$"
            ]
          }
        },
        "attachmentNames": {
          "patterns": {
            "any": [
              "\\\\b(?:attach|attachment|attached)\\\\b.{0,40}?([\\\u005cw_.-]+\\\\.(?:pdf|docx?|xlsx?|pptx?|csv|txt))"
            ]
          }
        }
      }
    }
  },
  "microcopy": {
    "missingRecipient": {
      "en": "Who should I email? Please include a recipient (example: alice@example.com).",
      "pt": "Para quem devo enviar o email? Inclua um destinat\u00e1rio (exemplo: alice@example.com)."
    }
  }
}

