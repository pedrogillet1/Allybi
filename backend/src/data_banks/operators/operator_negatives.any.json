{
  "_meta": {
    "id": "operator_negatives",
    "version": "3.0.0",
    "description": "Canonical operator-level negative intent and collision-avoidance rules for Koda. Prevents operator hijacking, cross-family bleed, conversational false positives, and misrouting using deterministic, ChatGPT-class intent shielding.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-routing",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "useRegex": true,
    "caseInsensitive": true,
    "stripDiacritics": true,
    "collapseWhitespace": true,
    "evaluationOrder": "pre_operator_scoring",
    "actionsContract": {
      "combination": {
        "multipleMatches": "sum_then_cap",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "hardBlockThreshold": 0.85,
        "softPenaltyThreshold": 0.35
      },
      "conflictResolution": {
        "ifHardBlockAndRedirect": "hard_block",
        "ifMultipleRedirects": "pick_highest_confidence"
      }
    }
  },
  "rules": [
    {
      "id": "conceptual_list_not_file_inventory",
      "scope": "cross_family",
      "description": "Prevent conceptual enumerations from being misrouted into file inventory operators.",
      "appliesToOperators": ["list", "filter", "sort", "group", "count_files"],
      "triggerPatterns": {
        "en": ["\\b(top|key|main)\\s+\\d+\\b", "\\b(assumptions?|risks?|takeaways?|findings?|points?)\\b"],
        "pt": ["\\b(principais|top)\\s+\\d+\\b", "\\b(suposi[cç][oõ]es|riscos|conclus[oõ]es|pontos)\\b"],
        "es": ["\\b(principales|top)\\s+\\d+\\b", "\\b(suposiciones|riesgos|conclusiones|puntos)\\b"]
      },
      "action": {
        "type": "confidence_penalty",
        "value": 0.45
      },
      "reasonCode": "conceptual_list_not_inventory",
      "severity": "high"
    },
    {
      "id": "inside_doc_query_redirect",
      "scope": "operator_specific",
      "description": "Redirect inside-document location queries away from open/preview.",
      "appliesToOperators": ["open"],
      "triggerPatterns": {
        "en": ["\\bwhere\\b.{0,40}\\b(mentioned|appears|discussed)\\b"],
        "pt": ["\\bonde\\b.{0,40}\\b(mencionad|aparece|discutid)\\b"],
        "es": ["\\bd[oó]nde\\b.{0,40}\\b(menciona|aparece|discute)\\b"]
      },
      "action": {
        "type": "redirect_preference",
        "preferredOperator": "locate_content",
        "confidencePenalty": 0.35
      },
      "reasonCode": "inside_doc_query",
      "severity": "high"
    },
    {
      "id": "explicit_quote_overrides_summary",
      "scope": "operator_specific",
      "description": "Explicit quote intent must block summarization.",
      "appliesToOperators": ["summarize"],
      "triggerPatterns": {
        "en": ["\\bquote\\b", "\\bverbatim\\b"],
        "pt": ["\\bcitar\\b", "\\bliteralmente\\b"],
        "es": ["\\bcitar\\b", "\\btextualmente\\b"]
      },
      "action": {
        "type": "hard_block"
      },
      "reasonCode": "explicit_quote_intent",
      "severity": "critical"
    },
    {
      "id": "conversation_only_hard_block",
      "scope": "global",
      "description": "Block operational routing when input is pure conversation.",
      "appliesToOperators": ["open", "list", "summarize", "extract", "compare", "compute", "locate_content", "locate_docs"],
      "triggerPatterns": {
        "en": ["^(hi|hello|hey|thanks|ok)[!?.]*$"],
        "pt": ["^(oi|ol[aá]|obrigado|ok)[!?.]*$"],
        "es": ["^(hola|gracias|ok)[!?.]*$"]
      },
      "when": {
        "all": [
          { "path": "signals.hasOperationalVerb", "op": "eq", "value": false }
        ]
      },
      "action": {
        "type": "hard_block"
      },
      "reasonCode": "conversation_only",
      "severity": "critical"
    },
    {
      "id": "conversation_prefix_soft_penalty",
      "scope": "global",
      "description": "Allow real intent after conversational prefixes with mild penalty.",
      "appliesToOperators": ["open", "list", "summarize", "extract", "compare", "compute", "locate_content", "locate_docs"],
      "triggerPatterns": {
        "en": ["^(hi|hey|ok)[,\\s]+"],
        "pt": ["^(oi|ok)[,\\s]+"],
        "es": ["^(hola|ok)[,\\s]+"]
      },
      "action": {
        "type": "confidence_penalty",
        "value": 0.15
      },
      "reasonCode": "conversation_prefix",
      "severity": "low"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "OPNEG_001_no_inventory_hijack",
        "input": "List the top 5 assumptions",
        "expect": { "operatorNot": "list" }
      },
      {
        "id": "OPNEG_002_redirect_locate",
        "input": "Where is ROI mentioned?",
        "expect": { "preferredOperator": "locate_content" }
      },
      {
        "id": "OPNEG_003_quote_blocks_summary",
        "input": "Quote this verbatim",
        "expect": { "operatorNot": "summarize" }
      },
      {
        "id": "OPNEG_004_prefix_allowed",
        "input": "ok open the file",
        "expect": { "operator": "open" }
      }
    ]
  }
}
