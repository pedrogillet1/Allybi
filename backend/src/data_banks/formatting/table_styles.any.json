{
  "_meta": {
    "id": "table_styles",
    "version": "1.0.0",
    "description": "Deterministic table rendering rules for Koda. Governs when tables are allowed, how dense they may be, when they must be downgraded to bullets or paragraphs, and enforces ChatGPT-like clarity without over-tabulation.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-formatting",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_most_restrictive",
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "maxRowsSoft": 8,
        "maxRowsHard": 12,
        "maxColumnsSoft": 5,
        "maxColumnsHard": 7,
        "maxCellCharsSoft": 120,
        "maxCellCharsHard": 200
      },
      "conflictResolution": {
        "ifHardAndSoft": "hard_limit",
        "ifMultipleRules": "lowest_limit_wins"
      }
    }
  },
  "rules": [
    {
      "id": "tables_only_for_comparison_or_metrics",
      "scope": "global",
      "description": "Allow tables only when intent is comparison, computation, or multi-row metrics.",
      "appliesTo": ["all_answers"],
      "when": {
        "any": [
          { "path": "signals.isComparisonIntent", "op": "eq", "value": true },
          { "path": "signals.isComputationIntent", "op": "eq", "value": true },
          { "path": "metrics.factCount", "op": "gte", "value": 3 }
        ]
      },
      "action": {
        "type": "allow_tables"
      },
      "reasonCode": "table_for_structured_data",
      "severity": "high"
    },
    {
      "id": "no_tables_for_single_fact",
      "scope": "global",
      "description": "Suppress tables when only a single fact or value is present.",
      "appliesTo": ["all_answers"],
      "when": {
        "all": [
          { "path": "metrics.factCount", "op": "lte", "value": 1 }
        ]
      },
      "action": {
        "type": "suppress_tables",
        "fallback": "paragraph"
      },
      "reasonCode": "single_fact_no_table",
      "severity": "medium"
    },
    {
      "id": "table_density_control",
      "scope": "global",
      "description": "Limit table size and cell density to avoid unreadable grids.",
      "appliesTo": ["all_answers"],
      "action": {
        "type": "enforce_table_limits",
        "maxRowsSoft": 8,
        "maxRowsHard": 12,
        "maxColumnsSoft": 5,
        "maxColumnsHard": 7,
        "maxCellCharsSoft": 120,
        "maxCellCharsHard": 200
      },
      "reasonCode": "table_density_control",
      "severity": "high"
    },
    {
      "id": "auto_degrade_large_tables",
      "scope": "global",
      "description": "Automatically degrade oversized tables into bullets or paragraphs.",
      "appliesTo": ["all_answers"],
      "when": {
        "any": [
          { "path": "metrics.rowCount", "op": "gt", "value": 12 },
          { "path": "metrics.columnCount", "op": "gt", "value": 7 }
        ]
      },
      "action": {
        "type": "auto_degrade",
        "fallback": "bullets"
      },
      "reasonCode": "table_auto_degrade",
      "severity": "critical"
    },
    {
      "id": "nav_pills_no_tables",
      "scope": "operator_specific",
      "description": "Suppress tables entirely in nav_pills answer mode.",
      "appliesTo": ["nav_pills"],
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": {
        "type": "suppress_tables"
      },
      "reasonCode": "nav_pills_no_tables",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "TAB_001_comparison_allows_table",
        "context": { "signals": { "isComparisonIntent": true } },
        "expect": { "tablesAllowed": true }
      },
      {
        "id": "TAB_002_single_fact_no_table",
        "context": { "metrics": { "factCount": 1 } },
        "expect": { "tablesSuppressed": true }
      },
      {
        "id": "TAB_003_large_table_degraded",
        "context": { "metrics": { "rowCount": 15 } },
        "expect": { "fallback": "bullets" }
      },
      {
        "id": "TAB_004_nav_pills_no_tables",
        "context": { "answerMode": "nav_pills" },
        "expect": { "tablesSuppressed": true }
      }
    ]
  }
}
