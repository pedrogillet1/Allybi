{
  "_meta": {
    "id": "truncation_and_limits",
    "version": "2.0.0",
    "description": "Hard and soft character/element limits for Koda responses. Defines budgets by answer mode and profile, controls paragraph/bullet density, and ensures graceful truncation at semantic boundaries.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-01-26",
    "owner": "koda-formatting",
    "compat": ">=1.0.0",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "truncationBehavior": "graceful_at_boundary",
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_most_restrictive",
        "hardBlockIsTerminal": true
      },
      "conflictResolution": {
        "ifHardAndSoft": "hard_limit",
        "ifMultipleRules": "lowest_limit_wins"
      }
    },
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "globalLimits": {
    "_comment": "Absolute maximums that override all other settings.",
    "maxResponseCharsHard": 20000,
    "maxResponseTokensHard": 8000,
    "maxParagraphsHard": 14,
    "maxBulletsHard": 14,
    "maxTableRowsHard": 25,
    "maxTableColumnsHard": 6,
    "maxQuestionsHard": 1
  },
  "profileBudgets": {
    "_comment": "Character and element budgets by profile. Used by answer composer.",
    "micro": {
      "maxChars": 260,
      "maxParagraphs": 1,
      "maxSentences": 1,
      "maxBullets": 4,
      "maxTableRows": 0
    },
    "brief": {
      "maxChars": 520,
      "maxParagraphs": 2,
      "maxSentences": 3,
      "maxBullets": 5,
      "maxTableRows": 5
    },
    "concise": {
      "maxChars": 850,
      "maxParagraphs": 3,
      "maxSentences": 6,
      "maxBullets": 7,
      "maxTableRows": 10
    },
    "standard": {
      "maxChars": 4000,
      "maxParagraphs": 6,
      "maxSentences": 20,
      "maxBullets": 10,
      "maxTableRows": 15
    },
    "detailed": {
      "maxChars": 6000,
      "maxParagraphs": 8,
      "maxSentences": 30,
      "maxBullets": 12,
      "maxTableRows": 20
    },
    "deep": {
      "maxChars": 8000,
      "maxParagraphs": 10,
      "maxSentences": 40,
      "maxBullets": 14,
      "maxTableRows": 25
    }
  },
  "answerModeLimits": {
    "_comment": "Mode-specific overrides that take precedence over profile budgets. maxOutputTokens/maxOutputTokensDefault are token caps used by runtime enforcers/builders.",
    "nav_pills": {
      "maxChars": 90,
      "maxOutputTokens": 220,
      "maxSentences": 1,
      "maxParagraphs": 1,
      "maxBullets": 0,
      "maxTableRows": 0,
      "forceProfile": "micro"
    },
    "rank_disambiguate": {
      "maxChars": 180,
      "maxOutputTokens": 220,
      "maxSentences": 2,
      "maxParagraphs": 1,
      "maxBullets": 0,
      "maxTableRows": 0,
      "forceProfile": "brief"
    },
    "rank_autopick": {
      "maxCharsDefault": 600,
      "maxOutputTokensDefault": 400,
      "preferProfile": "concise"
    },
    "doc_grounded_single": {
      "maxCharsDefault": 4400,
      "maxOutputTokensDefault": 6000,
      "preferProfile": "detailed"
    },
    "doc_grounded_multi": {
      "maxCharsDefault": 5200,
      "maxOutputTokensDefault": 7000,
      "preferProfile": "detailed"
    },
    "doc_grounded_table": {
      "maxCharsDefault": 5500,
      "maxOutputTokensDefault": 5000,
      "maxTableRows": 20,
      "preferProfile": "deep"
    },
    "doc_grounded_quote": {
      "maxCharsDefault": 1600,
      "maxOutputTokensDefault": 1000,
      "maxQuoteLines": 12,
      "preferProfile": "standard"
    },
    "doc_discovery_list": {
      "maxCharsDefault": 2000,
      "maxOutputTokensDefault": 1200,
      "maxBullets": 7,
      "preferProfile": "standard"
    },
    "help_steps": {
      "maxCharsDefault": 2000,
      "maxOutputTokensDefault": 1200,
      "maxBullets": 7,
      "preferProfile": "standard"
    },
    "no_docs": {
      "maxChars": 800,
      "maxOutputTokens": 600,
      "maxSentences": 6,
      "forceProfile": "concise"
    },
    "scoped_not_found": {
      "maxChars": 280,
      "maxOutputTokens": 220,
      "maxSentences": 2,
      "forceProfile": "brief"
    },
    "refusal": {
      "maxChars": 200,
      "maxOutputTokens": 220,
      "maxSentences": 2,
      "forceProfile": "micro"
    },
    "general_answer": {
      "maxCharsDefault": 5200,
      "maxOutputTokensDefault": 4000,
      "preferProfile": "deep"
    }
  },
  "paragraphLimits": {
    "maxSentencesSoft": 3,
    "maxSentencesHard": 6,
    "maxCharsSoft": 350,
    "maxCharsHard": 650
  },
  "bulletLimits": {
    "maxBulletsSoft": 5,
    "maxBulletsHard": 7,
    "maxSentencesPerBulletSoft": 2,
    "maxSentencesPerBulletHard": 3,
    "maxCharsPerBulletSoft": 240,
    "maxCharsPerBulletHard": 320
  },
  "tableLimits": {
    "maxRowsSoft": 15,
    "maxRowsHard": 25,
    "maxColumnsSoft": 4,
    "maxColumnsHard": 6,
    "maxCellCharsSoft": 80,
    "maxCellCharsHard": 120
  },
  "truncationRules": {
    "_comment": "How to truncate when limits are exceeded.",
    "preferredBoundaries": [
      "sentence",
      "clause",
      "word"
    ],
    "suffix": {
      "en": "...",
      "pt": "...",
      "es": "..."
    },
    "preserveLastSentence": true,
    "neverTruncateMid": [
      "number",
      "currency",
      "percentage",
      "date"
    ],
    "tableTruncation": {
      "strategy": "drop_rows_from_bottom",
      "showTruncationNote": true,
      "truncationNote": {
        "en": "({remaining} more rows not shown)",
        "pt": "({remaining} linhas adicionais não exibidas)",
        "es": "({remaining} filas adicionales no mostradas)"
      }
    },
    "bulletTruncation": {
      "strategy": "drop_bullets_from_bottom",
      "showTruncationNote": false
    }
  },
  "rules": [
    {
      "id": "profile_budget_enforcement",
      "scope": "global",
      "description": "Enforce character and element budgets based on selected profile.",
      "appliesTo": [
        "all_answers"
      ],
      "action": {
        "type": "enforce_profile_budget",
        "source": "profileBudgets"
      },
      "reasonCode": "profile_budget",
      "severity": "high"
    },
    {
      "id": "answer_mode_override",
      "scope": "global",
      "description": "Answer mode limits override profile budgets when stricter.",
      "appliesTo": [
        "all_answers"
      ],
      "action": {
        "type": "apply_mode_limits",
        "source": "answerModeLimits",
        "precedence": "mode_over_profile"
      },
      "reasonCode": "mode_limit_override",
      "severity": "critical"
    },
    {
      "id": "graceful_truncation",
      "scope": "global",
      "description": "When truncation is needed, cut at semantic boundaries.",
      "appliesTo": [
        "all_answers"
      ],
      "when": {
        "any": [
          {
            "path": "metrics.totalChars",
            "op": "gt",
            "value": "{{budget.maxChars}}"
          }
        ]
      },
      "action": {
        "type": "truncate_gracefully",
        "boundaries": [
          "sentence",
          "clause"
        ],
        "addSuffix": true
      },
      "reasonCode": "graceful_truncation",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "TRUNC_001_nav_pills_max_90",
        "context": {
          "answerMode": "nav_pills"
        },
        "input": "This is a very long sentence that exceeds the nav_pills character limit of 90 characters and should be truncated.",
        "expect": {
          "outputCharsMax": 90
        }
      },
      {
        "id": "TRUNC_002_profile_standard_4000",
        "context": {
          "profile": "standard"
        },
        "expect": {
          "maxChars": 4000,
          "maxBullets": 10
        }
      },
      {
        "id": "TRUNC_003_table_row_limit",
        "context": {
          "answerMode": "doc_grounded_table"
        },
        "input": {
          "tableRows": 30
        },
        "expect": {
          "rowsMax": 20,
          "truncationNoteShown": true
        }
      },
      {
        "id": "TRUNC_004_graceful_sentence_boundary",
        "input": "First sentence. Second sentence. Third sentence that is very long.",
        "context": {
          "maxChars": 50
        },
        "expect": {
          "endsAtSentenceBoundary": true
        }
      },
      {
        "id": "TRUNC_005_global_token_hard_cap",
        "context": {},
        "expect": {
          "outputTokensHardMax": 8000
        }
      },
      {
        "id": "TRUNC_006_doc_grounded_multi_token_cap",
        "context": {
          "answerMode": "doc_grounded_multi"
        },
        "expect": {
          "maxOutputTokens": 7000
        }
      }
    ]
  }
}
