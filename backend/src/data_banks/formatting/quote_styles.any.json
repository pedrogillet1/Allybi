{
  "_meta": {
    "id": "quote_styles",
    "version": "1.0.0",
    "description": "Deterministic quotation rendering rules for Koda. Controls when verbatim quotes are allowed, how long they may be, when they must be truncated or summarized, and prevents quote misuse that degrades readability or violates intent.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-formatting",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_most_restrictive",
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "maxQuoteCharsSoft": 420,
        "maxQuoteCharsHard": 800,
        "maxQuoteLinesSoft": 6,
        "maxQuoteLinesHard": 10
      },
      "conflictResolution": {
        "ifHardAndSoft": "hard_limit",
        "ifMultipleRules": "lowest_limit_wins"
      }
    }
  },
  "rules": [
    {
      "id": "quotes_only_on_explicit_request",
      "scope": "global",
      "description": "Allow verbatim quotes only when explicit quote intent is present.",
      "appliesTo": ["all_answers"],
      "when": {
        "all": [
          { "path": "signals.isQuoteIntent", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "allow_quotes"
      },
      "reasonCode": "explicit_quote_intent",
      "severity": "high"
    },
    {
      "id": "suppress_quotes_without_request",
      "scope": "global",
      "description": "Suppress quotes when quote intent is not explicit.",
      "appliesTo": ["all_answers"],
      "when": {
        "all": [
          { "path": "signals.isQuoteIntent", "op": "neq", "value": true }
        ]
      },
      "action": {
        "type": "suppress_quotes"
      },
      "reasonCode": "no_quote_intent",
      "severity": "medium"
    },
    {
      "id": "quote_length_control",
      "scope": "global",
      "description": "Limit quote length and line count to preserve readability.",
      "appliesTo": ["all_answers"],
      "action": {
        "type": "enforce_quote_limits",
        "maxCharsSoft": 420,
        "maxCharsHard": 800,
        "maxLinesSoft": 6,
        "maxLinesHard": 10
      },
      "reasonCode": "quote_length_control",
      "severity": "high"
    },
    {
      "id": "auto_truncate_long_quotes",
      "scope": "global",
      "description": "Automatically truncate quotes that exceed hard limits, preserving leading and trailing context.",
      "appliesTo": ["all_answers"],
      "when": {
        "any": [
          { "path": "metrics.quoteChars", "op": "gt", "value": 800 },
          { "path": "metrics.quoteLines", "op": "gt", "value": 10 }
        ]
      },
      "action": {
        "type": "auto_truncate",
        "preserve": ["start", "end"],
        "ellipsis": true
      },
      "reasonCode": "quote_auto_truncate",
      "severity": "critical"
    },
    {
      "id": "nav_pills_no_quotes",
      "scope": "operator_specific",
      "description": "Suppress quotes entirely in nav_pills mode.",
      "appliesTo": ["nav_pills"],
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": {
        "type": "suppress_quotes"
      },
      "reasonCode": "nav_pills_no_quotes",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "QUO_001_explicit_quote_allowed",
        "context": { "signals": { "isQuoteIntent": true } },
        "expect": { "quotesAllowed": true }
      },
      {
        "id": "QUO_002_no_quote_intent_suppressed",
        "context": { "signals": { "isQuoteIntent": false } },
        "expect": { "quotesSuppressed": true }
      },
      {
        "id": "QUO_003_long_quote_truncated",
        "context": { "metrics": { "quoteChars": 900 } },
        "expect": { "truncated": true }
      },
      {
        "id": "QUO_004_nav_pills_no_quotes",
        "context": { "answerMode": "nav_pills" },
        "expect": { "quotesSuppressed": true }
      }
    ]
  }
}
