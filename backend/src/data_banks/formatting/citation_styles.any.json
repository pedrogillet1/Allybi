{
  "_meta": {
    "id": "citation_styles",
    "version": "2.0.0",
    "description": "Citation and source attribution rules for Koda. Enforces sources via UI attachments only (never inline), standardizes location references (page/slide/sheet), and sanitizes any leaked inline citations.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-formatting",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "primaryRule": "sources_via_attachments_only",
    "inlineCitationBehavior": "strip_and_attach",
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_all",
        "hardBlockIsTerminal": true
      }
    }
  },
  "sourceAttachment": {
    "_comment": "All source attribution must go through UI attachments (source_buttons), never inline text.",
    "enabled": true,
    "attachmentType": "source_buttons",
    "maxSourceDocs": 3,
    "maxButtons": 8,
    "buttonFormat": {
      "labelSource": "documentName",
      "truncateAt": 40,
      "showFileType": true,
      "showLocation": true
    }
  },
  "locationFormatting": {
    "_comment": "Standardize location references when shown in attachments or rare inline contexts.",
    "page": {
      "en": "p. {number}",
      "pt": "p. {number}",
      "es": "p. {number}"
    },
    "pages": {
      "en": "pp. {start}-{end}",
      "pt": "pp. {start}-{end}",
      "es": "pp. {start}-{end}"
    },
    "slide": {
      "en": "slide {number}",
      "pt": "slide {number}",
      "es": "diapositiva {number}"
    },
    "sheet": {
      "en": "sheet \"{name}\"",
      "pt": "planilha \"{name}\"",
      "es": "hoja \"{name}\""
    },
    "cell": {
      "en": "cell {reference}",
      "pt": "célula {reference}",
      "es": "celda {reference}"
    },
    "section": {
      "en": "section {name}",
      "pt": "seção {name}",
      "es": "sección {name}"
    }
  },
  "inlineSanitization": {
    "_comment": "Detect and strip any inline citation patterns that leak into answer body.",
    "enabled": true,
    "patterns": [
      {
        "id": "CSAN_001_bracket_source",
        "regex": "\\[Source:\\s*[^\\]]+\\]",
        "action": "strip"
      },
      {
        "id": "CSAN_002_paren_citation",
        "regex": "\\([^)]*,\\s*p\\.?\\s*\\d+[^)]*\\)",
        "action": "strip"
      },
      {
        "id": "CSAN_003_footnote_marker",
        "regex": "\\[\\d+\\]",
        "action": "strip"
      },
      {
        "id": "CSAN_004_according_to_doc",
        "regex": "(?i)according to (?:the )?(?:document|file|report)\\s*[\"']?[^,\\.]+[\"']?[,:]?",
        "action": "strip"
      },
      {
        "id": "CSAN_005_as_stated_in",
        "regex": "(?i)as (?:stated|mentioned|shown|indicated) in (?:the )?(?:document|file|report)",
        "action": "strip"
      },
      {
        "id": "CSAN_006_from_document",
        "regex": "(?i)\\bfrom (?:the )?(?:document|file|report)\\b",
        "action": "strip"
      }
    ],
    "postStripCleanup": {
      "removeDoubleSpaces": true,
      "removeLeadingPunctuation": true,
      "trimSentences": true
    }
  },
  "rules": [
    {
      "id": "sources_via_attachments_only",
      "scope": "global",
      "description": "Never render sources inline. Always use source_buttons attachment.",
      "appliesTo": ["all_answers"],
      "action": {
        "type": "enforce_attachment_sources",
        "stripInlineSources": true,
        "requireSourceButtonsAttachment": true
      },
      "reasonCode": "sources_attachment_only",
      "severity": "critical"
    },
    {
      "id": "nav_pills_no_inline_refs",
      "scope": "operator_specific",
      "description": "nav_pills mode must have zero inline document references.",
      "appliesTo": ["nav_pills"],
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": {
        "type": "strip_all_inline_refs",
        "stripPatterns": ["according_to", "as_stated", "from_document", "bracket_source"]
      },
      "reasonCode": "nav_pills_clean_body",
      "severity": "critical"
    },
    {
      "id": "doc_grounded_location_in_attachment",
      "scope": "cross_family",
      "description": "For doc-grounded answers, include location (page/slide/sheet) in attachment metadata, not body.",
      "appliesTo": ["doc_grounded_single", "doc_grounded_quote", "doc_grounded_table"],
      "action": {
        "type": "location_in_attachment",
        "includePageNumber": true,
        "includeSheetName": true,
        "includeSlideNumber": true
      },
      "reasonCode": "location_via_attachment",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "CIT_001_strip_bracket_source",
        "input": "The revenue was $5M [Source: Q4 Report]. This represents growth.",
        "expect": { "output": "The revenue was $5M. This represents growth." }
      },
      {
        "id": "CIT_002_strip_according_to",
        "input": "According to the document, costs increased by 10%.",
        "expect": { "output": "Costs increased by 10%." }
      },
      {
        "id": "CIT_003_nav_pills_clean",
        "context": { "answerMode": "nav_pills" },
        "input": "Here it is: [Source: Budget.xlsx]",
        "expect": { "output": "Here it is:", "hasSourceAttachment": true }
      },
      {
        "id": "CIT_004_location_formatting",
        "input": { "documentName": "Report.pdf", "page": 12 },
        "expect": { "locationLabel": "p. 12" }
      }
    ]
  }
}
