{
  "_meta": {
    "id": "list_styles",
    "version": "1.0.0",
    "description": "ChatGPT-like list styling rules for Koda. Enforces dash bullets, clean spacing, and readable list items. Bullet items must be 1–3 sentences max (no walls). Used by answer_style_policy + markdownNormalizer + render_policy.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "defaultStyle": "bullet",
    "bulletMarker": "-",
    "allowAsteriskBullets": false,
    "allowPlusBullets": false,
    "allowUnicodeBullets": true,
    "convertUnsupportedBulletsToDash": true,
    "ensureBlankLineBeforeList": true,
    "ensureSpaceAfterMarker": true,
    "maxNestedDepth": 2,
    "nestedIndentSpaces": 2
  },
  "bulletRules": {
    "_comment": "Hard list hygiene: 1–3 sentences per bullet item.",
    "maxSentencesPerBullet": 3,
    "maxCharsPerBullet": 320,
    "minWordsPerBullet": 6,
    "splitLongBullets": true,
    "splitStrategy": "sentence_boundary_then_length",
    "ifStillTooLong": "split_into_two_bullets",
    "avoidMultiIdeaBullets": true,
    "normalizePunctuation": {
      "ensureTerminalPunctuationIfMultiSentence": true,
      "allowNoPunctuationIfSingleSentence": true
    }
  },
  "numberedRules": {
    "_comment": "Numbered lists are allowed for steps. Must be 1., 2., 3. and contiguous.",
    "enabled": true,
    "format": "1.",
    "resequenceIfWeirdJumps": true,
    "removeEmptyItems": true,
    "maxStepsSoft": 12,
    "maxStepsHard": 24,
    "maxSentencesPerStep": 3,
    "maxCharsPerStep": 340
  },
  "spacing": {
    "_comment": "ChatGPT spacing: lead-in paragraph optional, but list itself must be clean.",
    "betweenItems": "\n",
    "betweenListsAndText": "\n\n",
    "collapseMultipleBlankLinesMax": 1,
    "preventGluedBulletsToText": true
  },
  "normalization": {
    "_comment": "Convert common list markers into dash bullets.",
    "convert": [
      { "from": "^\\*\\s+", "to": "- " },
      { "from": "^\\+\\s+", "to": "- " },
      { "from": "^•\\s+", "to": "- " }
    ],
    "removeEmptyBulletsPattern": "^[-*+•]\\s*$",
    "collapseRepeatedMarkers": true
  },
  "renderingHints": {
    "_comment": "Hints for UI renderer (not mandatory for markdown).",
    "preferBulletsFor": ["extract", "summarize_key_points", "compare_key_differences", "recommendations"],
    "preferParagraphsFor": ["definition", "single_value", "short_overview"],
    "neverUseBulletsInAnswerMode": ["nav_pills"]
  },
  "tests": {
    "cases": [
      {
        "id": "LST_0001_convert_asterisk_to_dash",
        "input": "* Item 1\n* Item 2",
        "expect": { "output": "- Item 1\n- Item 2" }
      },
      {
        "id": "LST_0002_no_empty_bullets",
        "input": "- \n- Real item",
        "expect": { "emptyBulletsRemoved": true }
      },
      {
        "id": "LST_0003_split_long_bullet",
        "inputMeta": { "bulletSentences": 5 },
        "expect": { "shouldSplit": true }
      }
    ]
  }
}
