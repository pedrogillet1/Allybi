{
  "_meta": {
    "id": "formatting_probes",
    "version": "1.0.0",
    "description": "Formatting integrity probe suite for Koda. Validates ChatGPT-like output structure (short paragraphs, bullets only when listing, tables/quotes gated by intent), strict nav_pills formatting, and banned phrase enforcement. Asserts constraints rather than fixed wording to preserve adaptive uniqueness.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-quality",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "suiteType": "formatting_integrity",
    "strict": true,
    "failFast": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "run_all_cases",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxFailures": 0
      },
      "conflictResolution": {
        "ifAnyFailure": "fail_suite"
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "formatting_overlays",
        "paragraph_rules",
        "bullet_rules",
        "table_styles",
        "quote_styles",
        "bolding_rules",
        "banned_phrases",
        "boilerplate_phrases",
        "answer_openers"
      ]
    },
    "invariantVocabulary": [
      "short_paragraphs_enforced",
      "no_wall_of_text",
      "bullets_only_when_list_intent",
      "tables_only_when_allowed",
      "quotes_only_when_intended",
      "nav_pills_intro_only",
      "nav_pills_no_body",
      "banned_phrases_never_emit",
      "bold_density_limited"
    ]
  },
  "rules": [
    {
      "id": "formatting_probe_invariants",
      "scope": "global",
      "description": "Defines formatting invariants used by the probe harness (assert behavior, not exact text).",
      "appliesTo": ["probe_harness"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "define_invariants",
        "checks": [
          {
            "id": "short_paragraphs_enforced",
            "assert": "doc_grounded => paragraphSentences<=3 (soft) OR paragraphSplitApplied==true"
          },
          {
            "id": "no_wall_of_text",
            "assert": "maxParagraphChars<=420 OR paragraphSplitApplied==true"
          },
          {
            "id": "bullets_only_when_list_intent",
            "assert": "bulletsRendered==true => signals.isListIntent==true AND bulletCount<=7"
          },
          {
            "id": "tables_only_when_allowed",
            "assert": "tablesRendered==true => signals.userAskedForTable==true OR signals.isComparisonIntent==true OR signals.isComputationIntent==true OR metrics.factCount>=3"
          },
          {
            "id": "quotes_only_when_intended",
            "assert": "quotesRendered==true => signals.isQuoteIntent==true OR answerMode==doc_grounded_quote"
          },
          {
            "id": "nav_pills_intro_only",
            "assert": "answerMode==nav_pills => introSentenceCount<=1"
          },
          {
            "id": "nav_pills_no_body",
            "assert": "answerMode==nav_pills => bodySuppressed==true"
          },
          {
            "id": "banned_phrases_never_emit",
            "assert": "outputText does NOT contain any banned phrases"
          },
          {
            "id": "bold_density_limited",
            "assert": "boldSpanCount<=6 AND boldDensity<=0.12"
          }
        ]
      },
      "reasonCode": "formatting_probe_invariants_defined",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "FP_0001_paragraph_split_regression",
        "language": "en",
        "input": "Summarize the document in detail",
        "context": { "metrics": { "paragraphSentences": 7, "paragraphChars": 900 }, "signals": { "hasEvidence": true } },
        "expect": { "invariants": ["no_wall_of_text", "short_paragraphs_enforced"] }
      },
      {
        "id": "FP_0002_bullets_only_when_list_intent",
        "language": "en",
        "input": "What is NOI?",
        "context": { "signals": { "isListIntent": false }, "bulletsRendered": true },
        "expect": { "invariants": ["bullets_only_when_list_intent"], "shouldFail": true }
      },
      {
        "id": "FP_0003_table_guard",
        "language": "en",
        "input": "What is NOI?",
        "context": { "signals": { "userAskedForTable": false }, "metrics": { "factCount": 1 }, "tablesRendered": true },
        "expect": { "invariants": ["tables_only_when_allowed"], "shouldFail": true }
      },
      {
        "id": "FP_0004_quote_guard",
        "language": "es",
        "input": "Resume el documento",
        "context": { "signals": { "isQuoteIntent": false }, "quotesRendered": true },
        "expect": { "invariants": ["quotes_only_when_intended"], "shouldFail": true }
      },
      {
        "id": "FP_0005_nav_pills_strict",
        "language": "en",
        "input": "Open report_Q4_2023.pdf",
        "context": { "answerMode": "nav_pills", "bodySuppressed": true, "introSentenceCount": 1 },
        "expect": { "invariants": ["nav_pills_intro_only", "nav_pills_no_body"] }
      },
      {
        "id": "FP_0006_banned_phrase_never_emit",
        "language": "en",
        "input": "Find ROI",
        "context": { "outputText": "No relevant information found." },
        "expect": { "invariants": ["banned_phrases_never_emit"], "shouldFail": true }
      },
      {
        "id": "FP_0007_bold_density_limit",
        "language": "pt",
        "input": "Resuma o documento",
        "context": { "metrics": { "boldDensity": 0.2, "boldSpanCount": 10 } },
        "expect": { "invariants": ["bold_density_limited"], "shouldFail": true }
      }
    ]
  }
}
