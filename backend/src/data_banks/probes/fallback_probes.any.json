{
  "_meta": {
    "id": "fallback_probes",
    "version": "1.0.0",
    "description": "Fallback integrity probe suite for Koda. Validates ChatGPT-like recovery behavior across empty scope, not-found-in-scope, extraction failures, indexing states, low-confidence routing, and ambiguity. Ensures fallbacks are actionable, non-repetitive, non-robotic, avoid banned phrases, and ask at most one clarification question.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-quality",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "suiteType": "fallback_integrity",
    "strict": true,
    "failFast": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "run_all_cases",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxFailures": 0
      },
      "conflictResolution": {
        "ifAnyFailure": "fail_suite"
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "fallback_processing",
        "fallback_extraction_recovery",
        "fallback_scope_empty",
        "fallback_not_found_scope",
        "clarification_phrases",
        "banned_phrases",
        "ui_copy_tokens",
        "ui_contracts",
        "operator_negatives"
      ]
    },
    "invariantVocabulary": [
      "never_use_banned_empty_result_phrase",
      "fallback_actionable_next_steps",
      "max_one_clarification_question",
      "fallback_not_over_apologetic",
      "anti_repetition_active",
      "scope_preserving_recovery_first",
      "no_false_absence_claims",
      "no_action_hallucination"
    ],
    "antiRepetitionContract": {
      "dedupeBy": ["reasonCode", "fallbackType", "strategy"],
      "cooldownTurns": 3,
      "entropyWindow": 6
    }
  },
  "rules": [
    {
      "id": "fallback_probe_invariants",
      "scope": "global",
      "description": "Defines fallback invariants to be enforced by the probe harness (behavioral, not copy).",
      "appliesTo": ["probe_harness"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "define_invariants",
        "checks": [
          {
            "id": "never_use_banned_empty_result_phrase",
            "assert": "outputText does NOT contain banned empty-result phrase"
          },
          {
            "id": "fallback_actionable_next_steps",
            "assert": "fallbackTriggered==true => nextStepOptionsCount>=1 AND nextStepOptions are actionable"
          },
          {
            "id": "max_one_clarification_question",
            "assert": "clarificationQuestionCount<=1"
          },
          {
            "id": "fallback_not_over_apologetic",
            "assert": "fallbackTriggered==true => apologyCount<=1"
          },
          {
            "id": "anti_repetition_active",
            "assert": "repeatedFallback(reasonCode,strategy) within cooldownTurns => strategy must differ OR token resolution must differ"
          },
          {
            "id": "scope_preserving_recovery_first",
            "assert": "scopeEmpty==true AND explicitDocLock==true => recoveryOptions prioritize scope-preserving adjustments before unlock"
          },
          {
            "id": "no_false_absence_claims",
            "assert": "fallbackType in {scope_empty,not_found_in_scope} => mustNotAssertGlobalAbsence==true"
          },
          {
            "id": "no_action_hallucination",
            "assert": "toolExecuted!=true => outputText does NOT imply executed actions"
          }
        ]
      },
      "reasonCode": "fallback_probe_invariants_defined",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "FBP_0001_no_docs_indexed_actionable",
        "language": "en",
        "input": "Summarize the document",
        "context": { "signals": { "hasIndexedDocs": false }, "fallbackTriggered": true },
        "expect": { "invariants": ["fallback_actionable_next_steps", "never_use_banned_empty_result_phrase"] }
      },
      {
        "id": "FBP_0002_scope_empty_preserve_lock_first",
        "language": "en",
        "input": "Find NOI in this file",
        "context": {
          "signals": { "hardScopeActive": true, "explicitDocLock": true },
          "metrics": { "retrievedChunks": 0 },
          "fallbackType": "scope_empty",
          "fallbackTriggered": true
        },
        "expect": { "invariants": ["scope_preserving_recovery_first", "no_false_absence_claims"] }
      },
      {
        "id": "FBP_0003_not_found_in_scope_variants_first",
        "language": "en",
        "input": "Find EBITDA",
        "context": {
          "signals": { "searchExecuted": true, "hasQueryVariants": true },
          "metrics": { "retrievedChunks": 0, "searchConfidence": 0.85 },
          "fallbackType": "not_found_in_scope",
          "fallbackTriggered": true
        },
        "expect": { "invariants": ["fallback_actionable_next_steps", "no_false_absence_claims"] }
      },
      {
        "id": "FBP_0004_extraction_failed_recovery",
        "language": "en",
        "input": "Summarize the file",
        "context": {
          "metrics": { "extractionCoverage": 0.2 },
          "fallbackType": "extraction_failed",
          "fallbackTriggered": true
        },
        "expect": { "invariants": ["fallback_actionable_next_steps", "never_use_banned_empty_result_phrase"] }
      },
      {
        "id": "FBP_0005_low_confidence_clarify_max_one",
        "language": "en",
        "input": "Find the value",
        "context": {
          "metrics": { "topConfidence": 0.3 },
          "fallbackType": "low_confidence",
          "fallbackTriggered": true,
          "metrics2": { "clarificationQuestionCount": 2 }
        },
        "expect": { "invariants": ["max_one_clarification_question"], "shouldFail": true }
      },
      {
        "id": "FBP_0006_anti_repetition_cooldown",
        "language": "en",
        "inputSequence": ["Find NOI", "Find NOI", "Find NOI"],
        "context": {
          "signals": { "hardScopeActive": true },
          "metrics": { "retrievedChunks": 0 },
          "fallbackType": "scope_empty",
          "fallbackTriggered": true,
          "history": { "recentFallbacks": [{ "reasonCode": "scope_hard_constraints_empty", "strategy": "offer_scope_relaxation", "turnAgo": 1 }] }
        },
        "expect": { "invariants": ["anti_repetition_active"] }
      },
      {
        "id": "FBP_0007_pt_no_banned_phrase",
        "language": "pt",
        "input": "Encontre ROI",
        "context": { "metrics": { "retrievedChunks": 0 }, "fallbackTriggered": true, "outputText": "Não foi encontrada informação relevante." },
        "expect": { "invariants": ["never_use_banned_empty_result_phrase"], "shouldFail": true }
      },
      {
        "id": "FBP_0008_es_no_false_absence",
        "language": "es",
        "input": "Encuentra NOI en este documento",
        "context": {
          "signals": { "hardScopeActive": true },
          "metrics": { "retrievedChunks": 0 },
          "fallbackType": "scope_empty",
          "fallbackTriggered": true,
          "mustNotAssertGlobalAbsence": true
        },
        "expect": { "invariants": ["no_false_absence_claims"] }
      }
    ]
  }
}
