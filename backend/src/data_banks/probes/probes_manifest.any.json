{
  "_meta": {
    "id": "probes_manifest",
    "version": "1.0.0",
    "description": "Canonical manifest for Koda probe suites. Defines deterministic run order, suite dependencies, environment gating, and shared invariants. Ensures CI can execute probes consistently and fail on regressions across routing, retrieval, formatting, fallbacks, multilingual behavior, security, and load integrity.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-quality",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "manifestType": "probe_registry",
    "defaultEnvEnabled": { "production": false, "staging": true, "dev": true, "local": true },
    "failFast": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "run_in_order",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxFailures": 0
      },
      "conflictResolution": {
        "ifAnyFailure": "halt_pipeline"
      }
    },
    "sharedInvariants": [
      "never_use_banned_empty_result_phrase",
      "nav_pills_no_sources_label",
      "max_one_clarification_question",
      "no_wrong_doc_after_explicit_lock",
      "no_action_hallucination",
      "no_internal_leakage"
    ]
  },
  "rules": [
    {
      "id": "probe_run_order_policy",
      "scope": "global",
      "description": "Defines deterministic probe run order: load integrity first, then security, then routing/retrieval, then UI/formatting, then fallbacks, then parity and multilingual.",
      "appliesTo": ["probe_runner"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "set_run_order",
        "order": [
          "load_tests",
          "security_probes",
          "routing_probes",
          "retrieval_tests",
          "hallucination_probes",
          "numeric_probes",
          "ui_probes",
          "formatting_probes",
          "failure_mode_tests",
          "fallback_probes",
          "parity_queries",
          "multilingual_probes"
        ]
      },
      "reasonCode": "probes_run_order_set",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "PM_0001_run_order_contains_all",
        "expect": {
          "containsAllSuites": [
            "load_tests",
            "security_probes",
            "routing_probes",
            "retrieval_tests",
            "hallucination_probes",
            "numeric_probes",
            "ui_probes",
            "formatting_probes",
            "failure_mode_tests",
            "fallback_probes",
            "parity_queries",
            "multilingual_probes"
          ]
        }
      },
      {
        "id": "PM_0002_prod_disabled_by_default",
        "expect": { "productionEnabled": false }
      },
      {
        "id": "PM_0003_shared_invariants_present",
        "expect": { "sharedInvariantsCountMin": 5 }
      },
      {
        "id": "PM_0004_fail_fast_enabled",
        "expect": { "failFast": true }
      }
    ]
  }
}
