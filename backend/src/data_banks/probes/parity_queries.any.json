{
  "_meta": {
    "id": "parity_queries",
    "version": "1.0.0",
    "description": "ChatGPT-parity end-to-end probe suite for Koda. Defines canonical user queries with expected behavioral invariants (not hardcoded copy). Validates routing, formatting, grounding, UI contracts, and fallback behavior against world-class chatbot standards.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-probes",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added invariant-based assertions for ChatGPT-parity validation",
      "Added multilingual query coverage (en, pt, es)",
      "Added collision regression cases for nav_pills vs doc-grounded"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "end_to_end_validation",
    "invariantCategories": ["ui", "structure", "grounding", "fallbacks", "routing", "language"],
    "actionsContract": {
      "combination": {
        "multipleInvariants": "all_must_pass",
        "failFast": false
      },
      "thresholds": {
        "minPassRate": 0.95,
        "criticalInvariantPassRate": 1.0
      },
      "conflictResolution": {
        "ifMultipleFailures": "report_all"
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "routing_overlays",
        "formatting_overlays",
        "ui_contracts",
        "retrieval_overlays",
        "hallucination_probes"
      ],
      "emitsSignals": [
        "parityValidationComplete",
        "invariantViolations",
        "parityScore"
      ]
    }
  },
  "invariants": {
    "ui": {
      "nav_pills_single_intro": "nav_pills mode produces at most 1 intro sentence",
      "nav_pills_no_sources_header": "nav_pills mode never contains 'Sources:' or 'Fontes:' or 'Fuentes:'",
      "nav_pills_button_only": "nav_pills mode outputs source_buttons only, no body text beyond intro",
      "no_action_hallucination": "never claim action was executed unless toolExecuted=true",
      "single_clarification_question": "at most 1 clarification question per response"
    },
    "structure": {
      "short_paragraphs": "paragraphs have at most 4 sentences (soft: 2)",
      "bullet_density_capped": "at most 7 bullets (soft: 5), each at most 3 sentences",
      "table_only_when_justified": "tables only for comparison/computation/multi-row metrics or explicit request",
      "quote_length_capped": "quotes at most 800 chars"
    },
    "grounding": {
      "no_fabricated_facts": "all facts trace to retrieved evidence",
      "no_wrong_doc_drift": "answer references only docs in scope",
      "no_invented_quotes": "quoted text exists in evidence chunks",
      "numeric_values_traceable": "numeric values appear in evidence"
    },
    "fallbacks": {
      "no_banned_empty_phrase": "never use 'No relevant information found' or equivalents",
      "graceful_no_match": "fallback offers next step or clarification",
      "language_match": "response language matches user query language"
    },
    "routing": {
      "quote_over_summarize": "quote intent routes to quote operator",
      "locate_content_over_open": "inside-doc location routes to locate_content",
      "help_over_file_actions": "capability questions route to capabilities operator",
      "discovery_ignores_doc_lock": "discovery intent can search corpus despite doc lock"
    }
  },
  "queries": [
    {
      "id": "PQ_001_nav_pills_open_file",
      "category": "ui",
      "language": "en",
      "query": "Open the budget report",
      "context": { "hasMatchingDoc": true },
      "invariants": ["nav_pills_single_intro", "nav_pills_no_sources_header", "nav_pills_button_only"],
      "expect": {
        "answerMode": "nav_pills",
        "maxIntroSentences": 1,
        "noSourcesLabel": true
      },
      "severity": "critical"
    },
    {
      "id": "PQ_002_nav_pills_locate_docs",
      "category": "ui",
      "language": "en",
      "query": "Which files mention NOI?",
      "context": { "explicitDocLock": true },
      "invariants": ["nav_pills_single_intro", "nav_pills_button_only", "discovery_ignores_doc_lock"],
      "expect": {
        "answerMode": "nav_pills",
        "operator": "locate_docs",
        "corpusWideAllowed": true
      },
      "severity": "critical"
    },
    {
      "id": "PQ_003_doc_grounded_summarize",
      "category": "structure",
      "language": "en",
      "query": "Summarize the main findings",
      "context": { "hasActiveDoc": true },
      "invariants": ["short_paragraphs", "no_fabricated_facts", "no_banned_empty_phrase"],
      "expect": {
        "answerMode": "doc_grounded_single",
        "maxParagraphSentences": 4,
        "requiresEvidence": true
      },
      "severity": "high"
    },
    {
      "id": "PQ_004_quote_mode_exact",
      "category": "grounding",
      "language": "en",
      "query": "Quote the exact wording about liability",
      "context": { "hasActiveDoc": true },
      "invariants": ["no_invented_quotes", "quote_length_capped", "quote_over_summarize"],
      "expect": {
        "answerMode": "doc_grounded_quote",
        "operator": "quote",
        "maxQuoteChars": 800
      },
      "severity": "critical"
    },
    {
      "id": "PQ_005_collision_open_vs_locate",
      "category": "routing",
      "language": "en",
      "query": "Open the report — where is ROI mentioned?",
      "context": { "hasMatchingDoc": true },
      "invariants": ["locate_content_over_open"],
      "expect": {
        "operator": "locate_content",
        "answerMode": "doc_grounded_single"
      },
      "severity": "high"
    },
    {
      "id": "PQ_006_help_over_file_actions",
      "category": "routing",
      "language": "en",
      "query": "What can you do?",
      "invariants": ["help_over_file_actions"],
      "expect": {
        "operator": "capabilities",
        "answerMode": "help_steps"
      },
      "severity": "high"
    },
    {
      "id": "PQ_007_followup_continuity",
      "category": "routing",
      "language": "en",
      "query": "and also the margin",
      "context": { "hasPriorTurn": true, "hasActiveDoc": true },
      "invariants": ["no_wrong_doc_drift", "single_clarification_question"],
      "expect": {
        "isFollowup": true,
        "carryoverDocScope": true,
        "noExtraClarification": true
      },
      "severity": "high"
    },
    {
      "id": "PQ_008_multilingual_pt_summarize",
      "category": "language",
      "language": "pt",
      "query": "Resuma o documento",
      "context": { "hasActiveDoc": true },
      "invariants": ["language_match", "short_paragraphs", "no_banned_empty_phrase"],
      "expect": {
        "responseLanguage": "pt",
        "answerMode": "doc_grounded_single"
      },
      "severity": "high"
    },
    {
      "id": "PQ_009_multilingual_es_locate",
      "category": "language",
      "language": "es",
      "query": "¿Qué archivos mencionan capex?",
      "invariants": ["language_match", "nav_pills_single_intro"],
      "expect": {
        "responseLanguage": "es",
        "answerMode": "nav_pills"
      },
      "severity": "high"
    },
    {
      "id": "PQ_010_table_guard_suppression",
      "category": "structure",
      "language": "en",
      "query": "Tell me the revenue",
      "context": { "hasActiveDoc": true, "factCount": 1 },
      "invariants": ["table_only_when_justified"],
      "expect": {
        "tableSuppressed": true,
        "formatFallback": "paragraph"
      },
      "severity": "medium"
    },
    {
      "id": "PQ_011_numeric_strictness",
      "category": "grounding",
      "language": "en",
      "query": "Calculate the profit margin",
      "context": { "hasActiveDoc": true, "isComputationIntent": true },
      "invariants": ["numeric_values_traceable", "no_fabricated_facts"],
      "expect": {
        "numericIntegrityStrict": true,
        "minSemanticScore": 0.6
      },
      "severity": "critical"
    },
    {
      "id": "PQ_012_graceful_no_match",
      "category": "fallbacks",
      "language": "en",
      "query": "What does the document say about quantum physics?",
      "context": { "hasActiveDoc": true, "noMatchingEvidence": true },
      "invariants": ["no_banned_empty_phrase", "graceful_no_match"],
      "expect": {
        "fallbackTriggered": true,
        "offersNextStep": true,
        "noBannedPhrase": true
      },
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "PQ_TEST_001_nav_pills_invariants",
        "queryIds": ["PQ_001_nav_pills_open_file", "PQ_002_nav_pills_locate_docs"],
        "expect": { "allInvariantsPass": true, "answerMode": "nav_pills" }
      },
      {
        "id": "PQ_TEST_002_grounding_invariants",
        "queryIds": ["PQ_004_quote_mode_exact", "PQ_011_numeric_strictness"],
        "expect": { "allInvariantsPass": true, "noFabricatedContent": true }
      },
      {
        "id": "PQ_TEST_003_multilingual_invariants",
        "queryIds": ["PQ_008_multilingual_pt_summarize", "PQ_009_multilingual_es_locate"],
        "expect": { "languageMatch": true }
      },
      {
        "id": "PQ_TEST_004_routing_collision_resolution",
        "queryIds": ["PQ_005_collision_open_vs_locate", "PQ_006_help_over_file_actions"],
        "expect": { "correctOperatorRouted": true }
      }
    ]
  }
}
