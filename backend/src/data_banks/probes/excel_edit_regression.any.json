{
  "_meta": {
    "id": "excel_edit_regression",
    "version": "1.0.0",
    "description": "Dev-only regression probes for deterministic Excel edit planning and routing.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-13",
    "owner": "allybi-editing"
  },
  "config": {
    "enabled": true,
    "devOnly": true
  },
  "fixtures": [
    {
      "id": "EXR_001_en_set_selected_zero",
      "language": "en",
      "docType": "xlsx",
      "prompt": "set all selected cells to 0",
      "selection": { "ranges": ["SUMMARY 1!D35:D48"] },
      "expected": {
        "operators": ["XLSX_SET_RANGE_VALUES"],
        "selectionAuthoritative": true
      }
    },
    {
      "id": "EXR_002_pt_set_selected_zero",
      "language": "pt",
      "docType": "xlsx",
      "prompt": "mude todas as c\u00e9lulas selecionadas para 0",
      "selection": { "ranges": ["SUMMARY 1!D35:D48"] },
      "expected": {
        "operators": ["XLSX_SET_RANGE_VALUES"],
        "selectionAuthoritative": true
      }
    },
    {
      "id": "EXR_003_en_multi_intent_currency_bold",
      "language": "en",
      "docType": "xlsx",
      "prompt": "convert selected cells to numbers, then apply currency and bold",
      "selection": { "ranges": ["SUMMARY 1!D35:D48"] },
      "expected": {
        "operators": ["XLSX_SET_RANGE_VALUES", "XLSX_SET_NUMBER_FORMAT", "XLSX_FORMAT_RANGE"],
        "ordered": true
      }
    },
    {
      "id": "EXR_004_en_explicit_range_beats_selection",
      "language": "en",
      "docType": "xlsx",
      "prompt": "set SUMMARY 1!D35:D48 to 0",
      "selection": { "ranges": ["SUMMARY 1!A1:A2"] },
      "expected": {
        "targetHint": "SUMMARY 1!D35:D48"
      }
    }
  ]
}
