{
  "_meta": {
    "id": "load_tests",
    "version": "1.0.0",
    "description": "Loader and boot integrity probe suite for Koda. Validates bank loading determinism, schema validation bootstrapping, dependency DAG correctness, env gating, path uniqueness, and integrationHook reference satisfaction. Prevents silent drift where wrong or missing banks load without failure.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-quality",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "suiteType": "bank_loader_integrity",
    "strict": true,
    "failFast": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "run_all_cases",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxFailures": 0
      },
      "conflictResolution": {
        "ifAnyFailure": "fail_suite"
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "bank_registry",
        "bank_aliases",
        "environments",
        "feature_flags",
        "versioning",
        "bank_schema"
      ]
    },
    "loaderInvariants": [
      "valid_json_only",
      "no_comments_allowed",
      "unique_bank_id",
      "unique_bank_path",
      "dependency_targets_exist",
      "dependency_graph_acyclic",
      "env_keys_standardized",
      "bootstrap_order_respected",
      "schema_validation_applied_post_bootstrap",
      "integrationHook_references_satisfied"
    ],
    "expectedEnvKeys": ["production", "staging", "dev", "local"],
    "bootstrapPolicy": {
      "unvalidatedBanksAllowed": ["bank_manifest", "bank_registry"],
      "schemaMustLoadBeforeValidatingOthers": true
    }
  },
  "rules": [
    {
      "id": "load_suite_invariants",
      "scope": "global",
      "description": "Defines loader invariants and the expected validation model for the probe harness.",
      "appliesTo": ["probe_harness"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "define_invariants",
        "checks": [
          { "id": "valid_json_only", "assert": "all banks parse as strict JSON" },
          { "id": "no_comments_allowed", "assert": "no bank contains // or /* */ style comments" },
          { "id": "unique_bank_id", "assert": "no duplicate bank ids across registry" },
          { "id": "unique_bank_path", "assert": "no duplicate bank paths across registry" },
          { "id": "dependency_targets_exist", "assert": "every dependsOn target exists in registry" },
          { "id": "dependency_graph_acyclic", "assert": "dependency DAG contains no cycles" },
          { "id": "env_keys_standardized", "assert": "enabledByEnv/requiredByEnv keys subsetOf {production,staging,dev,local}" },
          { "id": "bootstrap_order_respected", "assert": "bank_registry and bank_manifest load without schema validation; bank_schema loads before validating others" },
          { "id": "schema_validation_applied_post_bootstrap", "assert": "all enabled non-bootstrap banks are validated against schemaId" },
          { "id": "integrationHook_references_satisfied", "assert": "all bank ids referenced by integrationHooks exist and are enabled in env" }
        ]
      },
      "reasonCode": "load_invariants_defined",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "LT_0001_registry_valid_json",
        "description": "Registry must parse as strict JSON and contain required sections.",
        "context": { "bankId": "bank_registry" },
        "expect": { "invariants": ["valid_json_only"] }
      },
      {
        "id": "LT_0002_no_comments_any_bank",
        "description": "No bank may include comment syntax that breaks strict JSON.",
        "context": { "scanAllBanks": true },
        "expect": { "invariants": ["no_comments_allowed"] }
      },
      {
        "id": "LT_0003_unique_ids_and_paths",
        "description": "Bank ids and bank paths must be globally unique.",
        "context": { "scanRegistry": true },
        "expect": { "invariants": ["unique_bank_id", "unique_bank_path"] }
      },
      {
        "id": "LT_0004_dependency_targets_exist",
        "description": "Every dependsOn id must exist in registry.",
        "context": { "scanRegistryDependencies": true },
        "expect": { "invariants": ["dependency_targets_exist"] }
      },
      {
        "id": "LT_0005_dependency_dag_acyclic",
        "description": "No cycles are allowed in dependsOn graph.",
        "context": { "scanDependencyGraph": true },
        "expect": { "invariants": ["dependency_graph_acyclic"] }
      },
      {
        "id": "LT_0006_env_keys_standardized",
        "description": "Env gating keys must match the standardized set.",
        "context": { "scanEnvKeys": true },
        "expect": { "invariants": ["env_keys_standardized"] }
      },
      {
        "id": "LT_0007_bootstrap_policy",
        "description": "Bootstrap banks load without schema validation; schema loads before validating others.",
        "context": { "simulateBoot": true },
        "expect": { "invariants": ["bootstrap_order_respected"] }
      },
      {
        "id": "LT_0008_schema_validation_applied",
        "description": "After bootstrap, all enabled banks must validate against their schemaId.",
        "context": { "simulateSchemaValidation": true },
        "expect": { "invariants": ["schema_validation_applied_post_bootstrap"] }
      },
      {
        "id": "LT_0009_integration_hooks_satisfied",
        "description": "All integrationHook references must exist and be enabled in the current env.",
        "context": { "scanIntegrationHooks": true, "env": "production" },
        "expect": { "invariants": ["integrationHook_references_satisfied"] }
      },
      {
        "id": "LT_0010_bank_aliases_resolve",
        "description": "Aliases must resolve to canonical ids that exist in registry.",
        "context": { "bankId": "bank_aliases", "scanAliasTargets": true },
        "expect": { "invariants": ["dependency_targets_exist"] }
      }
    ]
  }
}
