{
  "_meta": {
    "id": "hallucination_probes",
    "version": "1.0.0",
    "description": "Hallucination and wrong-doc drift probe suite for Koda. Validates that responses remain evidence-grounded, do not fabricate facts/sources/quotes, and maintain numeric integrity. Prevents ChatGPT-unlike failures such as invented document titles, wrong-doc attribution, and numeric hallucination.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-probes",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added comprehensive hallucination invariant categories",
      "Added wrong-doc drift and scope violation probes",
      "Added numeric integrity and quote accuracy probes",
      "Added multilingual hallucination regression cases"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "post_generation_validation",
    "invariantCategories": ["fabrication", "drift", "quotes", "numerics", "sources", "language"],
    "actionsContract": {
      "combination": {
        "multipleViolations": "report_all_then_block",
        "failFast": true
      },
      "thresholds": {
        "minPassRate": 1.0,
        "toleranceForMinorDrift": 0.0
      },
      "conflictResolution": {
        "ifAnyHallucination": "hard_block"
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "retrieval_overlays",
        "scope_hints",
        "content_guard",
        "evidence_packaging"
      ],
      "emitsSignals": [
        "hallucinationDetected",
        "wrongDocDrift",
        "fabricatedFactDetected",
        "numericIntegrityViolation",
        "quoteIntegrityViolation"
      ]
    },
    "severityLevels": {
      "critical": "hard_block_response",
      "high": "flag_for_review",
      "medium": "log_warning"
    }
  },
  "invariants": {
    "fabrication": {
      "no_fabricated_facts": "All factual claims must trace to retrieved evidence chunks",
      "no_invented_entities": "Entity names (companies, people, products) must appear in evidence",
      "no_invented_dates": "Dates/years must appear in evidence",
      "no_invented_statistics": "Statistics and percentages must appear in evidence"
    },
    "drift": {
      "no_wrong_doc_drift": "Response must not attribute facts to documents not in scope",
      "no_scope_violation": "Response must not reference documents outside activeDocId when doc-locked",
      "no_cross_doc_conflation": "Response must not merge facts from different documents without attribution"
    },
    "quotes": {
      "no_invented_quotes": "Quoted text must exist verbatim in evidence chunks",
      "no_paraphrase_as_quote": "Paraphrased content must not be presented as direct quotes",
      "quote_attribution_accurate": "Quote must be attributed to correct document/section"
    },
    "numerics": {
      "numeric_values_traceable": "All numeric values must appear in evidence",
      "calculation_inputs_traceable": "Inputs to calculations must appear in evidence",
      "no_rounded_hallucination": "Rounded values must be flagged as approximate"
    },
    "sources": {
      "no_invented_doc_titles": "Document titles must match actual uploaded documents",
      "no_invented_page_numbers": "Page numbers must exist in referenced document",
      "no_invented_sections": "Section names must appear in document structure"
    },
    "language": {
      "no_cross_language_fabrication": "Response language matches query; no fabricated translations"
    }
  },
  "probes": [
    {
      "id": "HP_001_fabricated_fact_detection",
      "category": "fabrication",
      "language": "en",
      "query": "What is the company's revenue?",
      "context": { "hasActiveDoc": true, "evidenceContains": ["$5.2 million"] },
      "invariants": ["no_fabricated_facts", "numeric_values_traceable"],
      "validationRules": {
        "mustContain": { "pattern": "\\$?5\\.?2\\s*million", "source": "evidence" },
        "mustNotContain": { "pattern": "\\$[0-9]+\\s*million", "notIn": "evidence" }
      },
      "severity": "critical"
    },
    {
      "id": "HP_002_wrong_doc_drift",
      "category": "drift",
      "language": "en",
      "query": "Summarize the main points",
      "context": {
        "hasActiveDoc": true,
        "activeDocId": "doc_A",
        "explicitDocLock": true,
        "otherDocsInCorpus": ["doc_B", "doc_C"]
      },
      "invariants": ["no_wrong_doc_drift", "no_scope_violation"],
      "validationRules": {
        "mustNotReference": ["doc_B", "doc_C"]
      },
      "severity": "critical"
    },
    {
      "id": "HP_003_invented_quote_detection",
      "category": "quotes",
      "language": "en",
      "query": "Quote the exact wording about liability",
      "context": {
        "hasActiveDoc": true,
        "evidenceContains": ["The company shall not be held liable for indirect damages"]
      },
      "invariants": ["no_invented_quotes", "quote_attribution_accurate"],
      "validationRules": {
        "quotedTextMustExistIn": "evidence",
        "noParaphraseAsQuote": true
      },
      "severity": "critical"
    },
    {
      "id": "HP_004_numeric_hallucination",
      "category": "numerics",
      "language": "en",
      "query": "What was the profit margin?",
      "context": {
        "hasActiveDoc": true,
        "evidenceContains": ["profit margin of 12.5%"],
        "isComputationIntent": true
      },
      "invariants": ["numeric_values_traceable", "no_fabricated_facts"],
      "validationRules": {
        "numericMustAppearIn": "evidence",
        "tolerancePercent": 0
      },
      "severity": "critical"
    },
    {
      "id": "HP_005_invented_doc_title",
      "category": "sources",
      "language": "en",
      "query": "Which document discusses capex?",
      "context": {
        "uploadedDocs": ["Q4_Report.pdf", "Budget_2025.xlsx"],
        "noMatchingDoc": false
      },
      "invariants": ["no_invented_doc_titles"],
      "validationRules": {
        "docTitlesMustBeIn": ["Q4_Report.pdf", "Budget_2025.xlsx"]
      },
      "severity": "critical"
    },
    {
      "id": "HP_006_multilingual_fabrication_pt",
      "category": "language",
      "language": "pt",
      "query": "Qual é a receita total?",
      "context": {
        "hasActiveDoc": true,
        "evidenceContains": ["R$ 2.3 milhões"]
      },
      "invariants": ["no_fabricated_facts", "no_cross_language_fabrication"],
      "validationRules": {
        "mustContain": { "pattern": "R\\$\\s*2[,.]?3\\s*milh", "source": "evidence" },
        "responseLanguage": "pt"
      },
      "severity": "high"
    },
    {
      "id": "HP_007_multilingual_fabrication_es",
      "category": "language",
      "language": "es",
      "query": "¿Cuál es el margen operativo?",
      "context": {
        "hasActiveDoc": true,
        "evidenceContains": ["margen operativo del 8.2%"]
      },
      "invariants": ["numeric_values_traceable", "no_cross_language_fabrication"],
      "validationRules": {
        "mustContain": { "pattern": "8[,.]?2\\s*%", "source": "evidence" },
        "responseLanguage": "es"
      },
      "severity": "high"
    },
    {
      "id": "HP_008_cross_doc_conflation",
      "category": "drift",
      "language": "en",
      "query": "Compare the revenue figures",
      "context": {
        "hasMultipleDocs": true,
        "docA_contains": ["revenue: $5M"],
        "docB_contains": ["revenue: $8M"]
      },
      "invariants": ["no_cross_doc_conflation"],
      "validationRules": {
        "eachFactAttributedToCorrectDoc": true
      },
      "severity": "high"
    },
    {
      "id": "HP_009_invented_page_number",
      "category": "sources",
      "language": "en",
      "query": "What does page 15 say about expenses?",
      "context": {
        "hasActiveDoc": true,
        "docPageCount": 12
      },
      "invariants": ["no_invented_page_numbers"],
      "validationRules": {
        "pageNumberMustExist": true,
        "maxPageNumber": 12
      },
      "severity": "high"
    },
    {
      "id": "HP_010_regression_followup_drift",
      "category": "drift",
      "language": "en",
      "query": "and also the operating expenses",
      "context": {
        "isFollowup": true,
        "hasActiveDoc": true,
        "activeDocId": "budget_2025",
        "priorTurnDocId": "budget_2025"
      },
      "invariants": ["no_wrong_doc_drift", "no_scope_violation"],
      "validationRules": {
        "mustMaintainDocScope": "budget_2025",
        "noUnauthorizedDocSwitch": true
      },
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "HP_TEST_001_fabrication_detection",
        "probeIds": ["HP_001_fabricated_fact_detection", "HP_004_numeric_hallucination"],
        "expect": { "allInvariantsPass": true, "noFabricatedContent": true }
      },
      {
        "id": "HP_TEST_002_drift_prevention",
        "probeIds": ["HP_002_wrong_doc_drift", "HP_010_regression_followup_drift"],
        "expect": { "noWrongDocDrift": true, "scopeMaintained": true }
      },
      {
        "id": "HP_TEST_003_quote_integrity",
        "probeIds": ["HP_003_invented_quote_detection"],
        "expect": { "quotesVerbatimFromEvidence": true }
      },
      {
        "id": "HP_TEST_004_source_integrity",
        "probeIds": ["HP_005_invented_doc_title", "HP_009_invented_page_number"],
        "expect": { "allSourceReferencesValid": true }
      },
      {
        "id": "HP_TEST_005_multilingual_integrity",
        "probeIds": ["HP_006_multilingual_fabrication_pt", "HP_007_multilingual_fabrication_es"],
        "expect": { "languageMatch": true, "noFabricatedContent": true }
      }
    ]
  }
}
