{
  "_meta": {
    "id": "operator_constraints",
    "version": "1.0.0",
    "description": "Canonical constraint model for Koda operators. Defines supported constraint keys, precedence, defaults per operator, and enforcement rules (paragraph splitting, bullet sentence limits, nav_pills strict body, no JSON). Consumed by query_rewrite, formatConstraintParser, answer_style_policy, answerComposer, render_policy, and quality_gates.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },

  "config": {
    "enabled": true,
    "strict": true,
    "failOnUnknownConstraintKey": true,
    "maxClarifyQuestions": 1,
    "denyJsonOutput": true
  },

  "precedence": {
    "_comment": "Highest wins. User explicit requests override operator defaults; hard safety/UX rules override all.",
    "order": [
      "hard_guards",
      "explicit_user_format_request",
      "operator_contract_defaults",
      "profile_selection_defaults",
      "global_defaults"
    ]
  },

  "constraintKeys": {
    "_comment": "These are the ONLY keys the runtime should pass into composer/context.",
    "list": [
      "outputShape",
      "exactBulletCount",
      "maxSentences",
      "maxSentencesPerParagraph",
      "maxCharsPerParagraph",
      "maxSentencesPerBullet",
      "requireIntro",
      "requireConclusion",
      "requireTable",
      "requireEvidence",
      "requireSourceButtons",
      "maxButtons",
      "maxFilesShown",
      "showMoreEnabled",
      "maxFollowups",
      "userRequestedShort"
    ]
  },

  "hardGuards": {
    "_comment": "Non-negotiable UX rules (ChatGPT-like). These apply regardless of operator.",
    "rules": [
      {
        "id": "HG_001_no_json",
        "enforce": { "denyJsonOutput": true },
        "mapsJsonTo": { "numericOrTabular": "table", "listLike": "bullets", "otherwise": "paragraph" }
      },
      {
        "id": "HG_002_short_paragraphs",
        "enforce": {
          "maxSentencesPerParagraph": 2,
          "maxCharsPerParagraph": 260
        },
        "notes": "Paragraphs must be readable. Split long paragraphs automatically."
      },
      {
        "id": "HG_003_bullets_sentence_limit",
        "enforce": {
          "maxSentencesPerBullet": 3
        },
        "notes": "Each bullet must be 1–3 sentences max."
      },
      {
        "id": "HG_004_nav_pills_body_strict",
        "when": { "outputShape": "button_only" },
        "enforce": {
          "maxSentences": 1,
          "maxButtons": 5,
          "maxFollowups": 0
        }
      }
    ]
  },

  "defaults": {
    "_comment": "Global defaults (lowest precedence).",
    "outputShape": "paragraph",
    "requireIntro": false,
    "requireConclusion": false,
    "requireEvidence": false,
    "requireSourceButtons": false,
    "maxFollowups": 1,
    "maxSentencesPerParagraph": 2,
    "maxCharsPerParagraph": 260,
    "maxSentencesPerBullet": 3,
    "maxButtons": 5,
    "maxFilesShown": 10,
    "showMoreEnabled": true
  },

  "byOperator": [
    {
      "operator": "open",
      "defaults": {
        "outputShape": "button_only",
        "requireSourceButtons": true,
        "maxButtons": 5,
        "maxSentences": 1,
        "maxFollowups": 0
      }
    },
    {
      "operator": "locate_file",
      "defaults": {
        "outputShape": "button_only",
        "requireSourceButtons": true,
        "maxButtons": 3,
        "maxSentences": 1,
        "maxFollowups": 0
      }
    },
    {
      "operator": "locate_docs",
      "defaults": {
        "outputShape": "button_only",
        "requireSourceButtons": true,
        "maxButtons": 5,
        "maxSentences": 1,
        "maxFollowups": 0
      }
    },
    {
      "operator": "list",
      "defaults": {
        "outputShape": "file_list",
        "maxFilesShown": 10,
        "showMoreEnabled": true,
        "maxSentences": 1,
        "maxFollowups": 0
      }
    },
    {
      "operator": "filter",
      "defaults": {
        "outputShape": "file_list",
        "maxFilesShown": 10,
        "showMoreEnabled": true,
        "maxSentences": 1,
        "maxFollowups": 0
      }
    },
    {
      "operator": "sort",
      "defaults": {
        "outputShape": "file_list",
        "maxFilesShown": 10,
        "showMoreEnabled": true,
        "maxSentences": 1,
        "maxFollowups": 0
      }
    },
    {
      "operator": "group",
      "defaults": {
        "outputShape": "file_list",
        "maxFilesShown": 10,
        "showMoreEnabled": true,
        "maxSentences": 1,
        "maxFollowups": 0
      }
    },
    {
      "operator": "summarize",
      "defaults": {
        "outputShape": "paragraph",
        "requireIntro": true,
        "requireConclusion": true,
        "requireEvidence": true,
        "maxFollowups": 1
      }
    },
    {
      "operator": "extract",
      "defaults": {
        "outputShape": "paragraph",
        "requireIntro": true,
        "requireConclusion": true,
        "requireEvidence": true,
        "maxFollowups": 1
      }
    },
    {
      "operator": "locate_content",
      "defaults": {
        "outputShape": "bullets",
        "requireIntro": true,
        "requireConclusion": true,
        "requireEvidence": true,
        "maxFollowups": 1
      }
    },
    {
      "operator": "quote",
      "defaults": {
        "outputShape": "quote",
        "requireEvidence": true,
        "maxFollowups": 1
      }
    },
    {
      "operator": "compare",
      "defaults": {
        "outputShape": "table",
        "requireTable": true,
        "requireIntro": true,
        "requireConclusion": true,
        "requireEvidence": true,
        "maxFollowups": 1
      }
    },
    {
      "operator": "compute",
      "defaults": {
        "outputShape": "table",
        "requireTable": true,
        "requireIntro": true,
        "requireConclusion": true,
        "requireEvidence": true,
        "maxFollowups": 1
      }
    },
    {
      "operator": "capabilities",
      "defaults": {
        "outputShape": "bullets",
        "maxFollowups": 0
      }
    },
    {
      "operator": "how_to",
      "defaults": {
        "outputShape": "steps",
        "maxFollowups": 0
      }
    },
    {
      "operator": "greeting",
      "defaults": { "outputShape": "paragraph", "maxSentences": 1, "maxFollowups": 0 }
    },
    {
      "operator": "thanks",
      "defaults": { "outputShape": "paragraph", "maxSentences": 1, "maxFollowups": 0 }
    },
    {
      "operator": "goodbye",
      "defaults": { "outputShape": "paragraph", "maxSentences": 1, "maxFollowups": 0 }
    },
    {
      "operator": "ack",
      "defaults": { "outputShape": "paragraph", "maxSentences": 1, "maxFollowups": 0 }
    }
  ],

  "tests": {
    "cases": [
      {
        "id": "OCON_0001_nav_pills_strict",
        "input": { "operator": "open" },
        "expect": { "outputShape": "button_only", "maxSentences": 1, "maxFollowups": 0 }
      },
      {
        "id": "OCON_0002_bullets_limit_sentences",
        "input": { "operator": "summarize", "userAskedForBullets": true },
        "expect": { "maxSentencesPerBullet": 3 }
      }
    ]
  }
}
