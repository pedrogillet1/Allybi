{
  "_meta": {
    "id": "operator_signals",
    "version": "1.0.0",
    "description": "Operator → signal mapping for Koda. Defines which signals each operator requires, sets, or suppresses. Keeps behavior stable across router, retrieval, composer, and quality gates.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },

  "config": {
    "enabled": true,
    "strict": true,
    "failOnUnknownSignal": true
  },

  "signals": [
    "discoveryQuery",
    "hasExplicitDocRef",
    "lockDocRequested",
    "isFollowup",
    "numericIntent",
    "numericIntentStrong",
    "spreadsheetQuery",
    "calculationIntent",
    "userRequestedShort",
    "shortOverview",
    "userAskedForQuote",
    "userAskedForTable",
    "userAskedForBullets",
    "userAskedForSteps",
    "userAskedForJson",
    "compareRequested",
    "explainWhyHow",
    "multiPartQuery",
    "lowEvidence",
    "ocrLowConfidence",
    "navQuery"
  ],

  "byOperator": [
    {
      "operator": "open",
      "sets": ["navQuery"],
      "requires": [],
      "suppresses": ["userAskedForQuote", "userAskedForTable", "userAskedForBullets", "userAskedForSteps"],
      "notes": "Open is navigation only; no content extraction."
    },
    {
      "operator": "locate_file",
      "sets": ["navQuery"],
      "requires": [],
      "suppresses": ["userAskedForQuote", "userAskedForTable", "userAskedForBullets", "userAskedForSteps"]
    },
    {
      "operator": "locate_docs",
      "sets": ["discoveryQuery", "navQuery"],
      "requires": [],
      "suppresses": [],
      "notes": "Discovery mode must search corpus-wide even if doc is hard-locked."
    },
    {
      "operator": "locate_content",
      "sets": [],
      "requires": [],
      "suppresses": ["navQuery"],
      "notes": "Locate content returns locations; never a pure nav pill."
    },
    {
      "operator": "quote",
      "sets": ["userAskedForQuote"],
      "requires": [],
      "suppresses": ["navQuery"]
    },
    {
      "operator": "compare",
      "sets": ["compareRequested"],
      "requires": [],
      "suppresses": ["navQuery"]
    },
    {
      "operator": "compute",
      "sets": ["numericIntent"],
      "requiresAny": ["numericIntent", "calculationIntent", "spreadsheetQuery"],
      "suppresses": ["navQuery"]
    },
    {
      "operator": "extract",
      "sets": [],
      "requires": [],
      "suppresses": ["navQuery"]
    },
    {
      "operator": "summarize",
      "sets": [],
      "requires": [],
      "suppresses": ["navQuery"]
    },
    {
      "operator": "list",
      "sets": ["navQuery"],
      "requires": [],
      "suppresses": []
    },
    {
      "operator": "filter",
      "sets": ["navQuery"],
      "requires": [],
      "suppresses": []
    },
    {
      "operator": "sort",
      "sets": ["navQuery"],
      "requires": [],
      "suppresses": []
    },
    {
      "operator": "group",
      "sets": ["navQuery"],
      "requires": [],
      "suppresses": []
    },
    {
      "operator": "greeting",
      "sets": [],
      "requires": [],
      "suppresses": ["navQuery", "discoveryQuery", "numericIntent"]
    },
    {
      "operator": "thanks",
      "sets": [],
      "requires": [],
      "suppresses": ["navQuery", "discoveryQuery", "numericIntent"]
    },
    {
      "operator": "goodbye",
      "sets": [],
      "requires": [],
      "suppresses": ["navQuery", "discoveryQuery", "numericIntent"]
    },
    {
      "operator": "ack",
      "sets": [],
      "requires": [],
      "suppresses": ["navQuery", "discoveryQuery", "numericIntent"]
    }
  ],

  "tests": {
    "cases": [
      {
        "id": "OPSIG_0001_open_sets_nav",
        "input": { "operator": "open" },
        "expect": { "setsAny": ["navQuery"] }
      },
      {
        "id": "OPSIG_0002_locate_docs_sets_discovery",
        "input": { "operator": "locate_docs" },
        "expect": { "setsAny": ["discoveryQuery"] }
      },
      {
        "id": "OPSIG_0003_quote_sets_userAskedForQuote",
        "input": { "operator": "quote" },
        "expect": { "setsAny": ["userAskedForQuote"] }
      }
    ]
  }
}
