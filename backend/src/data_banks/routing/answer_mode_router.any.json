{
  "_meta": {
    "id": "answer_mode_router",
    "version": "2.2.0",
    "description": "Answer mode router for Koda. Chooses response mode (nav_pills, doc_grounded_single/table/quote/multi, rank_disambiguate/autopick, scoped_not_found, no_docs, help_steps, refusal). Enforces: explicit doc locks; discovery/open/where -> nav_pills; never say 'no docs' when docs exist; never output JSON.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },

  "config": {
    "enabled": true,

    "integrationHooks": {
      "rankFeaturesBankId": "ambiguity_rank_features",
      "scopeResolutionBankId": "scope_resolution",
      "followupDetectionBankId": "followup_detection",
      "answerStylePolicyBankId": "answer_style_policy",
      "routingOperatorTiebreakersBankId": "routing_operator_tiebreakers",
      "docGroundingChecksBankId": "doc_grounding_checks",
      "hallucinationGuardsBankId": "hallucination_guards"
    },

    "thresholds": {
      "autoPickTopScoreGte": 0.70,
      "autoPickMarginGte": 0.05,
      "ambiguousMarginLt": 0.03,
      "forceClarifyTopScoreBelow": 0.40
    },

    "guardrails": {
      "neverReturnDocGroundedModesIfNoDocs": true,
      "neverChooseFileActionsForContentMarkers": true,
      "neverOutputJson": true,
      "maxClarifyQuestions": 1
    }
  },

  "modes": [
    "no_docs",
    "scoped_not_found",
    "refusal",
    "nav_pills",
    "rank_disambiguate",
    "rank_autopick",
    "doc_grounded_single",
    "doc_grounded_table",
    "doc_grounded_quote",
    "doc_grounded_multi",
    "help_steps",
    "general_answer"
  ],

  "rules": [
    {
      "id": "AM_1000_policy_refusal",
      "priority": 1000,
      "when": { "path": "signals.policyRefusalRequired", "op": "eq", "value": true },
      "then": { "mode": "refusal", "reason": "policy_refusal_required" },
      "terminal": true
    },

    {
      "id": "AM_990_no_docs",
      "priority": 990,
      "when": { "path": "docContext.docCount", "op": "lte", "value": 0 },
      "then": { "mode": "no_docs", "reason": "no_docs_indexed" },
      "terminal": true
    },

    {
      "id": "AM_988_scoped_not_found",
      "_comment": "Docs exist, but *scoped* candidate set is empty. Must not say 'no docs'.",
      "priority": 988,
      "when": {
        "all": [
          { "path": "docContext.docCount", "op": "gte", "value": 1 },
          { "path": "docContext.candidateCount", "op": "eq", "value": 0 },
          {
            "any": [
              { "path": "scope.hard.docIdAllowlist", "op": "exists", "value": true },
              { "path": "scope.hard.filenameMustContain", "op": "exists", "value": true },
              { "path": "state.activeDocRef.lockType", "op": "eq", "value": "hard" }
            ]
          }
        ]
      },
      "then": { "mode": "scoped_not_found", "reason": "no_relevant_in_scoped_doc" },
      "terminal": true
    },

    {
      "id": "AM_985_nav_pills_open",
      "priority": 985,
      "when": { "path": "operator", "op": "eq", "value": "open" },
      "then": { "mode": "nav_pills", "reason": "open_operator", "navType": "open" },
      "terminal": true
    },

    {
      "id": "AM_980_nav_pills_locate_file",
      "priority": 980,
      "when": { "path": "operator", "op": "eq", "value": "locate_file" },
      "then": { "mode": "nav_pills", "reason": "locate_file_operator", "navType": "where" },
      "terminal": true
    },

    {
      "id": "AM_975_nav_pills_discovery",
      "_comment": "Discovery should render as nav_pills (intro + pills only).",
      "priority": 975,
      "when": {
        "any": [
          { "path": "operator", "op": "eq", "value": "locate_docs" },
          { "path": "signals.discoveryQuery", "op": "eq", "value": true }
        ]
      },
      "then": { "mode": "nav_pills", "reason": "document_discovery", "navType": "discover" },
      "terminal": true
    },

    {
      "id": "AM_950_quote_request",
      "priority": 950,
      "when": {
        "all": [
          { "path": "signals.userAskedForQuote", "op": "eq", "value": true },
          { "path": "userPrefs.noQuotes", "op": "neq", "value": true }
        ]
      },
      "then": { "mode": "doc_grounded_quote", "reason": "explicit_quote_request" },
      "terminal": true
    },

    {
      "id": "AM_940_table_or_json_request",
      "_comment": "User JSON request is mapped to doc_grounded_table (never raw JSON).",
      "priority": 940,
      "when": {
        "any": [
          { "path": "signals.userAskedForTable", "op": "eq", "value": true },
          { "path": "signals.userAskedForJson", "op": "eq", "value": true }
        ]
      },
      "then": { "mode": "doc_grounded_table", "reason": "table_or_json_request_mapped" },
      "terminal": true
    },

    {
      "id": "AM_930_compare_request",
      "priority": 930,
      "when": { "path": "signals.userAskedForComparison", "op": "eq", "value": true },
      "then": { "mode": "doc_grounded_multi", "reason": "comparison_request" },
      "terminal": true
    },

    {
      "id": "AM_920_help_intent",
      "priority": 920,
      "when": {
        "any": [
          { "path": "operator", "op": "in", "value": ["capabilities", "how_to"] },
          { "path": "intentFamily", "op": "eq", "value": "help" }
        ]
      },
      "then": { "mode": "help_steps", "reason": "help_intent" },
      "terminal": true
    },

    {
      "id": "AM_905_disambiguate_if_ambiguous",
      "priority": 905,
      "when": {
        "all": [
          { "path": "docContext.candidateCount", "op": "gte", "value": 2 },
          {
            "any": [
              { "path": "docContext.margin", "op": "lt", "value": 0.03 },
              { "path": "docContext.topScore", "op": "lt", "value": 0.40 }
            ]
          }
        ]
      },
      "then": { "mode": "rank_disambiguate", "reason": "ambiguous_doc_choice" },
      "terminal": true
    },

    {
      "id": "AM_880_autopick_strong",
      "priority": 880,
      "when": {
        "all": [
          { "path": "docContext.candidateCount", "op": "gte", "value": 1 },
          { "path": "docContext.topScore", "op": "gte", "value": 0.70 },
          { "path": "docContext.margin", "op": "gte", "value": 0.05 }
        ]
      },
      "then": { "mode": "rank_autopick", "reason": "strong_ranking" },
      "terminal": true
    },

    {
      "id": "AM_850_single_candidate_doc",
      "priority": 850,
      "when": { "path": "docContext.candidateCount", "op": "eq", "value": 1 },
      "then": { "mode": "doc_grounded_single", "reason": "single_candidate" },
      "terminal": true
    },

    {
      "id": "AM_800_docs_default",
      "priority": 800,
      "when": { "path": "docContext.docCount", "op": "gte", "value": 1 },
      "then": { "mode": "doc_grounded_single", "reason": "docs_available" },
      "terminal": true
    },

    {
      "id": "AM_100_fallback_general",
      "priority": 100,
      "when": {},
      "then": { "mode": "general_answer", "reason": "fallback" },
      "terminal": true
    }
  ],

  "tests": {
    "cases": [
      {
        "id": "AMT_0001_discovery_nav_pills",
        "input": {
          "operator": "locate_docs",
          "signals": { "discoveryQuery": true },
          "docContext": { "docCount": 5, "candidateCount": 3, "topScore": 0.75, "margin": 0.05 }
        },
        "expect": { "mode": "nav_pills" }
      },
      {
        "id": "AMT_0002_open_nav_pills",
        "input": { "operator": "open", "docContext": { "docCount": 5 } },
        "expect": { "mode": "nav_pills" }
      },
      {
        "id": "AMT_0003_scoped_not_found",
        "input": { "docContext": { "docCount": 5, "candidateCount": 0 }, "scope": { "hard": { "docIdAllowlist": ["doc:x"] } } },
        "expect": { "mode": "scoped_not_found" }
      },
      {
        "id": "AMT_0004_table_request",
        "input": { "signals": { "userAskedForTable": true }, "docContext": { "docCount": 5 } },
        "expect": { "mode": "doc_grounded_table" }
      },
      {
        "id": "AMT_0005_json_request_maps_to_table",
        "input": { "signals": { "userAskedForJson": true }, "docContext": { "docCount": 5 } },
        "expect": { "mode": "doc_grounded_table" }
      },
      {
        "id": "AMT_0006_ambiguous_disambiguate",
        "input": { "docContext": { "docCount": 5, "candidateCount": 3, "topScore": 0.35, "margin": 0.02 } },
        "expect": { "mode": "rank_disambiguate" }
      }
    ]
  }
}
