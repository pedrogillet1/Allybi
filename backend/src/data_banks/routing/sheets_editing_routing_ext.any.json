    {
      "ruleId": "SX_120_sheets_selection_precise_edit",
      "priority": 120,
      "supportedLocales": [
        "en",
        "pt"
      ],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(change|update|edit|rewrite|set)\\b.{0,30}\\b(this cell|selected cells|selection|this range)\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(mudar|atualizar|editar|reescrever|definir)\\b.{0,30}\\b(esta c[eé]lula|c[eé]lulas selecionadas|sele[cç][aã]o|intervalo)\\b"
            ]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "EDIT_RANGE",
        "domain": "sheets",
        "scope": "documents",
        "defaultEntities": {
          "useSelection": true
        }
      },
      "confidenceBoost": 0.15,
      "reasonCode": "sheets_selection_precise_edit"
    },
