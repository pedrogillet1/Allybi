{
  "_meta": {
    "id": "sheets_editing_routing_ext",
    "version": "1.1.0",
    "description": "Extension routing rules for spreadsheet (XLSX) editing intents: computations, bulk formulas, formatting, tables, sorting/filtering, and chart creation. Complements editing_routing with additional natural-language coverage.",
    "languages": [
      "any",
      "en",
      "pt"
    ],
    "lastUpdated": "2026-02-11"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "matching": {
      "useRegex": true,
      "caseSensitive": false,
      "stripDiacriticsForMatching": true,
      "collapseWhitespace": true,
      "maxCandidates": 3
    },
    "thresholds": {
      "minConfidence": 0.58,
