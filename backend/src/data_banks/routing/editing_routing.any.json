    {
      "ruleId": "ER_072_sheets_format_as_table",
      "priority": 72,
      "supportedLocales": [
        "en",
        "pt"
      ],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(format|make|turn|convert)\\b.{0,35}\\b(this|these|selected|range|data)\\b.{0,25}\\binto\\b.{0,15}\\b(a\\s+)?table\\b",
              "\\bformat\\b.{0,35}\\bas\\b.{0,10}\\btable\\b",
              "\\bcreate\\b.{0,25}\\b(table)\\b.{0,25}\\bfrom\\b.{0,25}\\b(range|selection|cells)\\b",
              "\\bmake\\b.{0,25}\\b(an\\s+)?excel\\s+table\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(formatar|criar|fazer|transformar|converter)\\b.{0,35}\\b(este|essa|isso|sele[c\u00e7][a\u00e3]o|intervalo|dados)\\b.{0,25}\\b(em|para)\\b.{0,15}\\b(uma\\s+)?tabela\\b",
              "\\bformatar\\b.{0,35}\\bcomo\\b.{0,10}\\btabela\\b",
              "\\bcriar\\b.{0,25}\\btabela\\b.{0,25}\\ba partir\\b.{0,25}\\b(intervalo|sele[c\u00e7][a\u00e3]o|c[e\u00e9]lulas)\\b"
            ]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "COMPUTE_BUNDLE",
        "domain": "sheets",
        "scope": "documents",
        "defaultEntities": {
          "preserveNumbers": true,
          "preserveEntities": true
        }
      },
      "confidenceBoost": 0.12,
      "reasonCode": "sheets_format_as_table"
    },
