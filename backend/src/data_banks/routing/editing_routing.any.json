{
  "bankId": "editing_routing",
  "version": "1.1.0",
  "localeSupport": ["en", "pt"],
  "description": "High-coverage routing rules for editing intents across DOCX, Sheets, and Slides. Deterministic operator selection with ambiguity/confirmation gates.",
  "updatedAt": "2026-02-07T00:00:00.000Z",
  "schemaVersion": 1,

  "_meta": {
    "id": "editing_routing",
    "version": "1.1.0",
    "description": "Routing rules for editing intents across DOCX, Sheets, and Slides. Deterministic operator selection with bilingual (EN/PT) coverage and ambiguity controls.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07"
  },

  "config": {
    "enabled": true,
    "strict": true,

    "matching": {
      "useRegex": true,
      "caseSensitive": false,
      "stripDiacriticsForMatching": true,
      "collapseWhitespace": true,
      "maxCandidates": 3
    },

    "defaults": {
      "intent": "EDITING",
      "domain": "documents",
      "scope": "documents"
    },

    "thresholds": {
      "minConfidence": 0.58,
      "highConfidence": 0.86,
      "minDecisionMargin": 0.12,
      "forceClarificationMarginBelow": 0.06,
      "silentExecuteConfidence": 0.9
    },

    "guardrails": {
      "destructiveOpsAlwaysConfirm": true,
      "ambiguousTargetsRequireChoice": true,
      "noCommitIfConfidenceBelowThresholdWithoutExplicitUserConfirm": true
    }
  },

  "operators": {
    "canonical": [
      "EDIT_PARAGRAPH",
      "EDIT_CELL",
      "EDIT_RANGE",
      "ADD_SHEET",
      "RENAME_SHEET",
      "CREATE_CHART",
      "ADD_SLIDE",
      "REWRITE_SLIDE_TEXT",
      "REWRITE_BULLETS",
      "ADD_SPEAKER_NOTES",
      "REPLACE_IMAGE",
      "DELETE_ROW",
      "DELETE_COLUMN",
      "DELETE_SHEET",
      "DELETE_SLIDE",
      "MOVE_COLUMN"
    ],
    "alwaysConfirm": ["DELETE_ROW", "DELETE_COLUMN", "DELETE_SHEET", "DELETE_SLIDE", "MOVE_COLUMN", "REPLACE_IMAGE"]
  },

  "rules": [
    {
      "ruleId": "ER_100_docx_text_edit",
      "priority": 100,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(edit|rewrite|reword|change|improve|polish)\\b.{0,50}\\b(paragraph|section|intro|introduction|conclusion|summary)\\b",
              "\\b(make|keep)\\b.{0,40}\\b(paragraph|section)\\b.{0,40}\\b(shorter|longer|clearer|more concise|more formal|more casual|more professional|executive)\\b",
              "\\b(tighten|condense|shorten)\\b.{0,40}\\b(this|the)\\b.{0,20}\\b(paragraph|section)\\b",
              "\\b(expand|elaborate)\\b.{0,40}\\b(this|the)\\b.{0,20}\\b(paragraph|section)\\b",
              "\\b(translate)\\b.{0,40}\\b(this|the)\\b.{0,40}\\b(to|into)\\b.{0,10}\\b(portuguese|english|pt|en)\\b",
              "\\b(change the tone|tone)\\b.{0,40}\\b(formal|casual|friendly|executive|professional|neutral)\\b",
              "\\b(fix grammar|correct grammar|proofread)\\b",
              "\\b(clean up)\\b.{0,30}\\b(wording|language|phrasing)\\b",
              "\\b(rewrite)\\b.{0,30}\\b(sentence|line)\\b",
              "\\b(rewrite)\\b.{0,40}\\bwithout changing meaning\\b",
              "\\bkeep (numbers|dates|names) the same\\b",
              "\\b(do not change|don't change)\\b.{0,30}\\b(numbers|dates|entities|names)\\b",
              "\\b(make it sound)\\b.{0,30}\\b(executive|leadership|board-ready)\\b",
              "\\b(remove redundancy|remove repetition)\\b",
              "\\b(simplify)\\b.{0,30}\\b(this|the)\\b.{0,30}\\b(paragraph|section)\\b"
            ]
          },
          {
            "type": "keyword",
            "locale": "en",
            "keywords": ["docx", "word", "document", "paragraph", "section", "rewrite", "reword", "proofread", "tone"]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(editar|reescrever|reformular|mudar|melhorar|lapidar)\\b.{0,50}\\b(par[aá]grafo|se[cç][aã]o|introdu[cç][aã]o|conclus[aã]o|resumo)\\b",
              "\\b(deixar|tornar)\\b.{0,40}\\b(par[aá]grafo|se[cç][aã]o)\\b.{0,40}\\b(mais curto|mais longo|mais claro|mais conciso|mais formal|mais casual|mais profissional|executivo)\\b",
              "\\b(encurtar|reduzir|condensar)\\b.{0,40}\\b(esse|este)\\b.{0,20}\\b(par[aá]grafo|trecho|se[cç][aã]o)\\b",
              "\\b(expandir|elaborar|detalhar)\\b.{0,40}\\b(esse|este)\\b.{0,20}\\b(par[aá]grafo|trecho|se[cç][aã]o)\\b",
              "\\b(traduzir)\\b.{0,50}\\b(para|pra)\\b.{0,10}\\b(portugu[eê]s|ingl[eê]s|pt|en)\\b",
              "\\b(mudar o tom|tom)\\b.{0,40}\\b(formal|casual|amig[aá]vel|executivo|profissional|neutro)\\b",
              "\\b(corrigir gram[aá]tica|revisar)\\b",
              "\\b(melhorar)\\b.{0,30}\\b(a escrita|o texto|a reda[cç][aã]o)\\b",
              "\\b(reescrever)\\b.{0,30}\\b(frase|linha|senten[cç]a)\\b",
              "\\b(sem mudar o sentido|sem alterar o significado)\\b",
              "\\b(mantenha|manter)\\b.{0,20}\\b(n[uú]meros|datas|nomes)\\b",
              "\\b(n[aã]o altere|nao altere|n[aã]o mude|nao mude)\\b.{0,30}\\b(n[uú]meros|datas|entidades|nomes)\\b",
              "\\b(deixar com cara de)\\b.{0,30}\\b(executivo|lideran[cç]a)\\b",
              "\\b(remover redund[aâ]ncia|tirar repeti[cç][aã]o)\\b",
              "\\b(simplificar)\\b.{0,30}\\b(esse|este)\\b.{0,30}\\b(par[aá]grafo|se[cç][aã]o)\\b"
            ]
          },
          {
            "type": "keyword",
            "locale": "pt",
            "keywords": ["docx", "word", "documento", "paragrafo", "seção", "reescrever", "revisar", "tom"]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "EDIT_PARAGRAPH",
        "domain": "docx",
        "scope": "documents",
        "defaultEntities": {
          "preserveNumbers": true,
          "preserveEntities": true,
          "strictMode": false
        }
      },
      "confidenceBoost": 0.18,
      "reasonCode": "edit_docx_text"
    },

    {
      "ruleId": "ER_090_sheets_cell_or_range_edit",
      "priority": 90,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(edit|change|update|set|fix)\\b.{0,40}\\b(cell|range|column|row)\\b",
              "\\b(in|at)\\s+[A-Z]{1,3}\\d{1,7}\\b.{0,30}\\b(set|change|replace|update|put)\\b",
              "\\b(set)\\b.{0,20}\\b[A-Z]{1,3}\\d{1,7}\\b.{0,20}\\bto\\b",
              "\\b(update)\\b.{0,20}\\b(range)\\b.{0,20}\\b[A-Z]{1,3}\\d{1,7}:[A-Z]{1,3}\\d{1,7}\\b",
              "\\b(fill down|fill the column|copy down)\\b",
              "\\b(recalculate|recompute)\\b.{0,30}\\b(formula|cell)\\b",
              "\\b(make the formula)\\b",
              "\\b(set formula)\\b",
              "\\b(change header|rename column)\\b",
              "\\b(sort)\\b.{0,30}\\b(by|on)\\b",
              "\\b(filter)\\b.{0,30}\\b(where)\\b",
              "\\b(remove duplicates)\\b",
              "\\b(insert row|add row)\\b",
              "\\b(insert column|add column)\\b",
              "\\b(delete row)\\b",
              "\\b(delete column)\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(editar|mudar|atualizar|definir|corrigir)\\b.{0,40}\\b(c[eé]lula|intervalo|coluna|linha)\\b",
              "\\b(em)\\s+[A-Z]{1,3}\\d{1,7}\\b.{0,30}\\b(definir|mudar|substituir|atualizar|colocar)\\b",
              "\\b(definir)\\b.{0,20}\\b[A-Z]{1,3}\\d{1,7}\\b.{0,20}\\bpara\\b",
              "\\b(atualizar)\\b.{0,20}\\b(intervalo)\\b.{0,20}\\b[A-Z]{1,3}\\d{1,7}:[A-Z]{1,3}\\d{1,7}\\b",
              "\\b(preencher para baixo|copiar para baixo)\\b",
              "\\b(recalcular)\\b.{0,30}\\b(f[oó]rmula|c[eé]lula)\\b",
              "\\b(definir f[oó]rmula|colocar f[oó]rmula)\\b",
              "\\b(mudar cabe[cç]alho|renomear coluna)\\b",
              "\\b(ordenar)\\b.{0,30}\\b(por)\\b",
              "\\b(filtrar)\\b.{0,30}\\b(onde)\\b",
              "\\b(remover duplicatas)\\b",
              "\\b(inserir linha|adicionar linha)\\b",
              "\\b(inserir coluna|adicionar coluna)\\b",
              "\\b(excluir linha|deletar linha|apagar linha)\\b",
              "\\b(excluir coluna|deletar coluna|apagar coluna)\\b"
            ]
          },
          {
            "type": "keyword",
            "locale": "en",
            "keywords": ["sheet", "tab", "spreadsheet", "excel", "cell", "range", "formula", "a1"]
          },
          {
            "type": "keyword",
            "locale": "pt",
            "keywords": ["planilha", "aba", "excel", "célula", "intervalo", "fórmula", "a1"]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "EDIT_CELL",
        "domain": "sheets",
        "scope": "documents",
        "defaultEntities": {
          "preserveNumbers": true,
          "preserveEntities": true
        }
      },
      "confidenceBoost": 0.16,
      "reasonCode": "edit_sheets_cell_or_range"
    },

    {
      "ruleId": "ER_080_create_or_rename_sheet",
      "priority": 80,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(add|create|insert|new)\\b.{0,30}\\b(sheet|tab|worksheet)\\b",
              "\\brename\\b.{0,30}\\b(sheet|tab)\\b",
              "\\b(change)\\b.{0,20}\\b(sheet name|tab name)\\b",
              "\\b(make a new tab)\\b",
              "\\bduplicate\\b.{0,20}\\b(sheet|tab)\\b",
              "\\bcopy\\b.{0,20}\\b(sheet|tab)\\b",
              "\\bcreate\\b.{0,20}\\b(another|one more)\\b.{0,20}\\b(tab|sheet)\\b",
              "\\badd a tab called\\b",
              "\\bcreate a sheet named\\b",
              "\\brename tab to\\b",
              "\\brename sheet to\\b",
              "\\btab name should be\\b",
              "\\bworksheet named\\b",
              "\\bnew worksheet\\b",
              "\\badd worksheet\\b",
              "\\binsert worksheet\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(adicionar|criar|inserir|nova|novo)\\b.{0,30}\\b(aba|planilha|guia)\\b",
              "\\b(renomear|mudar o nome)\\b.{0,30}\\b(aba|planilha)\\b",
              "\\b(trocar)\\b.{0,20}\\b(nome da aba|nome da planilha)\\b",
              "\\b(criar uma nova aba)\\b",
              "\\b(duplicar)\\b.{0,20}\\b(aba|planilha)\\b",
              "\\b(copiar)\\b.{0,20}\\b(aba|planilha)\\b",
              "\\badicionar uma aba chamada\\b",
              "\\bcriar uma aba chamada\\b",
              "\\brenomear aba para\\b",
              "\\brenomear planilha para\\b",
              "\\bo nome da aba deve ser\\b",
              "\\bcriar guia\\b",
              "\\bnova guia\\b",
              "\\binserir aba\\b",
              "\\binserir planilha\\b",
              "\\badicionar planilha\\b"
            ]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "ADD_SHEET",
        "domain": "sheets",
        "scope": "documents"
      },
      "confidenceBoost": 0.14,
      "reasonCode": "sheet_create_or_rename"
    },

    {
      "ruleId": "ER_070_create_chart",
      "priority": 70,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(create|add|insert|build|generate|make)\\b.{0,30}\\b(chart|graph)\\b",
              "\\b(bar chart|column chart)\\b",
              "\\b(line chart)\\b",
              "\\b(pie chart)\\b",
              "\\b(scatter plot|scatter chart)\\b",
              "\\b(area chart)\\b",
              "\\bchart from\\b.{0,20}\\b(range|table)\\b",
              "\\bgraph this\\b",
              "\\bvisualize\\b.{0,20}\\b(this|these)\\b.{0,20}\\bdata\\b",
              "\\bplot\\b.{0,20}\\bthis\\b",
              "\\badd a chart for\\b",
              "\\bturn this into a chart\\b",
              "\\bcreate a chart using\\b",
              "\\bchart the revenue\\b",
              "\\bchart title\\b",
              "\\bseries\\b.{0,20}\\bfrom\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(criar|adicionar|inserir|gerar|montar|fazer)\\b.{0,30}\\b(gr[aá]fico)\\b",
              "\\bgr[aá]fico de barras\\b",
              "\\bgr[aá]fico de colunas\\b",
              "\\bgr[aá]fico de linha\\b",
              "\\bgr[aá]fico de pizza\\b",
              "\\bgr[aá]fico de dispers[aã]o\\b",
              "\\bgr[aá]fico de [aá]rea\\b",
              "\\bgr[aá]fico a partir do\\b.{0,20}\\b(intervalo|tabela)\\b",
              "\\bvisualizar\\b.{0,20}\\b(dados|isso)\\b",
              "\\bplotar\\b.{0,20}\\b(esse|este)\\b",
              "\\btransformar em gr[aá]fico\\b",
              "\\badicionar gr[aá]fico para\\b",
              "\\bgr[aá]fico da receita\\b",
              "\\bt[ií]tulo do gr[aá]fico\\b",
              "\\bs[eé]rie\\b.{0,20}\\bdo\\b",
              "\\bcriar um gr[aá]fico usando\\b"
            ]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "CREATE_CHART",
        "domain": "sheets",
        "scope": "documents"
      },
      "confidenceBoost": 0.12,
      "reasonCode": "chart_create_requested"
    },

    {
      "ruleId": "ER_060_slides_add_or_edit",
      "priority": 60,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(add|create|insert|new)\\b.{0,25}\\b(slide)\\b",
              "\\b(add slide)\\b",
              "\\b(insert slide)\\b",
              "\\bnew slide)\\b",
              "\\brewrite\\b.{0,40}\\b(slide|title|bullets|bullet points|text)\\b",
              "\\b(update)\\b.{0,30}\\b(slide)\\b.{0,30}\\b(text|copy)\\b",
              "\\b(make the slide)\\b.{0,40}\\b(more concise|more executive|more visual|clearer)\\b",
              "\\b(reorder|move)\\b.{0,30}\\b(slides)\\b",
              "\\b(delete)\\b.{0,20}\\b(slide)\\b",
              "\\badd speaker notes\\b",
              "\\bspeaker notes\\b",
              "\\breplace image\\b",
              "\\bchange the image\\b",
              "\\bupdate the bullets\\b",
              "\\brewrite bullets\\b",
              "\\btitle slide\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(adicionar|criar|inserir|novo|nova)\\b.{0,25}\\b(slide)\\b",
              "\\badicionar slide\\b",
              "\\binserir slide\\b",
              "\\bnovo slide\\b",
              "\\b(reescrever|reformular|atualizar|mudar|editar)\\b.{0,40}\\b(slide|t[ií]tulo|bullets|t[oó]picos|texto)\\b",
              "\\b(atualizar)\\b.{0,30}\\b(texto|copy)\\b.{0,30}\\b(do slide)\\b",
              "\\b(deixar o slide)\\b.{0,40}\\b(mais conciso|mais executivo|mais visual|mais claro)\\b",
              "\\b(reordenar|mover)\\b.{0,30}\\b(slides)\\b",
              "\\b(excluir|deletar|apagar)\\b.{0,20}\\b(slide)\\b",
              "\\badicionar notas do apresentador\\b",
              "\\bnotas do apresentador\\b",
              "\\bsubstituir imagem\\b",
              "\\btrocar a imagem\\b",
              "\\batualizar os bullets\\b",
              "\\breescrever bullets\\b",
              "\\bslide de t[ií]tulo\\b"
            ]
          },
          {
            "type": "keyword",
            "locale": "en",
            "keywords": ["slides", "deck", "presentation", "ppt", "pptx", "speaker notes", "bullets"]
          },
          {
            "type": "keyword",
            "locale": "pt",
            "keywords": ["slides", "apresentação", "deck", "ppt", "pptx", "notas", "bullets"]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "ADD_SLIDE",
        "domain": "slides",
        "scope": "documents"
      },
      "confidenceBoost": 0.1,
      "reasonCode": "slides_edit_requested"
    }
  ],

  "disambiguation": {
    "requiredWhen": {
      "confidenceBelow": 0.62,
      "decisionMarginBelow": 0.06,
      "candidateCountGte": 2
    },
    "actions": ["pick_target", "clarify_instruction", "cancel"],
    "uiBlock": "choices"
  },

  "outputContract": {
    "shape": {
      "intent": "EDITING",
      "operator": "string",
      "domain": "docx|sheets|slides",
      "scope": "documents|workspace",
      "confidence": "number",
      "reasonCodes": "string[]",
      "databanksUsed": "string[]"
    }
  },

  "tests": {
    "cases": [
      {
        "id": "ER_T_0001_docx_rewrite_pt",
        "input": { "text": "reescreve a introdução deixando mais formal", "language": "pt" },
        "expect": { "operator": "EDIT_PARAGRAPH", "domain": "docx" }
      },
      {
        "id": "ER_T_0002_sheet_set_cell_en",
        "input": { "text": "set B12 to 42", "language": "en" },
        "expect": { "operator": "EDIT_CELL", "domain": "sheets" }
      },
      {
        "id": "ER_T_0003_add_slide_en",
        "input": { "text": "add a new slide with key metrics", "language": "en" },
        "expect": { "operator": "ADD_SLIDE", "domain": "slides" }
      }
    ]
  }
}
