{
  "bankId": "source_selection_routing",
  "version": "1.0.0",
  "localeSupport": ["en", "pt"],
  "description": "Decides which evidence layers to use for answering: user documents, connectors, or both. Provides deterministic precedence rules and safety gates.",
  "updatedAt": "2026-02-07T00:00:00.000Z",
  "schemaVersion": 1,

  "_meta": {
    "id": "source_selection_routing",
    "version": "1.0.0",
    "description": "Source selection router: choose between documents, connectors, or blended retrieval based on query cues (email/slack/doc markers) and safety rules.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07"
  },

  "config": {
    "enabled": true,
    "strict": true,

    "defaults": {
      "sourceMode": "documents_only",
      "allowBlended": true
    },

    "thresholds": {
      "minConfidence": 0.6,
      "highConfidence": 0.9
    },

    "guardrails": {
      "neverUseConnectorsIfNotConnected": true,
      "neverReadConnectorBodiesUnlessUserOptedIn": true,
      "requireCitationsForConnectorAnswers": true
    }
  },

  "modes": [
    "documents_only",
    "connectors_only",
    "documents_then_connectors",
    "connectors_then_documents",
    "blended"
  ],

  "rules": [
    {
      "ruleId": "SSR_100_explicit_doc_reference_documents_only",
      "priority": 100,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          { "type": "regex", "locale": "en", "patterns": ["\\b(in the pdf|in the doc|in the document|in the contract|in the report|in the spreadsheet|in the deck)\\b"] },
          { "type": "regex", "locale": "pt", "patterns": ["\\b(no pdf|no documento|no contrato|no relat[oó]rio|na planilha|no deck|na apresenta[cç][aã]o)\\b"] },
          { "type": "regex", "locale": "any", "patterns": ["\\b\\w+\\.(pdf|docx|xlsx|pptx|csv)\\b"] }
        ]
      },
      "then": {
        "sourceMode": "documents_only",
        "reasonCode": "explicit_document_reference"
      },
      "confidenceBoost": 0.25
    },

    {
      "ruleId": "SSR_090_explicit_connector_reference_connectors_only",
      "priority": 90,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(in gmail|from gmail|gmail thread|inbox)\\b",
              "\\b(in outlook|from outlook)\\b",
              "\\b(in slack|on slack|slack channel|slack dm|slack thread)\\b",
              "\\b(email thread)\\b",
              "\\bmessage thread)\\b",
              "\\bchannel)\\b.{0,20}\\b#\\w+\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(no gmail|do gmail|thread do gmail|caixa de entrada)\\b",
              "\\b(no outlook|do outlook)\\b",
              "\\b(no slack|no canal do slack|dm do slack|thread do slack)\\b",
              "\\b(thread de email)\\b",
              "\\b(conversa)\\b.{0,20}\\b(no slack)\\b",
              "\\bcanal)\\b.{0,20}\\b#\\w+\\b"
            ]
          }
        ]
      },
      "then": {
        "sourceMode": "connectors_only",
        "reasonCode": "explicit_connector_reference"
      },
      "confidenceBoost": 0.22
    },

    {
      "ruleId": "SSR_080_decisions_prefer_slack_then_docs",
      "priority": 80,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(what did we decide|decision|agreed|alignment|action items|next steps|who owns|owner)\\b",
              "\\b(decide|agreed)\\b.{0,30}\\b(on|about)\\b",
              "\\bmeeting)\\b.{0,20}\\bnotes)\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(o que foi decidido|decis[aã]o|combinado|alinhamento|pr[oó]ximos passos|a[cç][oõ]es|respons[aá]vel)\\b",
              "\\b(decidiram|combinamos)\\b.{0,30}\\b(sobre|em)\\b",
              "\\banota[cç][oõ]es)\\b.{0,20}\\b(reuni[aã]o)\\b"
            ]
          }
        ]
      },
      "then": {
        "sourceMode": "connectors_then_documents",
        "preferredConnectors": ["slack"],
        "reasonCode": "decision_queries_prefer_slack"
      },
      "confidenceBoost": 0.18
    },

    {
      "ruleId": "SSR_070_invoice_or_subject_prefer_email_then_docs",
      "priority": 70,
      "supportedLocales": ["en", "pt"],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\b(invoice|receipt|purchase order|po number|subject line|sender|from:)\\b",
              "\\b(attachment|attached|pdf attached)\\b",
              "\\bemail)\\b.{0,20}\\b(subject|sender|from|date)\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(fatura|nota fiscal|recibo|pedido de compra|assunto do email|remetente|de:)\\b",
              "\\b(anexo|anexado|pdf anexado)\\b",
              "\\bemail)\\b.{0,20}\\b(assunto|remetente|de|data)\\b"
            ]
          }
        ]
      },
      "then": {
        "sourceMode": "connectors_then_documents",
        "preferredConnectors": ["gmail", "outlook"],
        "reasonCode": "email_queries_prefer_email"
      },
      "confidenceBoost": 0.14
    },

    {
      "ruleId": "SSR_050_general_qa_default_documents_then_connectors",
      "priority": 50,
      "supportedLocales": ["en", "pt"],
      "when": { "any": [] },
      "then": {
        "sourceMode": "documents_then_connectors",
        "preferredConnectors": ["slack", "gmail", "outlook"],
        "reasonCode": "default_documents_then_connectors"
      },
      "confidenceBoost": 0.02
    }
  ],

  "outputContract": {
    "shape": {
      "sourceMode": "documents_only|connectors_only|documents_then_connectors|connectors_then_documents|blended",
      "preferredConnectors": "string[]|optional",
      "confidence": "number|optional",
      "reasonCode": "string",
      "databanksUsed": "string[]|optional"
    }
  },

  "tests": {
    "cases": [
      {
        "id": "SSR_T_0001_pdf_reference_documents_only",
        "input": { "text": "In the contract PDF, what does termination say?", "language": "en" },
        "expect": { "sourceMode": "documents_only" }
      },
      {
        "id": "SSR_T_0002_slack_decision_connectors_first",
        "input": { "text": "what did we decide about pricing in slack?", "language": "en" },
        "expect": { "sourceMode": "connectors_then_documents" }
      },
      {
        "id": "SSR_T_0003_invoice_email_connectors_first",
        "input": { "text": "find the invoice email subject", "language": "en" },
        "expect": { "sourceMode": "connectors_then_documents" }
      }
    ]
  }
}
