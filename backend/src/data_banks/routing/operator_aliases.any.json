          "\\ben qu[eé] carpeta\\b",
          "\\bd[oó]nde est[aá] (el|mi) (archivo|documento)\\b",
          "\\bencontrar la ubicaci[oó]n\\b"
        ]
      },
      "negatives": {
        "_comment": "Do not treat locate_content (inside-doc) as locate_file (folder/path).",
        "en": ["\\bwhere in the document\\b", "\\bfind all mentions\\b", "\\bon which page\\b"],
        "pt": ["\\bonde no documento\\b", "\\bencontre todas as men[cç][oõ]es\\b", "\\bem qual p[aá]gina\\b"],
        "es": ["\\bd[oó]nde en el documento\\b", "\\bencuentra todas las menciones\\b", "\\ben qu[eé] p[aá]gina\\b"]
      }
    },
    {
