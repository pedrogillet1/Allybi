  "tests": {
    "_comment": "Alias routing tests. These assert operator mapping, not downstream behavior.",
    "cases": [
      {
        "id": "OA_0001_open_preview",
        "input": "Can you preview the file for me?",
        "expect": { "operator": "open" }
      },
      {
        "id": "OA_0002_list_my_files",
        "input": "List my files",
        "expect": { "operator": "list" }
      },
      {
        "id": "OA_0003_prevent_top5_assumptions_inventory_hijack",
        "input": "List the top 5 assumptions",
        "expect": { "operatorNot": "list" }
      },
      {
        "id": "OA_0004_where_in_doc_is_mention",
        "input": "Where is ROI mentioned?",
        "expect": { "operator": "locate_content" }
      },
      {
        "id": "OA_0005_lock_doc",
        "input": "Keep this document active from now on",
