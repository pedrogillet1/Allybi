{
  "_meta": {
    "id": "operator_aliases",
    "version": "1.2.0",
    "description": "Multilingual operator alias patterns for Koda. Maps human phrasing to canonical operators without requiring command-like wording. Used by query_rewrite/operatorResolver before routing tiebreakers. Includes precision (high-confidence) patterns + safeguards to avoid misrouting list-top-N content into file inventory.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "useRegex": true,
    "caseInsensitive": true,
    "stripDiacritics": true,
    "collapseWhitespace": true,
    "requireWordBoundaryForSimpleTokens": true,
    "maxHitsPerOperatorSoft": 6,
    "stopAfterHighConfidenceHit": true,
    "highConfidenceThreshold": 0.86,
    "minConfidenceFallback": 0.55
  },
  "aliases": [
    {
      "operator": "open",
      "priority": 95,
      "confidence": 0.9,
      "patterns": {
        "en": [
          "\\bopen\\b",
          "\\bopen (the )?(file|document|doc|pdf|spreadsheet|presentation)\\b",
          "\\bpreview\\b",
          "\\bview\\b",
          "\\bbring it up\\b",
          "\\bpull it up\\b"
        ],
        "pt": [
          "\\babrir\\b",
          "\\babrir (o|a)?\\s*(arquivo|documento|pdf|planilha|apresenta[cç][aã]o)\\b",
          "\\bprevisualizar\\b",
          "\\bvisualizar\\b",
          "\\bmostra (isso|pra mim)\\b"
        ],
        "es": [
          "\\babrir\\b",
          "\\babrir (el|la)?\\s*(archivo|documento|pdf|hoja|presentaci[oó]n)\\b",
          "\\bprevisualizar\\b",
          "\\bver\\b",
          "\\bmu[eé]strame\\b"
        ]
      },
      "negatives": {
        "_comment": "Avoid misrouting locate_content 'where in the doc' to open.",
        "en": ["\\bwhere in\\b.{0,30}\\b(document|file)\\b", "\\bon which (page|slide)\\b"],
        "pt": ["\\bonde no\\b.{0,30}\\b(documento|arquivo)\\b", "\\bem qual (p[aá]gina|slide)\\b"],
        "es": ["\\bd[oó]nde en\\b.{0,30}\\b(documento|archivo)\\b", "\\ben qu[eé] (p[aá]gina|diapositiva)\\b"]
      }
    },
    {
