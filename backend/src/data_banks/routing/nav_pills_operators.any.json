{
  "_meta": {
    "id": "nav_pills_operators",
    "version": "1.0.0",
    "description": "Defines which operators must render using nav_pills UI (pills/buttons only via source_buttons attachment). Enforces: no inline 'Sources:' section, no inline filename lists, and no message actions in nav responses.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },

  "config": {
    "enabled": true,
    "strict": true,
    "maxPills": 5,
    "maxIntroSentences": 1,
    "maxIntroChars": 90,
    "noSourcesLabel": true,
    "noDivider": true,
    "noFollowups": true
  },

  "operators": [
    {
      "operator": "open",
      "navType": "open",
      "outputShape": "button_only"
    },
    {
      "operator": "locate_file",
      "navType": "where",
      "outputShape": "button_only"
    },
    {
      "operator": "locate_docs",
      "navType": "discover",
      "outputShape": "button_only"
    }
  ],

  "uiRules": {
    "_comment": "Frontend contract: nav pills should render centered with sphere and should not show message actions.",
    "render": {
      "hideSourcesLabel": true,
      "hideSourcesDivider": true,
      "pillsOnly": true,
      "hideMessageActions": true,
      "alignToSphereCenter": true
    }
  },

  "tests": {
    "cases": [
      {
        "id": "NPO_0001_open_is_nav",
        "input": { "operator": "open" },
        "expect": { "navType": "open", "outputShape": "button_only" }
      }
    ]
  }
}
