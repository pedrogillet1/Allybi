{
  "_meta": {
    "id": "docx_editing_routing_ext",
    "version": "1.1.0",
    "description": "Extension routing rules for DOCX editing intents (formatting, structure, bulk transforms). Designed to complement editing_routing with higher coverage for natural editor commands.",
    "languages": [
      "any",
      "en",
      "pt"
    ],
    "lastUpdated": "2026-02-11"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "matching": {
      "useRegex": true,
      "caseSensitive": false,
      "stripDiacriticsForMatching": true,
      "collapseWhitespace": true,
      "maxCandidates": 3
    },
    "thresholds": {
      "minConfidence": 0.58,
      "highConfidence": 0.86
    }
  },
  "rules": [
    {
      "ruleId": "DX_122_docx_text_case",
      "priority": 122,
      "supportedLocales": [
        "en",
        "pt"
      ],
      "when": {
        "any": [
          {
            "type": "regex",
            "locale": "en",
            "patterns": [
              "\\btitle\\s*case\\b",
              "\\b(?:upper\\s*case|uppercase|all\\s+caps)\\b",
              "\\b(?:lower\\s*case|lowercase)\\b",
              "\\bsentence\\s*case\\b",
              "\\bcapitali[sz]e\\b.{0,20}\\b(?:words?|each)\\b"
            ]
          },
          {
            "type": "regex",
            "locale": "pt",
            "patterns": [
              "\\b(?:mai[uú]sculas?|caixa\\s+alta)\\b",
              "\\b(?:min[uú]sculas?|caixa\\s+baixa)\\b",
              "\\bcapitalizar\\b",
              "\\biniciais\\s+mai[uú]sculas?\\b",
              "\\bcaixa\\s+de\\s+frase\\b"
            ]
          }
        ]
      },
      "then": {
        "intent": "EDITING",
        "operator": "EDIT_DOCX_BUNDLE",
        "domain": "docx",
        "scope": "documents",
        "defaultEntities": {
          "transform": "text_case_change"
        }
      },
      "confidenceBoost": 0.16,
      "reasonCode": "docx_text_case"
    },
