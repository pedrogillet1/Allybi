{
  "_meta": {
    "id": "intent_transition_rules",
    "version": "1.0.0",
    "description": "ChatGPT-like intent transition rules for Koda. Controls how the system reuses or switches intentFamily/operator across turns based on follow-ups, active doc locks, explicit doc refs, and user navigation actions. Prevents drift (wrong-doc / wrong-intent) while avoiding unnecessary clarifying questions.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "evaluationStage": "after_followup_detection_before_scope_resolution",
    "maxCarryTurnsSoft": 10,
    "maxCarryTurnsHard": 18,
    "preferProgressOverQuestions": true,
    "maxClarifyQuestions": 1,
    "defaults": {
      "ifFollowupAndNoExplicitRef": "reuse_previous_intent",
      "ifExplicitDocRef": "switch_to_documents_family",
      "ifDiscoverySignal": "switch_to_locate_docs",
      "ifUserSaidPickForMe": "bias_autopick"
    }
  },
  "rules": [
    {
      "id": "ITR_1000_explicit_doc_ref_forces_documents",
      "priority": 1000,
      "when": {
        "any": [
          { "path": "signals.hasExplicitDocRef", "op": "eq", "value": true },
          { "path": "query.hints.docRefs.filenames.length", "op": "gte", "value": 1 },
          { "path": "query.hints.docRefs.docIds.length", "op": "gte", "value": 1 }
        ]
      },
      "then": {
        "force": { "intentFamily": "documents" },
        "notes": ["explicit_doc_ref_switches_to_documents"]
      },
      "terminal": false
    },
    {
      "id": "ITR_980_discovery_signal_forces_locate_docs",
      "priority": 980,
      "when": {
        "any": [
          { "path": "signals.discoveryQuery", "op": "eq", "value": true },
          { "path": "operator", "op": "eq", "value": "locate_docs" }
        ]
      },
      "then": {
        "force": { "operator": "locate_docs", "intentFamily": "documents" },
        "notes": ["discovery_mode_turn"]
      },
      "terminal": true
    },
    {
      "id": "ITR_960_nav_open_followup_stays_file_actions",
      "priority": 960,
      "when": {
        "all": [
          { "path": "signals.isFollowup", "op": "eq", "value": true },
          { "path": "state.lastTurn.operator", "op": "in", "value": ["list", "filter", "sort", "group"] },
          { "path": "signals.navQuery", "op": "eq", "value": true }
        ]
      },
      "then": {
        "force": { "intentFamily": "file_actions" },
        "notes": ["followup_after_file_list_keeps_file_actions"]
      },
      "terminal": false
    },
    {
      "id": "ITR_940_hard_active_doc_lock_reuses_documents",
      "priority": 940,
      "_comment": "ChatGPT-like: if user locked a doc hard, follow-ups should remain doc-grounded unless user explicitly switches or requests discovery.",
      "when": {
        "all": [
          { "path": "signals.isFollowup", "op": "eq", "value": true },
          { "path": "signals.hasExplicitDocRef", "op": "neq", "value": true },
          { "path": "signals.discoveryQuery", "op": "neq", "value": true },
          { "path": "state.activeDocRef.lockType", "op": "eq", "value": "hard" }
        ]
      },
      "then": {
        "force": { "intentFamily": "documents" },
        "notes": ["hard_doc_lock_followup_reuse"]
      },
      "terminal": false
    },
    {
      "id": "ITR_920_soft_active_doc_followup_bias_documents",
      "priority": 920,
      "when": {
        "all": [
          { "path": "signals.isFollowup", "op": "eq", "value": true },
          { "path": "signals.hasExplicitDocRef", "op": "neq", "value": true },
          { "path": "signals.discoveryQuery", "op": "neq", "value": true },
          { "path": "state.activeDocRef.lockType", "op": "in", "value": ["soft"] }
        ]
      },
      "then": {
        "bias": { "intentFamily": "documents", "amount": 0.10 },
        "notes": ["soft_doc_context_followup_bias"]
      },
      "terminal": false
    },
    {
      "id": "ITR_900_conversation_shield_does_not_transition",
      "priority": 900,
      "when": { "path": "intentFamily", "op": "eq", "value": "conversation" },
      "then": {
        "force": { "intentFamily": "conversation" },
        "notes": ["conversation_should_not_trigger_doc_or_file_actions"]
      },
      "terminal": true
    },
    {
      "id": "ITR_860_help_intent_sticky_within_turn",
      "priority": 860,
      "when": {
        "any": [
          { "path": "intentFamily", "op": "eq", "value": "help" },
          { "path": "operator", "op": "in", "value": ["capabilities", "how_to"] }
        ]
      },
      "then": {
        "force": { "intentFamily": "help" },
        "notes": ["help_queries_should_not_be_misread_as_doc_ops"]
      },
      "terminal": true
    },
    {
      "id": "ITR_820_user_chose_doc_promotes_documents",
      "priority": 820,
      "when": {
        "all": [
          { "path": "signals.userChoseDocThisTurn", "op": "eq", "value": true },
          { "path": "state.lastDisambiguation.chosenDocId", "op": "exists", "value": true }
        ]
      },
      "then": {
        "force": { "intentFamily": "documents" },
        "notes": ["user_choice_promotes_documents_turn"]
      },
      "terminal": false
    },
    {
      "id": "ITR_780_file_actions_followup_keep_family",
      "priority": 780,
      "_comment": "If last turn was file_actions and this turn is a follow-up without doc content intent, keep file_actions.",
      "when": {
        "all": [
          { "path": "signals.isFollowup", "op": "eq", "value": true },
          { "path": "state.lastTurn.intentFamily", "op": "eq", "value": "file_actions" },
          { "path": "signals.contentMarkerPresent", "op": "neq", "value": true },
          { "path": "signals.discoveryQuery", "op": "neq", "value": true }
        ]
      },
      "then": {
        "force": { "intentFamily": "file_actions" },
        "notes": ["followup_after_file_actions_keeps_file_actions"]
      },
      "terminal": false
    },
    {
      "id": "ITR_700_documents_followup_default_reuse",
      "priority": 700,
      "when": {
        "all": [
          { "path": "signals.isFollowup", "op": "eq", "value": true },
          { "path": "state.lastTurn.intentFamily", "op": "eq", "value": "documents" },
          { "path": "signals.hasExplicitDocRef", "op": "neq", "value": true },
          { "path": "signals.discoveryQuery", "op": "neq", "value": true }
        ]
      },
      "then": {
        "force": { "intentFamily": "documents" },
        "notes": ["followup_after_documents_reuse"]
      },
      "terminal": false
    },
    {
      "id": "ITR_100_default_noop",
      "priority": 100,
      "when": {},
      "then": {
        "notes": ["no_transition_rule_applied"]
      },
      "terminal": true
    }
  ],
  "tests": {
    "_comment": "Transition tests ensure ChatGPT-like follow-up behavior and prevent drift.",
    "cases": [
      {
        "id": "ITRT_001_explicit_filename_forces_documents",
        "input": {
          "signals": { "hasExplicitDocRef": true, "isFollowup": false },
          "query": { "hints": { "docRefs": { "filenames": ["Budget.xlsx"], "docIds": [] } } },
          "state": { "lastTurn": { "intentFamily": "file_actions", "operator": "list" } }
        },
        "expect": { "forcedIntentFamily": "documents" }
      },
      {
        "id": "ITRT_002_discovery_signal_forces_locate_docs",
        "input": {
          "signals": { "discoveryQuery": true },
          "state": { "lastTurn": { "intentFamily": "documents", "operator": "extract" } }
        },
        "expect": { "forcedOperator": "locate_docs" }
      },
      {
        "id": "ITRT_003_hard_lock_followup_keeps_documents",
        "input": {
          "signals": { "isFollowup": true, "hasExplicitDocRef": false, "discoveryQuery": false },
          "state": {
            "activeDocRef": { "docId": "doc:locked", "lockType": "hard" },
            "lastTurn": { "intentFamily": "documents", "operator": "extract" }
          }
        },
        "expect": { "forcedIntentFamily": "documents" }
      }
    ]
  }
}
