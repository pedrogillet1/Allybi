{
  "_meta": {
    "id": "disambiguation_negatives",
    "version": "1.0.0",
    "description": "Negative rules used during disambiguation UI decisions. Prevents showing disambiguation when (1) a hard doc constraint exists, (2) a nav_pills action is clearly intended, (3) the user asked a pure conversation utterance, or (4) candidates differ only by weak tokens like 'final'/'v2'. Also prevents 'pick a file' prompts when the user is asking about content within the active doc.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "useRegex": true,
    "caseInsensitive": true,
    "stripDiacritics": true,
    "collapseWhitespace": true,
    "evaluationStage": "rank_disambiguate",
    "maxRulesApplied": 8
  },
  "policy": {
    "_comment": "How these negatives influence the disambiguation decision.",
    "preferAutopickWhenSafe": true,
    "preferClarifyOnlyWhenBlocking": true,
    "neverDisambiguateWhenHardScoped": true,
    "neverDisambiguateForConversationUtterances": true,
    "doNotShowMoreThanOneQuestion": true
  },
  "rules": [
    {
      "id": "DN_001_block_disambiguation_when_hard_scoped",
      "description": "If scope has a hard allowlist (explicit filename/docId or hard lock), do not disambiguate across other docs.",
      "triggerIf": {
        "any": [
          "scope.hard.docIdAllowlist.exists == true",
          "scope.hard.filenameMustContain.exists == true",
          "state.activeDocRef.lockType == 'hard'"
        ]
      },
      "action": {
        "type": "force_mode",
        "mode": "doc_grounded_single_or_scoped_not_found",
        "reasonCode": "hard_scope_blocks_disambiguation"
      }
    },
    {
      "id": "DN_002_block_disambiguation_for_nav_pills",
      "description": "If operator is open/locate_file/locate_docs, prefer nav_pills rather than disambiguation prompts in body.",
      "triggerIf": {
        "any": [
          "operator == 'open'",
          "operator == 'locate_file'",
          "operator == 'locate_docs'",
          "signals.navQuery == true"
        ]
      },
      "action": {
        "type": "force_mode",
        "mode": "nav_pills",
        "reasonCode": "nav_intent_blocks_disambiguation"
      }
    },
    {
      "id": "DN_003_conversation_only_blocks_disambiguation",
      "description": "Short conversational utterances should not trigger a doc-choice UI.",
      "triggerIfMatchesAny": {
        "en": ["^\\s*(hi|hello|hey|thanks|thank you|ok|okay|got it|cool)\\s*[!?.]*\\s*$"],
        "pt": ["^\\s*(oi|ol[aá]|obrigado|valeu|ok|certo|entendi)\\s*[!?.]*\\s*$"],
        "es": ["^\\s*(hola|gracias|ok|vale|entendido|bien)\\s*[!?.]*\\s*$"]
      },
      "action": {
        "type": "force_mode",
        "mode": "conversation",
        "reasonCode": "conversation_only"
      }
    },
    {
      "id": "DN_004_versions_only_should_autopick_latest",
      "description": "If candidates differ only by weak version tokens (final/v2/draft), autopick newest unless user asked for a specific version.",
      "triggerIf": {
        "all": [
          "docContext.candidateCount >= 2",
          "docContext.candidatesDifferOnlyByWeakTokens == true",
          "signals.userSpecifiedVersion != true"
        ]
      },
      "action": {
        "type": "prefer_autopick",
        "strategy": "newest_upload",
        "reasonCode": "version_tokens_only_autopick_newest"
      }
    },
    {
      "id": "DN_005_inside_doc_query_should_not_disambiguate_docs",
      "description": "If the user asks 'where is X mentioned' and we have an active doc, prefer locate_content inside that doc.",
      "triggerIfMatchesAny": {
        "en": ["\\bwhere\\b.{0,40}\\bmentioned\\b", "\\bfind all mentions\\b", "\\bon which page\\b"],
        "pt": ["\\bonde\\b.{0,40}\\bmencionad\\b", "\\bencontre todas as men[cç][oõ]es\\b", "\\bem qual p[aá]gina\\b"],
        "es": ["\\bd[oó]nde\\b.{0,40}\\bmenciona\\b", "\\bencuentra todas las menciones\\b", "\\ben qu[eé] p[aá]gina\\b"]
      },
      "triggerIfAlso": "state.activeDocRef.present == true AND signals.hasExplicitDocRef != true",
      "action": {
        "type": "redirect_preference",
        "preferredOperator": "locate_content",
        "preferredScope": "active_doc_soft",
        "reasonCode": "inside_doc_prefer_active_doc"
      }
    },
    {
      "id": "DN_006_margin_low_only_then_disambiguate",
      "description": "Only disambiguate when ranking margin is actually low; otherwise autopick for speed (ChatGPT-like).",
      "triggerIf": {
        "all": [
          "docContext.candidateCount >= 2",
          "docContext.topScore >= 0.70",
          "docContext.margin >= 0.08"
        ]
      },
      "action": {
        "type": "prefer_autopick",
        "strategy": "top_score",
        "reasonCode": "margin_high_autopick"
      }
    }
  ],
  "outputs": {
    "_comment": "Optional debug trace for why disambiguation was suppressed.",
    "shape": {
      "forcedMode": "string|optional",
      "preferredOperator": "string|optional",
      "reasonCodes": "string[]|optional"
    }
  },
  "tests": {
    "cases": [
      {
        "id": "DN_T001_hard_scope_blocks_disambiguation",
        "scope": { "hard": { "docIdAllowlist": ["doc:only"] } },
        "docContext": { "candidateCount": 3 },
        "expect": { "forcedMode": "doc_grounded_single_or_scoped_not_found" }
      },
      {
        "id": "DN_T002_nav_intent_blocks_disambiguation",
        "operator": "open",
        "docContext": { "candidateCount": 3 },
        "expect": { "forcedMode": "nav_pills" }
      },
      {
        "id": "DN_T003_versions_only_autopick",
        "docContext": { "candidateCount": 2, "candidatesDifferOnlyByWeakTokens": true },
        "signals": { "userSpecifiedVersion": false },
        "expect": { "reasonCodesAny": ["version_tokens_only_autopick_newest"] }
      }
    ]
  }
}
