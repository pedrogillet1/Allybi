{
  "_meta": {
    "id": "patterns_editor_scope_precedence_rules",
    "version": "1.0.0",
    "owner": "editor-patterns",
    "languages": [
      "any"
    ],
    "description": "Machine-actionable editor scope precedence rules: selection-first, explicit target, semantic resolver, then clarify.",
    "usedBy": [
      "editor_scope_resolver",
      "selection_router",
      "tests.patternDeterminism"
    ],
    "tests": {
      "positive": [
        "select range and then apply",
        "no selection but explicit heading target"
      ],
      "negative": [
        "apply to random area",
        "resolve without clarifying missing scope"
      ]
    },
    "lastUpdated": "2026-03-03"
  },
  "config": {
    "enabled": true,
    "deterministic": true,
    "dedupe": true,
    "sortBy": "priority",
    "minPatterns": 40,
    "maxPatterns": 120
  },
  "rules": [
