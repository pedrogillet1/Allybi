        "hasExplicitTarget": false,
        "hasSemanticCandidates": true,
        "isSelectionValid": true,
        "selectionCount": 1,
        "requiresEditorMode": true
      },
      "action": "LOCK_SELECTION",
      "priority": 1000,
      "validSelectionDefinition": {
        "minChars": 1,
        "maxChars": 50000,
        "forbidPartial": false,
        "allowCrossBoundary": true,
        "supportsTable": true
      },
