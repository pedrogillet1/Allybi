{
  "_meta": {
    "id": "patterns_editor_multi_selection_rules",
    "version": "1.0.0",
    "owner": "editor-patterns",
    "languages": [
      "any"
    ],
    "description": "Machine-actionable rules for handling multiple selection targets and clarify-vs-apply-to-all behavior.",
    "usedBy": [
      "editor_scope_resolver",
      "selection_dispatcher",
      "tests.patternDeterminism"
    ],
    "tests": {
      "positive": [
        "select three tables and apply same edit",
        "select all overdue cells and apply"
      ],
      "negative": [
        "select conflicting ranges without consent",
        "apply to mixed target classes without confirmation"
      ]
    },
    "lastUpdated": "2026-03-03"
  },
  "config": {
    "enabled": true,
    "deterministic": true,
    "dedupe": true,
    "sortBy": "priority",
    "minPatterns": 40,
    "maxPatterns": 120
  },
  "rules": [
    {
      "id": "MS_0001",
      "trigger": "editor.multi_selection",
      "check": {
        "minSelections": 2,
        "selectionCount": 1,
        "allSelectionsParsed": false,
        "hasUniformScope": true,
        "hasConflictingTargets": false,
        "appliesAcrossPages": true,
        "appliesAcrossTables": true,
        "appliesAcrossCharts": true,
        "allowsBatchEdit": true
      },
      "action": "APPLY_TO_ALL",
      "priority": 850,
      "examples": [
        "apply action to 1 selected targets",
        "if 1 targets conflict -> apply to all"
      ]
    },
