{
  "_meta": {
    "id": "editing_schema",
    "version": "1.0.0",
    "description": "Validation schema for editing routing decisions and edit orchestration payloads/results.",
    "languages": ["any"],
    "lastUpdated": "2026-02-07"
  },
  "config": {
    "enabled": true
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "editing.schema.json",
  "title": "Editing Contracts",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/EditingRoutingDecision"
    },
    {
      "$ref": "#/$defs/EditPlanRequest"
    },
    {
      "$ref": "#/$defs/EditPreviewResult"
    },
    {
      "$ref": "#/$defs/EditApplyRequest"
    },
    {
      "$ref": "#/$defs/EditApplyResult"
    },
    {
      "$ref": "#/$defs/EditPatch"
    },
    {
      "$ref": "#/$defs/UndoRequest"
    }
  ],
  "$defs": {
    "EditIntent": {
      "type": "string",
      "enum": [
        "EDITING"
      ]
    },
    "EditDomain": {
      "type": "string",
      "enum": [
        "docx",
        "sheets",
        "slides"
      ]
    },
    "EditScope": {
      "type": "string",
      "enum": [
        "workspace",
        "documents"
      ]
    },
    "EditOperator": {
      "type": "string",
      "enum": [
        "EDIT_PARAGRAPH",
        "EDIT_CELL",
        "EDIT_RANGE",
        "ADD_SHEET",
        "RENAME_SHEET",
        "CREATE_CHART",
        "ADD_SLIDE",
        "REWRITE_SLIDE_TEXT",
        "REPLACE_IMAGE",
        "DELETE_ROW",
        "DELETE_COLUMN",
        "DELETE_SHEET",
        "DELETE_SLIDE",
        "MOVE_COLUMN"
      ]
    },
    "TargetCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "score"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        }
      }
    },
    "EditingRoutingDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "operator",
        "domain",
        "scope",
        "confidence",
        "reasonCodes",
        "databanksUsed"
      ],
      "properties": {
        "intent": {
          "$ref": "#/$defs/EditIntent"
        },
        "operator": {
          "$ref": "#/$defs/EditOperator"
        },
        "domain": {
          "$ref": "#/$defs/EditDomain"
        },
        "scope": {
          "$ref": "#/$defs/EditScope"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "databanksUsed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "EditPlanRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "userInstruction",
        "routing"
      ],
      "properties": {
        "userInstruction": {
          "type": "string",
          "minLength": 1
        },
        "routing": {
          "$ref": "#/$defs/EditingRoutingDecision"
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preserveNumbers": {
              "type": "boolean"
            },
            "preserveEntities": {
              "type": "boolean"
            },
            "styleTarget": {
              "type": "string",
              "enum": [
                "formal",
                "casual",
                "professional",
                "neutral"
              ]
            },
            "language": {
              "type": "string",
              "enum": [
                "en",
                "pt"
              ]
            },
            "strictMode": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "DiffSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "unchanged",
            "inserted",
            "deleted",
            "replaced"
          ]
        },
        "before": {
          "type": "string"
        },
        "after": {
          "type": "string"
        }
      }
    },
    "EditPreviewResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planId",
        "previewId",
        "blocks",
        "requiresConfirmation",
        "reasonCodes"
      ],
      "properties": {
        "planId": {
          "type": "string",
          "minLength": 1
        },
        "previewId": {
          "type": "string",
          "minLength": 1
        },
        "requiresConfirmation": {
          "type": "boolean"
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target",
            "diff",
            "why",
            "proof",
            "actions"
          ],
          "properties": {
            "target": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "label",
                "confidence"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "candidates": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/TargetCandidate"
                  }
                }
              }
            },
            "diff": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "summary",
                "segments"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "paragraph",
                    "cell",
                    "slide_text",
                    "structural"
                  ]
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "segments": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/DiffSegment"
                  },
                  "maxItems": 200
                },
                "before": {
                  "type": "string"
                },
                "after": {
                  "type": "string"
                }
              }
            },
            "why": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reasons",
                "preserved",
                "riskLevel"
              ],
              "properties": {
                "reasons": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "preserved": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "styleMatched": {
                  "type": "string"
                },
                "riskLevel": {
                  "type": "string",
                  "enum": [
                    "LOW",
                    "MED",
                    "HIGH"
                  ]
                }
              }
            },
            "proof": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "sourceType",
                  "label",
                  "value"
                ],
                "properties": {
                  "sourceType": {
                    "type": "string",
                    "enum": [
                      "target_excerpt",
                      "retrieval_chunk",
                      "policy_check",
                      "validator"
                    ]
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "value": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "actions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "type",
                  "label"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "confirm",
                      "cancel",
                      "pick_target",
                      "undo",
                      "open_doc",
                      "go_to_location",
                      "export"
                    ]
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "payload": {
                    "type": "object",
                    "additionalProperties": {
                      "type": [
                        "string",
                        "number",
                        "boolean"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "EditApplyRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planId",
        "previewId",
        "confirmed"
      ],
      "properties": {
        "planId": {
          "type": "string",
          "minLength": 1
        },
        "previewId": {
          "type": "string",
          "minLength": 1
        },
        "confirmed": {
          "type": "boolean"
        },
        "selectedTargetId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "EditApplyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applied",
        "receiptActions",
        "reasonCodes"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "revision": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "documentId",
            "revisionId"
          ],
          "properties": {
            "documentId": {
              "type": "string",
              "minLength": 1
            },
            "revisionId": {
              "type": "string",
              "minLength": 1
            },
            "previousRevisionId": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "receiptActions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "confirm",
                  "cancel",
                  "pick_target",
                  "undo",
                  "open_doc",
                  "go_to_location",
                  "export"
                ]
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "payload": {
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "string",
                    "number",
                    "boolean"
                  ]
                }
              }
            }
          }
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "EditPatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "operator"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": [
            "docx",
            "sheets",
            "slides"
          ]
        },
        "operator": {
          "$ref": "#/$defs/EditOperator"
        },
        "docx": {
          "type": "object",
          "additionalProperties": false,
          "required": [],
          "properties": {
            "paragraphId": {
              "type": "string",
              "minLength": 1
            },
            "newText": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "sheets": {
          "type": "object",
          "additionalProperties": false,
          "required": [],
          "properties": {
            "sheetName": {
              "type": "string",
              "minLength": 1
            },
            "a1": {
              "type": "string",
              "minLength": 1
            },
            "rangeA1": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            },
            "values": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": [
                    "string",
                    "number",
                    "boolean",
                    "null"
                  ]
                }
              }
            }
          }
        },
        "slides": {
          "type": "object",
          "additionalProperties": false,
          "required": [],
          "properties": {
            "objectId": {
              "type": "string",
              "minLength": 1
            },
            "newText": {
              "type": "string",
              "minLength": 1
            },
            "imageObjectId": {
              "type": "string",
              "minLength": 1
            },
            "imageUrl": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "domain": {
                "const": "docx"
              }
            },
            "required": [
              "domain"
            ]
          },
          "then": {
            "properties": {
              "docx": {
                "required": [
                  "paragraphId",
                  "newText"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "domain": {
                "const": "sheets"
              }
            },
            "required": [
              "domain"
            ]
          },
          "then": {
            "properties": {
              "sheets": {
                "anyOf": [
                  {
                    "required": [
                      "sheetName",
                      "a1",
                      "value"
                    ]
                  },
                  {
                    "required": [
                      "rangeA1",
                      "values"
                    ]
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "domain": {
                "const": "slides"
              }
            },
            "required": [
              "domain"
            ]
          },
          "then": {
            "properties": {
              "slides": {
                "anyOf": [
                  {
                    "required": [
                      "objectId",
                      "newText"
                    ]
                  },
                  {
                    "required": [
                      "imageObjectId",
                      "imageUrl"
                    ]
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "UndoRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documentId",
        "revisionId"
      ],
      "properties": {
        "documentId": {
          "type": "string",
          "minLength": 1
        },
        "revisionId": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
