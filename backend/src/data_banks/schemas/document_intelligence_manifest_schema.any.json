{
  "_meta": {
    "id": "document_intelligence_manifest_schema",
    "version": "1.0.0",
    "description": "Schema for document intelligence manifest family banks (schema registry, dependency graph, usage manifest, orphan allowlist, runtime wiring gates).",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "koda://schemas/document_intelligence_manifest_schema.any.json",
    "title": "Document Intelligence Manifest Schema",
    "type": "object",
    "required": [
      "_meta",
      "config"
    ],
    "additionalProperties": true,
    "properties": {
      "_meta": {
        "type": "object",
        "required": [
          "id",
          "version",
          "description",
          "languages",
          "lastUpdated"
        ],
        "additionalProperties": true
      },
      "config": {
        "type": "object",
        "required": [
          "enabled"
        ],
        "additionalProperties": true
      },
      "schemaFamilies": {
        "type": "array"
      },
      "schemaAssignments": {
        "type": "array"
      },
      "banks": {
        "type": "array"
      },
      "runtimeConsumers": {
        "type": "array"
      },
      "consumedBankIds": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "consumedIdPrefixes": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "consumedIdPatterns": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "allowlistedBankIds": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "allowlistedIdPrefixes": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "allowlistedIdPatterns": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "gates": {
        "type": "array"
      }
    },
    "anyOf": [
      {
        "required": [
          "schemaFamilies"
        ]
      },
      {
        "required": [
          "banks"
        ]
      },
      {
        "required": [
          "runtimeConsumers",
          "consumedBankIds"
        ]
      },
      {
        "required": [
          "allowlistedBankIds"
        ]
      },
      {
        "required": [
          "gates"
        ]
      }
    ]
  }
}
