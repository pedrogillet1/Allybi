{
  "_meta": {
    "id": "domain_profile_schema",
    "version": "1.0.0",
    "description": "Schema for document intelligence domain profile banks. Requires domain, displayName, scope, coreConcepts, supportedOperators.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-27",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "koda://schemas/domain_profile_schema.any.json",
    "title": "Domain Profile Bank Schema",
    "type": "object",
    "required": [
      "_meta",
      "config",
      "domain",
      "displayName",
      "scope",
      "coreConcepts",
      "supportedOperators"
    ],
    "additionalProperties": true,
    "properties": {
      "_meta": {
        "type": "object",
        "required": [
          "id",
          "version",
          "description",
          "languages",
          "lastUpdated"
        ],
        "additionalProperties": true
      },
      "config": {
        "type": "object",
        "required": [
          "enabled"
        ],
        "additionalProperties": true
      },
      "domain": {
        "type": "string",
        "minLength": 2
      },
      "displayName": {
        "type": "string",
        "minLength": 2
      },
      "scope": {
        "type": "string",
        "minLength": 8
      },
      "coreConcepts": {
        "type": "array",
        "minItems": 1
      },
      "supportedOperators": {
        "type": "array",
        "minItems": 1
      },
      "detectionSignals": {
        "type": "array"
      },
      "relatedDomains": {
        "type": "array"
      },
      "ontologyPrefix": {
        "type": "string"
      }
    }
  }
}
