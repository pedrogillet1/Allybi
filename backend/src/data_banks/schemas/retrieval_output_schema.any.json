{
  "_meta": {
    "id": "retrieval_output_schema",
    "version": "1.0.0",
    "description": "Schema-level guard for retrieval output that keeps result lists dense, clamps confidences, blocks empty-result microcopy (e.g., forbidden Sources/No relevant information phrases), and enforces explicit-doc alignment so Koda never drifts.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-retrieval",
    "compat": ">=1.0.0",
    "changeLog": [
      "Replaced loose schema with deterministic validation bank",
      "Added banned empty-result phrase guard and attachment enforcement",
      "Added explicit-document regression coverage"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "post_retrieval",
    "purpose": "retrieval_output_schema_validation",
    "expectedShape": {
      "results": {
        "type": "array",
        "minItems": 1,
        "description": "Ordered list of retrieved documents with confidence and snippet"
      },
      "results[].docId": { "type": "string", "description": "Document identifier" },
      "results[].snippet": { "type": "string", "minLength": 20 },
      "results[].confidence": { "type": "number", "range": [0, 1] },
      "results[].sourceTitle": { "type": "string" },
      "attachments": { "type": "array", "description": "Buttons or files tied to results" },
      "responseText": { "type": "string" }
    },
    "variationControl": {
      "entropyWindow": 4,
      "cooldownTurns": 2,
      "dedupeBy": ["retrievalTemplateId", "userIntent"]
    },
    "actionsContract": {
      "combination": {
        "multipleMatches": "sum_then_cap",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "hardBlockThreshold": 0.85,
        "softPenaltyThreshold": 0.35,
        "maxPenaltyPerTest": 0.3
      },
      "conflictResolution": {
        "ifHardBlockAndRedirect": "hard_block",
        "ifMultipleRedirects": "pick_highest_confidence"
      }
    },
    "integrationHooks": {
      "dependsOn": ["semantic_search_config", "candidate_filters_schema", "scope_output_schema"],
      "emitsSignals": [
        "retrievalResultsMissing",
        "retrievalConfidenceClamped",
        "retrievalBannedPhraseBlocked",
        "retrievalAttachmentsRequired",
        "retrievalExplicitDocMatched"
      ]
    }
  },
  "rules": [
    {
      "id": "retrieval_results_presence",
      "scope": "global",
      "description": "Reject retrieval outputs with no results so the user never sees an empty pill.",
      "appliesTo": ["retrieval_output"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "any": [
          { "path": "output.results", "op": "not_exists", "value": true },
          { "path": "metrics.resultsCount", "op": "lt", "value": 1 }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["retrievalResultsMissing"]
      },
      "reasonCode": "retrieval_results_missing",
      "severity": "high"
    },
    {
      "id": "retrieval_confidence_clamped",
      "scope": "global",
      "description": "Clamp result confidences to [0,1] to keep downstream scoring deterministic.",
      "appliesTo": ["retrieval_output"],
      "triggerPatterns": {
        "en": ["\\bconfidence\\b"],
        "pt": ["\\bconfiança\\b"],
        "es": ["\\bconfianza\\b"]
      },
      "when": {
        "any": [
          { "path": "output.results[].confidence", "op": "lt", "value": 0 },
          { "path": "output.results[].confidence", "op": "gt", "value": 1 }
        ]
      },
      "action": {
        "type": "clamp_collection_field",
        "field": "output.results[].confidence",
        "min": 0,
        "max": 1,
        "emitSignals": ["retrievalConfidenceClamped"]
      },
      "reasonCode": "retrieval_confidence_clamped",
      "severity": "medium"
    },
    {
      "id": "retrieval_banned_empty_phrase_blocked",
      "scope": "global",
      "description": "Block banned empty-result microcopy such as 'No relevant information found' or 'Sem informações relevantes'.",
      "appliesTo": ["retrieval_output"],
      "triggerPatterns": {
        "en": ["No relevant information found", "Sources:"],
        "pt": ["Sem informações relevantes", "Fontes:"],
        "es": ["Sin información relevante", "Fuentes:"]
      },
      "when": {
        "any": [
          { "path": "signals.responseText", "op": "matches", "value": "No relevant information found" },
          { "path": "signals.responseText", "op": "matches", "value": "Sem informações relevantes" },
          { "path": "signals.responseText", "op": "matches", "value": "Sin información relevante" }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["retrievalBannedPhraseBlocked"]
      },
      "reasonCode": "retrieval_banned_empty_phrase",
      "severity": "critical"
    },
    {
      "id": "retrieval_attachments_required",
      "scope": "global",
      "description": "If the intent requests files, there must be attachments instead of inline text.",
      "appliesTo": ["retrieval_output"],
      "triggerPatterns": {
        "en": ["\\bfile(s)?\\b"],
        "pt": ["\\barquiv(o|os)\\b"],
        "es": ["\\barchivo(s)?\\b"]
      },
      "when": {
        "all": [
          { "path": "signals.expectAttachments", "op": "eq", "value": true },
          { "path": "output.attachments", "op": "not_exists", "value": true }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["retrievalAttachmentsRequired"]
      },
      "reasonCode": "retrieval_attachments_required",
      "severity": "high"
    },
    {
      "id": "retrieval_explicit_doc_match",
      "scope": "global",
      "description": "Ensure the first retrieval result matches an explicitly mentioned filename/document to avoid drift.",
      "appliesTo": ["retrieval_output"],
      "triggerPatterns": {
        "en": ["\\bfilename\\b"],
        "pt": ["\\barquivo\\b"],
        "es": ["\\barquivo\\b"]
      },
      "when": {
        "all": [
          { "path": "signals.explicitDocMentioned", "op": "eq", "value": true },
          { "path": "output.results[0].docId", "op": "neq", "value": "signals.explicitDocId" }
        ]
      },
      "action": {
        "type": "override_result_order",
        "field": "output.results",
        "matchKey": "docId",
        "source": "signals.explicitDocId",
        "emitSignals": ["retrievalExplicitDocMatched"]
      },
      "reasonCode": "retrieval_explicit_doc_mismatch_corrected",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "RO_0001_happy_path",
        "context": {
          "signals": { "userIntent": "answer", "explicitDocMentioned": false },
          "output": {
            "results": [
              { "docId": "doc:budget", "snippet": "Q2 funding trends", "confidence": 0.82 },
              { "docId": "doc:plan", "snippet": "Strategy details", "confidence": 0.65 }
            ],
            "attachments": [],
            "responseText": "Here are two relevant documents."
          },
          "metrics": { "resultsCount": 2 }
        },
        "expect": { "retrievalValidated": true }
      },
      {
        "id": "RO_0002_non_trigger_mode",
        "context": {
          "signals": { "userIntent": "chitchat" },
          "output": { "results": [], "attachments": [], "responseText": "Just saying hi.", "metrics": { "resultsCount": 0 } }
        },
        "expect": { "noRetrievalRuleMatched": true }
      },
      {
        "id": "RO_0003_zero_results_collision",
        "context": {
          "signals": { "userIntent": "answer" },
          "output": { "results": [], "responseText": "I have nothing.", "attachments": [] },
          "metrics": { "resultsCount": 0 }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "retrieval_results_missing"
        }
      },
      {
        "id": "RO_0004_pt_banned_phrase_blocked",
        "context": {
          "signals": { "responseText": "Sem informações relevantes para o pedido", "userIntent": "answer", "language": "pt" },
          "output": { "results": [], "attachments": [] },
          "metrics": { "resultsCount": 0 }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "retrieval_banned_empty_phrase"
        }
      },
      {
        "id": "RO_0005_attachment_expected",
        "context": {
          "signals": { "expectAttachments": true, "userIntent": "answer" },
          "output": { "results": [{ "docId": "doc:file", "snippet": "File preview", "confidence": 0.9 }], "attachments": [] }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "retrieval_attachments_required"
        }
      },
      {
        "id": "RO_0006_explicit_doc_regression",
        "context": {
          "signals": { "explicitDocMentioned": true, "explicitDocId": "doc:Q1", "language": "en" },
          "output": {
            "results": [
              { "docId": "doc:other", "snippet": "Wrong doc", "confidence": 0.9 },
              { "docId": "doc:Q1", "snippet": "Correct doc", "confidence": 0.6 }
            ]
          },
          "metrics": { "resultsCount": 2 }
        },
        "expect": {
          "retrievalExplicitDocMatched": true,
          "reasonCode": "retrieval_explicit_doc_mismatch_corrected"
        }
      }
    ]
  }
}
