{
  "_meta": {
    "id": "evidence_requirements_schema",
    "version": "1.0.0",
    "description": "Schema for document intelligence evidence requirements banks. Requires domain, evidenceHierarchy, and rules.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-27",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "koda://schemas/evidence_requirements_schema.any.json",
    "title": "Evidence Requirements Bank Schema",
    "type": "object",
    "required": [
      "_meta",
      "config",
      "domain"
    ],
    "additionalProperties": true,
    "properties": {
      "_meta": {
        "type": "object",
        "required": [
          "id",
          "version",
          "description",
          "languages",
          "lastUpdated"
        ],
        "additionalProperties": true
      },
      "config": {
        "type": "object",
        "required": [
          "enabled"
        ],
        "additionalProperties": true
      },
      "domain": {
        "type": "string",
        "minLength": 2
      },
      "evidenceHierarchy": {
        "type": "array",
        "minItems": 1
      },
      "rules": {
        "type": "array",
        "minItems": 1
      }
    },
    "anyOf": [
      {
        "required": [
          "evidenceHierarchy"
        ]
      },
      {
        "required": [
          "rules"
        ]
      }
    ]
  }
}
