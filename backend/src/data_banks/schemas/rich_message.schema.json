{
  "_meta": {
    "id": "rich_message_schema",
    "version": "1.0.0",
    "description": "Schema for structured chat responses as blocks[]. Used for stable UX across editing/connectors/creative.",
    "languages": ["any"],
    "lastUpdated": "2026-02-07"
  },
  "config": {
    "enabled": true
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rich_message.schema.json",
  "title": "RichMessage",
  "type": "object",
  "additionalProperties": false,
  "required": ["blocks"],
  "properties": {
    "blocks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": { "$ref": "#/$defs/Block" }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "BlockType": {
      "type": "string",
      "enum": [
        "status",
        "text",
        "bullets",
        "table",
        "citations",
        "target",
        "diff",
        "why",
        "proof",
        "actions",
        "choices",
        "preview"
      ]
    },

    "Block": {
      "oneOf": [
        { "$ref": "#/$defs/StatusBlock" },
        { "$ref": "#/$defs/TextBlock" },
        { "$ref": "#/$defs/BulletsBlock" },
        { "$ref": "#/$defs/TableBlock" },
        { "$ref": "#/$defs/CitationsBlock" },
        { "$ref": "#/$defs/TargetBlock" },
        { "$ref": "#/$defs/DiffBlock" },
        { "$ref": "#/$defs/WhyBlock" },
        { "$ref": "#/$defs/ProofBlock" },
        { "$ref": "#/$defs/ActionsBlock" },
        { "$ref": "#/$defs/ChoicesBlock" },
        { "$ref": "#/$defs/PreviewBlock" }
      ]
    },

    "StatusBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "stage"],
      "properties": {
        "type": { "const": "status" },
        "stage": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "message": { "type": "string", "maxLength": 240 }
      }
    },

    "TextBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "text" },
        "text": { "type": "string", "minLength": 1, "maxLength": 8000 }
      }
    },

    "BulletsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "bullets" },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "items": { "type": "string", "minLength": 1, "maxLength": 800 }
        }
      }
    },

    "TableBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "headers", "rows"],
      "properties": {
        "type": { "const": "table" },
        "caption": { "type": "string", "maxLength": 240 },
        "headers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "maxItems": 80,
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "items": { "type": "string", "maxLength": 800 }
          }
        }
      }
    },

    "Citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "sourceId", "timestamp"],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["doc", "gmail", "outlook", "slack"]
        },
        "sourceId": { "type": "string", "minLength": 1, "maxLength": 200 },
        "timestamp": { "type": "string", "format": "date-time" },
        "title": { "type": "string", "maxLength": 200 },
        "subject": { "type": "string", "maxLength": 200 },
        "from": { "type": "string", "maxLength": 200 },
        "channel": { "type": "string", "maxLength": 120 },
        "threadId": { "type": "string", "maxLength": 200 },
        "permalink": { "type": "string", "format": "uri" },
        "snippet": { "type": "string", "maxLength": 500 }
      }
    },

    "CitationsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "citations" },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/Citation" }
        }
      }
    },

    "TargetCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "score"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 200 },
        "label": { "type": "string", "minLength": 1, "maxLength": 240 },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasons": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        }
      }
    },

    "TargetBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "confidence"],
      "properties": {
        "type": { "const": "target" },
        "label": { "type": "string", "minLength": 1, "maxLength": 240 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "candidates": {
          "type": "array",
          "maxItems": 4,
          "items": { "$ref": "#/$defs/TargetCandidate" }
        }
      }
    },

    "DiffSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["unchanged", "inserted", "deleted", "replaced"]
        },
        "before": { "type": "string", "maxLength": 2000 },
        "after": { "type": "string", "maxLength": 2000 }
      }
    },

    "DiffBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "kind", "summary", "segments"],
      "properties": {
        "type": { "const": "diff" },
        "kind": {
          "type": "string",
          "enum": ["paragraph", "cell", "slide_text", "structural"]
        },
        "summary": { "type": "string", "minLength": 1, "maxLength": 300 },
        "segments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 200,
          "items": { "$ref": "#/$defs/DiffSegment" }
        },
        "before": { "type": "string", "maxLength": 8000 },
        "after": { "type": "string", "maxLength": 8000 },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        }
      }
    },

    "WhyBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reasons", "preserved", "riskLevel"],
      "properties": {
        "type": { "const": "why" },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        },
        "preserved": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        },
        "styleMatched": { "type": "string", "maxLength": 120 },
        "riskLevel": {
          "type": "string",
          "enum": ["LOW", "MED", "HIGH"]
        }
      }
    },

    "ProofItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "label", "value"],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["target_excerpt", "retrieval_chunk", "policy_check", "validator"]
        },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "value": { "type": "string", "minLength": 1, "maxLength": 1200 }
      }
    },

    "ProofBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "proof" },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/ProofItem" }
        }
      }
    },

    "Action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 48
        },
        "label": { "type": "string", "minLength": 1, "maxLength": 48 },
        "payload": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        }
      }
    },

    "ActionsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "actions" },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": { "$ref": "#/$defs/Action" }
        }
      }
    },

    "ChoiceOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 200 },
        "label": { "type": "string", "minLength": 1, "maxLength": 240 },
        "payload": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        }
      }
    },

    "ChoicesBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "prompt", "options"],
      "properties": {
        "type": { "const": "choices" },
        "prompt": { "type": "string", "minLength": 1, "maxLength": 240 },
        "options": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/ChoiceOption" }
        }
      }
    },

    "PreviewBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "assetUrl"],
      "properties": {
        "type": { "const": "preview" },
        "assetUrl": { "type": "string", "format": "uri" },
        "thumbUrl": { "type": "string", "format": "uri" },
        "width": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "height": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "aspectRatio": { "type": "string", "maxLength": 16 },
        "palette": {
          "type": "array",
          "maxItems": 12,
          "items": { "type": "string", "pattern": "^#([0-9A-Fa-f]{6})$" }
        },
        "styleMode": { "type": "string", "maxLength": 40 }
      }
    }
  }
}
