{
  "_meta": {
    "id": "reasoning_policy_schema",
    "version": "1.0.0",
    "description": "Schema for reasoning policy banks (assumptions, decision support, explain styles).",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "koda://schemas/reasoning_policy_schema.any.json",
    "title": "Reasoning Policy Schema",
    "type": "object",
    "required": [
      "_meta",
      "config"
    ],
    "additionalProperties": true,
    "properties": {
      "_meta": {
        "type": "object",
        "required": [
          "id",
          "version",
          "description",
          "languages",
          "lastUpdated"
        ],
        "additionalProperties": true
      },
      "config": {
        "type": "object",
        "required": [
          "enabled"
        ],
        "additionalProperties": true
      },
      "rules": {
        "type": "array"
      },
      "templates": {
        "type": "array"
      },
      "optionsFramework": {
        "type": "array"
      }
    },
    "anyOf": [
      {
        "required": [
          "rules"
        ]
      },
      {
        "required": [
          "templates"
        ]
      },
      {
        "required": [
          "optionsFramework"
        ]
      }
    ]
  }
}
