{
  "_meta": {
    "id": "evidence_schema",
    "version": "1.0.0",
    "description": "Evidence output validation bank ensuring every block ties back to a document, coordinates with retrieval_schema, clamps relevance scores, and keeps banned empty-result phrases out of highlights.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-retrieval",
    "compat": ">=1.0.0",
    "changeLog": [
      "Elevated evidence schema to deterministic bank",
      "Added doc-id requirement and relevance clamps",
      "Added banned-phrase regression coverage"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "post_evidence_generation",
    "purpose": "evidence_schema_validation",
    "expectedShape": {
      "evidenceBlocks": {
        "type": "array",
        "minItems": 1,
        "description": "Ordered evidence highlights"
      },
      "evidenceBlocks[].docId": { "type": "string" },
      "evidenceBlocks[].highlight": { "type": "string", "minLength": 30 },
      "evidenceBlocks[].excerpts": { "type": "string" },
      "evidenceBlocks[].relevanceScore": { "type": "number", "range": [0, 1] },
      "responseConfidence": { "type": "number", "range": [0, 1] }
    },
    "variationControl": {
      "entropyWindow": 3,
      "cooldownTurns": 2,
      "dedupeBy": ["evidenceTemplateId", "queryHash"]
    },
    "actionsContract": {
      "combination": {
        "multipleMatches": "sum_then_cap",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "hardBlockThreshold": 0.85,
        "softPenaltyThreshold": 0.35,
        "maxPenaltyPerTest": 0.3
      },
      "conflictResolution": {
        "ifHardBlockAndRedirect": "hard_block",
        "ifMultipleRedirects": "pick_highest_confidence"
      }
    },
    "integrationHooks": {
      "dependsOn": ["retrieval_output_schema", "scope_output_schema"],
      "emitsSignals": [
        "evidenceDocIdEnforced",
        "evidenceRelevanceClamped",
        "evidenceBannedPhraseBlocked",
        "evidenceHighlightLengthened",
        "evidenceTitlePresent"
      ]
    }
  },
  "rules": [
    {
      "id": "evidence_blocks_require_doc_id",
      "scope": "global",
      "description": "Every evidence block must reference a docId to keep provenance tight.",
      "appliesTo": ["evidence_output"],
      "triggerPatterns": {
        "en": ["\\bdocId\\b"],
        "pt": ["\\bdOCID\\b"],
        "es": ["\\bidDocumento\\b"]
      },
      "when": {
        "any": [
          { "path": "output.evidenceBlocks[].docId", "op": "not_exists", "value": true }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["evidenceDocIdEnforced"]
      },
      "reasonCode": "evidence_blocks_missing_doc_id",
      "severity": "high"
    },
    {
      "id": "evidence_relevance_clamped",
      "scope": "global",
      "description": "Clamp block relevance scores to [0,1] so downstream ranking remains sane.",
      "appliesTo": ["evidence_output"],
      "triggerPatterns": {
        "en": ["\\brelevance\\b"],
        "pt": ["\\brelevância\\b"],
        "es": ["\\brelevancia\\b"]
      },
      "when": {
        "any": [
          { "path": "output.evidenceBlocks[].relevanceScore", "op": "lt", "value": 0 },
          { "path": "output.evidenceBlocks[].relevanceScore", "op": "gt", "value": 1 }
        ]
      },
      "action": {
        "type": "clamp_collection_field",
        "field": "output.evidenceBlocks[].relevanceScore",
        "min": 0,
        "max": 1,
        "emitSignals": ["evidenceRelevanceClamped"]
      },
      "reasonCode": "evidence_relevance_clamped",
      "severity": "medium"
    },
    {
      "id": "evidence_banned_phrase_highlight_blocked",
      "scope": "global",
      "description": "Block highlights containing banned empty-result phrases so users never see them twice.",
      "appliesTo": ["evidence_output"],
      "triggerPatterns": {
        "en": ["No relevant information found", "Sources:"],
        "pt": ["Sem informações relevantes", "Fontes:"],
        "es": ["Sin información relevante", "Fuentes:"]
      },
      "when": {
        "any": [
          { "path": "output.evidenceBlocks[].highlight", "op": "matches", "value": "No relevant information found" },
          { "path": "output.evidenceBlocks[].highlight", "op": "matches", "value": "Sem informações relevantes" }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["evidenceBannedPhraseBlocked"]
      },
      "reasonCode": "evidence_banned_phrase_blocked",
      "severity": "critical"
    },
    {
      "id": "evidence_highlight_length_guard",
      "scope": "global",
      "description": "Enforce highlights have at least 30 characters so evidence is substantive.",
      "appliesTo": ["evidence_output"],
      "triggerPatterns": {
        "en": ["\\bhighlight\\b"],
        "pt": ["\\bdestaque\\b"],
        "es": ["\\bdestacado\\b"]
      },
      "when": {
        "any": [
          { "path": "output.evidenceBlocks[].highlight", "op": "length", "value": 0, "modifier": "lt", "threshold": 30 }
        ]
      },
      "action": {
        "type": "extend_highlight",
        "minLength": 30,
        "emitSignals": ["evidenceHighlightLengthened"]
      },
      "reasonCode": "evidence_highlight_too_short",
      "severity": "medium"
    },
    {
      "id": "evidence_source_title_required",
      "scope": "global",
      "description": "Every evidence block needs a source title for traceability.",
      "appliesTo": ["evidence_output"],
      "triggerPatterns": {
        "en": ["\\bsource title\\b"],
        "pt": ["\\btítulo da fonte\\b"],
        "es": ["\\btítulo de la fuente\\b"]
      },
      "when": {
        "any": [
          { "path": "output.evidenceBlocks[].sourceTitle", "op": "not_exists", "value": true }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["evidenceTitlePresent"]
      },
      "reasonCode": "evidence_source_title_missing",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "EV_0001_happy_path",
        "context": {
          "signals": { "expectEvidence": true, "userIntent": "answer" },
          "output": {
            "evidenceBlocks": [
              {
                "docId": "doc:budget",
                "highlight": "Budget trends show a 12% increase in Q1 revenue across sales and services, anchored by product X.",
                "excerpts": "Detailed table includes metrics.",
                "relevanceScore": 0.88,
                "sourceTitle": "Budget Q1"
              }
            ],
            "responseConfidence": 0.78
          }
        },
        "expect": { "evidenceValidated": true }
      },
      {
        "id": "EV_0002_non_trigger_mode",
        "context": {
          "signals": { "userIntent": "chitchat" },
          "output": { "evidenceBlocks": [], "responseConfidence": 0.4 }
        },
        "expect": { "noEvidenceRuleMatched": true }
      },
      {
        "id": "EV_0003_relevance_out_of_bounds",
        "context": {
          "signals": { "expectEvidence": true },
          "output": {
            "evidenceBlocks": [
              {
                "docId": "doc:plan",
                "highlight": "Plan summary.",
                "relevanceScore": 1.2,
                "sourceTitle": "Strategy"
              }
            ],
            "responseConfidence": 0.95
          }
        },
        "expect": {
          "evidenceRelevanceClamped": true,
          "reasonCode": "evidence_relevance_clamped"
        }
      },
      {
        "id": "EV_0004_es_banned_phrase",
        "input": "Necesito la evidencia principal",
        "context": {
          "signals": { "language": "es" },
          "output": {
            "evidenceBlocks": [
              {
                "docId": "doc:es",
                "highlight": "Sin información relevante disponible.",
                "relevanceScore": 0.3,
                "sourceTitle": "Resumen"
              }
            ],
            "responseConfidence": 0.2
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "evidence_banned_phrase_blocked"
        }
      },
      {
        "id": "EV_0005_missing_doc_id",
        "context": {
          "signals": { "expectEvidence": true },
          "output": {
            "evidenceBlocks": [
              {
                "highlight": "Missing doc id highlight.",
                "relevanceScore": 0.5,
                "sourceTitle": "Unknown"
              }
            ],
            "responseConfidence": 0.5
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "evidence_blocks_missing_doc_id"
        }
      },
      {
        "id": "EV_0006_regression_highlight_length",
        "context": {
          "signals": { "expectEvidence": true },
          "output": {
            "evidenceBlocks": [
              {
                "docId": "doc:legacy",
                "highlight": "Too short.",
                "relevanceScore": 0.6,
                "sourceTitle": "Legacy"
              }
            ],
            "responseConfidence": 0.6
          }
        },
        "expect": {
          "evidenceHighlightLengthened": true,
          "reasonCode": "evidence_highlight_too_short"
        }
      }
    ]
  }
}
