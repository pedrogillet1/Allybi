{
  "_meta": {
    "id": "connectors_schema",
    "version": "1.0.0",
    "description": "Validation schema for connectors routing decisions, sync requests, ingestion records, and search results.",
    "languages": ["any"],
    "lastUpdated": "2026-02-07"
  },
  "config": {
    "enabled": true
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "connectors.schema.json",
  "title": "Connectors Contracts",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/ConnectorsRoutingDecision"
    },
    {
      "$ref": "#/$defs/ConnectorSyncRequest"
    },
    {
      "$ref": "#/$defs/ConnectorDocument"
    },
    {
      "$ref": "#/$defs/ConnectorIngestionResult"
    },
    {
      "$ref": "#/$defs/ConnectorSearchResult"
    },
    {
      "$ref": "#/$defs/ConnectorStatus"
    },
    {
      "$ref": "#/$defs/NormalizedEmail"
    },
    {
      "$ref": "#/$defs/NormalizedSlackMessage"
    }
  ],
  "$defs": {
    "ConnectorIntent": {
      "type": "string",
      "enum": [
        "CONNECTORS"
      ]
    },
    "ConnectorProvider": {
      "type": "string",
      "enum": [
        "gmail",
        "outlook",
        "slack"
      ]
    },
    "ConnectorOperator": {
      "type": "string",
      "enum": [
        "CONNECT_START",
        "CONNECTOR_SYNC",
        "CONNECTOR_SEARCH",
        "CONNECTOR_STATUS",
        "CONNECTOR_DISCONNECT"
      ]
    },
    "ConnectorsRoutingDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "operator",
        "domain",
        "scope",
        "provider",
        "confidence",
        "reasonCodes",
        "databanksUsed"
      ],
      "properties": {
        "intent": {
          "$ref": "#/$defs/ConnectorIntent"
        },
        "operator": {
          "$ref": "#/$defs/ConnectorOperator"
        },
        "domain": {
          "type": "string",
          "enum": [
            "connectors"
          ]
        },
        "scope": {
          "type": "string",
          "enum": [
            "connectors"
          ]
        },
        "provider": {
          "oneOf": [
            {
              "$ref": "#/$defs/ConnectorProvider"
            },
            {
              "type": "null"
            }
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "databanksUsed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "ConnectorSyncRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider"
      ],
      "properties": {
        "provider": {
          "$ref": "#/$defs/ConnectorProvider"
        },
        "cursor": {
          "type": "string",
          "minLength": 1
        },
        "backfillDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        }
      }
    },
    "ConnectorActor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ConnectorDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "sourceId",
        "title",
        "body",
        "timestamp",
        "actors",
        "sourceMeta"
      ],
      "properties": {
        "sourceType": {
          "$ref": "#/$defs/ConnectorProvider"
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "actors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ConnectorActor"
          }
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "threadId": {
          "type": "string",
          "minLength": 1
        },
        "sourceMeta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "messageId": {
              "type": "string",
              "minLength": 1
            },
            "threadId": {
              "type": "string",
              "minLength": 1
            },
            "channelId": {
              "type": "string",
              "minLength": 1
            },
            "historyId": {
              "type": "string",
              "minLength": 1
            },
            "conversationTs": {
              "type": "string",
              "minLength": 1
            },
            "permalink": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "ConnectorIngestionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "totalFetched",
        "totalIngested",
        "totalSkipped",
        "reasonCodes"
      ],
      "properties": {
        "provider": {
          "$ref": "#/$defs/ConnectorProvider"
        },
        "totalFetched": {
          "type": "integer",
          "minimum": 0
        },
        "totalIngested": {
          "type": "integer",
          "minimum": 0
        },
        "totalSkipped": {
          "type": "integer",
          "minimum": 0
        },
        "cursor": {
          "type": "string",
          "minLength": 1
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ConnectorCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "sourceId",
        "timestamp"
      ],
      "properties": {
        "sourceType": {
          "$ref": "#/$defs/ConnectorProvider"
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "threadId": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ConnectorSearchResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query",
        "total",
        "items",
        "reasonCodes"
      ],
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "citation",
              "snippet",
              "score"
            ],
            "properties": {
              "citation": {
                "$ref": "#/$defs/ConnectorCitation"
              },
              "snippet": {
                "type": "string",
                "minLength": 1
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ConnectorStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "connected"
      ],
      "properties": {
        "provider": {
          "$ref": "#/$defs/ConnectorProvider"
        },
        "connected": {
          "type": "boolean"
        },
        "lastSyncAt": {
          "type": "string",
          "format": "date-time"
        },
        "cursor": {
          "type": "string",
          "minLength": 1
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "NormalizedEmail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "messageId",
        "timestamp",
        "subject",
        "from",
        "to",
        "bodySnippet"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "gmail",
            "outlook"
          ]
        },
        "messageId": {
          "type": "string",
          "minLength": 1
        },
        "threadId": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "from": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "to": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        },
        "cc": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "hasAttachments": {
          "type": "boolean"
        },
        "bodySnippet": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "body": {
          "type": "string",
          "maxLength": 200000
        },
        "sourceMeta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "permalink": {
              "type": "string",
              "format": "uri"
            },
            "mailbox": {
              "type": "string",
              "maxLength": 120
            }
          }
        }
      }
    },
    "NormalizedSlackMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "channelId",
        "timestamp",
        "text"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "slack"
          ]
        },
        "channelId": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "ts": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "threadTs": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "author": {
          "type": "string",
          "maxLength": 200
        },
        "userId": {
          "type": "string",
          "maxLength": 120
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 12000
        },
        "permalink": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
