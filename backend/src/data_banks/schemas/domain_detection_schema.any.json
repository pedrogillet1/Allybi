{
  "_meta": {
    "id": "domain_detection_schema",
    "version": "1.0.0",
    "description": "Schema for document intelligence domain detection rule banks. Requires domain and non-empty rules array.",
    "languages": ["any"],
    "lastUpdated": "2026-02-27"
  },
  "config": {
    "enabled": true
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "koda://schemas/domain_detection_schema.any.json",
    "title": "Domain Detection Rules Bank Schema",
    "type": "object",
    "required": ["_meta", "config", "domain", "rules"],
    "additionalProperties": true,
    "properties": {
      "_meta": {
        "type": "object",
        "required": ["id", "version", "description", "languages", "lastUpdated"],
        "additionalProperties": true
      },
      "config": {
        "type": "object",
        "required": ["enabled"],
        "additionalProperties": true
      },
      "domain": { "type": "string", "minLength": 2 },
      "rules": { "type": "array", "minItems": 1 }
    }
  }
}
