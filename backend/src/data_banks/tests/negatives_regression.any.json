{
  "_meta": {
    "id": "negatives_regression",
    "version": "1.0.0",
    "description": "Regression test suite for operator negatives. Ensures that negative patterns correctly block misroutes and that fixes for past routing bugs don't regress. Each case represents a known misroute that was fixed.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-routing",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "runOnStartup": false,
    "runOnDeploy": true,
    "failThreshold": 0,
    "reportFormat": "detailed"
  },
  "suites": [
    {
      "id": "NEG_REG_conceptual_vs_inventory",
      "name": "Conceptual List vs File Inventory",
      "description": "Ensure conceptual list requests (list top 5 risks) don't route to file inventory operator (list).",
      "cases": [
        {
          "id": "NEG_REG_001",
          "input": "list the top 5 risks",
          "lang": "en",
          "mustNotRoute": ["list", "filter", "sort"],
          "shouldRoute": ["extract", "summarize"],
          "reason": "Conceptual extraction, not file inventory"
        },
        {
          "id": "NEG_REG_002",
          "input": "list the assumptions in the report",
          "lang": "en",
          "mustNotRoute": ["list"],
          "shouldRoute": ["extract", "locate_content"],
          "reason": "Document content extraction"
        },
        {
          "id": "NEG_REG_003",
          "input": "list all the key takeaways",
          "lang": "en",
          "mustNotRoute": ["list"],
          "shouldRoute": ["summarize", "extract"],
          "reason": "Summarization request"
        },
        {
          "id": "NEG_REG_004",
          "input": "liste os principais riscos",
          "lang": "pt",
          "mustNotRoute": ["list"],
          "shouldRoute": ["extract", "summarize"],
          "reason": "Portuguese conceptual list"
        },
        {
          "id": "NEG_REG_005",
          "input": "enumera las conclusiones del informe",
          "lang": "es",
          "mustNotRoute": ["list"],
          "shouldRoute": ["extract", "summarize"],
          "reason": "Spanish conceptual enumeration"
        },
        {
          "id": "NEG_REG_006",
          "input": "list my files",
          "lang": "en",
          "mustNotRoute": ["extract", "summarize"],
          "shouldRoute": ["list"],
          "reason": "Actual file inventory request"
        },
        {
          "id": "NEG_REG_007",
          "input": "show all uploaded documents",
          "lang": "en",
          "mustNotRoute": ["extract"],
          "shouldRoute": ["list"],
          "reason": "File inventory request"
        }
      ]
    },
    {
      "id": "NEG_REG_open_vs_summarize",
      "name": "Open File vs Summarize Content",
      "description": "Ensure summarization requests with file mentions don't route to open operator.",
      "cases": [
        {
          "id": "NEG_REG_010",
          "input": "summarize the Q4 report",
          "lang": "en",
          "mustNotRoute": ["open", "locate_file"],
          "shouldRoute": ["summarize"],
          "reason": "Summarization with doc reference"
        },
        {
          "id": "NEG_REG_011",
          "input": "give me an overview of budget.xlsx",
          "lang": "en",
          "mustNotRoute": ["open"],
          "shouldRoute": ["summarize"],
          "reason": "Overview is summarization"
        },
        {
          "id": "NEG_REG_012",
          "input": "open the Q4 report",
          "lang": "en",
          "mustNotRoute": ["summarize", "extract"],
          "shouldRoute": ["open"],
          "reason": "Explicit open request"
        },
        {
          "id": "NEG_REG_013",
          "input": "abre o relatório",
          "lang": "pt",
          "mustNotRoute": ["summarize"],
          "shouldRoute": ["open"],
          "reason": "Portuguese open request"
        },
        {
          "id": "NEG_REG_014",
          "input": "resume o relatório",
          "lang": "pt",
          "mustNotRoute": ["open"],
          "shouldRoute": ["summarize"],
          "reason": "Portuguese summarize request"
        }
      ]
    },
    {
      "id": "NEG_REG_quote_vs_extract",
      "name": "Quote vs Extract",
      "description": "Ensure quote requests (exact wording) don't route to extract (values/facts).",
      "cases": [
        {
          "id": "NEG_REG_020",
          "input": "quote the exact wording about liability",
          "lang": "en",
          "mustNotRoute": ["extract", "summarize"],
          "shouldRoute": ["quote"],
          "reason": "Explicit quote request"
        },
        {
          "id": "NEG_REG_021",
          "input": "what does it say verbatim about the deadline?",
          "lang": "en",
          "mustNotRoute": ["extract"],
          "shouldRoute": ["quote"],
          "reason": "Verbatim implies quote"
        },
        {
          "id": "NEG_REG_022",
          "input": "what is the total revenue?",
          "lang": "en",
          "mustNotRoute": ["quote"],
          "shouldRoute": ["extract"],
          "reason": "Value extraction, not quote"
        },
        {
          "id": "NEG_REG_023",
          "input": "cite textualmente o parágrafo sobre riscos",
          "lang": "pt",
          "mustNotRoute": ["extract", "summarize"],
          "shouldRoute": ["quote"],
          "reason": "Portuguese quote request"
        },
        {
          "id": "NEG_REG_024",
          "input": "cita textualmente la cláusula de terminación",
          "lang": "es",
          "mustNotRoute": ["extract"],
          "shouldRoute": ["quote"],
          "reason": "Spanish quote request"
        }
      ]
    },
    {
      "id": "NEG_REG_locate_content_vs_locate_file",
      "name": "Locate Content vs Locate File",
      "description": "Ensure in-document searches don't route to file location operators.",
      "cases": [
        {
          "id": "NEG_REG_030",
          "input": "where is ROI mentioned?",
          "lang": "en",
          "mustNotRoute": ["locate_file", "locate_docs", "open"],
          "shouldRoute": ["locate_content"],
          "reason": "In-document content search"
        },
        {
          "id": "NEG_REG_031",
          "input": "on which page does it discuss capex?",
          "lang": "en",
          "mustNotRoute": ["locate_file"],
          "shouldRoute": ["locate_content"],
          "reason": "Page reference implies content location"
        },
        {
          "id": "NEG_REG_032",
          "input": "where is the budget file?",
          "lang": "en",
          "mustNotRoute": ["locate_content"],
          "shouldRoute": ["locate_file", "locate_docs"],
          "reason": "File location request"
        },
        {
          "id": "NEG_REG_033",
          "input": "which folder is the contract in?",
          "lang": "en",
          "mustNotRoute": ["locate_content"],
          "shouldRoute": ["locate_file"],
          "reason": "Folder/path location"
        },
        {
          "id": "NEG_REG_034",
          "input": "onde aparece a palavra 'lucro'?",
          "lang": "pt",
          "mustNotRoute": ["locate_file"],
          "shouldRoute": ["locate_content"],
          "reason": "Portuguese in-document search"
        }
      ]
    },
    {
      "id": "NEG_REG_help_vs_docs",
      "name": "Help vs Document Questions",
      "description": "Ensure help requests don't accidentally route to document operators.",
      "cases": [
        {
          "id": "NEG_REG_040",
          "input": "how do I upload a file?",
          "lang": "en",
          "mustNotRoute": ["extract", "summarize", "open"],
          "shouldRoute": ["help_steps", "help_explain"],
          "reason": "Product help, not doc question"
        },
        {
          "id": "NEG_REG_041",
          "input": "what can you do?",
          "lang": "en",
          "mustNotRoute": ["extract", "summarize"],
          "shouldRoute": ["help_capabilities"],
          "reason": "Capabilities question"
        },
        {
          "id": "NEG_REG_042",
          "input": "how does the revenue compare year over year?",
          "lang": "en",
          "mustNotRoute": ["help_steps", "help_explain"],
          "shouldRoute": ["compare", "extract"],
          "reason": "Document comparison, not help"
        },
        {
          "id": "NEG_REG_043",
          "input": "como faço para deletar um arquivo?",
          "lang": "pt",
          "mustNotRoute": ["extract", "delete"],
          "shouldRoute": ["help_steps"],
          "reason": "Portuguese help request"
        }
      ]
    },
    {
      "id": "NEG_REG_greeting_vs_query",
      "name": "Greeting vs Document Query",
      "description": "Ensure greetings don't accidentally trigger document queries.",
      "cases": [
        {
          "id": "NEG_REG_050",
          "input": "hi",
          "lang": "en",
          "mustNotRoute": ["extract", "summarize", "open", "list"],
          "shouldRoute": ["greeting"],
          "reason": "Pure greeting"
        },
        {
          "id": "NEG_REG_051",
          "input": "hello, can you summarize the report?",
          "lang": "en",
          "mustNotRoute": ["greeting"],
          "shouldRoute": ["summarize"],
          "reason": "Greeting with doc request should route to doc operator"
        },
        {
          "id": "NEG_REG_052",
          "input": "thanks",
          "lang": "en",
          "mustNotRoute": ["extract", "summarize"],
          "shouldRoute": ["thanks"],
          "reason": "Pure thanks"
        },
        {
          "id": "NEG_REG_053",
          "input": "thanks, now show me the revenue",
          "lang": "en",
          "mustNotRoute": ["thanks"],
          "shouldRoute": ["extract"],
          "reason": "Thanks with followup request"
        }
      ]
    }
  ],
  "regressionHistory": {
    "_comment": "Track when regressions were introduced and fixed.",
    "entries": [
      {
        "date": "2026-01-15",
        "caseId": "NEG_REG_001",
        "description": "list top 5 risks was routing to file inventory",
        "fix": "Added conceptual_list_not_inventory negative rule"
      },
      {
        "date": "2026-01-18",
        "caseId": "NEG_REG_020",
        "description": "quote requests were routing to extract",
        "fix": "Added verbatim/exact negative patterns to extract operator"
      },
      {
        "date": "2026-01-22",
        "caseId": "NEG_REG_030",
        "description": "where is X mentioned was routing to locate_file",
        "fix": "Added content_search_not_file_search negative rule"
      }
    ]
  }
}
