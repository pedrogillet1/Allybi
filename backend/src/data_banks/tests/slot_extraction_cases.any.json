        { "snippet": "Party A: Acme Corp, hereinafter referred to as the first party. Party B: Beta LLC, hereinafter the second party.", "docId": "doc1", "locationKey": "p1" }
      ],
      "expectedEntities": ["Beta LLC"],
      "forbiddenEntities": ["Acme Corp"],
      "expectedStatus": "EXACT"
    },
