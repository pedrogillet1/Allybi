{
  "_meta": { "id": "slot_extraction_cases", "version": "1.0.0", "description": "Golden test cases for entity-role slot extraction: confusion pairs (owner vs signatory, party A vs B, guarantor vs witness).", "languages": ["any", "en", "pt"], "lastUpdated": "2026-02-20" },
  "cases": [
    {
      "id": "SE_001_owner_not_signatory_en",
      "query": "who is the owner?",
      "language": "en",
      "expectedSlotId": "contract_owner_names",
      "expectedTargetRoleId": "owner",
      "mockEvidence": [
        { "snippet": "The owner of the property is John Smith. Signed by Maria Garcia as signatory.", "docId": "doc1", "locationKey": "p1" },
        { "snippet": "Maria Garcia, signatory, hereby agrees to the terms.", "docId": "doc1", "locationKey": "p2" }
      ],
      "expectedEntities": ["John Smith"],
      "forbiddenEntities": ["Maria Garcia"],
      "expectedStatus": "EXACT"
    },
    {
      "id": "SE_002_signatory_not_owner_en",
      "query": "who signed the contract?",
      "language": "en",
      "expectedSlotId": "contract_signatory_names",
      "expectedTargetRoleId": "signatory",
      "mockEvidence": [
        { "snippet": "The owner of the property is John Smith. Signed by Maria Garcia as signatory.", "docId": "doc1", "locationKey": "p1" }
      ],
      "expectedEntities": ["Maria Garcia"],
      "forbiddenEntities": ["John Smith"],
      "expectedStatus": "EXACT"
    },
    {
      "id": "SE_003_party_a_not_party_b_en",
