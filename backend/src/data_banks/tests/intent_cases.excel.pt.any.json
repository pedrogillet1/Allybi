    "languages": [
      "pt"
    ]
  },
  "config": {
    "enabled": true
  },
  "cases": [
    {
      "_comment": "=== MANDATORY SPEC CASE #1: set_value.range ===",
      "id": "pt_mandatory_set_range_01",
      "input": "Na faixa SUMMARY 1!D35:D48, defina todas as células como 0 (todas, não só a célula ativa)",
      "context": {
        "domain": "excel",
        "sheetName": "SUMMARY 1",
        "selection": {
          "rangeA1": "D35:D48"
        },
        "language": "pt"
      },
      "expected": {
        "intentIds": [
          "excel.set_value.range"
        ],
        "plan": [
          {
            "op": "XLSX_SET_RANGE_VALUES"
          }
        ],
        "clarificationRequired": false
      }
    },
