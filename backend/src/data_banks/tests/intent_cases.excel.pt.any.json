{
  "_meta": {
    "id": "intent_cases_excel_pt",
    "version": "1.0.0",
    "description": "Brazilian Portuguese golden test cases for Excel intent pattern matching. Each case validates the full pipeline: message -> segment -> match patterns -> fill slots -> assemble plan.",
