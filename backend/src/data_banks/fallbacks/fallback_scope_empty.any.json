{
  "_meta": {
    "id": "fallback_scope_empty",
    "version": "2.0.0",
    "description": "Canonical recovery rules for scope-constrained empty retrieval.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-01",
    "owner": "koda-fallbacks",
    "compat": ">=1.0.0",
    "linkedMicrocopy": "processing_messages",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "canonicalReasonCodes": [
      "scope_hard_constraints_empty",
      "explicit_doc_not_found",
      "needs_doc_choice"
    ],
    "maxRecoveryOptions": 3,
    "preferDocLockPreservation": true,
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "rules": [
    {
      "id": "fse_detect_scope_hard_constraints_empty",
      "priority": 120,
      "when": {
        "all": [
          {
            "path": "signals.hardScopeActive",
            "op": "eq",
            "value": true
          },
          {
            "path": "metrics.retrievedChunks",
            "op": "eq",
            "value": 0
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "scope_empty",
        "recoveryStrategy": "offer_scope_relaxation"
      },
      "reasonCode": "scope_hard_constraints_empty",
      "severity": "high"
    },
    {
      "id": "fse_explicit_doc_not_found",
      "priority": 110,
      "when": {
        "all": [
          {
            "path": "signals.explicitDocRef",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.resolvedDocId",
            "op": "eq",
            "value": ""
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "doc_not_found",
        "recoveryStrategy": "request_precise_doc_selection"
      },
      "reasonCode": "explicit_doc_not_found",
      "severity": "high"
    },
    {
      "id": "fse_needs_doc_choice",
      "priority": 100,
      "when": {
        "all": [
          {
            "path": "signals.needsDocChoice",
            "op": "eq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "doc_ambiguous",
        "recoveryStrategy": "ask_minimal_disambiguation"
      },
      "reasonCode": "needs_doc_choice",
      "severity": "medium"
    },
    {
      "id": "fse_limit_recovery_options",
      "priority": 10,
      "when": {},
      "action": {
        "type": "limit_recovery_options",
        "max": 3
      },
      "reasonCode": "scope_hard_constraints_empty",
      "severity": "low"
    }
  ]
}
