{
  "_meta": {
    "id": "fallback_router",
    "version": "2.0.0",
    "description": "Deterministic fallback router with canonical reason-code policy.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-01"
  },
  "config": {
    "enabled": true,
    "canonicalReasonCodes": [
      "no_docs_indexed",
      "scope_hard_constraints_empty",
      "no_relevant_chunks_in_scoped_docs",
      "indexing_in_progress",
      "extraction_failed",
      "low_confidence",
      "doc_ambiguous",
      "needs_doc_choice",
      "explicit_doc_not_found",
      "safety_block",
      "privacy_block",
      "timeout",
      "network",
      "provider_down",
      "rate_limit",
      "bad_request",
      "unknown"
    ],
    "defaults": {
      "riskTier": "medium",
      "attempt": 1,
      "action": "ask_one_question",
      "telemetryReason": "UNKNOWN",
      "retryPolicy": {
        "maxAttempts": 1,
        "backoffMs": 250
      }
    }
  },
  "maps": {
    "reasonCodeToTelemetryReason": {
      "no_docs_indexed": "NO_EVIDENCE",
      "scope_hard_constraints_empty": "SCOPE_LOCK",
      "no_relevant_chunks_in_scoped_docs": "NO_EVIDENCE",
      "indexing_in_progress": "TIMEOUT",
      "extraction_failed": "EXTRACTION_FAILED",
      "low_confidence": "WEAK_EVIDENCE",
      "doc_ambiguous": "WRONG_DOC",
      "needs_doc_choice": "WRONG_DOC",
      "explicit_doc_not_found": "WRONG_DOC",
      "safety_block": "SAFETY_BLOCK",
      "privacy_block": "PRIVACY_REDACT",
      "timeout": "TIMEOUT",
      "network": "NETWORK",
      "provider_down": "PROVIDER_DOWN",
      "rate_limit": "RATE_LIMIT",
      "bad_request": "BAD_REQUEST",
      "unknown": "UNKNOWN",
      "NO_DOCS_INDEXED": "NO_EVIDENCE",
      "SCOPE_HARD_CONSTRAINTS_EMPTY": "SCOPE_LOCK",
      "NO_RELEVANT_CHUNKS_IN_SCOPED_DOCS": "NO_EVIDENCE",
      "INDEXING_IN_PROGRESS": "TIMEOUT",
      "EXTRACTION_FAILED": "EXTRACTION_FAILED",
      "LOW_CONFIDENCE": "WEAK_EVIDENCE",
      "DOC_AMBIGUOUS": "WRONG_DOC",
      "NEEDS_DOC_CHOICE": "WRONG_DOC",
      "EXPLICIT_DOC_NOT_FOUND": "WRONG_DOC",
      "SAFETY_BLOCK": "SAFETY_BLOCK",
      "PRIVACY_BLOCK": "PRIVACY_REDACT",
      "TIMEOUT": "TIMEOUT",
      "NETWORK": "NETWORK",
      "PROVIDER_DOWN": "PROVIDER_DOWN",
      "RATE_LIMIT": "RATE_LIMIT",
      "BAD_REQUEST": "BAD_REQUEST",
      "UNKNOWN": "UNKNOWN"
    }
  },
  "rules": [
    {
      "id": "fr_safety_block_terminal",
      "when": {
        "reasonCodeIn": [
          "safety_block"
        ]
      },
      "do": {
        "action": "return_reason_only",
        "telemetryReason": "SAFETY_BLOCK"
      }
    },
    {
      "id": "fr_privacy_block",
      "when": {
        "reasonCodeIn": [
          "privacy_block"
        ]
      },
      "do": {
        "action": "ask_one_question",
        "telemetryReason": "PRIVACY_REDACT"
      }
    },
    {
      "id": "fr_scope_or_not_found",
      "when": {
        "reasonCodeIn": [
          "scope_hard_constraints_empty",
          "no_relevant_chunks_in_scoped_docs",
          "explicit_doc_not_found",
          "needs_doc_choice",
          "doc_ambiguous"
        ]
      },
      "do": {
        "action": "ask_one_question",
        "telemetryReason": "WRONG_DOC"
      }
    },
    {
      "id": "fr_no_docs_indexed",
      "when": {
        "reasonCodeIn": [
          "no_docs_indexed"
        ]
      },
      "do": {
        "action": "route_to_discovery",
        "nextOperator": "discover",
        "telemetryReason": "NO_EVIDENCE"
      }
    },
    {
      "id": "fr_extraction_or_low_confidence",
      "when": {
        "reasonCodeIn": [
          "extraction_failed",
          "low_confidence"
        ]
      },
      "do": {
        "action": "regen_with_stricter_model",
        "fallbackProvider": "openai",
        "fallbackModelKey": "GPT_5_MINI",
        "telemetryReason": "WEAK_EVIDENCE"
      }
    },
    {
      "id": "fr_indexing_in_progress",
      "when": {
        "reasonCodeIn": [
          "indexing_in_progress"
        ]
      },
      "do": {
        "action": "retry_same_provider",
        "retryPolicy": {
          "maxAttempts": 1,
          "backoffMs": 500
        },
        "telemetryReason": "TIMEOUT"
      }
    },
    {
      "id": "fr_provider_failures",
      "when": {
        "reasonCodeIn": [
          "timeout",
          "network",
          "provider_down",
          "rate_limit"
        ]
      },
      "do": {
        "action": "switch_provider",
        "fallbackProvider": "openai",
        "fallbackModelKey": "GPT_5_MINI",
        "telemetryReason": "PROVIDER_DOWN"
      }
    },
    {
      "id": "fr_default",
      "when": {},
      "do": {
        "action": "ask_one_question",
        "telemetryReason": "UNKNOWN"
      }
    }
  ]
}
