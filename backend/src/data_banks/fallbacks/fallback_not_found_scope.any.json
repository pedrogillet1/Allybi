{
  "_meta": {
    "id": "fallback_not_found_scope",
    "version": "2.0.0",
    "description": "Canonical fallback strategy for not-found results within active scope.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-01",
    "owner": "koda-fallbacks",
    "compat": ">=1.0.0",
    "linkedMicrocopy": "processing_messages"
  },
  "config": {
    "enabled": true,
    "canonicalReasonCodes": [
      "no_relevant_chunks_in_scoped_docs",
      "scope_hard_constraints_empty",
      "low_confidence"
    ],
    "minSearchConfidence": 0.7
  },
  "rules": [
    {
      "id": "fns_not_found_in_scope",
      "priority": 120,
      "when": {
        "all": [
          {
            "path": "signals.searchExecuted",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.hardScopeActive",
            "op": "eq",
            "value": true
          },
          {
            "path": "metrics.retrievedChunks",
            "op": "eq",
            "value": 0
          },
          {
            "path": "metrics.searchConfidence",
            "op": "gte",
            "value": 0.7
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "not_found_in_scope",
        "strategy": "acknowledge_and_offer_rephrase"
      },
      "reasonCode": "no_relevant_chunks_in_scoped_docs",
      "severity": "medium"
    },
    {
      "id": "fns_offer_scope_expansion_after_confirmation",
      "priority": 90,
      "when": {
        "all": [
          {
            "path": "signals.searchExecuted",
            "op": "eq",
            "value": true
          },
          {
            "path": "metrics.retrievedChunks",
            "op": "eq",
            "value": 0
          }
        ]
      },
      "action": {
        "type": "offer_scope_expansion"
      },
      "reasonCode": "no_relevant_chunks_in_scoped_docs",
      "severity": "low"
    },
    {
      "id": "fns_scope_hard_constraints_empty",
      "priority": 110,
      "when": {
        "all": [
          {
            "path": "signals.hardScopeActive",
            "op": "eq",
            "value": true
          },
          {
            "path": "metrics.retrievedChunks",
            "op": "eq",
            "value": 0
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "scope_empty",
        "strategy": "offer_scope_adjustment"
      },
      "reasonCode": "scope_hard_constraints_empty",
      "severity": "high"
    },
    {
      "id": "fns_low_confidence_not_found",
      "priority": 80,
      "when": {
        "all": [
          {
            "path": "metrics.topConfidence",
            "op": "lt",
            "value": 0.28
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "low_confidence",
        "strategy": "ask_clarification_or_hedge"
      },
      "reasonCode": "low_confidence",
      "severity": "medium"
    }
  ]
}
