{
  "_meta": {
    "id": "fallback_processing",
    "version": "2.0.0",
    "description": "Canonical fallback decision rules shared across runtime fallback banks.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-01",
    "owner": "koda-fallbacks",
    "compat": ">=1.0.0",
    "linkedMicrocopy": "processing_messages"
  },
  "config": {
    "enabled": true,
    "canonicalReasonCodes": [
      "no_docs_indexed",
      "scope_hard_constraints_empty",
      "no_relevant_chunks_in_scoped_docs",
      "indexing_in_progress",
      "extraction_failed",
      "low_confidence",
      "doc_ambiguous",
      "needs_doc_choice",
      "explicit_doc_not_found"
    ],
    "actionsContract": {
      "maxFallbacksPerTurn": 1,
      "defaultFallbackType": "fallback_default",
      "conflictResolution": "highest_severity_then_priority"
    },
    "variationControl": {
      "enableEntropy": true,
      "entropyWindow": 7,
      "cooldownTurns": 3,
      "dedupeBy": [
        "reasonCode",
        "fallbackType"
      ]
    }
  },
  "rules": [
    {
      "id": "fp_no_docs_indexed",
      "priority": 120,
      "when": {
        "all": [
          {
            "path": "signals.hasIndexedDocs",
            "op": "eq",
            "value": false
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "no_docs_indexed",
        "strategy": "guide_upload_or_indexing"
      },
      "reasonCode": "no_docs_indexed",
      "severity": "critical"
    },
    {
      "id": "fp_scope_hard_constraints_empty",
      "priority": 110,
      "when": {
        "all": [
          {
            "path": "signals.hardScopeActive",
            "op": "eq",
            "value": true
          },
          {
            "path": "metrics.retrievedChunks",
            "op": "eq",
            "value": 0
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "scope_empty",
        "strategy": "offer_scope_adjustment"
      },
      "reasonCode": "scope_hard_constraints_empty",
      "severity": "high"
    },
    {
      "id": "fp_no_relevant_chunks_in_scoped_docs",
      "priority": 100,
      "when": {
        "all": [
          {
            "path": "signals.searchExecuted",
            "op": "eq",
            "value": true
          },
          {
            "path": "metrics.retrievedChunks",
            "op": "eq",
            "value": 0
          },
          {
            "path": "signals.hardScopeActive",
            "op": "eq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "not_found_in_scope",
        "strategy": "confirm_and_rephrase"
      },
      "reasonCode": "no_relevant_chunks_in_scoped_docs",
      "severity": "medium"
    },
    {
      "id": "fp_extraction_failed",
      "priority": 90,
      "when": {
        "all": [
          {
            "path": "metrics.extractionCoverage",
            "op": "lt",
            "value": 0.6
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "extraction_failed",
        "strategy": "offer_recovery_steps"
      },
      "reasonCode": "extraction_failed",
      "severity": "high"
    },
    {
      "id": "fp_low_confidence",
      "priority": 80,
      "when": {
        "all": [
          {
            "path": "metrics.topConfidence",
            "op": "lt",
            "value": 0.55
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "low_confidence",
        "strategy": "ask_clarification_or_hedge"
      },
      "reasonCode": "low_confidence",
      "severity": "medium"
    },
    {
      "id": "fp_doc_ambiguous",
      "priority": 70,
      "when": {
        "all": [
          {
            "path": "signals.isAmbiguous",
            "op": "eq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "doc_ambiguous",
        "strategy": "ask_minimal_disambiguation"
      },
      "reasonCode": "doc_ambiguous",
      "severity": "medium"
    }
  ]
}
