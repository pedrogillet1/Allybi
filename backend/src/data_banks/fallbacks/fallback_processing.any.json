{
  "_meta": {
    "id": "fallback_processing",
    "version": "1.0.0",
    "description": "Adaptive fallback decision and behavior rules for Koda. Governs fallback selection, prioritization, and recovery paths without hardcoded responses, ensuring dynamic, unique, and ChatGPT-like fallback behavior.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-fallbacks",
    "compat": ">=1.0.0",
    "linkedMicrocopy": "processing_messages"
  },
  "config": {
    "enabled": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_highest_severity",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxFallbacksPerTurn": 1,
        "minConfidenceToProceed": 0.55
      },
      "conflictResolution": {
        "ifMultipleFallbacks": "most_specific_reason"
      }
    },
    "variationControl": {
      "enableEntropy": true,
      "entropyWindow": 7,
      "cooldownTurns": 3,
      "dedupeBy": ["reasonCode", "fallbackType"]
    }
  },
  "rules": [
    {
      "id": "no_docs_indexed",
      "scope": "global",
      "description": "Handle cases where no documents are indexed.",
      "appliesTo": ["all_fallbacks"],
      "when": {
        "all": [
          { "path": "signals.hasIndexedDocs", "op": "eq", "value": false }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "no_docs_indexed",
        "strategy": "guide_next_step"
      },
      "reasonCode": "no_docs_indexed",
      "severity": "critical"
    },
    {
      "id": "scope_empty",
      "scope": "cross_family",
      "description": "Handle empty results caused by hard scope constraints.",
      "appliesTo": ["all_fallbacks"],
      "when": {
        "all": [
          { "path": "signals.hardScopeActive", "op": "eq", "value": true },
          { "path": "metrics.retrievedChunks", "op": "eq", "value": 0 }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "scope_empty",
        "strategy": "offer_scope_adjustment"
      },
      "reasonCode": "scope_hard_constraints_empty",
      "severity": "high"
    },
    {
      "id": "low_confidence_answer_block",
      "scope": "global",
      "description": "Block answer generation when confidence is too low to proceed safely.",
      "appliesTo": ["all_fallbacks"],
      "when": {
        "all": [
          { "path": "metrics.topConfidence", "op": "lt", "value": 0.55 }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "low_confidence",
        "strategy": "request_clarification_or_rephrase"
      },
      "reasonCode": "low_confidence",
      "severity": "medium"
    },
    {
      "id": "ambiguous_intent",
      "scope": "global",
      "description": "Handle unresolved ambiguity after routing and operator resolution.",
      "appliesTo": ["all_fallbacks"],
      "when": {
        "all": [
          { "path": "signals.isAmbiguous", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "fallback",
        "fallbackType": "ambiguous_intent",
        "strategy": "clarify_with_minimal_question"
      },
      "reasonCode": "doc_ambiguous",
      "severity": "medium"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "FBP_001_no_docs_indexed",
        "context": { "signals": { "hasIndexedDocs": false } },
        "expect": { "fallbackType": "no_docs_indexed" }
      },
      {
        "id": "FBP_002_scope_empty",
        "context": {
          "signals": { "hardScopeActive": true },
          "metrics": { "retrievedChunks": 0 }
        },
        "expect": { "fallbackType": "scope_empty" }
      },
      {
        "id": "FBP_003_low_confidence",
        "context": { "metrics": { "topConfidence": 0.3 } },
        "expect": { "fallbackType": "low_confidence" }
      },
      {
        "id": "FBP_004_single_fallback_only",
        "context": {
          "signals": { "hasIndexedDocs": false, "isAmbiguous": true }
        },
        "expect": { "fallbackCountMax": 1 }
      }
    ]
  }
}
