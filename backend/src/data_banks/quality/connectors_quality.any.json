{
  "bankId": "connectors_quality",
  "version": "1.0.0",
  "localeSupport": ["en", "pt"],
  "description": "Connector answer quality gates: citation requirements, evidence rules, recency prioritization, and refusal behavior for Gmail/Outlook/Slack content.",
  "updatedAt": "2026-02-07T00:00:00.000Z",
  "schemaVersion": 1,

  "_meta": {
    "id": "connectors_quality",
    "version": "1.0.0",
    "description": "Quality gates for connector-backed answers (Gmail/Outlook/Slack). Enforces citations, recency, thread integrity, and no-guessing behavior.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07",
    "owner": "koda-quality",
    "compat": ">=1.0.0"
  },

  "config": {
    "enabled": true,
    "strict": true,
    "failClosedByEnv": {
      "production": true,
      "staging": true,
      "dev": false,
      "local": false
    },

    "integrationHooks": {
      "connectorsPolicyBankId": "connectors_policy",
      "privacyMinimalRulesBankId": "privacy_minimal_rules",
      "piiLabelsBankId": "pii_field_labels"
    },

    "limits": {
      "maxResultsToCite": 6,
      "maxThreadMessagesToSummarize": 22,
      "maxQuoteCharsPerItem": 320,
      "maxSnippetCharsPerItem": 220,
      "maxAnswerCharsHard": 4200
    }
  },

  "requirements": {
    "citations": {
      "required": true,
      "mustIncludeFields": ["sourceType", "sourceId", "timestamp"],
      "preferredFieldsByProvider": {
        "gmail": ["subject", "from", "date", "threadId"],
        "outlook": ["subject", "from", "date", "threadId"],
        "slack": ["channel", "author", "timestamp", "permalink"]
      },
      "forbidFakeCitations": true,
      "forbidUndatedCitations": true
    },

    "evidence": {
      "noGuessingWithoutEvidence": true,
      "refuseIfNoEvidence": true,
      "requireAtLeastOneCitedItem": true,
      "requireProviderMatchIfProviderSpecified": true
    },

    "privacy": {
      "neverLogRawBodies": true,
      "neverEchoAccessTokens": true,
      "defaultToSnippetsNotFullBodies": true,
      "redactSecretsPatterns": [
        "\\bAIza[0-9A-Za-z\\-_]{35}\\b",
        "\\bya29\\.[0-9A-Za-z\\-_]+\\b",
        "\\bxox[baprs]-[0-9A-Za-z-]{10,48}\\b",
        "\\bsk-[0-9A-Za-z]{20,}\\b"
      ]
    }
  },

  "recencyPolicy": {
    "defaultTimeWindowDays": 30,
    "preferMoreRecentWhen": [
      "query.containsAny(['latest','most recent','newest','last email','yesterday','today'])",
      "query.containsAny(['mais recente','último','ultima','ontem','hoje'])"
    ],
    "tieBreakers": [
      "ifSameThreadPreferThreadRoot",
      "preferSameChannelOrThread",
      "preferHigherRetrievalScore"
    ],
    "hardRules": {
      "ifUserAsksForTimeRangeMustRespect": true,
      "ifUserSaysOnlyThisThreadMustNotCrossThreads": true
    }
  },

  "threadPolicy": {
    "summary": {
      "allowed": true,
      "mustStateScope": true,
      "mustIncludeThreadIdentifier": true,
      "mustDistinguishMessagesVsAttachments": true
    },
    "integrity": {
      "neverMergeDifferentThreads": true,
      "requireThreadIdForThreadSummary": true,
      "ifMissingThreadIdAskClarifier": true
    }
  },

  "gates": {
    "citation_required": {
      "enabled": true,
      "checks": [
        {
          "id": "CQ_CIT_001_require_citations_block",
          "severity": "error",
          "description": "Connector-backed answers must include at least one citation with required fields.",
          "condition": "context.intent == 'CONNECTORS' AND context.operator.in(['CONNECTOR_SEARCH','CONNECTOR_SUMMARIZE_THREAD']) == true AND output.citations.count < 1",
          "actionOnFail": "refuse_no_evidence",
          "reasonCode": "connector_citations_missing"
        },
        {
          "id": "CQ_CIT_002_forbid_undated",
          "severity": "error",
          "description": "Citations must include timestamps (no undated claims for connector content).",
          "condition": "output.citations.anyMissing(['timestamp']) == true",
          "actionOnFail": "retry_with_strict_citation_contract",
          "reasonCode": "connector_citation_timestamp_missing"
        }
      ]
    },

    "no_guessing": {
      "enabled": true,
      "checks": [
        {
          "id": "CQ_EVID_001_refuse_if_no_evidence",
          "severity": "error",
          "description": "If connector index has no evidence for the query, refuse instead of guessing.",
          "condition": "context.intent == 'CONNECTORS' AND metrics.evidenceItemsCount == 0",
          "actionOnFail": "refuse_no_evidence",
          "reasonCode": "connector_no_evidence"
        },
        {
          "id": "CQ_EVID_002_provider_must_match",
          "severity": "error",
          "description": "If user specified a provider, do not answer using other provider evidence.",
          "condition": "context.providerSpecified == true AND metrics.evidenceProvidersOutsideSpecifiedCount > 0",
          "actionOnFail": "retry_filter_to_provider",
          "reasonCode": "connector_wrong_provider"
        }
      ]
    },

    "privacy_minimal": {
      "enabled": true,
      "checks": [
        {
          "id": "CQ_PRIV_001_strip_secrets",
          "severity": "error",
          "description": "Strip any token-like strings before returning connector-derived content.",
          "patterns": "@requirements.privacy.redactSecretsPatterns",
          "actionOnFail": "redact_secrets",
          "reasonCode": "connector_secret_redaction_required"
        },
        {
          "id": "CQ_PRIV_002_limit_body_leak",
          "severity": "warning",
          "description": "Prefer snippets; do not dump full email/slack bodies unless user asked explicitly.",
          "condition": "context.userAskedForFullBody != true AND output.longQuotedBodyChars > config.limits.maxQuoteCharsPerItem",
          "actionOnFail": "truncate_to_snippets",
          "reasonCode": "connector_body_too_long"
        }
      ]
    }
  },

  "actions": {
    "definitions": [
      {
        "id": "refuse_no_evidence",
        "type": "route",
        "notes": "Route to no-evidence microcopy; do not fabricate connector content."
      },
      {
        "id": "retry_with_strict_citation_contract",
        "type": "retry_retrieval_then_regen",
        "notes": "Regenerate with enforced citation schema and required fields."
      },
      {
        "id": "retry_filter_to_provider",
        "type": "retry_retrieval_then_regen",
        "notes": "Filter evidence to specified provider only; then regenerate."
      },
      {
        "id": "redact_secrets",
        "type": "transform",
        "notes": "Redact any detected secrets/tokens from output."
      },
      {
        "id": "truncate_to_snippets",
        "type": "transform",
        "notes": "Replace long body quotations with short snippets and citations."
      }
    ]
  },

  "outputContract": {
    "requiredBlocks": ["citations", "actions"],
    "citationsContract": {
      "requiredFields": ["sourceType", "sourceId", "timestamp"],
      "preferredFields": ["subject", "from", "channel", "threadId", "permalink"]
    }
  },

  "tests": {
    "cases": [
      {
        "id": "CQ_T001_refuse_no_evidence",
        "input": { "context": { "intent": "CONNECTORS" }, "metrics": { "evidenceItemsCount": 0 } },
        "expect": { "action": "refuse_no_evidence", "reasonCode": "connector_no_evidence" }
      },
      {
        "id": "CQ_T002_missing_citations",
        "input": { "context": { "intent": "CONNECTORS", "operator": "CONNECTOR_SEARCH" }, "output": { "citations": { "count": 0 } } },
        "expect": { "reasonCode": "connector_citations_missing" }
      },
      {
        "id": "CQ_T003_redact_secrets",
        "input": { "output": { "text": "token ya29.abc123" } },
        "expect": { "actionsAny": ["redact_secrets"] }
      }
    ]
  }
}
