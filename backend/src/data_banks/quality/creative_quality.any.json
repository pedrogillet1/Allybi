{
  "bankId": "creative_quality",
  "version": "1.0.0",
  "localeSupport": ["en", "pt"],
  "description": "Creative asset quality gates: aspect ratio and dimension enforcement, palette/brand consistency, readability checks when text is allowed, safe-zone rules, and regeneration triggers.",
  "updatedAt": "2026-02-07T00:00:00.000Z",
  "schemaVersion": 1,

  "_meta": {
    "id": "creative_quality",
    "version": "1.0.0",
    "description": "Quality gates for creative assets and slide visuals. Enforces aspect ratio, safe zones, deck palette consistency, and readability.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07",
    "owner": "koda-quality",
    "compat": ">=1.0.0"
  },

  "config": {
    "enabled": true,
    "strict": true,
    "failClosedByEnv": {
      "production": true,
      "staging": true,
      "dev": false,
      "local": false
    },

    "limits": {
      "maxRegenerations": 2,
      "maxAssetBytes": 12000000,
      "minThumbSizePx": 256,
      "maxThumbSizePx": 1024
    },

    "integrationHooks": {
      "privacyMinimalRulesBankId": "privacy_minimal_rules"
    }
  },

  "requirements": {
    "aspectRatios": {
      "allowed": ["16:9", "4:3", "1:1"],
      "default": "16:9",
      "tolerance": 0.02
    },

    "safeZones": {
      "defaults": {
        "16:9": { "marginPct": 0.06 },
        "4:3": { "marginPct": 0.07 },
        "1:1": { "marginPct": 0.08 }
      },
      "enforce": true
    },

    "palette": {
      "mustMatchDeckByDefault": true,
      "maxColorDistance": 0.18,
      "maxNonPaletteAccentColors": 1
    },

    "textInImage": {
      "defaultPolicy": "none",
      "allowIfUserRequested": true,
      "ifAllowed": {
        "minContrastRatio": 4.2,
        "minFontSizePx": 22,
        "maxLines": 6
      }
    },

    "composition": {
      "alignment": { "requireConsistentGrid": true, "maxOffGridPct": 0.06 },
      "readability": { "minLegibilityScore": 0.7 },
      "clutter": { "maxElementDensity": 0.78 }
    }
  },

  "gates": {
    "asset_dimensions": {
      "enabled": true,
      "checks": [
        {
          "id": "CQV_DIM_001_aspect_ratio_match",
          "severity": "error",
          "description": "Generated asset must match requested aspect ratio within tolerance.",
          "condition": "metrics.aspectRatioDelta > requirements.aspectRatios.tolerance",
          "actionOnFail": "regenerate_with_aspect_ratio_lock",
          "reasonCode": "creative_aspect_ratio_mismatch"
        },
        {
          "id": "CQV_DIM_002_asset_size_limit",
          "severity": "error",
          "description": "Asset must be under max bytes.",
          "condition": "metrics.assetBytes > config.limits.maxAssetBytes",
          "actionOnFail": "reencode_and_optimize",
          "reasonCode": "creative_asset_too_large"
        }
      ]
    },

    "palette_consistency": {
      "enabled": true,
      "checks": [
        {
          "id": "CQV_PAL_001_palette_similarity",
          "severity": "error",
          "description": "If styleMode=match_deck, palette similarity must be above threshold.",
          "condition": "context.styleMode == 'match_deck' AND metrics.paletteDistance > requirements.palette.maxColorDistance",
          "actionOnFail": "regenerate_with_palette_lock",
          "reasonCode": "creative_palette_mismatch"
        },
        {
          "id": "CQV_PAL_002_limit_non_palette_colors",
          "severity": "warning",
          "description": "Limit accent colors outside deck palette.",
          "condition": "metrics.nonPaletteAccentColors > requirements.palette.maxNonPaletteAccentColors",
          "actionOnFail": "reduce_accent_colors",
          "reasonCode": "creative_too_many_accent_colors"
        }
      ]
    },

    "text_readability": {
      "enabled": true,
      "checks": [
        {
          "id": "CQV_TXT_001_no_text_unless_requested",
          "severity": "error",
          "description": "Do not place text in images unless user requested it.",
          "condition": "context.textPolicy != 'allowed' AND metrics.textDetected == true",
          "actionOnFail": "regenerate_no_text",
          "reasonCode": "creative_text_not_allowed"
        },
        {
          "id": "CQV_TXT_002_contrast_if_text_allowed",
          "severity": "error",
          "description": "If text is allowed, enforce contrast and font-size minimums.",
          "condition": "context.textPolicy == 'allowed' AND (metrics.minContrastRatio < requirements.textInImage.ifAllowed.minContrastRatio OR metrics.minFontSizePx < requirements.textInImage.ifAllowed.minFontSizePx)",
          "actionOnFail": "regenerate_with_readability_lock",
          "reasonCode": "creative_text_readability_failed"
        }
      ]
    },

    "safe_zone": {
      "enabled": true,
      "checks": [
        {
          "id": "CQV_SZ_001_safe_zone_margin",
          "severity": "warning",
          "description": "Keep critical content within safe zone margins.",
          "condition": "metrics.safeZoneViolationPct > 0",
          "actionOnFail": "reposition_with_safe_zone",
          "reasonCode": "creative_safe_zone_violation"
        }
      ]
    },

    "composition_quality": {
      "enabled": true,
      "checks": [
        {
          "id": "CQV_COMP_001_alignment",
          "severity": "warning",
          "description": "Prefer grid-aligned composition.",
          "condition": "metrics.offGridPct > requirements.composition.alignment.maxOffGridPct",
          "actionOnFail": "regenerate_with_grid_lock",
          "reasonCode": "creative_alignment_offgrid"
        },
        {
          "id": "CQV_COMP_002_clutter",
          "severity": "warning",
          "description": "Avoid cluttered visuals.",
          "condition": "metrics.elementDensity > requirements.composition.clutter.maxElementDensity",
          "actionOnFail": "simplify_layout",
          "reasonCode": "creative_cluttered"
        }
      ]
    }
  },

  "actions": {
    "definitions": [
      { "id": "regenerate_with_aspect_ratio_lock", "type": "regenerate", "notes": "Regenerate with explicit width/height and aspect constraints." },
      { "id": "reencode_and_optimize", "type": "transform", "notes": "Convert/optimize image (e.g. png->webp) while preserving dimensions." },
      { "id": "regenerate_with_palette_lock", "type": "regenerate", "notes": "Regenerate forcing deck palette, reducing non-palette colors." },
      { "id": "reduce_accent_colors", "type": "transform", "notes": "Tone down extra accent colors; map to closest palette colors." },
      { "id": "regenerate_no_text", "type": "regenerate", "notes": "Regenerate with textPolicy=none and negative prompts for text." },
      { "id": "regenerate_with_readability_lock", "type": "regenerate", "notes": "Regenerate enforcing larger font and high-contrast placement." },
      { "id": "reposition_with_safe_zone", "type": "transform", "notes": "Reposition/crop to keep content within safe zones." },
      { "id": "regenerate_with_grid_lock", "type": "regenerate", "notes": "Regenerate with a stronger grid/alignment constraint." },
      { "id": "simplify_layout", "type": "regenerate", "notes": "Regenerate with fewer elements and more whitespace." }
    ]
  },

  "outputContract": {
    "requiredBlocks": ["preview", "why", "actions"],
    "previewContract": {
      "mustInclude": ["assetUrl", "thumbUrl"],
      "optional": ["width", "height", "aspectRatio", "palette", "styleMode"]
    }
  },

  "tests": {
    "cases": [
      {
        "id": "CQV_T001_aspect_ratio_mismatch_regens",
        "input": { "metrics": { "aspectRatioDelta": 0.12 } },
        "expect": { "reasonCode": "creative_aspect_ratio_mismatch" }
      },
      {
        "id": "CQV_T002_text_not_allowed",
        "input": { "context": { "textPolicy": "none" }, "metrics": { "textDetected": true } },
        "expect": { "reasonCode": "creative_text_not_allowed" }
      },
      {
        "id": "CQV_T003_palette_mismatch",
        "input": { "context": { "styleMode": "match_deck" }, "metrics": { "paletteDistance": 0.3 } },
        "expect": { "reasonCode": "creative_palette_mismatch" }
      }
    ]
  }
}
