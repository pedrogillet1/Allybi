{
  "bankId": "response_contract",
  "version": "1.0.0",
  "localeSupport": ["en", "pt"],
  "description": "Defines required RichMessage blocks per operator for editing/connectors/creative. Used by orchestrator/rendering to ensure stable UX.",
  "updatedAt": "2026-02-07T00:00:00.000Z",
  "schemaVersion": 1,

  "_meta": {
    "id": "response_contract",
    "version": "1.0.0",
    "description": "Response block contract per operator for Koda. Enforces stable block ordering and required UI affordances (diff/why/proof/actions, citations/actions, preview/insert actions).",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07",
    "owner": "koda-quality",
    "compat": ">=1.0.0"
  },

  "config": {
    "enabled": true,
    "strict": true,

    "blockOrderDefaults": {
      "editing": ["target", "diff", "why", "proof", "actions"],
      "connectors": ["text", "citations", "actions"],
      "creative": ["preview", "why", "actions"]
    },

    "limits": {
      "maxBlocks": 14,
      "maxActions": 8,
      "maxChoices": 4,
      "maxProofItems": 8,
      "maxCitationItems": 8,
      "maxDiffSegments": 200
    }
  },

  "blocks": {
    "allowed": [
      "status",
      "text",
      "bullets",
      "table",
      "citations",
      "target",
      "diff",
      "why",
      "proof",
      "actions",
      "choices",
      "preview"
    ],

    "requiredByOperator": {
      "EDIT_PARAGRAPH": ["target", "diff", "why", "proof", "actions"],
      "EDIT_CELL": ["target", "diff", "why", "proof", "actions"],
      "EDIT_RANGE": ["target", "diff", "why", "proof", "actions"],
      "ADD_SHEET": ["diff", "why", "actions"],
      "CREATE_CHART": ["diff", "why", "proof", "actions"],
      "ADD_SLIDE": ["diff", "why", "actions"],
      "REWRITE_SLIDE_TEXT": ["target", "diff", "why", "proof", "actions"],
      "REPLACE_IMAGE": ["target", "diff", "why", "proof", "actions"],

      "CONNECT_START": ["actions"],
      "CONNECTOR_STATUS": ["text", "actions"],
      "CONNECTOR_SYNC": ["status", "actions"],
      "CONNECTOR_SEARCH": ["text", "citations", "actions"],
      "CONNECTOR_DISCONNECT": ["choices", "actions"],

      "GENERATE_SLIDE_VISUAL": ["preview", "why", "actions"],
      "GENERATE_DIAGRAM_ASSET": ["preview", "why", "actions"],
      "GENERATE_ICON_SET": ["preview", "why", "actions"],
      "GENERATE_BACKGROUND": ["preview", "why", "actions"],
      "GENERATE_CHART_STYLE_ASSET": ["preview", "why", "actions"]
    }
  },

  "blockSchemas": {
    "target": {
      "requiredFields": ["label", "confidence"],
      "optionalFields": ["candidates"],
      "notes": "If ambiguous, include candidates (<= maxChoices) and include a choices block."
    },
    "diff": {
      "requiredFields": ["kind", "summary", "segments"],
      "notes": "Diff payload should be compact and safe for streaming."
    },
    "why": {
      "requiredFields": ["reasons", "preserved", "riskLevel"],
      "notes": "User-facing rationale only; never include chain-of-thought."
    },
    "proof": {
      "requiredFields": ["sourceType", "label", "value"],
      "notes": "Proof items should be short excerpts/metadata, not full document dumps."
    },
    "citations": {
      "requiredFields": ["sourceType", "sourceId", "timestamp"],
      "notes": "Connector answers must cite subject/from/date/thread/channel where available."
    },
    "preview": {
      "requiredFields": ["assetUrl"],
      "optionalFields": ["thumbUrl", "width", "height", "aspectRatio", "palette", "styleMode"],
      "notes": "Preview must be safe URLs only; no local paths."
    },
    "actions": {
      "requiredFields": ["type", "label"],
      "notes": "Actions are pill-like UI commands; keep count <= maxActions."
    },
    "choices": {
      "requiredFields": ["prompt", "options"],
      "notes": "Use when target/provider is ambiguous or confirmation is required."
    }
  },

  "enforcement": {
    "onViolation": [
      {
        "id": "RC_001_missing_required_blocks",
        "action": "block",
        "reasonCode": "response_contract_missing_blocks"
      },
      {
        "id": "RC_002_blocks_out_of_order",
        "action": "transform",
        "reasonCode": "response_contract_reorder_blocks"
      },
      {
        "id": "RC_003_too_many_blocks",
        "action": "transform",
        "reasonCode": "response_contract_trim_blocks"
      }
    ]
  },

  "tests": {
    "cases": [
      {
        "id": "RC_T001_edit_requires_diff",
        "input": { "operator": "EDIT_PARAGRAPH" },
        "expect": { "requiredBlocksAny": ["diff"] }
      },
      {
        "id": "RC_T002_connector_search_requires_citations",
        "input": { "operator": "CONNECTOR_SEARCH" },
        "expect": { "requiredBlocksAny": ["citations"] }
      },
      {
        "id": "RC_T003_creative_requires_preview",
        "input": { "operator": "GENERATE_DIAGRAM_ASSET" },
        "expect": { "requiredBlocksAny": ["preview"] }
      }
    ]
  }
}
