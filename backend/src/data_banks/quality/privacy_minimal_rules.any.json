{
  "_meta": {
    "id": "privacy_minimal_rules",
    "version": "1.0.0",
    "description": "ChatGPT-like minimal privacy and sensitive-data handling rules for Koda. Prevents leaking internal ids/debug traces; discourages overexposing sensitive identifiers in normal answers; enforces safer display patterns for personal documents (US + Brazil) while still allowing document-grounded extraction when the user explicitly asks.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "scope": {
      "_comment": "Applies to all answer modes; strictest in production.",
      "appliesToAnswerModes": ["any"],
      "byEnv": {
        "production": { "strictness": "high" },
        "staging": { "strictness": "high" },
        "dev": { "strictness": "medium" },
        "local": { "strictness": "medium" }
      }
    },
    "integrationHooks": {
      "piiLabelsBankId": "pii_field_labels",
      "refusalBankId": "refusal_phrases",
      "clarificationBankId": "clarification_phrases"
    },
    "policies": {
      "_comment": "This is NOT a refusal policy. It's display hygiene + debug-leak prevention.",
      "neverShowDebugTraceToUser": true,
      "neverShowInternalDocIdsUnlessUserAsked": true,
      "neverShowRawStoragePaths": true,
      "preferMaskingForSensitiveIdsUnlessUserExplicitlyRequestsFull": true,
      "maskingStyle": "keep_last_4",
      "doNotMaskIfUserAsksForExactValue": true,
      "doNotStoreOrEchoRecoveryPhrases": true
    },
    "patterns": {
      "debugSections": [
        "^\\s*DEBUG\\b.*$",
        "^\\s*trace\\b.*$",
        "^\\s*stack\\s*trace\\b.*$",
        "\\bstateUpdateTrace\\b",
        "\\bqualityGateTrace\\b"
      ],
      "internalIds": [
        "\\bdoc:[a-zA-Z0-9_\\-]+\\b",
        "\\bfileId:[a-zA-Z0-9_\\-]+\\b",
        "\\bconversationId\\b\\s*[:=]\\s*[a-zA-Z0-9_\\-]+",
        "\\bturnId\\b\\s*[:=]\\s*[a-zA-Z0-9_\\-]+"
      ],
      "storagePaths": [
        "\\b/Users/[^\\s]+\\b",
        "\\bC:\\\\Users\\\\[^\\s]+\\b",
        "\\b/srv/[^\\s]+\\b",
        "\\b/var/[^\\s]+\\b"
      ],
      "sensitiveIds": {
        "_comment": "Detection patterns for optional masking (only when user didn't request full).",
        "us": {
          "ssn": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
          "ein": "\\b\\d{2}-\\d{7}\\b",
          "passport": "\\b[0-9]{9}\\b"
        },
        "br": {
          "cpf": "\\b\\d{3}\\.?\\d{3}\\.?\\d{3}-?\\d{2}\\b",
          "cnpj": "\\b\\d{2}\\.?\\d{3}\\.?\\d{3}/?\\d{4}-?\\d{2}\\b",
          "rg": "\\b\\d{1,2}\\.?\\d{3}\\.?\\d{3}-?[0-9Xx]\\b",
          "cnh": "\\b\\d{11}\\b"
        }
      }
    }
  },
  "checks": [
    {
      "id": "PRIV_001_strip_debug",
      "severity": "error",
      "description": "Remove any debug/trace sections from user-visible output.",
      "patterns": "@config.patterns.debugSections",
      "actionOnMatch": "strip_debug_sections"
    },
    {
      "id": "PRIV_002_hide_internal_ids",
      "severity": "warning",
      "description": "Hide internal ids (doc ids, file ids) unless the user explicitly requested ids.",
      "patterns": "@config.patterns.internalIds",
      "onlyIf": "signals.userRequestedIds != true",
      "actionOnMatch": "hide_internal_ids"
    },
    {
      "id": "PRIV_003_hide_storage_paths",
      "severity": "error",
      "description": "Never show raw local/server storage paths.",
      "patterns": "@config.patterns.storagePaths",
      "actionOnMatch": "strip_storage_paths"
    },
    {
      "id": "PRIV_004_optional_mask_sensitive_ids",
      "severity": "warning",
      "description": "Mask common sensitive identifiers in answers unless user asked for exact value. Applies only to user-visible rendering, not retrieval.",
      "when": "signals.userAskedForExactValue != true AND config.policies.preferMaskingForSensitiveIdsUnlessUserExplicitlyRequestsFull == true",
      "detect": "@config.patterns.sensitiveIds",
      "actionOnMatch": "mask_sensitive_ids_keep_last_4"
    },
    {
      "id": "PRIV_005_no_recovery_phrase_echo",
      "severity": "error",
      "description": "Never echo 12-word recovery phrases or seed phrases.",
      "patterns": [
        "\\b(?:\\w+\\s+){11}\\w+\\b",
        "\\b(seed phrase|recovery phrase|mnemonic)\\b"
      ],
      "onlyIf": "signals.looksLikeRecoveryPhrase == true",
      "actionOnMatch": "block_and_instruct_safe"
    }
  ],
  "actions": {
    "definitions": [
      {
        "id": "strip_debug_sections",
        "type": "transform",
        "notes": "Remove any lines/blocks that look like debug output or traces."
      },
      {
        "id": "hide_internal_ids",
        "type": "transform",
        "notes": "Replace internal ids with neutral labels (e.g., 'this document') unless user asked for ids."
      },
      {
        "id": "strip_storage_paths",
        "type": "transform",
        "notes": "Remove filesystem paths; keep only user-facing filenames."
      },
      {
        "id": "mask_sensitive_ids_keep_last_4",
        "type": "transform",
        "notes": "Mask identifiers (CPF/SSN/etc.) leaving last 4 characters visible (e.g., ***-**-1234)."
      },
      {
        "id": "block_and_instruct_safe",
        "type": "route",
        "notes": "Block displaying recovery phrases; provide safe next steps without exposing the phrase."
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "PRIV_T001_strips_sources_trace",
        "input": { "answerText": "DEBUG: stateUpdateTrace=..." },
        "expect": { "actionsAny": ["strip_debug_sections"] }
      },
      {
        "id": "PRIV_T002_hides_doc_ids",
        "input": { "answerText": "doc:abc123 contains the clause", "signals": { "userRequestedIds": false } },
        "expect": { "actionsAny": ["hide_internal_ids"] }
      },
      {
        "id": "PRIV_T003_masks_cpf",
        "input": { "answerText": "CPF: 123.456.789-10", "signals": { "userAskedForExactValue": false } },
        "expect": { "actionsAny": ["mask_sensitive_ids_keep_last_4"] }
      }
    ]
  }
}
