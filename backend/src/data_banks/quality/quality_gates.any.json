{
  "_meta": {
    "id": "quality_gates",
    "version": "3.1.0",
    "description": "Post-generation verification gates for Koda answers. Guarantees: (1) never answer from the wrong doc when explicit docRef exists, (2) nav_pills responses stay UI-safe, (3) block malformed/truncated numbers, (4) enforce markdown sanity, (5) reduce repetition and banned phrases, (6) keep output privacy-safe. Designed to be deterministic and explainable.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-01",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "pipelinePlacement": {
      "runAfter": [
        "render_policy",
        "placeholders_and_sanitization",
        "answer_style_policy",
        "doc_grounding_checks"
      ],
      "runBefore": [
        "final_output",
        "state_update_rules"
      ]
    },
    "modes": {
      "byEnv": {
        "production": {
          "strictness": "high",
          "failClosed": true
        },
        "staging": {
          "strictness": "high",
          "failClosed": true
        },
        "dev": {
          "strictness": "medium",
          "failClosed": false
        },
        "local": {
          "strictness": "medium",
          "failClosed": false
        }
      }
    },
    "limits": {
      "maxSourcesButtonsHard": 8
    },
    "normalization": {
      "navAnswerModes": [
        "nav_pills",
        "nav_pill"
      ],
      "stripDiacritics": true,
      "caseInsensitiveMatch": true,
      "collapseWhitespace": true
    },
    "integrationHooks": {
      "dedupeBankId": "dedupe_and_repetition",
      "piiLabelsBankId": "pii_field_labels"
    },
    "debugHooks": {
      "emitGateTrace": false,
      "traceKey": "qualityGateTrace",
      "maxTraceItems": 140
    },
    "gateSeverityByName": {
      "requested_slot_covered": "warn",
      "forbidden_adjacent_role_absent": "warn",
      "entity_role_consistency": "warn",
      "explicit_doc_enforcement": "block",
      "nav_pills_enforcement": "warn",
      "numeric_integrity": "warn",
      "repetition_and_banned_phrases": "warn",
      "privacy_minimal": "block",
      "final_consistency": "warn",
      "markdown_sanity": "warn",
      "no_raw_json": "warn",
      "structural_completeness": "warn"
    }
  },
  "gateOrder": [
    "explicit_doc_enforcement",
    "nav_pills_enforcement",
    "numeric_integrity",
    "markdown_sanity",
    "repetition_and_banned_phrases",
    "privacy_minimal",
    "final_consistency"
  ],
  "reasonCodes": {
    "wrong_doc": "wrong_doc",
    "numeric_malformed": "numeric_malformed",
    "json_disallowed": "json_disallowed",
    "nav_missing_buttons": "nav_missing_buttons"
  },
  "gates": {
    "explicit_doc_enforcement": {
      "enabled": true,
      "checks": [
        {
          "id": "QG_DOC_001_explicit_docref_requires_single_doc",
          "severity": "error",
          "description": "If query has an explicit filename/docId, chosen docs and sources must match that explicit ref.",
          "condition": "context.explicitDocRef.present == true AND context.chosenDocs.count >= 1 AND context.chosenDocs.allMatchExplicit != true",
          "actionOnFail": "fail_hard_wrong_doc",
          "reasonCode": "wrong_doc"
        },
        {
          "id": "QG_DOC_002_sources_must_not_include_other_docs_when_explicit",
          "severity": "error",
          "description": "If explicit docRef exists, attachments/source_buttons must not contain other docs.",
          "condition": "context.explicitDocRef.present == true AND attachments.source_buttons.containsNonExplicit == true",
          "actionOnFail": "strip_wrong_sources_and_regen",
          "reasonCode": "wrong_doc"
        },
        {
          "id": "QG_DOC_003_active_docref_must_match_explicit",
          "severity": "error",
          "description": "If explicit ref is active, state.activeDocRef must match it (prevents silent drift).",
          "condition": "context.explicitDocRef.present == true AND context.state.activeDocRef.present == true AND context.state.activeDocRef.matchesExplicit != true",
          "actionOnFail": "fail_hard_wrong_doc",
          "reasonCode": "wrong_doc"
        }
      ]
    },
    "nav_pills_enforcement": {
      "enabled": true,
      "checks": [
        {
          "id": "QG_NAV_001_requires_source_buttons",
          "severity": "error",
          "description": "nav_pills must be pills-only (no inline file listing). If there are no pills, route to a nav-safe not-found.",
          "condition": "answerMode.in(['nav_pills','nav_pill']) == true AND attachments.source_buttons.count < 1",
          "actionOnFail": "emit_nav_pills_not_found",
          "reasonCode": "nav_missing_buttons"
        },
        {
          "id": "QG_NAV_002_body_must_be_concise",
          "severity": "warning",
          "description": "nav_pills body verification is limited to contract violations that can break the UI.",
          "condition": "answerMode.in(['nav_pills','nav_pill']) == true",
          "actionOnFail": "flag_nav_body_contract_violation"
        },
        {
          "id": "QG_NAV_003_no_sources_label_or_divider",
          "severity": "error",
          "description": "nav_pills must not show Sources label/dividers inside the answer body (UI handles pills).",
          "condition": "answerMode.in(['nav_pills','nav_pill']) == true",
          "patterns": [
            "\\bSources\\s*:\\b",
            "\\bFontes\\s*:\\b",
            "\\bFuentes\\s*:\\b"
          ],
          "actionOnFail": "strip_inline_sources"
        },
        {
          "id": "QG_NAV_004_no_inline_file_list",
          "severity": "error",
          "description": "nav_pills must not render filenames in the answer body.",
          "condition": "answerMode.in(['nav_pills','nav_pill']) == true",
          "patterns": [
            "\\d+\\.\\s+[^\\n]+\\.(pdf|xlsx?|pptx?|docx?|csv|txt|jpg|jpeg|png)",
            "^\\s*[-*]\\s+[^\\n]+\\.(pdf|xlsx?|pptx?|docx?|csv|txt|jpg|jpeg|png)"
          ],
          "actionOnFail": "strip_inline_file_list"
        }
      ]
    },
    "numeric_integrity": {
      "enabled": true,
      "checks": [
        {
          "id": "QG_NUM_001_no_truncated_currency",
          "severity": "error",
          "description": "Block obviously truncated currency (e.g., 'R$ 900' when context implies thousands).",
          "patterns": [
            "R\\$\\s*[\\d.,]+,\\s*$",
            "\\$\\s*[\\d.,]+,\\s*$",
            "R\\$\\s*\\d{1,3}\\b(?![\\d.,])",
            "\\$\\s*\\d{1,3}\\b(?![\\d.,])"
          ],
          "actionOnFail": "retry_retrieval_then_regen",
          "reasonCode": "numeric_malformed",
          "regenHint": "Copy numbers EXACTLY as shown in the source. Keep all digits, separators, and decimals. Do not truncate."
        },
        {
          "id": "QG_NUM_002_no_partial_numbers",
          "severity": "error",
          "description": "Block partial numbers ending with '.' or ',' or '**' artifacts.",
          "patterns": [
            "\\d+\\.$",
            "\\d+,$",
            "\\d+\\*+$"
          ],
          "actionOnFail": "retry_retrieval_then_regen",
          "reasonCode": "numeric_malformed"
        },
        {
          "id": "QG_NUM_003_currency_should_exist_verbatim_in_evidence",
          "severity": "error",
          "description": "If output contains currency values, they must be found verbatim in evidence for doc-grounded answers.",
          "condition": "answerMode.startsWith('doc_grounded') == true AND output.hasCurrency == true AND evidence.containsExactCurrency != true",
          "actionOnFail": "retry_retrieval_then_regen",
          "reasonCode": "numeric_malformed",
          "regenHint": "The currency value stated is not found verbatim in the evidence. Quote or extract the exact value from the document."
        }
      ]
    },
    "markdown_sanity": {
      "enabled": true,
      "checks": [
        {
          "id": "QG_MD_001_no_unclosed_code_fence",
          "severity": "error",
          "description": "No unclosed code fences (even though allowCodeBlocks=false for user output, models sometimes emit them).",
          "condition": "answerText.hasUnclosedCodeFence == true",
          "actionOnFail": "auto_fix_close_fence"
        },
        {
          "id": "QG_MD_002_table_separator_required",
          "severity": "warning",
          "description": "Repair broken markdown table separators or convert to key/value.",
          "condition": "answerText.hasBrokenTable == true",
          "actionOnFail": "repair_table_or_convert"
        },
        {
          "id": "QG_MD_003_no_invalid_unicode",
          "severity": "error",
          "description": "Normalize invalid unicode to display-safe output.",
          "condition": "answerText.hasInvalidUnicode == true",
          "actionOnFail": "unicode_normalize_display_safe"
        }
      ]
    },
    "repetition_and_banned_phrases": {
      "enabled": true,
      "checks": [
        {
          "id": "QG_REP_001_remove_banned_phrases",
          "severity": "warning",
          "condition": "answerText.containsBannedPhrases == true",
          "actionOnFail": "remove_banned_phrases"
        },
        {
          "id": "QG_REP_002_reduce_exact_repeats",
          "severity": "warning",
          "condition": "answerText.isNearDuplicateOfRecent == true",
          "actionOnFail": "light_rephrase_keep_facts"
        }
      ]
    },
    "privacy_minimal": {
      "enabled": true,
      "checks": [
        {
          "id": "QG_PRIV_001_strip_debug_sections",
          "severity": "error",
          "condition": "env.isProduction == true AND answerText.containsDebugTrace == true",
          "actionOnFail": "strip_debug_sections"
        },
        {
          "id": "QG_PRIV_002_hide_internal_ids",
          "severity": "warning",
          "condition": "answerText.containsInternalIds == true AND userAskedForIds != true",
          "actionOnFail": "hide_internal_ids"
        }
      ]
    },
    "final_consistency": {
      "enabled": true,
      "checks": [
        {
          "id": "QG_FIN_001_nav_pills_no_extra_blocks",
          "severity": "warning",
          "condition": "answerMode.in(['nav_pills','nav_pill']) == true AND answerText.sentenceCount > 3",
          "actionOnFail": "strip_body_keep_intro"
        },
        {
          "id": "QG_FIN_002_answer_not_empty",
          "severity": "error",
          "condition": "answerText.isEmpty == true",
          "actionOnFail": "emit_adaptive_failure_message"
        }
      ]
    }
  },
  "actions": {
    "definitions": [
      {
        "id": "fail_hard_wrong_doc",
        "type": "route",
        "notes": "Block answer and ask user to confirm/choose the intended doc (single question max)."
      },
      {
        "id": "strip_wrong_sources_and_regen",
        "type": "transform_then_regen",
        "notes": "Remove sources not matching explicit docRef then regenerate."
      },
      {
        "id": "emit_nav_pills_not_found",
        "type": "route",
        "notes": "nav_pills-specific fallback: show a short not-found message (no Sources label) and optionally offer doc choice."
      },
      {
        "id": "strip_inline_sources",
        "type": "transform",
        "notes": "Remove inline Sources/Fontes/Fuentes section from body."
      },
      {
        "id": "strip_inline_file_list",
        "type": "transform",
        "notes": "Remove inline filename lists; files must be represented via source_buttons."
      },
      {
        "id": "strip_body_keep_intro",
        "type": "transform",
        "notes": "Keep only the first sentence of the body (nav_pills intro only)."
      },
      {
        "id": "emit_adaptive_failure_message",
        "type": "route",
        "notes": "Select best fallback based on reason codes: no_docs/indexing/extraction_failed/scope_empty/scoped_not_found/weak_evidence."
      },
      {
        "id": "retry_retrieval_then_regen",
        "type": "route",
        "priority": "high",
        "notes": "Re-run retrieval with exact-match boosting for numbers then regenerate; include regenHint."
      },
      {
        "id": "convert_json_to_table_or_bullets",
        "type": "transform",
        "notes": "Convert JSON-like output into table/bullets."
      },
      {
        "id": "split_long_paragraphs",
        "type": "transform",
        "notes": "Split long paragraphs into short paragraphs (1–2 sentences each)."
      },
      {
        "id": "fix_bullet_hygiene",
        "type": "transform",
        "notes": "Split multi-sentence bullets into multiple bullets or trim to <=3 sentences each."
      },
      {
        "id": "repair_table_or_convert",
        "type": "transform",
        "notes": "Repair table separator/columns; if impossible convert to key/value bullets."
      },
      {
        "id": "auto_fix_close_fence",
        "type": "transform",
        "notes": "Close unclosed code fences to keep markdown valid."
      },
      {
        "id": "unicode_normalize_display_safe",
        "type": "transform",
        "notes": "Normalize unicode for display-safe output."
      },
      {
        "id": "auto_shorten_to_constraint",
        "type": "transform",
        "notes": "Auto-shorten to meet max sentence/char constraint without losing core answer."
      },
      {
        "id": "truncate_with_offer_narrow",
        "type": "transform",
        "notes": "Truncate and add one short line suggesting a narrower ask."
      },
      {
        "id": "ask_one_clarification",
        "type": "route",
        "notes": "Ask one crisp clarification using clarification_phrases bank."
      },
      {
        "id": "add_hedge_and_limit_scope",
        "type": "transform",
        "notes": "Reduce certainty; only claim what’s evidenced; suggest next best step."
      },
      {
        "id": "remove_banned_phrases",
        "type": "transform",
        "notes": "Strip banned/robotic phrases; keep meaning."
      },
      {
        "id": "light_rephrase_keep_facts",
        "type": "transform",
        "notes": "Rephrase without changing facts to reduce exact repetition."
      },
      {
        "id": "strip_debug_sections",
        "type": "transform",
        "notes": "Remove debug sections from user-visible output."
      },
      {
        "id": "hide_internal_ids",
        "type": "transform",
        "notes": "Hide internal ids unless user requested them."
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "QGT_001_nav_pills_strips_sources_label",
        "input": {
          "answerMode": "nav_pills",
          "answerText": "Here it is:\n\nSources: X",
          "attachments": {
            "source_buttons": {
              "count": 1
            }
          }
        },
        "expect": {
          "actionsAny": [
            "strip_inline_sources"
          ]
        }
      },
      {
        "id": "QGT_002_replace_bad_no_relevant",
        "input": {
          "answerText": "No relevant information found in your documents."
        },
        "expect": {
          "actionsAny": [
            "emit_adaptive_failure_message"
          ]
        }
      },
      {
        "id": "QGT_003_truncated_currency_blocks",
        "input": {
          "answerText": "Total investment is R$ 900"
        },
        "expect": {
          "actionsAny": [
            "retry_retrieval_then_regen"
          ]
        }
      },
      {
        "id": "QGT_004_explicit_doc_blocks_wrong_doc",
        "input": {
          "context": {
            "explicitDocRef": {
              "present": true
            },
            "chosenDocs": {
              "count": 1,
              "allMatchExplicit": false
            }
          }
        },
        "expect": {
          "actionsAny": [
            "fail_hard_wrong_doc"
          ]
        }
      }
    ]
  }
}
