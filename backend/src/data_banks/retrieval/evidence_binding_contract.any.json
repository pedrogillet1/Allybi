{
  "_meta": {
    "id": "evidence_binding_contract",
    "version": "1.0.0",
    "description": "Strict field-to-evidence binding contract for exact query fulfillment. Blocks role drift, forbidden substitutions, and quote-free table/value inference unless explicitly allowed by evidence evidence signals.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "koda-retrieval",
    "compat": ">=1.0.0",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts",
      "services/core/banks/runtimeWiringIntegrity.service.ts"
    ],
    "tests": [
      "src/tests/certification/bank-wave-runtime-metadata.cert.test.ts",
      "src/tests/certification/runtime-wiring.cert.test.ts"
    ],
    "changeLog": [
      "Added strict binding contract for exact field and role matching",
      "Added explicit allowed and forbidden substitution map",
      "Added weak-evidence fallback signals for cautious answer mode"
    ]
  },
  "config": {
    "enabled": true,
    "mode": "strict_field_exactness",
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id",
    "requireRequestedFieldAnchor": true,
    "requireRoleAnchor": true,
    "requireSourceSpan": true,
    "requiredEvidenceFields": [
      "docId",
      "title",
      "filename",
      "location",
      "sourceSpan",
      "fieldCanonical",
      "value"
    ],
    "substitutionPolicy": {
      "allowFieldAlias": true,
      "allowRoleAlias": true,
      "forbidRoleCollision": true,
      "default": "forbid",
      "maxSubstitutionsPerClaim": 1,
      "requireSubstitutionEvidence": true
    }
  },
  "runtimeUsageNotes": {
    "selectionStage": "after retrieval ranking before evidence packaging",
    "consumer": "retrieval evidence resolver",
    "intent": "enforce exact field binding and prevent role/value drift",
    "emittedSignals": [
      "fieldBindingAccepted",
      "fieldBindingRejected",
      "fieldSubstitutionUsed",
      "requiredClarificationType"
    ]
  },
  "allowedSubstitutions": [
    {
      "fromCanonical": "amount_due",
      "allowedAlias": [
        "balance_due",
        "total_due"
      ],
      "guard": "exact_same_unit_and_period_required",
      "forbidden": [
        "total"
      ]
    },
    {
      "fromCanonical": "coverage_period",
      "allowedAlias": [
        "period",
        "reference_period"
      ],
      "guard": "unit_not_required",
      "forbidden": [
        "as_of_date"
      ]
    },
    {
      "fromCanonical": "issued_by",
      "allowedAlias": [
        "issuer",
        "authorized_issuer"
      ],
      "guard": "role_match_required",
      "forbidden": [
        "owner"
      ]
    }
  ],
  "forbiddenSubstitutions": [
    {
      "fromCanonical": "owner",
      "toCanonical": "signer",
      "reason": "high role-confusion risk: ownership and signature are not interchangeable"
    },
    {
      "fromCanonical": "owner",
      "toCanonical": "beneficiary",
      "reason": "different legal capacity and obligation set"
    },
    {
      "fromCanonical": "subscriber",
      "toCanonical": "patient",
      "reason": "can overlap in context but are not equivalent in evidence extraction"
    },
    {
      "fromCanonical": "witness",
      "toCanonical": "signer",
      "reason": "signature witnessing does not imply signatory authority"
    },
    {
      "fromCanonical": "issuer",
      "toCanonical": "owner",
      "reason": "issuer role is declaration authority, not title owner"
    }
  ],
  "rules": [
    {
      "id": "EBC_001_missing_requested_field_anchor",
      "trigger": "Question asks for a field-level fact but no requested field anchor is present",
      "check": "context.intent == 'extract' AND binding.requestedField == null",
      "failureAction": "ASK_FIELD_CLARIFICATION",
      "severity": "error",
      "reasonCode": "missing_requested_field_anchor"
    },
    {
      "id": "EBC_002_non_anchor_field_candidate",
      "trigger": "Retrieved item maps to a near-match field but not to the requested canonical field",
      "check": "binding.isExactFieldMatch == false AND binding.fieldSubstitutionAttempted == false",
      "failureAction": "HARD_BLOCK_ITEM_AND_REDUCE_SCORE",
      "severity": "high",
      "reasonCode": "exact_field_match_required"
    },
    {
      "id": "EBC_003_forbidden_field_substitution",
      "trigger": "A candidate was generated by a forbidden role/field substitution",
      "check": "binding.forbiddenSubstitution == true",
      "failureAction": "REJECT_SUBSTITUTION",
      "severity": "error",
      "reasonCode": "forbidden_field_or_role_substitution"
    },
    {
      "id": "EBC_004_role_mismatch_without_confirmation",
      "trigger": "Requested role and extracted role are different and no confirmation signal exists",
      "check": "context.queryRole != null AND context.queryRole != candidate.role AND candidate.confirmedRoleSubstitution != true",
      "failureAction": "ASK_ROLE_CLARIFICATION",
      "severity": "high",
      "reasonCode": "role_conflict_no_confirmation"
    },
    {
      "id": "EBC_005_missing_source_span_for_binding",
      "trigger": "Evidence item has field value but no usable source span",
      "check": "candidate.value != null AND candidate.sourceSpan == null",
      "failureAction": "DROP_ITEM_UNLESS_hard_required",
      "severity": "high",
      "reasonCode": "no_source_span_for_bound_field"
    },
    {
      "id": "EBC_006_double_binding_without_scope",
      "trigger": "Same query needs two role-specific fields but candidates are merged into a single role",
      "check": "query.requiresMultiField == true AND context.boundRoles.uniquesCount == 1 AND query.requiredRolesCount > 1",
      "failureAction": "ASK_FIELD_ROLE_SPLIT",
      "severity": "warning",
      "reasonCode": "multi_field_merge_detected"
    },
    {
      "id": "EBC_007_value_from_forbidden_aggregator_without_context",
      "trigger": "Binding uses total/aggregate field for an atomic question",
      "check": "query.answerRequiresAtomic == true AND candidate.isAggregate == true",
      "failureAction": "RETURN_AGGREGATE_DISCLOSURE",
      "severity": "warning",
      "reasonCode": "aggregate_used_for_atomic_request"
    },
    {
      "id": "EBC_008_low_binding_confidence_with_substitution",
      "trigger": "Allowed substitution used with confidence below threshold",
      "check": "binding.fieldSubstitutionAttempted == true AND binding.evidenceConfidence < 0.82",
      "failureAction": "ASK_CAUTIOUS_RETRY",
      "severity": "warning",
      "reasonCode": "weak_substitution_confidence"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "evidence_binding_owner_not_allowed_as_signer",
        "input": {
          "binding": {
            "queryRole": "owner",
            "candidateRole": "signer",
            "forbiddenSubstitution": true
          }
        },
        "expect": {
          "failureAction": "ASK_ROLE_CLARIFICATION"
        }
      },
      {
        "id": "evidence_binding_exact_field_required",
        "input": {
          "context": {
            "intent": "extract"
          },
          "binding": {
            "requestedField": "total_due",
            "isExactFieldMatch": false,
            "fieldSubstitutionAttempted": false
          }
        },
        "expect": {
          "failureAction": "HARD_BLOCK_ITEM_AND_REDUCE_SCORE"
        }
      },
      {
        "id": "evidence_binding_forbidden_merge",
        "input": {
          "query": {
            "requiresMultiField": true
          },
          "context": {
            "boundRoles": {
              "uniquesCount": 1
            },
            "requiredRolesCount": 2
          }
        },
        "expect": {
          "failureAction": "ASK_FIELD_ROLE_SPLIT"
        }
      }
    ]
  }
}
