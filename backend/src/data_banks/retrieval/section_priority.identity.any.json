      ],
      "operators": [
        "advise"
      ],
      "domains": [
        "identity"
      ],
      "requireDomainMatch": true,
      "sections": [
        "personal_information",
        "document_details",
        "validity_information",
        "issuing_authority",
        "biometric_data"
      ],
      "docTypes": [
        "birth_certificate",
