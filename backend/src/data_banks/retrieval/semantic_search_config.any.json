{
  "_meta": {
    "id": "semantic_search_config",
    "version": "1.0.0",
    "description": "Deterministic semantic retrieval configuration for Koda. Defines embedding/search behavior, hybrid retrieval phases, query expansion gating, scope handling, and evidence candidate assembly without guessing. Prevents wrong-doc drift, over-broad semantic expansion, and unstable retrieval results across environments.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-retrieval",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added deterministic actionsContract and phase ordering for semantic retrieval",
      "Added scope-aware gating, expansion policy, and negative constraints integration points",
      "Added multilingual query normalization hooks and regression-focused tests"
    ]
  },
  "config": {
    "enabled": true,
    "mode": "hybrid_semantic_first_then_lexical_rescue",
    "preserveOriginalQuery": true,
    "neverInventEvidence": true,
    "neverAssumeLocale": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_phases_in_order",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_expansion"
      },
      "thresholds": {
        "minSemanticScore": 0.55,
        "minLexicalScore": 0.15,
        "minHybridScore": 0.58,
        "maxCandidateDocsSoft": 8,
        "maxCandidateDocsHard": 16,
        "maxChunksSoft": 18,
        "maxChunksHard": 36,
        "expansionAllowedMinConfidence": 0.8,
        "expansionDisallowedMaxAmbiguity": 0.6
      },
      "conflictResolution": {
        "ifScopeHardLockAndCorpusSearch": "scope_wins",
        "ifExpansionAndExplicitPhraseQuery": "no_expansion",
        "ifMultiplePhasesProduceSameChunk": "keep_highest_score",
        "ifSemanticAndLexicalDisagree": "prefer_scoped_and_high_precision"
      }
    },
    "integrationHooks": {
      "normalizers": [
        "tokenization_rules",
        "whitespace_rules",
        "casing_rules",
        "stopwords_query",
        "language_indicators",
        "month_normalization",
        "number_normalization",
        "units_normalization",
        "currency_formats",
        "filename_normalization",
        "stopwords_docnames",
        "doc_aliases"
      ],
      "negatives": [
        "retrieval_negatives",
        "unsafe_patterns"
      ],
      "boosts": [
        "keyword_boost_rules",
        "doc_title_boost_rules",
        "doc_type_boost_rules",
        "recency_boost_rules",
        "diversification_rules"
      ],
      "packaging": [
        "evidence_packaging"
      ]
    },
    "embedding": {
      "provider": "pluggable",
      "modelId": "embedding_model_placeholder",
      "vectorDimensions": 0,
      "distanceMetric": "cosine",
      "normalizeVectors": true,
      "cache": {
        "enabled": true,
        "ttlSeconds": 3600,
        "keyFields": ["normalizedQuery", "scopeKey", "corpusVersion"]
      }
    },
    "hybridPhases": [
      {
        "id": "phase_semantic_primary",
        "type": "semantic",
        "enabled": true,
        "k": 80,
        "fetchChunksPerDocSoft": 4,
        "fetchChunksPerDocHard": 8,
        "minScore": 0.55,
        "reasonCode": "semantic_primary"
      },
      {
        "id": "phase_lexical_rescue",
        "type": "lexical",
        "enabled": true,
        "k": 120,
        "fetchChunksPerDocSoft": 3,
        "fetchChunksPerDocHard": 6,
        "minScore": 0.15,
        "reasonCode": "lexical_rescue"
      },
      {
        "id": "phase_structural_anchors",
        "type": "structural",
        "enabled": true,
        "k": 60,
        "anchors": ["headings", "captions", "toc_signal", "table_headers"],
        "reasonCode": "structural_anchor_boost"
      }
    ],
    "scopeHandling": {
      "hardLockRules": {
        "respectExplicitDocLock": true,
        "respectExplicitSheetLock": true,
        "discoveryCanIgnoreDocLock": true,
        "hardLockWinsOverExpansion": true
      },
      "docSelection": {
        "candidateDocSourceOrder": ["explicit_doc_ref", "active_doc_lock", "doc_aliases", "corpus_wide"],
        "maxCandidateDocsSoft": 8,
        "maxCandidateDocsHard": 16
      },
      "chunkSelection": {
        "maxChunksSoft": 18,
        "maxChunksHard": 36,
        "preferSpreadAcrossDocs": true,
        "preferTopicalClusters": true
      }
    },
    "queryExpansionPolicy": {
      "enabled": true,
      "neverExpandQuotedText": true,
      "neverExpandFilenames": true,
      "neverExpandExplicitMetrics": true,
      "expansionStyles": ["synonyms", "abbreviations", "metric_aliases"],
      "gatingSignals": {
        "allowExpansionSignal": "signals.allowExpansion",
        "explicitPhraseSignal": "signals.hasQuotedText",
        "explicitDocLockSignal": "signals.explicitDocLock"
      }
    },
    "dedupePolicy": {
      "enabled": true,
      "dedupeBy": ["docId", "locationKey", "normalizedSnippetHash"],
      "maxNearDuplicatePerDoc": 3,
      "nearDuplicateWindowChars": 280
    }
  },
  "rules": [
    {
      "id": "semantic_phase_order_enforced",
      "scope": "global",
      "description": "Run retrieval phases in the configured order and merge candidates deterministically.",
      "appliesTo": ["retrieval_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "enforce_phase_order",
        "order": ["phase_semantic_primary", "phase_lexical_rescue", "phase_structural_anchors"]
      },
      "reasonCode": "phase_order_enforced",
      "severity": "high"
    },
    {
      "id": "scope_hard_lock_blocks_corpus_search",
      "scope": "global",
      "description": "When explicit doc lock is active, block corpus-wide retrieval and restrict candidates to locked scope.",
      "appliesTo": ["retrieval_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.explicitDocLock", "op": "eq", "value": true },
          { "path": "signals.intentFamily", "op": "neq", "value": "doc_discovery" }
        ]
      },
      "action": {
        "type": "restrict_scope_to_locked_doc"
      },
      "reasonCode": "explicit_doc_lock_enforced",
      "severity": "critical"
    },
    {
      "id": "disallow_expansion_for_quoted_or_filename",
      "scope": "global",
      "description": "Disable query expansion when quoted text or filenames are present to prevent semantic drift.",
      "appliesTo": ["retrieval_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "any": [
          { "path": "signals.hasQuotedText", "op": "eq", "value": true },
          { "path": "signals.hasFilename", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "disable_query_expansion"
      },
      "reasonCode": "expansion_blocked_for_literals",
      "severity": "high"
    },
    {
      "id": "expansion_allowed_only_when_confident",
      "scope": "global",
      "description": "Allow query expansion only when intent is clear and confidence is high; otherwise keep query tight.",
      "appliesTo": ["retrieval_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.allowExpansion", "op": "eq", "value": true },
          { "path": "metrics.intentConfidence", "op": "gte", "value": 0.8 },
          { "path": "metrics.queryAmbiguity", "op": "lt", "value": 0.6 }
        ]
      },
      "action": {
        "type": "enable_query_expansion",
        "styles": ["synonyms", "abbreviations", "metric_aliases"]
      },
      "reasonCode": "expansion_enabled_confident",
      "severity": "medium"
    },
    {
      "id": "candidate_limits_enforced",
      "scope": "global",
      "description": "Enforce candidate doc/chunk caps and apply dedupe before packaging evidence.",
      "appliesTo": ["retrieval_pipeline"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "enforce_candidate_limits_and_dedupe",
        "maxCandidateDocsSoft": 8,
        "maxCandidateDocsHard": 16,
        "maxChunksSoft": 18,
        "maxChunksHard": 36
      },
      "reasonCode": "candidate_limits_enforced",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "SSC_001_phase_order_and_merge",
        "context": { "signals": { "intentFamily": "documents" } },
        "input": "Find NOI in the report",
        "expect": { "phasesRunInOrder": ["phase_semantic_primary", "phase_lexical_rescue", "phase_structural_anchors"] }
      },
      {
        "id": "SSC_002_doc_lock_blocks_corpus",
        "context": { "signals": { "explicitDocLock": true, "intentFamily": "documents" } },
        "input": "What does it say about capex?",
        "expect": { "scopeRestrictedToLockedDoc": true }
      },
      {
        "id": "SSC_003_discovery_can_ignore_lock",
        "context": { "signals": { "explicitDocLock": true, "intentFamily": "doc_discovery" } },
        "input": "Which files mention ROI?",
        "expect": { "corpusSearchAllowed": true }
      },
      {
        "id": "SSC_004_no_expansion_for_quoted",
        "context": { "signals": { "hasQuotedText": true, "allowExpansion": true } },
        "input": "Find \"net operating income\"",
        "expect": { "queryExpansionEnabled": false }
      },
      {
        "id": "SSC_005_no_expansion_for_filename",
        "context": { "signals": { "hasFilename": true, "allowExpansion": true } },
        "input": "Open report_Q4_2023.pdf and find NOI",
        "expect": { "queryExpansionEnabled": false }
      },
      {
        "id": "SSC_006_expansion_only_when_confident",
        "context": { "signals": { "allowExpansion": true }, "metrics": { "intentConfidence": 0.9, "queryAmbiguity": 0.2 } },
        "input": "Find NOI",
        "expect": { "queryExpansionEnabled": true }
      },
      {
        "id": "SSC_007_multilingual_pt_semantic",
        "context": { "signals": { "allowExpansion": true }, "metrics": { "intentConfidence": 0.9, "queryAmbiguity": 0.2 } },
        "input": "Encontre NOI no relatório",
        "expect": { "phasesRunInOrder": ["phase_semantic_primary", "phase_lexical_rescue", "phase_structural_anchors"] }
      },
      {
        "id": "SSC_008_regression_no_wrong_doc_drift_after_lock",
        "context": { "signals": { "explicitDocLock": true, "intentFamily": "documents" }, "metrics": { "candidateDocCountOutsideLock": 1 } },
        "input": "Summarize it",
        "expect": { "outsideLockCandidatesExcluded": true }
      }
    ]
  }
}
