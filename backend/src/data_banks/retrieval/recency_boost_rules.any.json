{
  "_meta": {
    "id": "recency_boost_rules",
    "version": "1.0.0",
    "description": "Deterministic recency boost rules for Koda retrieval. Applies small, controlled freshness preference to recently uploaded/modified documents without overriding relevance. Includes safeguards to prevent recency bias from causing wrong-doc drift and supports time-filtered queries correctly.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-retrieval",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "applyStage": "doc_ranking_post_relevance",
    "softPreferenceOnly": true,
    "neverOverrideExplicitDocLock": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_highest_then_sum_with_cap",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxTotalRecencyBoost": 0.08,
        "maxBoostPerRule": 0.05,
        "recentDaysStrong": 7,
        "recentDaysMedium": 30,
        "recentDaysLight": 90
      },
      "conflictResolution": {
        "ifExplicitTimeFilterPresent": "reduce_recency_weight",
        "ifDocLock": "disable_recency"
      }
    },
    "recencyWeights": {
      "strong": 0.05,
      "medium": 0.03,
      "light": 0.015
    },
    "timeFilterGuards": {
      "enabled": true,
      "reduceFactorWhenTimeConstraintsPresent": 0.5,
      "disableWhenExplicitYearOrQuarterComparison": true
    }
  },
  "rules": [
    {
      "id": "disable_recency_when_doc_locked",
      "scope": "global",
      "description": "Disable recency boosts entirely when explicit doc lock is active.",
      "appliesTo": ["doc_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.explicitDocLock", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "disable_recency_boost"
      },
      "reasonCode": "recency_disabled_doc_lock",
      "severity": "critical"
    },
    {
      "id": "strong_recency_boost",
      "scope": "global",
      "description": "Apply strong recency boost for very recent documents (<= 7 days).",
      "appliesTo": ["doc_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "metrics.docAgeDays", "op": "lte", "value": 7 }
        ]
      },
      "action": {
        "type": "apply_recency_boost",
        "boost": 0.05
      },
      "reasonCode": "recency_strong",
      "severity": "low"
    },
    {
      "id": "medium_recency_boost",
      "scope": "global",
      "description": "Apply medium recency boost for documents up to 30 days old.",
      "appliesTo": ["doc_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "metrics.docAgeDays", "op": "gt", "value": 7 },
          { "path": "metrics.docAgeDays", "op": "lte", "value": 30 }
        ]
      },
      "action": {
        "type": "apply_recency_boost",
        "boost": 0.03
      },
      "reasonCode": "recency_medium",
      "severity": "low"
    },
    {
      "id": "light_recency_boost",
      "scope": "global",
      "description": "Apply light recency boost for documents up to 90 days old.",
      "appliesTo": ["doc_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "metrics.docAgeDays", "op": "gt", "value": 30 },
          { "path": "metrics.docAgeDays", "op": "lte", "value": 90 }
        ]
      },
      "action": {
        "type": "apply_recency_boost",
        "boost": 0.015
      },
      "reasonCode": "recency_light",
      "severity": "low"
    },
    {
      "id": "reduce_recency_when_time_constraints_present",
      "scope": "cross_family",
      "description": "Reduce recency effect when user query has explicit time constraints (year/quarter/month) to avoid biasing toward newest.",
      "appliesTo": ["doc_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "any": [
          { "path": "signals.timeConstraintsPresent", "op": "eq", "value": true },
          { "path": "signals.explicitYearOrQuarterComparison", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "scale_recency_boost",
        "factor": 0.5
      },
      "reasonCode": "recency_scaled_time_constraints",
      "severity": "medium"
    },
    {
      "id": "cap_total_recency_boost",
      "scope": "global",
      "description": "Cap total recency boost to keep relevance dominant.",
      "appliesTo": ["doc_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "cap_boost",
        "cap": 0.08
      },
      "reasonCode": "recency_capped",
      "severity": "medium"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "REC_001_disable_when_doc_locked",
        "context": { "signals": { "explicitDocLock": true }, "metrics": { "docAgeDays": 2 } },
        "expect": { "recencyBoostApplied": false }
      },
      {
        "id": "REC_002_strong_recency",
        "context": { "metrics": { "docAgeDays": 3 } },
        "expect": { "recencyBoost": 0.05 }
      },
      {
        "id": "REC_003_medium_recency",
        "context": { "metrics": { "docAgeDays": 20 } },
        "expect": { "recencyBoost": 0.03 }
      },
      {
        "id": "REC_004_light_recency",
        "context": { "metrics": { "docAgeDays": 60 } },
        "expect": { "recencyBoost": 0.015 }
      },
      {
        "id": "REC_005_reduce_when_time_constraints",
        "context": { "signals": { "timeConstraintsPresent": true }, "metrics": { "docAgeDays": 3, "rawRecencyBoost": 0.05 } },
        "expect": { "scaledFactor": 0.5 }
      },
      {
        "id": "REC_006_cap_total_recency",
        "context": { "metrics": { "totalRecencyBoostBeforeCap": 0.2 } },
        "expect": { "totalRecencyBoostAfterCapAtOrBelow": 0.08 }
      },
      {
        "id": "REC_007_multilingual_es_time_constraints",
        "context": { "signals": { "timeConstraintsPresent": true }, "metrics": { "docAgeDays": 5, "rawRecencyBoost": 0.05 } },
        "input": "comparar 2022 vs 2023",
        "expect": { "scaledFactor": 0.5 }
      }
    ]
  }
}
