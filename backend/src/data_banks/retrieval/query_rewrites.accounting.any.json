      "id": "accounting_rewrite_ap_guarded",
      "priority": 96,
      "enabled": true,
      "intents": [
        "documents"
      ],
      "operators": [
        "extract",
        "calculate",
        "compare",
        "evaluate",
        "locate",
        "monitor",
        "advise"
      ],
