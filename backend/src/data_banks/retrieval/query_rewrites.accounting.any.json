        "accounting"
      ],
      "languages": [
        "en",
        "pt",
        "any"
      ],
      "patterns": [
        "\\bap\\b"
      ],
      "negativePatterns": [
        "\\bemployee review\\b",
        "\\bperformance review\\b",
        "\\badvanced placement\\b"
      ],
      "requireContextAny": [
        "accounts payable",
        "ap aging",
        "aging report",
        "vendor invoice",
        "invoice aging",
        "fornecedores",
        "contas a pagar"
      ],
      "requireContextAll": [],
      "forbidContextAny": [
        "athletic performance",
        "class placement"
      ],
      "rewrites": [
        {
          "value": "accounts payable",
          "weight": 1
        },
        {
          "value": "ap aging report",
          "weight": 0.92
        },
        {
          "value": "vendor invoice payables",
          "weight": 0.86
        }
      ],
      "conditions": {
        "requireDomainMatch": true,
        "domains": [
          "accounting"
        ]
      }
    },
