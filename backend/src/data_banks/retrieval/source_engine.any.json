  "operators": [
    {
      "operatorId": "source.locate_exact",
      "mode": "locate",
      "requiredOutputs": [
        "citations"
      ],
      "default": true
    },
    {
      "operatorId": "source.quote_short",
      "mode": "quote",
      "requiredOutputs": [
        "quote",
        "citations"
      ],
      "default": true
    },
    {
      "operatorId": "source.explain_with_evidence",
      "mode": "explain",
      "requiredOutputs": [
        "answerText",
        "citations",
        "assumptions"
      ],
      "default": true
    },
    {
      "operatorId": "source.validate_claims",
      "mode": "validate",
      "requiredOutputs": [
        "citations",
        "validation",
        "gaps"
      ],
      "default": true
    },
    {
      "operatorId": "source.compare_sources",
      "mode": "compare",
      "requiredOutputs": [
        "citations",
        "diffSummary"
      ],
      "default": false
    },
    {
      "operatorId": "assistant.advise_next_steps",
      "mode": "advise",
      "requiredOutputs": [
        "nextActions",
        "citations_or_constraints"
      ],
      "default": true
    }
  ],
  "outputSchemas": {
    "citation": {
      "docId": "string",
      "docTitle": "string",
      "layerId": "string",
      "locationType": "string",
      "location": {
        "page": "number?",
        "slide": "number?",
        "sheet": "string?",
        "cell": "string?",
        "range": "string?",
        "headingPath": "string?",
        "paraIndex": "number?",
        "charStart": "number?",
        "charEnd": "number?",
        "blockId": "string?",
        "bbox": "string?",
        "confidence": "number?",
        "url": "string?",
        "title": "string?",
        "publishedAt": "string?"
      },
      "excerpt": "string"
    },
    "answer": {
      "answerText": "string",
      "citations": "citation[]",
      "confidence": "number",
      "uncertainty": "string?",
      "assumptions": "string[]?"
    }
  },
  "guardrails": {
    "requireCitations": true,
    "refuseIfNoEvidence": true,
    "noHallucinatedSources": true,
    "safetyPolicies": {
      "finance": {
        "requireCitations": true,
        "refuseIfNoEvidence": true
      },
      "legal": {
        "requireCitations": true,
        "refuseIfNoEvidence": true
      },
      "medical": {
        "requireCitations": true,
        "refuseIfNoEvidence": true
      },
      "tax_us": {
        "requireCitations": true,
        "refuseIfNoEvidence": true
      },
      "tax_br": {
        "requireCitations": true,
        "refuseIfNoEvidence": true
      }
    },
    "privacy": {
      "storeRawText": false,
      "storeQueryText": false,
      "storeQueryHash": true,
      "storeConnectorBodiesByDefault": false
    }
  },
  "telemetry": {
    "emit": [
      "rag.query_received",
      "router.decision",
      "retrieval.started",
      "retrieval.completed",
      "retrieval.citations_selected",
      "rag.answer_generated",
      "rag.answer_failed",
      "llm.call_completed",
      "security.refusal_no_evidence"
    ],
    "kpis": [
      "citation_coverage",
      "avg_citations_per_answer",
      "scoped_retrieval_rate",
      "fallback_rate",
      "no_evidence_refusal_rate",
      "top_score_p50",
      "top_score_p95",
      "domain_distribution",
      "intent_distribution"
    ],
    "integrityChecks": [
      "citations_have_locations",
      "citations_have_docId",
      "citations_have_layerId",
      "no_plaintext_query_stored"
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "SE_001_exact_location",
        "query": "Where does it say the total investment amount? Give exact page/slide/cell.",
        "expected": {
          "minCitations": 1,
          "mustIncludeLocation": true,
          "maxExcerptChars": 220
        }
      },
      {
        "id": "SE_002_compare_sources",
        "query": "Compare the net profit in two uploaded financial documents and cite both sources.",
        "expected": {
          "minCitations": 2,
          "mustIncludeLocation": true
        }
      },
      {
        "id": "SE_003_refuse_no_evidence",
        "query": "If there is no evidence in my documents, tell me you can't find it.",
        "expected": {
          "mustRefuseIfNoEvidence": true
        }
      },
      {
        "id": "SE_004_no_filename_match",
        "query": "What are the Koda pillars?",
        "expected": {
          "excludeFilenameOnlyMatches": true,
          "onlyContentMatches": true
        }
      },
      {
        "id": "SE_005_strict_content_match",
        "query": "What does the document say about sprint retrospectives?",
        "expected": {
          "minPhraseLength": 5,
          "requireContentOverlap": true
        }
      }
    ]
  },
  "retention": {
    "telemetryDays": 180,
    "derivedDataDays": 3650
  }
}
