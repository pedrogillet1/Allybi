{
  "_meta": {
    "id": "source_engine",
    "version": "1.0.0",
    "domain": "meta_source_engine",
    "description": "Vast coverage source engine with strict provenance. Feels ChatGPT-wide by routing across user/org/connector/domain/public sources while enforcing exact citations and location metadata for any claim grounded in private data.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-02-04",
    "owner": "koda-core",
    "compat": ">=1.0.0",
    "usedBy": [
      "services/core/retrieval/retrievalEngine.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "riskLevel": "high"
  },
  "coverageLayers": [
    {
      "layerId": "user_vault",
      "priority": 100,
      "sourceTypes": [
        "user_uploads"
      ],
      "privacyClass": "private",
      "mustCite": true
    },
    {
      "layerId": "org_vault",
      "priority": 90,
      "sourceTypes": [
        "org_uploads",
        "shared_workspace"
      ],
      "privacyClass": "private",
      "mustCite": true
    },
    {
      "layerId": "connectors",
      "priority": 80,
      "sourceTypes": [
        "gmail",
        "outlook",
        "slack",
        "gdrive"
      ],
      "privacyClass": "private",
      "mustCite": true,
      "connectorRules": {
        "gmail": {
          "defaultScope": "metadata_only",
          "allowBodyOptIn": true,
          "retentionDays": 90
        },
        "outlook": {
          "defaultScope": "metadata_only",
          "allowBodyOptIn": true,
          "retentionDays": 90
        },
        "slack": {
          "defaultScope": "channels_opt_in",
          "retentionDays": 30
        },
        "gdrive": {
          "defaultScope": "files_opt_in",
          "retentionDays": 365
        }
      }
    },
    {
      "layerId": "domain_packs",
      "priority": 70,
      "sourceTypes": [
        "domain_pack"
      ],
      "privacyClass": "internal",
      "mustCite": true
    },
    {
      "layerId": "public_knowledge",
      "priority": 10,
      "sourceTypes": [
        "web_retrieval",
        "curated_public_corpus"
      ],
      "privacyClass": "public",
      "mustCite": true,
      "publicRules": {
        "allowWebRetrieval": true,
        "cachePolicy": {
          "enabled": true,
          "ttlDays": 7,
          "storeFullText": false,
          "storeSnippetsOnly": true
        }
      }
    }
  ],
  "identityModel": {
    "canonicalDocId": "documentId",
    "canonicalChunkId": "chunkId",
    "locationTypes": [
      "pdf_page",
      "docx_heading",
      "pptx_slide",
      "xlsx_sheet_cell",
      "text_line",
      "image_ocr_block",
      "email_message",
      "slack_message",
      "web_source"
    ],
    "locationFieldsByType": {
      "pdf_page": [
        "page",
        "charStart",
        "charEnd"
      ],
      "docx_heading": [
        "headingPath",
        "paraIndex",
        "charStart",
        "charEnd"
      ],
      "pptx_slide": [
        "slide",
        "shapeId"
      ],
      "xlsx_sheet_cell": [
        "sheet",
        "cell",
        "range"
      ],
      "text_line": [
        "lineStart",
        "lineEnd"
      ],
      "image_ocr_block": [
        "blockId",
        "bbox",
        "confidence"
      ],
      "email_message": [
        "messageId",
        "threadId"
      ],
      "slack_message": [
        "channelId",
        "messageTs"
      ],
      "web_source": [
        "url",
        "title",
        "publishedAt"
      ]
    }
  },
  "domainRouter": {
    "domains": [
      "finance",
      "legal",
      "medical",
      "research",
      "comp_sci",
      "tax_us",
      "tax_br",
      "insurance",
      "general",
      "other"
    ],
    "intents": [
      "qa",
      "summarize",
      "extract",
      "compare",
      "compute",
      "validate",
      "explain",
      "advise",
      "monitor",
      "action"
    ],
    "fallbackDomain": "general",
    "fallbackIntent": "qa",
    "disambiguationPolicy": {
      "askClarifyingQuestionIf": [
        "domain_confidence_below_threshold",
        "multiple_domains_tied",
        "user_requests_action_without_target"
      ],
      "domainConfidenceThreshold": 0.62,
      "maxClarifyingQuestions": 1
    }
  },
  "terminology": {
    "synonyms": {
      "source": [
        "citation",
        "evidence",
        "reference",
        "where it says",
        "onde diz",
        "fonte"
      ],
      "page": [
        "p.",
        "page",
        "pagina",
        "página"
      ],
      "slide": [
        "slide",
        "diapositivo"
      ],
      "cell": [
        "cell",
        "célula",
        "celula",
        "sheet",
        "aba"
      ],
      "contract": [
        "agreement",
        "msa",
        "nda",
        "sow"
      ],
      "tax": [
        "imposto",
        "tributo",
        "irs",
        "receita federal"
      ]
    },
    "disambiguationRules": [
      {
        "ifQueryContains": [
          "page",
          "página",
          "p."
        ],
        "preferLocationType": "pdf_page"
      },
      {
        "ifQueryContains": [
          "slide",
          "diapositivo"
        ],
        "preferLocationType": "pptx_slide"
      },
      {
        "ifQueryContains": [
          "cell",
          "célula",
          "aba",
          "sheet"
        ],
        "preferLocationType": "xlsx_sheet_cell"
      }
    ]
  },
  "retrievalPolicy": {
    "strategy": "hybrid_with_rerank",
    "chunking": {
      "mode": "structure_aware",
      "maxTokens": 520,
      "overlap": 80,
      "tableHandling": "row_aware"
    },
    "ranking": {
      "stage1": "lexical",
      "stage2": "vector",
      "stage3": "reranker",
      "tieBreaker": "same_doc_proximity"
    },
    "scopeRules": [
      {
        "when": "query_refs_current_doc",
        "mode": "scoped_only",
        "maxDocs": 3
      },
      {
        "when": "user_selected_doc",
        "mode": "scoped_only",
        "maxDocs": 1
      },
      {
        "when": "no_doc_context",
        "mode": "scoped_then_global",
        "maxDocs": 8
      }
    ],
    "fallbackRules": {
      "allowGlobalSearch": true,
      "triggerIf": [
        "low_top_score",
        "insufficient_chunks"
      ],
      "minTopScore": 0.18,
      "minChunks": 6
    }
  },
  "sourceFiltering": {
    "hardRequirements": {
      "mustIncludeDocId": true,
      "mustIncludeLocation": true,
      "mustIncludeExcerpt": true,
      "rejectIfNoEvidenceForPrivateClaims": true
    },
    "matchingRules": {
      "minPhraseLength": 5,
      "minPhraseChars": 25,
      "minMeaningfulWords": 3,
      "minMatchScore": 2,
      "minFallbackScore": 1,
      "requireMultipleTermMatches": 3,
      "numericMatchThreshold": 2
    },
    "citationRules": {
      "minCitationsForPrivateClaims": 1,
      "maxCitations": 5,
      "excerptMaxChars": 220,
      "quoteMaxWords": 25,
      "format": "title + location + excerpt",
      "locationVerbosity": "full"
    },
    "exclusionRules": {
      "excludeFilenameOnlyMatches": true,
      "excludeGenericTermMatches": true,
      "excludeShortPhraseMatches": true
    },
    "conflictPolicy": {
      "whenSourcesDisagree": "present_both_and_flag_uncertainty",
      "requireTwoSourcesIf": [
        "compliance",
        "tax",
        "medical",
        "legal_high_risk"
      ]
    }
  },
