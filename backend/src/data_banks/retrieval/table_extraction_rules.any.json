{
  "_meta": {
    "id": "table_extraction_rules",
    "version": "1.0.0",
    "description": "Deterministic table extraction rules for Koda. Controls table detection, parsing, structural validation, numeric integrity checks, trimming, and evidence packaging across PDF/Docs/Spreadsheets. Prevents header hallucination, row/column invention, malformed table promotion, and unsafe numeric extraction from broken structure.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-retrieval",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "mode": "structure_first",
    "preferExplicitTables": true,
    "neverInventCells": true,
    "preserveOriginalText": true,
    "maxTablesPerDocSoft": 10,
    "maxTablesPerDocHard": 25,
    "maxRowsSoft": 30,
    "maxRowsHard": 120,
    "maxColsSoft": 10,
    "maxColsHard": 24,
    "minHeaderConfidence": 0.75,
    "minRowConsistency": 0.7,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_in_precedence_order_then_emit",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "hardBlockThreshold": 0.85,
        "softPenaltyThreshold": 0.35
      },
      "conflictResolution": {
        "ifHeaderAndNoHeaderConflict": "prefer_headered_when_confident",
        "ifMultipleTablesSameRegion": "pick_highest_structure_score"
      }
    },
    "outputs": {
      "evidenceShape": "table_evidence",
      "fields": [
        "docId",
        "title",
        "filename",
        "page",
        "sheet",
        "tableId",
        "bbox",
        "header",
        "rows",
        "structureScore",
        "numericIntegrityScore",
        "warnings"
      ]
    }
  },
  "rules": [
    {
      "id": "detect_explicit_table_structures",
      "scope": "global",
      "description": "Detect explicit table structures (grid lines, consistent separators, spreadsheet cell boundaries).",
      "appliesTo": ["table_extraction"],
      "triggerPatterns": {
        "en": ["\\|\\s*[^\\n]+\\s*\\|", "\\b(table|tabular)\\b", "\\b(sheet|worksheet|tab)\\b"],
        "pt": ["\\|\\s*[^\\n]+\\s*\\|", "\\b(tabela|tabular)\\b", "\\b(planilha|aba)\\b"],
        "es": ["\\|\\s*[^\\n]+\\s*\\|", "\\b(tabla|tabular)\\b", "\\b(hoja|pestaña)\\b"]
      },
      "action": {
        "type": "detect_tables",
        "detectors": ["grid", "delimiter", "sheet_cells"],
        "minColumns": 2,
        "minRows": 2
      },
      "reasonCode": "table_detect_explicit",
      "severity": "medium"
    },
    {
      "id": "header_row_inference_guarded",
      "scope": "global",
      "description": "Infer a header row only when confidence is high; otherwise keep header unknown (do not guess labels).",
      "appliesTo": ["table_extraction"],
      "when": {
        "all": [
          { "path": "metrics.headerConfidence", "op": "gte", "value": 0.75 }
        ]
      },
      "action": {
        "type": "set_header_policy",
        "policy": "use_inferred_header"
      },
      "reasonCode": "table_header_inferred",
      "severity": "low"
    },
    {
      "id": "no_header_when_low_confidence",
      "scope": "global",
      "description": "Disable header inference when header confidence is low; prevent header hallucination.",
      "appliesTo": ["table_extraction"],
      "when": {
        "all": [
          { "path": "metrics.headerConfidence", "op": "lt", "value": 0.75 }
        ]
      },
      "action": {
        "type": "set_header_policy",
        "policy": "no_header"
      },
      "reasonCode": "table_header_not_inferred",
      "severity": "high"
    },
    {
      "id": "row_consistency_validation",
      "scope": "global",
      "description": "Validate table structure by row consistency; penalize inconsistent column counts, merged-cell ambiguity, and empty-column drift.",
      "appliesTo": ["table_extraction"],
      "action": {
        "type": "validate_structure",
        "checks": ["row_column_consistency", "merged_cell_detection", "empty_column_detection"],
        "minRowConsistency": 0.7
      },
      "reasonCode": "table_structure_validated",
      "severity": "high"
    },
    {
      "id": "reject_malformed_tables_hard",
      "scope": "global",
      "description": "Hard-block malformed tables that fail structure thresholds or exceed hard caps.",
      "appliesTo": ["table_extraction"],
      "when": {
        "any": [
          { "path": "metrics.structureScore", "op": "lt", "value": 0.55 },
          { "path": "metrics.rowConsistency", "op": "lt", "value": 0.7 },
          { "path": "metrics.columnCount", "op": "gt", "value": 24 },
          { "path": "metrics.rowCount", "op": "gt", "value": 120 }
        ]
      },
      "action": {
        "type": "hard_block_table",
        "fallback": "emit_as_text_chunks"
      },
      "reasonCode": "table_malformed_blocked",
      "severity": "critical"
    },
    {
      "id": "numeric_integrity_checks_for_tables",
      "scope": "global",
      "description": "Run numeric integrity checks and attach warnings; do not change values.",
      "appliesTo": ["table_extraction"],
      "action": {
        "type": "validate_numeric_integrity",
        "checks": ["truncated_currency", "mixed_decimal_separators", "percent_vs_currency_collision", "range_preservation"],
        "attachWarnings": true
      },
      "reasonCode": "table_numeric_integrity_checked",
      "severity": "high"
    },
    {
      "id": "limit_table_emission",
      "scope": "global",
      "description": "Limit emitted tables and trim oversized tables while preserving header and top rows.",
      "appliesTo": ["table_extraction"],
      "action": {
        "type": "limit_and_trim_tables",
        "maxTablesSoft": 10,
        "maxTablesHard": 25,
        "maxRowsSoft": 30,
        "maxRowsHard": 120,
        "maxColsSoft": 10,
        "maxColsHard": 24,
        "trimPolicy": "preserve_header_and_top_rows"
      },
      "reasonCode": "table_emission_limited",
      "severity": "medium"
    },
    {
      "id": "table_to_evidence_packaging",
      "scope": "global",
      "description": "Package extracted tables into evidence objects with stable identifiers and provenance fields (page/sheet/bbox).",
      "appliesTo": ["table_extraction"],
      "action": {
        "type": "package_table_evidence",
        "stableTableId": true,
        "requireProvenance": true
      },
      "reasonCode": "table_packaged_as_evidence",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "TER_001_detect_markdown_table",
        "input": "| a | b |\n|---|---|\n| 1 | 2 |",
        "expect": { "tablesDetected": true, "minColumns": 2, "minRows": 2 }
      },
      {
        "id": "TER_002_no_header_low_confidence",
        "context": { "metrics": { "headerConfidence": 0.5 } },
        "expect": { "headerPolicy": "no_header" }
      },
      {
        "id": "TER_003_header_high_confidence",
        "context": { "metrics": { "headerConfidence": 0.9 } },
        "expect": { "headerPolicy": "use_inferred_header" }
      },
      {
        "id": "TER_004_reject_malformed_structure",
        "context": { "metrics": { "structureScore": 0.4, "rowConsistency": 0.5 } },
        "expect": { "tableBlocked": true, "fallback": "emit_as_text_chunks" }
      },
      {
        "id": "TER_005_numeric_integrity_warning",
        "input": "R$ 900\nR$ 1.234,56",
        "context": { "signals": { "tableExpected": true } },
        "expect": { "numericWarningsAttached": true }
      },
      {
        "id": "TER_006_limit_emission_caps_rows_cols",
        "context": { "metrics": { "rowCount": 200, "columnCount": 40 } },
        "expect": { "rowsCappedAt": 120, "colsCappedAt": 24 }
      },
      {
        "id": "TER_007_multilingual_pt_trigger",
        "input": "tabela de custos",
        "expect": { "tablesDetectedOrAttempted": true }
      },
      {
        "id": "TER_008_multilingual_es_trigger",
        "input": "tabla de ingresos",
        "expect": { "tablesDetectedOrAttempted": true }
      }
    ]
  }
}
