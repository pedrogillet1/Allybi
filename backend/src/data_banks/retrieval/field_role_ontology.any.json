  "forbiddenPairs": [
    {
      "left": "signer",
      "right": "owner",
      "reason": "same lexical context can exist but role semantics differ"
    },
    {
      "left": "patient",
      "right": "subscriber",
      "reason": "can co-refer but should never auto-substitute"
    },
    {
      "left": "beneficiary",
      "right": "issuer",
      "reason": "recipient vs source authority"
    },
    {
      "left": "witness",
      "right": "signer",
      "reason": "presence in same sentence often causes accidental collapse"
    }
  ],
  "rules": [
    {
      "id": "FRO_001_require_exact_role_forbidden_subs",
      "check": "query.roleMentioned == true AND binding.roleSubstitutionAttempted == true AND roles.canSubstitute == false",
      "failureAction": "BLOCK_ROLE_SUBSTITUTION",
      "severity": "high"
    },
    {
      "id": "FRO_002_patient_subscriber_disambiguation",
      "check": "context.roleCandidates.contains('patient') AND context.roleCandidates.contains('subscriber') AND context.roleCandidates.count > 1",
      "failureAction": "ASK_ROLE_DISAMBIGUATION",
      "severity": "error"
    },
    {
      "id": "FRO_003_owner_signer_disambiguation",
      "check": "context.roleCandidates.contains('owner') AND context.roleCandidates.contains('signer') AND context.roleCandidates.count > 1",
      "failureAction": "ASK_ROLE_DISAMBIGUATION",
      "severity": "error"
    },
    {
      "id": "FRO_004_witness_context_guard",
      "check": "binding.role == 'witness' AND binding.roleSource.hasNoSignatureCue == true",
      "failureAction": "ASK_SIGNING_CONTEXT",
      "severity": "warning"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "role_ontology_forbids_owner_as_signer",
        "input": {
          "query": {
            "roleCandidates": [
              "owner",
              "signer"
            ]
          },
          "context": {
            "roleCandidates": {
              "count": 2
            }
          }
        },
        "expect": {
          "failureAction": "ASK_ROLE_DISAMBIGUATION"
        }
      },
      {
        "id": "role_ontology_patient_vs_subscriber_disambiguate",
        "input": {
          "context": {
            "roleCandidates": {
              "contains": {
                "patient": true,
                "subscriber": true
              },
              "count": 2
            }
          }
        },
        "expect": {
          "failureAction": "ASK_ROLE_DISAMBIGUATION"
        }
      }
    ]
  }
}
