  "config": {
    "enabled": true,
    "deterministic": true,
    "sortBy": "id",
    "minRoleSignalConfidence": 0.8,
    "requireRoleAnchorIfAmbiguous": true
  },
  "runtimeUsageNotes": {
    "selectionStage": "before field binding and table row disambiguation",
    "consumer": "retrieval role resolver",
    "intent": "resolve signer/owner/witness/beneficiary/patient/subscriber role labels without silent role substitution",
    "emittedSignals": [
      "resolvedRole",
      "roleAnchorConfidence",
      "roleConfusionRisk",
      "requiresRoleClarification"
    ]
  },
