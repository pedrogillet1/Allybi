    "id": "field_role_ontology",
    "version": "1.0.0",
    "description": "Canonical role ontology and role-confusion graph used before exact-field binding.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "koda-retrieval",
    "compat": ">=1.0.0",
