      "templateId": "tmpl.histogram_distribution",
      "intentId": "histogram_distribution",
      "chartType": "histogram",
      "localeAware": true,
      "title": {
        "en": "histogram distribution chart",
        "pt": "grafico histogram distribution"
      },
      "axis": {
        "x": {
          "label": "x_axis",
          "sourceSlot": "input_range",
          "formatHint": "auto"
        },
        "y": {
          "label": "y_axis",
          "sourceSlot": "input_range",
          "formatHint": "numeric"
        }
      },
      "seriesPolicy": {
        "maxSeries": 4,
        "missingData": "skip_and_flag",
        "sortDefault": "none"
      },
      "visualDefaults": {
        "palette": "koda_default",
        "showLegend": false,
        "showDataLabels": false,
        "grid": "y_major"
      },
      "validationHooks": [
