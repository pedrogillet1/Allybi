    "pt": {
      "EDIT_CELL": "Atualizou **{{targetHint}}** para `{{value}}`.",
      "EDIT_RANGE": "Atualizou intervalo **{{targetHint}}** com novos valores.",
      "COMPUTE_BUNDLE__default": "Aplicou mudancas em **{{targetHint}}**.",
      "CREATE_CHART": "Criou grafico {{chartType}} de **{{targetHint}}**.",
