      "EDIT_DOCX_BUNDLE__replace_all": "Substituiu {{changes}} ocorrencia(s) de \"{{query}}\" por \"{{replacement}}\".",
      "EDIT_DOCX_BUNDLE__default": "Fez {{changes}} mudanca(s) no documento.",
      "ADD_PARAGRAPH": "Inseriu novo paragrafo{{locationHint}}.",
      "fallback": "Edicao aplicada em **{{filename}}**."
    }
  }
}
