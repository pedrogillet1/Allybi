{
  "_meta": {
    "id": "conversation_messages",
    "version": "1.2.0",
    "description": "ChatGPT-like conversational microcopy bank for non-document actions: greetings, thanks, acknowledgements, goodbyes, small talk, and lightweight 'help' nudges. Designed for high variety without meaning drift. Uses anti-repetition + seedable selection. Never hardcodes domain facts; only controls tone and flow.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "selection": {
      "method": "weighted_random",
      "temperature": 0.55,
      "preferShorterWhen": ["signals.userRequestedShort", "signals.oneLiner", "signals.justAnswer"],
      "minWeightToConsider": 0.02,
      "fallbackTemplateId": "conv_ack_minimal_en_01"
    },
    "style": {
      "maxSentences": 2,
      "maxCharsSoft": 220,
      "avoidEmoji": true,
      "avoidExclamation": true,
      "avoidApologiesByDefault": true,
      "avoidMetaPhrases": [
        "as an ai",
        "as a language model",
        "i can't access",
        "i do not have access",
        "i'm unable to access"
      ],
      "preferNatural": true,
      "preferDirect": true
    },
    "antiRepetition": {
      "enabled": true,
      "cooldownTurnsGlobal": 10,
      "cooldownTurnsPerType": 8,
      "dedupeExactWithinTurns": 40,
      "dedupeNormalizedWithinTurns": 24,
      "maxReusePerSession": 2,
      "historyKey": "microcopy.conversation",
      "normalizedRules": {
        "lowercase": true,
        "stripPunctuation": true,
        "stripDiacritics": true,
        "collapseWhitespace": true
      }
    },
    "placeholders": {
      "allowed": [
        "{{userName}}",
        "{{productName}}",
        "{{capabilityHint}}",
        "{{nextStepHint}}"
      ],
      "sanitization": {
        "maxReplacementChars": 80,
        "truncateEllipsis": "…",
        "stripNewlines": true,
        "escapeMarkdown": true
      }
    },
    "composition": {
      "parts": ["message", "optionalHint"],
      "optionalParts": ["optionalHint"],
      "maxParts": 2,
      "joinWith": " "
    }
  },
  "routing": {
    "_comment": "Map operator/intentFamily/signals to a conversation type. First match wins.",
    "bySignalsOrOperator": [
      { "when": "operator == 'greeting' OR signals.isGreeting == true", "type": "greeting" },
      { "when": "operator == 'thanks' OR signals.isThanks == true", "type": "thanks" },
      { "when": "operator == 'goodbye' OR signals.isGoodbye == true", "type": "goodbye" },
      { "when": "operator == 'ack' OR signals.isAck == true", "type": "ack" },
      { "when": "signals.userFrustrated == true", "type": "frustration_ack" },
      { "when": "signals.userAskedCapabilities == true OR intentFamily == 'help'", "type": "help_hint" },
      { "when": "signals.smallTalk == true", "type": "small_talk" }
    ],
    "fallbackType": "ack"
  },
  "types": {
    "greeting": {
      "weight": 0.95,
      "messages": [
        { "id": "conv_greet_en_01", "lang": "en", "text": "Hey." , "weight": 0.25},
        { "id": "conv_greet_en_02", "lang": "en", "text": "Hi.", "weight": 0.25 },
        { "id": "conv_greet_en_03", "lang": "en", "text": "Hello.", "weight": 0.20 },
        { "id": "conv_greet_en_04", "lang": "en", "text": "Hey — what are you working on?", "weight": 0.30, "tags": ["has_question"] },

        { "id": "conv_greet_pt_01", "lang": "pt", "text": "Oi.", "weight": 0.30 },
        { "id": "conv_greet_pt_02", "lang": "pt", "text": "Olá.", "weight": 0.25 },
        { "id": "conv_greet_pt_03", "lang": "pt", "text": "Opa — no que você quer focar?", "weight": 0.30, "tags": ["has_question"] },
        { "id": "conv_greet_pt_04", "lang": "pt", "text": "Tudo certo. O que você precisa agora?", "weight": 0.15, "tags": ["has_question"] },

        { "id": "conv_greet_es_01", "lang": "es", "text": "Hola.", "weight": 0.35 },
        { "id": "conv_greet_es_02", "lang": "es", "text": "Buenas.", "weight": 0.20 },
        { "id": "conv_greet_es_03", "lang": "es", "text": "Hola — ¿en qué quieres enfocarte?", "weight": 0.30, "tags": ["has_question"] },
        { "id": "conv_greet_es_04", "lang": "es", "text": "Perfecto. ¿Qué necesitas ahora?", "weight": 0.15, "tags": ["has_question"] }
      ],
      "optionalHints": [
        {
          "id": "conv_greet_hint_en_01",
          "lang": "en",
          "text": "If you want, tell me the file or topic and I'll jump in.",
          "weight": 0.35,
          "onlyIf": "signals.docsAvailable == true"
        },
        {
          "id": "conv_greet_hint_en_02",
          "lang": "en",
          "text": "If you upload a doc, I can answer using it.",
          "weight": 0.35,
          "onlyIf": "signals.docsAvailable != true"
        },
        {
          "id": "conv_greet_hint_pt_01",
          "lang": "pt",
          "text": "Se quiser, diga o arquivo ou o tema e eu começo.",
          "weight": 0.35,
          "onlyIf": "signals.docsAvailable == true"
        },
        {
          "id": "conv_greet_hint_pt_02",
          "lang": "pt",
          "text": "Se você enviar um documento, eu respondo usando ele.",
          "weight": 0.35,
          "onlyIf": "signals.docsAvailable != true"
        },
        {
          "id": "conv_greet_hint_es_01",
          "lang": "es",
          "text": "Si quieres, dime el archivo o el tema y empiezo.",
          "weight": 0.35,
          "onlyIf": "signals.docsAvailable == true"
        },
        {
          "id": "conv_greet_hint_es_02",
          "lang": "es",
          "text": "Si subes un documento, puedo responder usando ese contenido.",
          "weight": 0.35,
          "onlyIf": "signals.docsAvailable != true"
        }
      ],
      "constraints": {
        "maxQuestions": 1,
        "preferNoQuestionWhen": ["signals.justAnswer", "signals.userRequestedShort"]
      }
    },

    "thanks": {
      "weight": 0.75,
      "messages": [
        { "id": "conv_thx_en_01", "lang": "en", "text": "You got it.", "weight": 0.30 },
        { "id": "conv_thx_en_02", "lang": "en", "text": "Anytime.", "weight": 0.20 },
        { "id": "conv_thx_en_03", "lang": "en", "text": "Sure.", "weight": 0.20 },
        { "id": "conv_thx_en_04", "lang": "en", "text": "Glad that helped.", "weight": 0.30 },

        { "id": "conv_thx_pt_01", "lang": "pt", "text": "Fechado.", "weight": 0.25 },
        { "id": "conv_thx_pt_02", "lang": "pt", "text": "Tamo junto.", "weight": 0.20 },
        { "id": "conv_thx_pt_03", "lang": "pt", "text": "De boa.", "weight": 0.20 },
        { "id": "conv_thx_pt_04", "lang": "pt", "text": "Que bom que ajudou.", "weight": 0.35 },

        { "id": "conv_thx_es_01", "lang": "es", "text": "Listo.", "weight": 0.25 },
        { "id": "conv_thx_es_02", "lang": "es", "text": "Cuando quieras.", "weight": 0.20 },
        { "id": "conv_thx_es_03", "lang": "es", "text": "Perfecto.", "weight": 0.25 },
        { "id": "conv_thx_es_04", "lang": "es", "text": "Me alegra que sirviera.", "weight": 0.30 }
      ],
      "optionalHints": [
        {
          "id": "conv_thx_hint_en_01",
          "lang": "en",
          "text": "Want a quick summary or the exact quote next?",
          "weight": 0.45,
          "onlyIf": "signals.docsAvailable == true",
          "tags": ["has_question"]
        },
        {
          "id": "conv_thx_hint_pt_01",
          "lang": "pt",
          "text": "Quer um resumo rápido ou a citação exata agora?",
          "weight": 0.45,
          "onlyIf": "signals.docsAvailable == true",
          "tags": ["has_question"]
        },
        {
          "id": "conv_thx_hint_es_01",
          "lang": "es",
          "text": "¿Quieres un resumen rápido o la cita exacta ahora?",
          "weight": 0.45,
          "onlyIf": "signals.docsAvailable == true",
          "tags": ["has_question"]
        }
      ],
      "constraints": { "maxQuestions": 1 }
    },

    "ack": {
