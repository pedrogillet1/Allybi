{
  "_meta": {
    "id": "file_actions_microcopy",
    "version": "1.0.0",
    "description": "Adaptive microcopy rules for file action responses in Koda. Governs phrasing, tone, and minimalism for file inventory, navigation, and action-related outputs while preserving ChatGPT-like clarity and trust.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-microcopy",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_specific",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxIntroSentences": 1,
        "maxIntroChars": 90
      },
      "conflictResolution": {
        "ifMultipleRules": "operator_specific_over_global"
      }
    }
  },
  "rules": [
    {
      "id": "file_action_nav_pills_intro",
      "scope": "operator_specific",
      "description": "Provide a single neutral intro line before nav pills for file actions.",
      "appliesTo": ["open", "locate_file", "locate_docs"],
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": {
        "type": "emit_intro",
        "style": "neutral",
        "allowVariation": true
      },
      "reasonCode": "file_action_nav_intro",
      "severity": "low"
    },
    {
      "id": "no_fake_confirmation",
      "scope": "operator_specific",
      "description": "Prevent language that implies a file action was executed when it was only offered.",
      "appliesTo": ["open", "delete", "move", "rename"],
      "when": {
        "all": [
          { "path": "signals.isActionOffered", "op": "eq", "value": true },
          { "path": "signals.isActionExecuted", "op": "neq", "value": true }
        ]
      },
      "action": {
        "type": "suppress_confirmation_language"
      },
      "reasonCode": "no_fake_action_confirmation",
      "severity": "critical"
    },
    {
      "id": "file_list_minimal_intro",
      "scope": "operator_specific",
      "description": "Keep file list introductions minimal and non-redundant.",
      "appliesTo": ["list", "filter", "sort", "group"],
      "action": {
        "type": "emit_intro",
        "style": "minimal",
        "allowVariation": true
      },
      "reasonCode": "file_list_minimal_intro",
      "severity": "low"
    },
    {
      "id": "count_files_direct_answer",
      "scope": "operator_specific",
      "description": "Force direct numeric answers for file count operations.",
      "appliesTo": ["count_files"],
      "action": {
        "type": "emit_direct_value"
      },
      "reasonCode": "file_count_direct",
      "severity": "medium"
    },
    {
      "id": "suppress_sources_label",
      "scope": "operator_specific",
      "description": "Suppress any sources/header language for file actions.",
      "appliesTo": ["open", "locate_file", "locate_docs", "list"],
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": {
        "type": "suppress_sources_header"
      },
      "reasonCode": "no_sources_for_file_actions",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "FA_001_nav_pills_single_intro",
        "context": { "answerMode": "nav_pills" },
        "expect": { "introSentencesMax": 1 }
      },
      {
        "id": "FA_002_no_fake_open_confirmation",
        "context": {
          "signals": { "isActionOffered": true, "isActionExecuted": false }
        },
        "expect": { "noConfirmationLanguage": true }
      },
      {
        "id": "FA_003_file_list_minimal",
        "input": "List my files",
        "expect": { "introStyle": "minimal" }
      },
      {
        "id": "FA_004_count_files_direct",
        "input": "How many files do I have?",
        "expect": { "directValue": true }
      }
    ]
  }
}
