{
  "_meta": {
    "id": "ui_soft_close",
    "version": "1.0.0",
    "description": "Semantic fragment bank for soft response closings in Koda. Provides non-hardcoded, minimal closers that end responses naturally without prompting repetitive loops. Enforces uniqueness via entropy/cooldowns and is suppressed in nav_pills mode. Does not contain fixed sentences; emits fragment intents for the renderer to realize uniquely.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-microcopy",
    "compat": ">=1.0.0",
    "changeLog": [
      "Defined soft-close fragment intents instead of canned phrases",
      "Added suppression in nav_pills and conversation minimalism",
      "Added anti-repetition tests and format-policy alignment"
    ]
  },
  "config": {
    "enabled": true,
    "fragmentBank": true,
    "resolutionMode": "semantic_fragments",
    "disallowFullSentences": true,
    "maxFragmentsPerResponse": 1,
    "maxSentencesPerResolvedOutput": 1,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_least_recent_then_emit",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "minFragmentConfidence": 0.75,
        "cooldownTurns": 3
      },
      "conflictResolution": {
        "ifNavPills": "suppress",
        "ifConversation": "suppress_or_minimize",
        "ifFallback": "prefer_next_step_over_close"
      }
    },
    "variationControl": {
      "enabled": true,
      "entropyWindow": 7,
      "cooldownTurns": 3,
      "dedupeBy": ["fragmentIntent", "selectorKey"]
    },
    "integrationHooks": {
      "dependsOn": ["ui_copy_tokens", "formatting_overlays", "ui_contracts"],
      "consumedBy": ["compose_answer_prompt", "formatting_policy", "global_system_policies"]
    }
  },
  "rules": [
    {
      "id": "soft_close_default_doc_grounded",
      "scope": "global",
      "description": "Emit a soft-close intent for doc-grounded answers when not in nav_pills and not in fallback-required state.",
      "appliesTo": ["response_closing"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.answerMode", "op": "neq", "value": "nav_pills" },
          { "path": "signals.fallbackTriggered", "op": "neq", "value": true },
          { "path": "signals.operatorFamily", "op": "neq", "value": "conversation" }
        ]
      },
      "action": {
        "type": "emit_fragment_intent",
        "fragmentIntent": "soft_close",
        "selectorKey": "doc_grounded_soft_close",
        "constraints": {
          "maxSentences": 1,
          "mustNotSolicitFeedback": true,
          "mustNotAskQuestion": true
        }
      },
      "reasonCode": "ui_soft_close",
      "severity": "low"
    },
    {
      "id": "suppress_soft_close_in_nav_pills",
      "scope": "operator_specific",
      "description": "Suppress soft closers in nav_pills mode to keep UI minimal and button-driven.",
      "appliesTo": ["response_closing"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.answerMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": { "type": "suppress_fragments" },
      "reasonCode": "nav_pills_contract_violation",
      "severity": "high"
    },
    {
      "id": "suppress_soft_close_in_conversation",
      "scope": "operator_specific",
      "description": "Suppress soft closers for conversation operators to avoid redundant closings.",
      "appliesTo": ["response_closing"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.operatorFamily", "op": "eq", "value": "conversation" }
        ]
      },
      "action": { "type": "suppress_fragments" },
      "reasonCode": "conversation_minimal_response",
      "severity": "medium"
    },
    {
      "id": "prefer_next_step_over_close_in_fallback",
      "scope": "cross_family",
      "description": "When fallback is triggered, prefer next-step suggestion fragments rather than soft close fragments.",
      "appliesTo": ["response_closing"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "signals.fallbackTriggered", "op": "eq", "value": true }
        ]
      },
      "action": { "type": "suppress_fragments" },
      "reasonCode": "fallback_processing",
      "severity": "medium"
    },
    {
      "id": "anti_repetition_close_selection",
      "scope": "global",
      "description": "Avoid repeating the same soft-close selector within cooldown window by selecting an alternate realization.",
      "appliesTo": ["response_closing"],
      "triggerPatterns": { "en": [".+"], "pt": [".+"], "es": [".+"] },
      "when": {
        "all": [
          { "path": "metrics.turnsSinceSameToken", "op": "lt", "value": 3 }
        ]
      },
      "action": {
        "type": "select_alternate_fragment",
        "withinIntent": "soft_close"
      },
      "reasonCode": "ui_soft_close",
      "severity": "low"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "USC_0001_doc_grounded_emits_soft_close_intent",
        "runtime": { "signals": { "answerMode": "doc_grounded_single", "fallbackTriggered": false, "operatorFamily": "documents" } },
        "expect": { "fragmentIntent": "soft_close" }
      },
      {
        "id": "USC_0002_nav_pills_suppresses_soft_close",
        "runtime": { "signals": { "answerMode": "nav_pills", "operatorFamily": "file_actions" } },
        "expect": { "fragmentsSuppressed": true }
      },
      {
        "id": "USC_0003_conversation_suppresses_soft_close",
        "runtime": { "signals": { "answerMode": "general_answer", "operatorFamily": "conversation" } },
        "expect": { "fragmentsSuppressed": true }
      },
      {
        "id": "USC_0004_fallback_prefers_next_step_over_close",
        "runtime": { "signals": { "answerMode": "doc_grounded_single", "fallbackTriggered": true, "operatorFamily": "documents" } },
        "expect": { "fragmentsSuppressed": true }
      },
      {
        "id": "USC_0005_anti_repetition_selects_alternate",
        "runtime": {
          "signals": { "answerMode": "doc_grounded_single", "fallbackTriggered": false, "operatorFamily": "documents" },
          "history": { "recentTokens": ["ui_soft_close:doc_grounded_soft_close"] },
          "metrics": { "turnsSinceSameToken": 1 }
        },
        "expect": { "selectsAlternateFragment": true }
      },
      {
        "id": "USC_0006_multilingual_pt_no_sentence_hardcode",
        "input": "encerrar",
        "runtime": { "signals": { "answerMode": "doc_grounded_single", "fallbackTriggered": false } },
        "expect": { "disallowFullSentences": true }
      }
    ]
  }
}
