{
  "_meta": {
    "id": "ambiguity_overlays",
    "version": "1.0.0",
    "description": "Deterministic nav-pill overlays that keep open/where/discover modes aligned with ChatGPT parity by enforcing single-sentence intros, blocking banned headers/phrases, and guiding file delivery, thus preventing misleading or multi-sentence pills.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-ambiguity",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added single-sentence enforcement and sources header guard",
      "Blocked inline files, message actions, and empty-result microcopy",
      "Added explicit-filename doc locks plus open-vs-locate clarity",
      "Documented list-top-N and quote-vs-summarize protections"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "post_render",
    "strict": true,
    "navPillModes": ["open", "where", "discover"],
    "navPillConstraints": {
      "maxIntroSentences": 1,
      "requireAttachmentForFiles": true,
      "disallowSourcesHeader": true,
      "disallowMessageActions": true,
      "enforceDocumentLockOnFilenameMention": true
    },
    "variationControl": {
      "entropyWindow": 5,
      "cooldownTurns": 2,
      "dedupeBy": ["navPillTemplateId", "intentId"]
    },
    "actionsContract": {
      "combination": {
        "multipleMatches": "sum_then_cap",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "hardBlockThreshold": 0.85,
        "softPenaltyThreshold": 0.35,
        "maxSentencePenalty": 0.25
      },
      "conflictResolution": {
        "ifHardBlockAndRedirect": "hard_block",
        "ifMultipleRedirects": "pick_highest_confidence"
      }
    },
    "integrationHooks": {
      "dependsOn": ["disambiguation_render_policy", "ambiguity_negatives", "option_labeling_rules"],
      "emitsSignals": ["navPillIntroClamped", "navPillSourcesHeaderBlocked", "navPillDocLocked", "navPillActionOverride"]
    }
  },
  "rules": [
    {
      "id": "nav_pill_intro_sentence_limit",
      "scope": "global",
      "description": "Restrict nav-pill bodies to the first sentence when open/where/discover modes produce multi-sentence intros.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "metrics.navPillSentenceCount", "op": "gt", "value": 1 }
        ]
      },
      "action": {
        "type": "clamp_to_first_sentence",
        "emitSignals": ["navPillIntroClamped"],
        "fallbackAction": "truncate_to_first_sentence"
      },
      "reasonCode": "nav_pill_intro_sentence_limit",
      "severity": "medium"
    },
    {
      "id": "nav_pill_sources_label_blocked",
      "scope": "global",
      "description": "Block nav pills that start with Sources/Fontes/Fuentes headers to prevent the forbidden header.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": ["^Sources:"],
        "pt": ["^Fontes:"],
        "es": ["^Fuentes:"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["navPillSourcesHeaderBlocked"],
        "fallbackAction": "rewrite_label_without_header"
      },
      "reasonCode": "nav_pill_sources_label_blocked",
      "severity": "critical"
    },
    {
      "id": "nav_pill_message_actions_blocked",
      "scope": "global",
      "description": "Disallow nav pills with message actions so the response stays strictly informational.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "signals.navPillHasMessageActions", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["navPillMessageActionBlocked"]
      },
      "reasonCode": "nav_pill_message_actions_blocked",
      "severity": "high"
    },
    {
      "id": "nav_pill_inline_files_blocked",
      "scope": "global",
      "description": "Prevent inline file links and force attachment/button delivery.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "signals.navPillInlineFileLinks", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["navPillInlineFilesBlocked"],
        "fallbackAction": "emit_attachment_only_links"
      },
      "reasonCode": "nav_pill_inline_files_blocked",
      "severity": "critical"
    },
    {
      "id": "nav_pill_list_top_n_reserved",
      "scope": "global",
      "description": "Keep list-top-N intents out of the nav-pill file inventory UI and redirect to a proper list response.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "signals.userIntent", "op": "eq", "value": "list_top_n" },
          { "path": "signals.navPillAttachType", "op": "eq", "value": "file_inventory" }
        ]
      },
      "action": {
        "type": "redirect_to_list",
        "emitSignals": ["navPillListTopNRedirected"]
      },
      "reasonCode": "nav_pill_list_top_n_reserved",
      "severity": "medium"
    },
    {
      "id": "nav_pill_explicit_filename_lock",
      "scope": "global",
      "description": "Lock nav pills to the explicitly mentioned document to avoid wrong-doc drift.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "signals.explicitDocMentioned", "op": "eq", "value": true },
          { "path": "signals.navPillActiveDocId", "op": "neq", "value": null }
        ]
      },
      "action": {
        "type": "lock_to_explicit_doc",
        "emitSignals": ["navPillDocLocked"]
      },
      "reasonCode": "nav_pill_explicit_filename_lock",
      "severity": "high"
    },
    {
      "id": "nav_pill_open_vs_locate_clarity",
      "scope": "global",
      "description": "Override nav-pill action to open a document when the intent is explicit, avoiding locate_content ambiguity.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "discover"] },
          { "path": "signals.userActionIntent", "op": "eq", "value": "open_document" },
          { "path": "signals.navPillPreferredAction", "op": "eq", "value": "locate_content" }
        ]
      },
      "action": {
        "type": "override_action",
        "preferredAction": "open_document",
        "emitSignals": ["navPillActionOverride"]
      },
      "reasonCode": "nav_pill_open_vs_locate_clarity",
      "severity": "medium"
    },
    {
      "id": "nav_pill_quote_vs_summarize_guard",
      "scope": "global",
      "description": "Force summary formatting when the user explicitly requests it, even if quote wording appears.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["discover"] },
          { "path": "signals.userCommandStyle", "op": "eq", "value": "summarize" },
          { "path": "signals.navPillFormatRequested", "op": "eq", "value": "quote" }
        ]
      },
      "action": {
        "type": "override_format",
        "preferredFormat": "summary",
        "emitSignals": ["navPillFormatOverride"]
      },
      "reasonCode": "nav_pill_quote_vs_summarize_guard",
      "severity": "medium"
    },
    {
      "id": "nav_pill_empty_result_phrase_blocked",
      "scope": "global",
      "description": "Block empty-result microcopy and ensure attachments or informative text are used instead.",
      "appliesTo": ["nav_pill_render"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "signals.navPillEmptyResultsPhraseDetected", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["navPillEmptyPhraseBlocked"],
        "fallbackAction": "offer_alternative_attachment"
      },
      "reasonCode": "nav_pill_empty_result_phrase_blocked",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "AO_0001_valid_single_sentence_nav",
        "context": {
          "signals": {
            "navPillMode": "open",
            "navPillHasMessageActions": false,
            "navPillInlineFileLinks": false,
            "navPillUsesAttachments": true
          },
          "metrics": { "navPillSentenceCount": 1 }
        },
        "expect": { "navPillValidated": true }
      },
      {
        "id": "AO_0002_non_trigger_mode",
        "context": {
          "signals": { "navPillMode": "formatting" },
          "metrics": { "navPillSentenceCount": 3 }
        },
        "expect": { "noNavPillRulesApplied": true }
      },
      {
        "id": "AO_0003_sources_header_collision",
        "input": "Sources: matching docs are attached.",
        "context": {
          "signals": {
            "navPillMode": "open",
            "navPillLabelNormalized": "sources: matching docs",
            "navPillUsesAttachments": true,
            "navPillHasMessageActions": false
          },
          "metrics": { "navPillSentenceCount": 1 }
        },
        "expect": {
          "blocked": true,
          "navPillSourcesHeaderBlocked": true,
          "reasonCode": "nav_pill_sources_label_blocked"
        }
      },
      {
        "id": "AO_0004_pt_sentence_limit",
        "input": "Mostre-me os relatórios e depois o resumo expandido, por favor.",
        "context": {
          "signals": { "navPillMode": "where" },
          "metrics": { "navPillSentenceCount": 3 }
        },
        "expect": {
          "navPillIntroClamped": true,
          "reasonCode": "nav_pill_intro_sentence_limit"
        }
      },
      {
        "id": "AO_0005_es_sources_block",
        "input": "Fuentes: los informes clave están aquí.",
        "context": {
          "signals": {
            "navPillMode": "discover",
            "navPillLabelNormalized": "fuentes: informes clave"
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "nav_pill_sources_label_blocked"
        }
      },
      {
        "id": "AO_0006_explicit_filename_lock",
        "context": {
          "signals": {
            "navPillMode": "open",
            "explicitDocMentioned": true,
            "explicitDocFilename": "budget_Q2.pdf",
            "navPillActiveDocId": "doc-budget-Q2"
          }
        },
        "expect": {
          "navPillDocLocked": true,
          "reasonCode": "nav_pill_explicit_filename_lock"
        }
      },
      {
        "id": "AO_0007_list_top_n_protected",
        "context": {
          "signals": {
            "navPillMode": "discover",
            "userIntent": "list_top_n",
            "navPillAttachType": "file_inventory"
          }
        },
        "expect": {
          "listTopNRedirected": true,
          "reasonCode": "nav_pill_list_top_n_reserved"
        }
      },
      {
        "id": "AO_0008_open_vs_locate_clarity",
        "context": {
          "signals": {
            "navPillMode": "open",
            "userActionIntent": "open_document",
            "navPillPreferredAction": "locate_content"
          }
        },
        "expect": {
          "navPillActionOverride": "open_document",
          "reasonCode": "nav_pill_open_vs_locate_clarity"
        }
      },
      {
        "id": "AO_0009_quote_vs_summarize_guard",
        "context": {
          "signals": {
            "navPillMode": "discover",
            "userCommandStyle": "summarize",
            "navPillFormatRequested": "quote"
          }
        },
        "expect": {
          "navPillFormatOverride": "summary",
          "reasonCode": "nav_pill_quote_vs_summarize_guard"
        }
      },
      {
        "id": "AO_0010_empty_phrase_block",
        "context": {
          "signals": {
            "navPillMode": "where",
            "navPillEmptyResultsPhraseDetected": true
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "nav_pill_empty_result_phrase_blocked"
        }
      },
      {
        "id": "AO_0011_message_actions_blocked",
        "context": {
          "signals": {
            "navPillMode": "discover",
            "navPillHasMessageActions": true
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "nav_pill_message_actions_blocked"
        }
      },
      {
        "id": "AO_0012_inline_files_blocked",
        "context": {
          "signals": {
            "navPillMode": "open",
            "navPillInlineFileLinks": true,
            "navPillUsesAttachments": false
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "nav_pill_inline_files_blocked"
        }
      }
    ]
  }
}
