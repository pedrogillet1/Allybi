{
  "_meta": {
    "id": "ambiguity_negatives",
    "version": "1.0.0",
    "description": "Deterministic negative constraints for Koda ambiguity handling. Prevents unnecessary disambiguation when evidence exists, blocks repeated clarification loops, prefers autopick when safe, and restricts cross-doc disambiguation under explicit locks. Ensures ChatGPT-like behavior: proceed when possible, ask only when truly blocked.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-ambiguity",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added negative guards against unnecessary disambiguation",
      "Added clarification loop prevention with cooldown",
      "Added cross-doc restriction under explicit locks",
      "Added tests for collision and regression scenarios"
    ]
  },
  "config": {
    "enabled": true,
    "mode": "negative_constraint_enforcement",
    "strict": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_all_then_hard_block_if_any",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "autopickTopScore": 0.85,
        "autopickGap": 0.25,
        "clarificationCooldownTurns": 3,
        "maxClarificationLoopCount": 2,
        "evidenceConfidenceForSuppression": 0.75
      },
      "conflictResolution": {
        "ifNegativeAndPositive": "negative_wins",
        "ifMultipleNegatives": "apply_all",
        "ifLoopDetected": "hard_block_clarification"
      }
    },
    "loopPrevention": {
      "enabled": true,
      "cooldownTurns": 3,
      "maxLoopCount": 2,
      "trackBy": ["reasonCode", "candidateSetHash"],
      "onLoopDetected": "suppress_clarification_proceed_with_best"
    },
    "evidenceSuppression": {
      "enabled": true,
      "suppressWhen": {
        "any": [
          { "path": "metrics.topScore", "op": "gte", "value": 0.85 },
          { "path": "signals.explicitDocRef", "op": "eq", "value": true },
          { "path": "signals.hasStrongEvidence", "op": "eq", "value": true }
        ]
      }
    },
    "scopeRestriction": {
      "enabled": true,
      "restrictCrossDocWhen": {
        "all": [
          { "path": "signals.explicitDocLock", "op": "eq", "value": true },
          { "path": "signals.intentFamily", "op": "neq", "value": "doc_discovery" }
        ]
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "disambiguation_policies",
        "clarification_phrases",
        "scope_hints",
        "followup_indicators"
      ],
      "emitsSignals": [
        "disambiguationSuppressed",
        "clarificationLoopBlocked",
        "autopickPreferred",
        "crossDocRestricted"
      ]
    }
  },
  "rules": [
    {
      "id": "suppress_disambiguation_when_evidence_exists",
      "scope": "global",
      "description": "Do not disambiguate when strong evidence exists (high score, explicit ref, or confident match).",
      "appliesTo": ["disambiguation_decision"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "any": [
          { "path": "metrics.topScore", "op": "gte", "value": 0.85 },
          { "path": "signals.explicitDocRef", "op": "eq", "value": true },
          { "path": "signals.hasStrongEvidence", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "suppress_disambiguation",
        "emitSignals": ["disambiguationSuppressed", "autopickPreferred"]
      },
      "reasonCode": "evidence_suppresses_disambiguation",
      "severity": "high"
    },
    {
      "id": "block_clarification_loop",
      "scope": "global",
      "description": "Block repeated clarification for the same ambiguity within cooldown window.",
      "appliesTo": ["clarification_decision"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "metrics.clarificationTurnsSinceLastSame", "op": "lt", "value": 3 },
          { "path": "metrics.clarificationLoopCount", "op": "gte", "value": 1 }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["clarificationLoopBlocked"],
        "fallbackAction": "proceed_with_best_candidate"
      },
      "reasonCode": "clarification_loop_blocked",
      "severity": "critical"
    },
    {
      "id": "prefer_autopick_when_safe",
      "scope": "global",
      "description": "Prefer autopick over disambiguation when score and margin thresholds are met.",
      "appliesTo": ["disambiguation_decision"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "metrics.topScore", "op": "gte", "value": 0.85 },
          { "path": "metrics.scoreGap", "op": "gte", "value": 0.25 }
        ]
      },
      "action": {
        "type": "suppress_disambiguation",
        "preferAction": "autopick",
        "notifyUser": true,
        "allowCorrection": true,
        "emitSignals": ["autopickPreferred"]
      },
      "reasonCode": "autopick_safe_margin",
      "severity": "high"
    },
    {
      "id": "restrict_cross_doc_under_explicit_lock",
      "scope": "cross_family",
      "description": "Do not offer cross-document disambiguation options when explicit doc lock is active (except discovery intent).",
      "appliesTo": ["disambiguation_options"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.explicitDocLock", "op": "eq", "value": true },
          { "path": "signals.intentFamily", "op": "neq", "value": "doc_discovery" }
        ]
      },
      "action": {
        "type": "filter_candidates",
        "keepOnly": "within_locked_doc",
        "emitSignals": ["crossDocRestricted"]
      },
      "reasonCode": "cross_doc_restricted_by_lock",
      "severity": "critical"
    },
    {
      "id": "suppress_disambiguation_on_followup_continuity",
      "scope": "operator_specific",
      "description": "Suppress disambiguation when followup clearly continues the active document context.",
      "appliesTo": ["disambiguation_decision"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.isFollowup", "op": "eq", "value": true },
          { "path": "signals.activeDocAffinity", "op": "gte", "value": 0.8 },
          { "path": "metrics.topScore", "op": "gte", "value": 0.7 }
        ]
      },
      "action": {
        "type": "suppress_disambiguation",
        "preferAction": "continue_with_active_doc",
        "emitSignals": ["disambiguationSuppressed"]
      },
      "reasonCode": "followup_continuity_suppresses",
      "severity": "medium"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "AN_0001_high_score_suppresses",
        "context": { "metrics": { "topScore": 0.9, "scoreGap": 0.3 } },
        "expect": { "disambiguationSuppressed": true, "reasonCode": "evidence_suppresses_disambiguation" }
      },
      {
        "id": "AN_0002_explicit_ref_suppresses",
        "context": { "signals": { "explicitDocRef": true } },
        "expect": { "disambiguationSuppressed": true }
      },
      {
        "id": "AN_0003_loop_blocked",
        "context": { "metrics": { "clarificationTurnsSinceLastSame": 1, "clarificationLoopCount": 2 } },
        "expect": { "blocked": true, "reasonCode": "clarification_loop_blocked" }
      },
      {
        "id": "AN_0004_autopick_preferred",
        "context": { "metrics": { "topScore": 0.88, "scoreGap": 0.28 } },
        "expect": { "autopickPreferred": true, "reasonCode": "autopick_safe_margin" }
      },
      {
        "id": "AN_0005_cross_doc_restricted",
        "context": { "signals": { "explicitDocLock": true, "intentFamily": "documents" } },
        "expect": { "crossDocRestricted": true, "reasonCode": "cross_doc_restricted_by_lock" }
      },
      {
        "id": "AN_0006_discovery_allows_cross_doc",
        "context": { "signals": { "explicitDocLock": true, "intentFamily": "doc_discovery" } },
        "expect": { "crossDocRestricted": false }
      },
      {
        "id": "AN_0007_followup_continuity_suppresses",
        "context": {
          "signals": { "isFollowup": true, "activeDocAffinity": 0.85 },
          "metrics": { "topScore": 0.75 }
        },
        "expect": { "disambiguationSuppressed": true, "reasonCode": "followup_continuity_suppresses" }
      }
    ]
  }
}
