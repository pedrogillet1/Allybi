{
  "_meta": {
    "id": "ambiguity_tests",
    "version": "1.0.0",
    "description": "Regression-level test overlays that proactively guard against known ambiguity failures (wrong-doc drift, list top N hijacks, open vs. locate confusion, quote vs. summarize mix-ups, forbidden sources headers, and empty-result microcopy).",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-ambiguity",
    "compat": ">=1.0.0",
    "changeLog": [
      "Documented regression coverage for explicit filenames and list-top-N hijacks",
      "Added clarity guards for open vs locate and quote vs summarize confusion",
      "Added proactive detection for nav-pill Sources headers and empty-result phrases"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "test_validation",
    "strict": true,
    "purpose": "ambiguity_regression_tests",
    "variationControl": {
      "entropyWindow": 4,
      "cooldownTurns": 1,
      "dedupeBy": ["testRegion", "regressionId"]
    },
    "actionsContract": {
      "combination": {
        "multipleMatches": "sum_then_cap",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "hardBlockThreshold": 0.85,
        "softPenaltyThreshold": 0.35,
        "maxPenaltyPerTest": 0.3
      },
      "conflictResolution": {
        "ifHardBlockAndRedirect": "hard_block",
        "ifMultipleRedirects": "pick_highest_confidence"
      }
    },
    "integrationHooks": {
      "dependsOn": ["ambiguity_overlays", "ambiguity_negatives"],
      "emitsSignals": [
        "wrongDocDriftPrevented",
        "listTopNHijackBlocked",
        "openVsLocateDisambiguated",
        "quoteVsSummarizeDisambiguated",
        "sourcesHeaderRegressionBlocked",
        "emptyResultPhraseBlocked"
      ]
    }
  },
  "rules": [
    {
      "id": "avoid_wrong_doc_drift_after_explicit_filename",
      "scope": "global",
      "description": "Force the nav pill to stay on the explicitly mentioned document to avoid drift.",
      "appliesTo": ["ambiguity_test"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "signals.explicitDocMentioned", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "force_doc_lock",
        "emitSignals": ["wrongDocDriftPrevented"]
      },
      "reasonCode": "wrong_doc_drift_prevented",
      "severity": "high"
    },
    {
      "id": "block_list_top_n_hijack",
      "scope": "global",
      "description": "Keep list-top-N intents out of the nav-pill file-inventory view.",
      "appliesTo": ["ambiguity_test"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "where", "discover"] },
          { "path": "signals.userIntent", "op": "eq", "value": "list_top_n" },
          { "path": "signals.navPillAttachType", "op": "eq", "value": "file_inventory" }
        ]
      },
      "action": {
        "type": "redirect_to_list",
        "emitSignals": ["listTopNHijackBlocked"]
      },
      "reasonCode": "list_top_n_hijack_prevented",
      "severity": "medium"
    },
    {
      "id": "clarify_open_vs_locate_intent",
      "scope": "global",
      "description": "Favor the open_document action when both open and locate_content indicators collide.",
      "appliesTo": ["ambiguity_test"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "in", "value": ["open", "discover"] },
          { "path": "signals.userActionIntent", "op": "eq", "value": "open_document" },
          { "path": "signals.navPillPreferredAction", "op": "eq", "value": "locate_content" }
        ]
      },
      "action": {
        "type": "override_action",
        "preferredAction": "open_document",
        "emitSignals": ["openVsLocateDisambiguated"]
      },
      "reasonCode": "open_vs_locate_disambiguated",
      "severity": "medium"
    },
    {
      "id": "clarify_quote_vs_summarize_intent",
      "scope": "global",
      "description": "Enforce summary formatting when the user explicitly asks for summarization.",
      "appliesTo": ["ambiguity_test"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.navPillMode", "op": "eq", "value": "discover" },
          { "path": "signals.userCommandStyle", "op": "eq", "value": "summarize" },
          { "path": "signals.navPillFormatRequested", "op": "eq", "value": "quote" }
        ]
      },
      "action": {
        "type": "override_format",
        "preferredFormat": "summary",
        "emitSignals": ["quoteVsSummarizeDisambiguated"]
      },
      "reasonCode": "quote_vs_summarize_disambiguated",
      "severity": "medium"
    },
    {
      "id": "block_sources_header_regression",
      "scope": "global",
      "description": "Catch Sources/Fontes/Fuentes headers that previously leaked onto nav pills.",
      "appliesTo": ["ambiguity_test"],
      "triggerPatterns": {
        "en": ["^Sources:"],
        "pt": ["^Fontes:"],
        "es": ["^Fuentes:"]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["sourcesHeaderRegressionBlocked"]
      },
      "reasonCode": "sources_header_regression_blocked",
      "severity": "critical"
    },
    {
      "id": "suppress_empty_result_phrase",
      "scope": "global",
      "description": "Block the banned empty-result phrases that used to surface to users.",
      "appliesTo": ["ambiguity_test"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.bannedPhraseKey", "op": "eq", "value": "empty_result_placeholder" }
        ]
      },
      "action": {
        "type": "hard_block",
        "emitSignals": ["emptyResultPhraseBlocked"]
      },
      "reasonCode": "empty_result_phrase_blocked",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "AT_0001_doc_lock_happy_path",
        "context": {
          "signals": {
            "navPillMode": "open",
            "explicitDocMentioned": true,
            "explicitDocFilename": "sales_brief.pdf",
            "navPillActiveDocId": "doc-sales-brief"
          },
          "metrics": { "activeDocAffinity": 0.4 }
        },
        "expect": {
          "docLockEnsured": true,
          "reasonCode": "wrong_doc_drift_prevented"
        }
      },
      {
        "id": "AT_0002_non_trigger_summary",
        "context": {
          "signals": {
            "navPillMode": "open",
            "userIntent": "summarize",
            "explicitDocMentioned": false
          }
        },
        "expect": { "noTestRuleMatched": true }
      },
      {
        "id": "AT_0003_collision_open_vs_locate",
        "context": {
          "signals": {
            "navPillMode": "open",
            "userActionIntent": "open_document",
            "navPillPreferredAction": "locate_content"
          }
        },
        "expect": {
          "finalAction": "open_document",
          "reasonCode": "open_vs_locate_disambiguated"
        }
      },
      {
        "id": "AT_0004_multilingual_pt_quote_summary",
        "input": "Por favor, resuma isso em um parágrafo único.",
        "context": {
          "signals": {
            "navPillMode": "discover",
            "userCommandStyle": "summarize",
            "navPillFormatRequested": "quote",
            "language": "pt"
          }
        },
        "expect": {
          "finalFormat": "summary",
          "reasonCode": "quote_vs_summarize_disambiguated"
        }
      },
      {
        "id": "AT_0005_multilingual_es_sources",
        "input": "Fuentes: no muestres ese encabezado.",
        "context": {
          "signals": {
            "navPillLabelNormalized": "fuentes: no muestres ese encabezado",
            "navPillMode": "open",
            "language": "es"
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "sources_header_regression_blocked"
        }
      },
      {
        "id": "AT_0006_list_top_n_hijack",
        "context": {
          "signals": {
            "navPillMode": "discover",
            "userIntent": "list_top_n",
            "navPillAttachType": "file_inventory"
          }
        },
        "expect": {
          "listTopNHijackBlocked": true,
          "reasonCode": "list_top_n_hijack_prevented"
        }
      },
      {
        "id": "AT_0007_empty_phrase_block",
        "context": {
          "signals": {
            "navPillMode": "where",
            "bannedPhraseKey": "empty_result_placeholder"
          }
        },
        "expect": {
          "blocked": true,
          "reasonCode": "empty_result_phrase_blocked"
        }
      }
    ]
  }
}
