{
  "_meta": {
    "id": "disambiguation_render_policy",
    "version": "1.0.0",
    "description": "Deterministic disambiguation rendering policy for Koda. Controls how ambiguity is presented (buttons vs short list), enforces single-question behavior, limits to 2–4 options, ensures concrete option labels, and guarantees nav-pills UI compliance (no Sources label, no actions) in discovery-style disambiguation.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-ambiguity",
    "compat": ">=1.0.0",
    "changeLog": [
      "Enforced 2–4 options and 1-question maximum with deterministic rendering modes",
      "Added nav-pills compliant rendering for discovery/file selection",
      "Added tests for collisions, multilingual rendering, and known UI regressions"
    ]
  },
  "config": {
    "enabled": true,
    "mode": "adaptive_render_by_candidate_type",
    "strict": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_specific_then_apply",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "minOptions": 2,
        "maxOptions": 4,
        "maxQuestionSentences": 1,
        "maxIntroSentencesNavPills": 1,
        "maxButtonsSoft": 4,
        "maxButtonsHard": 6
      },
      "conflictResolution": {
        "ifNavPillsAndListConflict": "nav_pills_for_terminal_navigation",
        "ifMultipleRenderModes": "prefer_candidate_type_specific",
        "ifQuestionAndNoQuestion": "no_question_when_options_are_clear"
      }
    },
    "renderModes": {
      "doc_selection": {
        "preferred": "nav_pills",
        "allowed": ["nav_pills", "short_list"],
        "ui": {
          "navType": "discover",
          "noSourcesHeader": true,
          "noActions": true,
          "introOnly": true
        }
      },
      "sheet_selection": {
        "preferred": "short_list",
        "allowed": ["short_list"],
        "ui": { "noSourcesHeader": true, "noActions": true }
      },
      "operator_selection": {
        "preferred": "short_list",
        "allowed": ["short_list"],
        "ui": { "noSourcesHeader": true, "noActions": true }
      }
    },
    "labeling": {
      "requireConcreteLabels": true,
      "labelPartsPriority": ["title", "filename", "type", "dateHint", "locationHint"],
      "maxLabelChars": 80,
      "truncateStrategy": "middle_ellipsis",
      "disallowVagueLabels": true
    },
    "questionPolicy": {
      "askSingleQuestion": true,
      "maxQuestions": 1,
      "noApologyTone": true,
      "noPolicyMentions": true
    },
    "navPillsCompliance": {
      "disallowSourcesLabelPatterns": ["\\bSources?:\\b", "\\bFontes?:\\b", "\\bFuentes?:\\b"],
      "disallowActionsAttachment": true,
      "maxIntroSentences": 1
    }
  },
  "rules": [
    {
      "id": "render_doc_candidates_as_nav_pills",
      "scope": "cross_family",
      "description": "Render document-choice ambiguity as nav pills (discover) with intro-only text and source buttons.",
      "appliesTo": ["disambiguation_rendering"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.candidateType", "op": "eq", "value": "document" }
        ]
      },
      "action": {
        "type": "set_render_mode",
        "renderMode": "nav_pills",
        "ui": {
          "navType": "discover",
          "introOnly": true,
          "noSourcesHeader": true,
          "noActions": true
        }
      },
      "reasonCode": "render_doc_nav_pills",
      "severity": "high"
    },
    {
      "id": "render_sheet_candidates_as_short_list",
      "scope": "cross_family",
      "description": "Render sheet/tab ambiguity as short list (names only), no nav pills.",
      "appliesTo": ["disambiguation_rendering"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "when": {
        "all": [
          { "path": "signals.candidateType", "op": "eq", "value": "sheet" }
        ]
      },
      "action": {
        "type": "set_render_mode",
        "renderMode": "short_list",
        "ui": { "noSourcesHeader": true, "noActions": true }
      },
      "reasonCode": "render_sheet_short_list",
      "severity": "medium"
    },
    {
      "id": "enforce_option_limits",
      "scope": "global",
      "description": "Limit options to 2–4 with deterministic trimming; never show 1 option as disambiguation.",
      "appliesTo": ["disambiguation_rendering"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "limit_options",
        "min": 2,
        "max": 4,
        "trimStrategy": "keep_top_scores_then_diverse"
      },
      "reasonCode": "limit_disambiguation_options",
      "severity": "critical"
    },
    {
      "id": "enforce_single_question",
      "scope": "global",
      "description": "Enforce single-question maximum and suppress multi-question prompts.",
      "appliesTo": ["disambiguation_rendering"],
      "triggerPatterns": {
        "en": ["\\?"],
        "pt": ["\\?"],
        "es": ["\\?"]
      },
      "when": {
        "all": [
          { "path": "metrics.clarificationQuestionCount", "op": "gt", "value": 1 }
        ]
      },
      "action": {
        "type": "hard_block"
      },
      "reasonCode": "multiple_clarifications",
      "severity": "critical"
    },
    {
      "id": "enforce_concrete_labels",
      "scope": "global",
      "description": "Require option labels to include at least one concrete identifier (filename, title fragment, sheet name, date) and forbid vague labels.",
      "appliesTo": ["disambiguation_rendering"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "enforce_label_policy",
        "requireConcrete": true,
        "maxLabelChars": 80,
        "truncateStrategy": "middle_ellipsis",
        "disallowVague": true
      },
      "reasonCode": "prefer_concrete_labels",
      "severity": "high"
    },
    {
      "id": "nav_pills_no_sources_label",
      "scope": "operator_specific",
      "description": "Hard-block any Sources header in nav-pills disambiguation.",
      "appliesTo": ["render_output"],
      "triggerPatterns": {
        "en": ["\\bSources?:\\b"],
        "pt": ["\\bFontes?:\\b"],
        "es": ["\\bFuentes?:\\b"]
      },
      "when": {
        "all": [
          { "path": "renderMode", "op": "eq", "value": "nav_pills" }
        ]
      },
      "action": {
        "type": "hard_block"
      },
      "reasonCode": "nav_pills_sources_label",
      "severity": "critical"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "DRP_0001_doc_candidates_nav_pills",
        "context": { "signals": { "candidateType": "document" }, "metrics": { "candidateCount": 3 } },
        "expect": { "renderMode": "nav_pills", "ui": { "introOnly": true, "noActions": true } }
      },
      {
        "id": "DRP_0002_sheet_candidates_short_list",
        "context": { "signals": { "candidateType": "sheet" }, "metrics": { "candidateCount": 3 } },
        "expect": { "renderMode": "short_list" }
      },
      {
        "id": "DRP_0003_option_limits",
        "context": { "metrics": { "candidateCount": 10 } },
        "expect": { "optionsMax": 4, "optionsMin": 2 }
      },
      {
        "id": "DRP_0004_single_question_enforced",
        "context": { "metrics": { "clarificationQuestionCount": 2 } },
        "expect": { "blocked": true, "reasonCode": "multiple_clarifications" }
      },
      {
        "id": "DRP_0005_concrete_labels_required",
        "context": { "metrics": { "labelsContainConcrete": false } },
        "expect": { "labelPolicyEnforced": true }
      },
      {
        "id": "DRP_0006_nav_pills_sources_regression",
        "context": { "renderMode": "nav_pills", "outputText": "Sources:\n- file" },
        "expect": { "blocked": true }
      },
      {
        "id": "DRP_0007_multilingual_pt_nav_pills_no_sources",
        "context": { "renderMode": "nav_pills", "outputText": "Fontes:\n- arquivo" },
        "expect": { "blocked": true }
      }
    ]
  }
}
