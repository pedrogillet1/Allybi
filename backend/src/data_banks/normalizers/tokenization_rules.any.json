{
  "_meta": {
    "id": "tokenization_rules",
    "version": "2.0.0",
    "description": "Deterministic tokenization rules for Koda. Governs how user input is segmented into tokens while preserving semantic units such as code blocks, filenames, numbers, currencies, dates, operators, and quoted text. Prevents loss of semantic meaning during tokenization.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-normalizers",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "caseInsensitive": true,
    "stripDiacritics": false,
    "collapseWhitespace": true,
    "preserveOriginalOffsets": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_first_match",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "minTokenLength": 1,
        "maxTokenLength": 256
      },
      "conflictResolution": {
        "ifConflict": "preserve_semantic_unit",
        "protectOrderPrecedence": true
      }
    }
  },
  "rules": [
    {
      "id": "protect_code_blocks",
      "scope": "global",
      "description": "Preserve fenced code blocks (triple backticks) as single semantic units.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["```[\\s\\S]*?```"],
        "pt": ["```[\\s\\S]*?```"],
        "es": ["```[\\s\\S]*?```"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "code_block"
      },
      "reasonCode": "code_block_preserved",
      "severity": "critical"
    },
    {
      "id": "protect_inline_code",
      "scope": "global",
      "description": "Preserve inline code (single backticks) as single semantic units.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["`[^`]+`"],
        "pt": ["`[^`]+`"],
        "es": ["`[^`]+`"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "inline_code"
      },
      "reasonCode": "inline_code_preserved",
      "severity": "high"
    },
    {
      "id": "protect_quoted_text",
      "scope": "global",
      "description": "Preserve quoted text (double or single quotes) as single semantic units for exact-match intent.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\"[^\"]+\"", "'[^']+'"],
        "pt": ["\"[^\"]+\"", "'[^']+'"],
        "es": ["\"[^\"]+\"", "'[^']+'"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "quoted_text"
      },
      "reasonCode": "quoted_text_preserved",
      "severity": "high"
    },
    {
      "id": "protect_filenames",
      "scope": "global",
      "description": "Preserve filenames with extensions as atomic tokens. Includes common document, spreadsheet, presentation, image, and archive formats.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\b[\\w][\\w\\-_.\\s]*\\.(pdf|docx?|xlsx?|pptx?|txt|csv|tsv|json|xml|html?|md|png|jpe?g|gif|bmp|svg|webp|zip|rar|7z|tar|gz)\\b"],
        "pt": ["\\b[\\w][\\w\\-_.\\s]*\\.(pdf|docx?|xlsx?|pptx?|txt|csv|tsv|json|xml|html?|md|png|jpe?g|gif|bmp|svg|webp|zip|rar|7z|tar|gz)\\b"],
        "es": ["\\b[\\w][\\w\\-_.\\s]*\\.(pdf|docx?|xlsx?|pptx?|txt|csv|tsv|json|xml|html?|md|png|jpe?g|gif|bmp|svg|webp|zip|rar|7z|tar|gz)\\b"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "filename"
      },
      "reasonCode": "filename_preserved",
      "severity": "critical"
    },
    {
      "id": "protect_currencies",
      "scope": "global",
      "description": "Preserve currency amounts with symbols or ISO codes as single tokens. Supports USD, EUR, BRL, GBP and their symbols.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["(\\$|€|£|R\\$|\\bUSD\\b|\\bEUR\\b|\\bBRL\\b|\\bGBP\\b)\\s*\\d+(?:[.,]\\d+)?(?:\\s*(thousand|million|billion|k|m|b))?", "\\d+(?:[.,]\\d+)?\\s*(\\bUSD\\b|\\bEUR\\b|\\bBRL\\b|\\bGBP\\b)"],
        "pt": ["(\\$|€|£|R\\$|\\bUSD\\b|\\bEUR\\b|\\bBRL\\b|\\bGBP\\b)\\s*\\d+(?:[.,]\\d+)?(?:\\s*(mil|milh[oõ]es?|bilh[oõ]es?|k|m|b))?", "\\d+(?:[.,]\\d+)?\\s*(\\bUSD\\b|\\bEUR\\b|\\bBRL\\b|\\bGBP\\b)"],
        "es": ["(\\$|€|£|R\\$|\\bUSD\\b|\\bEUR\\b|\\bBRL\\b|\\bGBP\\b)\\s*\\d+(?:[.,]\\d+)?(?:\\s*(mil|millones?|billones?|k|m|b))?", "\\d+(?:[.,]\\d+)?\\s*(\\bUSD\\b|\\bEUR\\b|\\bBRL\\b|\\bGBP\\b)"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "currency"
      },
      "reasonCode": "currency_preserved",
      "severity": "high"
    },
    {
      "id": "protect_numbers_and_ranges",
      "scope": "global",
      "description": "Preserve numeric values, percentages, and ranges as single tokens. Includes decimal separators for both dot and comma locales.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\b\\d+(?:[.,]\\d+)?\\s*%", "\\b\\d+(?:[.,]\\d+)?\\s*(?:-|to)\\s*\\d+(?:[.,]\\d+)?\\b", "\\b\\d+(?:[.,]\\d+)?\\b"],
        "pt": ["\\b\\d+(?:[.,]\\d+)?\\s*%", "\\b\\d+(?:[.,]\\d+)?\\s*(?:-|a)\\s*\\d+(?:[.,]\\d+)?\\b", "\\b\\d+(?:[.,]\\d+)?\\b"],
        "es": ["\\b\\d+(?:[.,]\\d+)?\\s*%", "\\b\\d+(?:[.,]\\d+)?\\s*(?:-|a)\\s*\\d+(?:[.,]\\d+)?\\b", "\\b\\d+(?:[.,]\\d+)?\\b"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "number"
      },
      "reasonCode": "number_preserved",
      "severity": "high"
    },
    {
      "id": "protect_month_words",
      "scope": "global",
      "description": "Preserve month names as single tokens to prevent splitting hyphenated or compound month references.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\b(january|february|march|april|may|june|july|august|september|october|november|december|jan|feb|mar|apr|aug|sep|sept|oct|nov|dec)\\b"],
        "pt": ["\\b(janeiro|fevereiro|mar[cç]o|abril|maio|junho|julho|agosto|setembro|outubro|novembro|dezembro|jan|fev|mar|abr|mai|jun|jul|ago|set|out|nov|dez)\\b"],
        "es": ["\\b(enero|febrero|marzo|abril|mayo|junio|julio|agosto|septiembre|octubre|noviembre|diciembre|ene|feb|mar|abr|may|jun|jul|ago|sep|oct|nov|dic)\\b"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "month"
      },
      "reasonCode": "month_preserved",
      "severity": "medium"
    },
    {
      "id": "protect_operator_tokens",
      "scope": "global",
      "description": "Preserve mathematical, logical, and comparison operators as standalone tokens.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\b(vs|versus|and|or|not|greater than|less than|equal to|between)\\b", "[+\\-*/=<>≤≥≠]"],
        "pt": ["\\b(vs|versus|e|ou|n[aã]o|maior que|menor que|igual a|entre)\\b", "[+\\-*/=<>≤≥≠]"],
        "es": ["\\b(vs|versus|y|o|no|mayor que|menor que|igual a|entre)\\b", "[+\\-*/=<>≤≥≠]"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "operator"
      },
      "reasonCode": "operator_preserved",
      "severity": "medium"
    },
    {
      "id": "split_on_structural_punctuation",
      "scope": "global",
      "description": "Split tokens on structural punctuation that delimits clauses or phrases.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["[,;:()\\[\\]{}]"],
        "pt": ["[,;:()\\[\\]{}]"],
        "es": ["[,;:()\\[\\]{}¿¡]"]
      },
      "action": {
        "type": "split"
      },
      "reasonCode": "structural_punctuation_split",
      "severity": "low"
    },
    {
      "id": "split_on_whitespace",
      "scope": "global",
      "description": "Split on whitespace as the final tokenization step for remaining unprotected text.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\s+"],
        "pt": ["\\s+"],
        "es": ["\\s+"]
      },
      "action": {
        "type": "split"
      },
      "reasonCode": "whitespace_split",
      "severity": "low"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "TOK_001_preserve_code_block",
        "input": "Analyze ```SELECT * FROM users``` query",
        "expect": { "containsTokenType": "code_block" }
      },
      {
        "id": "TOK_002_preserve_inline_code",
        "input": "Check the `config.json` file",
        "expect": { "containsTokenType": "inline_code" }
      },
      {
        "id": "TOK_003_preserve_quoted",
        "input": "Find \"net operating income\"",
        "expect": { "containsTokenType": "quoted_text" }
      },
      {
        "id": "TOK_004_preserve_filename",
        "input": "Open mezanino_analysis_v2.pdf",
        "expect": { "containsTokenType": "filename" }
      },
      {
        "id": "TOK_005_preserve_filename_with_spaces",
        "input": "Open \"My Report 2023.xlsx\"",
        "expect": { "containsTokenType": "filename" }
      },
      {
        "id": "TOK_006_preserve_currency_prefix",
        "input": "Budget is $1,500,000",
        "expect": { "containsTokenType": "currency" }
      },
      {
        "id": "TOK_007_preserve_currency_brl",
        "input": "Valor de R$ 2.500,00",
        "expect": { "containsTokenType": "currency" }
      },
      {
        "id": "TOK_008_preserve_percentage",
        "input": "ROI of 12.5%",
        "expect": { "containsTokenType": "number" }
      },
      {
        "id": "TOK_009_preserve_range",
        "input": "Compare 2022-2023 revenue",
        "expect": { "containsTokenType": "number" }
      },
      {
        "id": "TOK_010_preserve_month",
        "input": "Data for September 2023",
        "expect": { "containsTokenType": "month" }
      },
      {
        "id": "TOK_011_preserve_operator",
        "input": "Revenue vs costs analysis",
        "expect": { "containsTokenType": "operator" }
      },
      {
        "id": "TOK_012_split_punctuation",
        "input": "Revenue, costs; and profit",
        "expect": { "tokenCountGreaterThan": 3 }
      },
      {
        "id": "TOK_013_pt_month_preserved",
        "input": "Relatório de março de 2024",
        "expect": { "containsTokenType": "month" }
      },
      {
        "id": "TOK_014_es_currency_preserved",
        "input": "Precio de €500 por m2",
        "expect": { "containsTokenType": "currency" }
      }
    ]
  }
}
