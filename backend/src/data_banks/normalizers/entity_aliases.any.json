{
  "_meta": {
    "id": "entity_aliases",
    "version": "1.0.0",
    "description": "Deterministic entity alias normalization rules for Koda. Maps alias forms to canonical entity identifiers across languages while preserving original references and preventing false-positive entity creation.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-normalizers",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "preserveOriginalText": true,
    "requireCanonicalMatch": true,
    "allowMultipleCanonicalCandidates": false,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_specific",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "minAliasConfidence": 0.75
      },
      "conflictResolution": {
        "ifAmbiguous": "do_not_normalize"
      }
    }
  },
  "rules": [
    {
      "id": "corporate_suffix_variants",
      "scope": "global",
      "description": "Normalize common corporate suffix variations.",
      "appliesTo": ["entity_names"],
      "triggerPatterns": {
        "en": ["\\b(inc\\.|incorporated|corp\\.|corporation|ltd\\.|limited|llc)\\b"],
        "pt": ["\\b(ltda\\.|limitada|s\\/a|sa)\\b"],
        "es": ["\\b(s\\.a\\.|sa|ltda\\.|limitada)\\b"]
      },
      "action": {
        "type": "strip_alias_token",
        "category": "corporate_suffix"
      },
      "reasonCode": "entity_suffix_normalized",
      "severity": "low"
    },
    {
      "id": "punctuation_and_case_variants",
      "scope": "global",
      "description": "Normalize punctuation and casing differences in entity names.",
      "appliesTo": ["entity_names"],
      "triggerPatterns": {
        "en": ["[.,&\\-_/]"],
        "pt": ["[.,&\\-_/]"],
        "es": ["[.,&\\-_/]"]
      },
      "action": {
        "type": "normalize_punctuation_case"
      },
      "reasonCode": "entity_punctuation_case",
      "severity": "low"
    },
    {
      "id": "common_abbreviations",
      "scope": "global",
      "description": "Normalize common abbreviations to full canonical forms when unambiguous.",
      "appliesTo": ["entity_names"],
      "triggerPatterns": {
        "en": ["\\bintl\\b", "\\bco\\b"],
        "pt": ["\\bint\\b", "\\bcia\\b"],
        "es": ["\\bint\\b", "\\bcia\\b"]
      },
      "when": {
        "all": [
          { "path": "signals.hasSingleEntityCandidate", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "expand_abbreviation"
      },
      "reasonCode": "entity_abbreviation_expanded",
      "severity": "medium"
    },
    {
      "id": "project_and_asset_aliases",
      "scope": "cross_family",
      "description": "Normalize project or asset shorthand references present in document metadata.",
      "appliesTo": ["entity_names"],
      "when": {
        "all": [
          { "path": "signals.entityFromMetadata", "op": "eq", "value": true }
        ]
      },
      "action": {
        "type": "map_to_metadata_entity"
      },
      "reasonCode": "entity_metadata_alias",
      "severity": "medium"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "ENT_001_strip_suffix",
        "input": "Acme Corp.",
        "expect": { "normalizedEntity": "Acme" }
      },
      {
        "id": "ENT_002_case_punctuation",
        "input": "ACME-Co",
        "expect": { "normalizedEntity": "Acme" }
      },
      {
        "id": "ENT_003_abbreviation_safe",
        "context": { "signals": { "hasSingleEntityCandidate": true } },
        "input": "Acme Intl",
        "expect": { "normalizedEntity": "Acme International" }
      },
      {
        "id": "ENT_004_ambiguous_no_normalize",
        "context": { "signals": { "hasSingleEntityCandidate": false } },
        "input": "ABC",
        "expect": { "notNormalized": true }
      }
    ]
  }
}
