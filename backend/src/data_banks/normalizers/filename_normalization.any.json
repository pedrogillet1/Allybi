{
  "_meta": {
    "id": "filename_normalization",
    "version": "1.0.0",
    "description": "Deterministic filename normalization rules for Koda. Produces stable matching keys for filenames while preserving original display names. Handles Unicode normalization, whitespace/punctuation variants, extension normalization, and safe token extraction without guessing or rewriting user intent.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-normalizers",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "preserveOriginalText": true,
    "normalizeUnicode": "NFKC",
    "casefoldForMatching": true,
    "stripDiacriticsForMatching": true,
    "collapseWhitespaceForMatching": true,
    "normalizeSeparatorsForMatching": true,
    "normalizeExtensionCase": true,
    "allowedExtensions": ["pdf", "doc", "docx", "xls", "xlsx", "ppt", "pptx", "txt", "csv", "png", "jpg", "jpeg", "webp"],
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_in_precedence_order_then_emit",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "minFilenameLength": 3,
        "maxFilenameLength": 180,
        "maxEditsRatio": 0.75
      },
      "conflictResolution": {
        "ifProtectedSegment": "preserve_original_and_emit_match_key",
        "ifOverEdited": "rollback_last"
      }
    },
    "emit": {
      "fields": ["original", "matchKey", "baseName", "extension", "tokens", "flags.hasExtension", "flags.isLikelyFilename"]
    }
  },
  "rules": [
    {
      "id": "detect_filename_like_token",
      "scope": "global",
      "description": "Detect filename-like tokens with known extensions and mark them as filename candidates.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\b\\w[\\w\\-_. ]{0,160}\\.(pdf|docx?|xlsx?|pptx?|txt|csv|png|jpe?g|webp)\\b"],
        "pt": ["\\b\\w[\\w\\-_. ]{0,160}\\.(pdf|docx?|xlsx?|pptx?|txt|csv|png|jpe?g|webp)\\b"],
        "es": ["\\b\\w[\\w\\-_. ]{0,160}\\.(pdf|docx?|xlsx?|pptx?|txt|csv|png|jpe?g|webp)\\b"]
      },
      "action": {
        "type": "mark_filename_candidate",
        "flags": { "isLikelyFilename": true, "hasExtension": true }
      },
      "reasonCode": "filename_candidate_detected",
      "severity": "high"
    },
    {
      "id": "unicode_nfkc_normalization",
      "scope": "global",
      "description": "Normalize Unicode to NFKC for stable matching (e.g., full-width characters).",
      "appliesTo": ["filename_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "unicode_normalize",
        "form": "NFKC"
      },
      "reasonCode": "filename_unicode_nfkc",
      "severity": "medium"
    },
    {
      "id": "normalize_extension_case",
      "scope": "global",
      "description": "Normalize extension to lowercase for matching while preserving original for display.",
      "appliesTo": ["filename_candidates"],
      "triggerPatterns": {
        "en": ["\\.[A-Za-z0-9]{2,5}\\b"],
        "pt": ["\\.[A-Za-z0-9]{2,5}\\b"],
        "es": ["\\.[A-Za-z0-9]{2,5}\\b"]
      },
      "action": {
        "type": "normalize_extension",
        "mode": "lowercase"
      },
      "reasonCode": "filename_extension_case",
      "severity": "low"
    },
    {
      "id": "normalize_separators_for_match_key",
      "scope": "global",
      "description": "Normalize separators (spaces, underscores, hyphens, dots) into single underscores for matchKey generation.",
      "appliesTo": ["filename_candidates"],
      "triggerPatterns": {
        "en": ["[\\s\\-\\.]+|_+"],
        "pt": ["[\\s\\-\\.]+|_+"],
        "es": ["[\\s\\-\\.]+|_+"]
      },
      "action": {
        "type": "normalize_separators",
        "to": "_",
        "collapseRepeats": true
      },
      "reasonCode": "filename_separators_normalized",
      "severity": "low"
    },
    {
      "id": "strip_diacritics_for_matching",
      "scope": "global",
      "description": "Strip diacritics for matchKey generation only (preserve original display).",
      "appliesTo": ["filename_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "strip_diacritics_for_match",
        "target": "matchKeyOnly"
      },
      "reasonCode": "filename_diacritics_stripped",
      "severity": "low"
    },
    {
      "id": "casefold_for_matching",
      "scope": "global",
      "description": "Casefold filename for matchKey generation only (preserve original display).",
      "appliesTo": ["filename_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "casefold_for_match",
        "target": "matchKeyOnly"
      },
      "reasonCode": "filename_casefolded",
      "severity": "low"
    },
    {
      "id": "extract_base_and_tokens",
      "scope": "global",
      "description": "Extract basename, extension, and stable tokens from matchKey for alias matching and retrieval boosts.",
      "appliesTo": ["filename_candidates"],
      "triggerPatterns": {
        "en": [".+"],
        "pt": [".+"],
        "es": [".+"]
      },
      "action": {
        "type": "extract_filename_parts",
        "tokenizeOn": "_",
        "dropEmptyTokens": true
      },
      "reasonCode": "filename_parts_extracted",
      "severity": "medium"
    },
    {
      "id": "over_edit_guard",
      "scope": "global",
      "description": "Rollback last normalization step if edits would change too much of the original filename, preventing accidental mismatches.",
      "appliesTo": ["filename_candidates"],
      "when": {
        "all": [
          { "path": "metrics.editsRatio", "op": "gt", "value": 0.75 }
        ]
      },
      "action": {
        "type": "rollback_last_action"
      },
      "reasonCode": "filename_over_edit_rollback",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "FN_001_detect_and_normalize_extension_case",
        "input": "Report_Q4_2023.PDF",
        "expect": { "extension": "pdf", "flags": { "isLikelyFilename": true } }
      },
      {
        "id": "FN_002_separator_normalization_match_key",
        "input": "mezanino.analysis-v2 final.pdf",
        "expect": { "matchKeyContains": "mezanino_analysis_v2_final.pdf" }
      },
      {
        "id": "FN_003_strip_diacritics_match_only",
        "input": "relatório_final.pdf",
        "expect": { "matchKeyContains": "relatorio_final.pdf", "originalPreserved": true }
      },
      {
        "id": "FN_004_token_extraction",
        "input": "analysis_mezanino_v2.pdf",
        "expect": { "tokensContainAny": ["analysis", "mezanino", "v2"] }
      },
      {
        "id": "FN_005_over_edit_guard",
        "context": { "metrics": { "editsRatio": 0.9 } },
        "input": "a.pdf",
        "expect": { "rolledBack": true }
      }
    ]
  }
}
