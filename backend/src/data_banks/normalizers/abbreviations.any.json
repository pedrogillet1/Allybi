{
  "_meta": {
    "id": "abbreviations",
    "version": "2.0.0",
    "description": "Canonical abbreviation expansions for Koda query normalization and retrieval. High-signal US and Brazil abbreviations with domain tagging. Entry-based structure for deterministic expansion with ambiguity gating.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-normalizers",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "caseInsensitive": true,
    "matchWordBoundaries": true,
    "stripDiacritics": true,
    "policy": {
      "maxExpansionsPerToken": 4,
      "requireDomainMatch": false,
      "preferDomainConsistent": true,
      "avoidAmbiguousUnlessDomainHigh": true
    },
    "thresholds": {
      "minDomainConfidenceForAmbiguous": 0.72
    }
  },
