  "tests": {
    "cases": [
      {
        "id": "ABR_001_identity_ssn",
        "input": "Find the SSN on this document",
        "expect": { "expandsTo": "Social Security Number" }
      },
      {
        "id": "ABR_002_identity_cpf",
        "input": "Qual é o CPF?",
        "expect": { "expandsTo": "Cadastro de Pessoas Físicas" }
      },
      {
        "id": "ABR_003_tax_irpf",
        "input": "Declaração de IRPF",
        "expect": { "expandsTo": "Imposto de Renda Pessoa Física" }
      },
      {
        "id": "ABR_004_invoice_nfe",
        "input": "NF-e número 12345",
        "expect": { "expandsTo": "Nota Fiscal Eletrônica" }
      },
      {
        "id": "ABR_005_finance_noi",
        "input": "What's the NOI?",
        "expect": { "expandsTo": "Net Operating Income" }
      },
      {
        "id": "ABR_006_finance_dre",
        "input": "Mostre o DRE",
        "expect": { "expandsTo": "Demonstração do Resultado do Exercício" }
      },
      {
        "id": "ABR_007_legal_nda",
        "input": "Check the NDA terms",
        "expect": { "expandsTo": "Non-Disclosure Agreement" }
      },
      {
        "id": "ABR_008_medical_spo2",
        "input": "SpO2 readings in the report",
        "expect": { "expandsTo": "oxygen saturation" }
      },
      {
        "id": "ABR_009_ambiguous_hr",
        "input": "What's the HR?",
        "context": { "domain": "medical", "domainConfidence": 0.8 },
        "expect": { "expandsTo": "heart rate", "requiresDomainMatch": true }
      },
      {
        "id": "ABR_010_ambiguous_doc",
        "input": "DOC transfer",
        "context": { "domain": "banking", "domainConfidence": 0.75 },
        "expect": { "expandsTo": "Documento de Ordem de Crédito", "requiresDomainMatch": true }
      }
    ]
  }
