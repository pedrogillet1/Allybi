{
  "_meta": {
    "id": "punctuation_rules",
    "version": "1.0.0",
    "description": "Deterministic punctuation handling rules for Koda. Governs which punctuation is semantic, which is structural, and how punctuation affects tokenization and normalization without altering meaning.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-normalizers",
    "compat": ">=1.0.0"
  },

  "config": {
    "enabled": true,
    "preserveOriginalText": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_all",
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "maxSplitOperations": 20
      },
      "conflictResolution": {
        "ifConflict": "preserve_semantic_unit"
      }
    }
  },

  "rules": [
    {
      "id": "preserve_filename_punctuation",
      "scope": "global",
      "description": "Preserve punctuation within filenames and extensions.",
      "appliesTo": ["all_inputs"],
      "when": {
        "all": [
          { "path": "signals.tokenType", "op": "eq", "value": "filename" }
        ]
      },
      "action": {
        "type": "preserve_punctuation"
      },
      "reasonCode": "filename_punctuation_preserved",
      "severity": "critical"
    },
    {
      "id": "preserve_abbreviation_dots",
      "scope": "global",
      "description": "Preserve dots in known abbreviations and initials.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\b[A-Z]\\.(?:[A-Z]\\.)+"],
        "pt": ["\\b[A-Z]\\.(?:[A-Z]\\.)+"],
        "es": ["\\b[A-Z]\\.(?:[A-Z]\\.)+"]
      },
      "action": {
        "type": "preserve_punctuation"
      },
      "reasonCode": "abbreviation_preserved",
      "severity": "medium"
    },
    {
      "id": "split_non_semantic_punctuation",
      "scope": "global",
      "description": "Split on punctuation that does not carry semantic meaning.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["[;,()]+", "[!?]+"],
        "pt": ["[;,()]+", "[!?]+"],
        "es": ["[;,()]+", "[!?]+"]
      },
      "action": {
        "type": "split_tokens"
      },
      "reasonCode": "non_semantic_punctuation_split",
      "severity": "low"
    },
    {
      "id": "preserve_hyphenated_terms",
      "scope": "global",
      "description": "Preserve hyphenated terms as single semantic units when meaning-bearing.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\b\\w+-\\w+\\b"],
        "pt": ["\\b\\w+-\\w+\\b"],
        "es": ["\\b\\w+-\\w+\\b"]
      },
      "action": {
        "type": "preserve_as_unit",
        "tokenType": "hyphenated_term"
      },
      "reasonCode": "hyphenated_term_preserved",
      "severity": "medium"
    },
    {
      "id": "ellipsis_normalization",
      "scope": "global",
      "description": "Normalize ellipses to a single semantic pause without splitting intent.",
      "appliesTo": ["all_inputs"],
      "triggerPatterns": {
        "en": ["\\.\\.\\."],
        "pt": ["\\.\\.\\."],
        "es": ["\\.\\.\\."]
      },
      "action": {
        "type": "normalize_ellipsis"
      },
      "reasonCode": "ellipsis_normalized",
      "severity": "low"
    }
  ],

  "tests": {
    "cases": [
      {
        "id": "PUNC_001_filename_preserved",
        "input": "Open report_v2.1-final.pdf",
        "expect": { "filenameIntact": true }
      },
      {
        "id": "PUNC_002_abbreviation_preserved",
        "input": "U.S.A. revenue",
        "expect": { "abbreviationPreserved": true }
      },
      {
        "id": "PUNC_003_split_commas",
        "input": "Revenue, costs, and profit",
        "expect": { "tokenCountGreaterThan": 3 }
      },
      {
        "id": "PUNC_004_hyphenated_preserved",
        "input": "long-term debt",
        "expect": { "containsTokenType": "hyphenated_term" }
      }
    ]
  }
}
