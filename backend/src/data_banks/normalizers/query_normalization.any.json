{
  "_meta": {
    "id": "query_normalization",
    "version": "3.0.0",
    "description": "Comprehensive query normalization pipeline for Koda. Defines ordered text preprocessing stages applied before routing, intent detection, and retrieval. Each stage is independently toggleable. Handles Unicode normalization, casing, tokenization, contraction expansion, whitespace, diacritics, and preservation guards.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-normalizers",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "usedBy": ["queryRewrite.service", "intentEngine.service", "router.service", "retrievalEngine.service"],
    "emitIntermediateSteps": false,
    "emitReasonCodes": true,
    "maxInputLength": 4000,
    "truncateIfExceeds": true
  },
  "pipeline": {
    "_comment": "Ordered stages. Each stage runs in sequence. Stages can be skipped via 'enabled: false'.",
    "stages": [
      {
        "id": "trim_and_cap",
        "order": 1,
        "enabled": true,
        "description": "Trim leading/trailing whitespace and enforce max length.",
        "operations": [
          { "op": "trim" },
          { "op": "cap_length", "maxChars": 4000, "truncateTo": 3950 }
        ],
        "reasonCode": "input_trimmed_or_capped"
      },
      {
        "id": "unicode_nfkc",
        "order": 2,
        "enabled": true,
        "description": "Normalize Unicode to NFKC form (compatibility decomposition + canonical composition). Handles fullwidth chars, ligatures, etc.",
        "operations": [
          { "op": "unicode_normalize", "form": "NFKC" }
        ],
        "reasonCode": "unicode_normalized"
      },
      {
        "id": "collapse_whitespace",
        "order": 3,
        "enabled": true,
        "description": "Collapse multiple spaces/tabs/newlines to single space.",
        "operations": [
          { "op": "regex_replace", "pattern": "[\\s\\t\\n\\r]+", "replacement": " " }
        ],
        "reasonCode": "whitespace_collapsed"
      },
      {
        "id": "tokenize",
        "order": 4,
        "enabled": true,
        "description": "Split into tokens for downstream processing. Preserves quoted strings and filenames as single tokens.",
        "operations": [
          { "op": "tokenize", "method": "whitespace_with_preservation" }
        ],
        "preservationGuards": ["quotedStrings", "filenames", "docIds", "currencyAmounts"],
        "reasonCode": "tokenized"
      },
      {
        "id": "lowercase_for_matching",
        "order": 5,
        "enabled": true,
        "description": "Convert to lowercase for pattern matching. Original case preserved in separate field for display.",
        "operations": [
          { "op": "lowercase", "preserveOriginal": true }
        ],
        "preservationGuards": ["quotedStrings", "properNouns"],
        "reasonCode": "lowercased"
      },
      {
        "id": "expand_contractions",
        "order": 6,
        "enabled": true,
        "description": "Expand common contractions for consistent matching.",
        "operations": [
          { "op": "contraction_expand", "langAware": true }
        ],
        "expansions": {
          "en": {
            "what's": "what is",
            "where's": "where is",
            "who's": "who is",
            "how's": "how is",
            "it's": "it is",
            "that's": "that is",
            "there's": "there is",
            "here's": "here is",
            "let's": "let us",
            "can't": "cannot",
            "won't": "will not",
            "don't": "do not",
            "doesn't": "does not",
            "didn't": "did not",
            "isn't": "is not",
            "aren't": "are not",
            "wasn't": "was not",
            "weren't": "were not",
            "hasn't": "has not",
            "haven't": "have not",
            "hadn't": "had not",
            "shouldn't": "should not",
            "wouldn't": "would not",
            "couldn't": "could not",
            "i'm": "i am",
            "i've": "i have",
            "i'll": "i will",
            "i'd": "i would",
            "you're": "you are",
            "you've": "you have",
            "you'll": "you will",
            "you'd": "you would",
            "we're": "we are",
            "we've": "we have",
            "we'll": "we will",
            "we'd": "we would",
            "they're": "they are",
            "they've": "they have",
            "they'll": "they will",
            "they'd": "they would",
            "he's": "he is",
            "she's": "she is",
            "ain't": "is not"
          },
          "pt": {
            "t├Ī": "est├Ī",
            "t├┤": "estou",
            "pra": "para",
            "pro": "para o",
            "pras": "para as",
            "pros": "para os",
            "dum": "de um",
            "duma": "de uma",
            "duns": "de uns",
            "dumas": "de umas",
            "num": "em um",
            "numa": "em uma",
            "nuns": "em uns",
            "numas": "em umas",
            "nesse": "em esse",
            "nessa": "em essa",
            "nesses": "em esses",
            "nessas": "em essas",
            "neste": "em este",
            "nesta": "em esta",
            "nestes": "em estes",
            "nestas": "em estas",
            "dele": "de ele",
            "dela": "de ela",
            "deles": "de eles",
            "delas": "de elas",
            "nele": "em ele",
            "nela": "em ela",
            "neles": "em eles",
            "nelas": "em elas",
            "pelo": "por o",
            "pela": "por a",
            "pelos": "por os",
            "pelas": "por as"
          },
          "es": {
            "pa": "para",
            "pa'": "para",
            "pal": "para el",
            "pa'l": "para el",
            "del": "de el",
            "al": "a el",
            "conmigo": "con m├Ł",
            "contigo": "con ti",
            "consigo": "con s├Ł"
          }
        },
        "reasonCode": "contractions_expanded"
      },
      {
        "id": "normalize_punctuation",
        "order": 7,
        "enabled": true,
        "description": "Normalize fancy quotes, dashes, and other Unicode punctuation to ASCII equivalents.",
        "operations": [
          { "op": "char_map", "map": {
            "\u201c": "\"", "\u201d": "\"", "\u2018": "'", "\u2019": "'",
            "\u2013": "-", "\u2014": "-", "\u2026": "...",
            "\u00ab": "\"", "\u00bb": "\"",
            "\u2039": "'", "\u203a": "'"
          }}
        ],
        "reasonCode": "punctuation_normalized"
      },
      {
        "id": "strip_diacritics_for_matching",
        "order": 8,
        "enabled": true,
        "description": "Remove diacritics for pattern matching. Original preserved for display.",
        "operations": [
          { "op": "strip_diacritics", "preserveOriginal": true }
        ],
        "charMap": {
          "├Ī": "a", "├Ā": "a", "├Ż": "a", "├ó": "a", "├ż": "a",
          "├®": "e", "├©": "e", "├¬": "e", "├½": "e",
          "├Ł": "i", "├¼": "i", "├«": "i", "├»": "i",
          "├│": "o", "├▓": "o", "├Ą": "o", "├┤": "o", "├Č": "o",
          "├║": "u", "├╣": "u", "├╗": "u", "├╝": "u",
          "├¦": "c", "├▒": "n", "├Į": "y", "├┐": "y"
        },
        "reasonCode": "diacritics_stripped"
      },
      {
        "id": "final_trim",
        "order": 9,
        "enabled": true,
        "description": "Final trim after all transformations.",
        "operations": [
          { "op": "trim" }
        ],
        "reasonCode": "final_trimmed"
      }
    ]
  },
  "preservationGuards": {
    "_comment": "These patterns are protected from normalization. Content matching these patterns is preserved exactly.",
    "quotedStrings": {
      "description": "Preserve text inside double or single quotes.",
      "patterns": ["\"[^\"]+\"", "'[^']+'"],
      "action": "preserve_exact"
    },
    "filenames": {
      "description": "Preserve file paths and filenames with extensions.",
      "patterns": [
        "\\b[^\\s\"']+\\.(pdf|docx|doc|pptx|ppt|xlsx|xls|csv|txt|md|png|jpg|jpeg|gif|mp4|mp3|wav)\\b",
        "\\b[A-Za-z]:\\\\[^\\s]+",
        "/[^\\s]+"
      ],
      "action": "preserve_exact"
    },
    "docIds": {
      "description": "Preserve doc: prefix references.",
      "patterns": ["doc:[a-zA-Z0-9_\\-:]+"],
      "action": "preserve_exact"
    },
    "currencyAmounts": {
      "description": "Preserve currency amounts with symbols.",
      "patterns": [
        "[$Ōé¼┬Ż┬ź]\\s*[\\d,.]+",
        "R\\$\\s*[\\d,.]+",
        "[\\d,.]+\\s*(USD|EUR|BRL|GBP|JPY)"
      ],
      "action": "preserve_exact"
    },
    "numericRanges": {
      "description": "Preserve numeric ranges (e.g., 2020-2024).",
      "patterns": ["\\d+\\s*[-ŌĆōŌĆö]\\s*\\d+"],
      "action": "preserve_exact"
    },
    "datePatterns": {
      "description": "Preserve date formats.",
      "patterns": [
        "\\d{1,2}[/\\-]\\d{1,2}[/\\-]\\d{2,4}",
        "\\d{4}[/\\-]\\d{1,2}[/\\-]\\d{1,2}",
        "(Q[1-4]|H[1-2])\\s*\\d{4}",
        "(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec|janeiro|fevereiro|mar├¦o|abril|maio|junho|julho|agosto|setembro|outubro|novembro|dezembro|enero|febrero|marzo|abril|mayo|junio|julio|agosto|septiembre|octubre|noviembre|diciembre)\\s*\\d{4}"
      ],
      "action": "preserve_exact"
    },
    "emailAddresses": {
      "description": "Preserve email addresses.",
      "patterns": ["[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}"],
      "action": "preserve_exact"
    }
  },
  "outputs": {
    "_comment": "What the normalizer should emit.",
    "shape": {
      "normalized": "string",
      "original": "string",
      "tokens": "string[]",
      "preservedSegments": "{ pattern: string, value: string }[]",
      "stagesApplied": "string[]",
      "reasonCodes": "string[]"
    }
  },
  "tests": {
    "cases": [
      {
        "id": "QN_0001_basic_contraction",
        "input": "what's the revenue?",
        "expect": { "normalized": "what is the revenue?" }
      },
      {
        "id": "QN_0002_whitespace_collapse",
        "input": "  show   me   the   data  ",
        "expect": { "normalized": "show me the data" }
      },
      {
        "id": "QN_0003_preserve_filename",
        "input": "open Report_2024.pdf",
        "expect": { "normalizedContains": "Report_2024.pdf", "filenamePreserved": true }
      },
      {
        "id": "QN_0004_preserve_docid",
        "input": "summarize doc:abc123",
        "expect": { "normalizedContains": "doc:abc123" }
      },
      {
        "id": "QN_0005_preserve_quoted",
        "input": "find \"exact phrase here\"",
        "expect": { "normalizedContains": "\"exact phrase here\"" }
      },
      {
        "id": "QN_0006_unicode_normalize",
        "input": "’Įå’ĮĢ’Įī’Įī’ĮŚ’Įē’Įä’Įö’Įł text",
        "expect": { "normalized": "fullwidth text" }
      },
      {
        "id": "QN_0007_diacritics_pt",
        "input": "relat├│rio de an├Īlise",
        "expect": { "normalizedForMatching": "relatorio de analise", "originalPreserved": true }
      },
      {
        "id": "QN_0008_contraction_pt",
        "input": "t├Ī no arquivo?",
        "expect": { "normalized": "esta no arquivo?" }
      },
      {
        "id": "QN_0009_preserve_currency",
        "input": "show expenses over R$ 10,000.00",
        "expect": { "normalizedContains": "R$ 10,000.00" }
      },
      {
        "id": "QN_0010_preserve_date_range",
        "input": "revenue 2020-2024",
        "expect": { "normalizedContains": "2020-2024" }
      },
      {
        "id": "QN_0011_fancy_quotes",
        "input": "search \u201csmart quotes\u201d",
        "expect": { "normalizedContains": "\"smart quotes\"" }
      },
      {
        "id": "QN_0012_max_length_cap",
        "input": "[4500 character input]",
        "expect": { "lengthMax": 4000, "reasonCodesAny": ["input_trimmed_or_capped"] }
      }
    ]
  }
}
