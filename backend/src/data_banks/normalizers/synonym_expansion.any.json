{
  "_meta": {
    "id": "synonym_expansion",
    "version": "2.0.0",
    "description": "Synonym expansion for Koda query rewriting and retrieval. Group-based structure for deterministic expansion of user phrasing into canonical domain terms. Supports US and Brazil document types with multilingual coverage.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-01-26",
    "owner": "koda-normalizers",
    "compat": ">=1.0.0",
    "integrates": [
      "abbreviations",
      "domain_detection"
    ],
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "caseInsensitive": true,
    "stripDiacritics": true,
    "collapseWhitespace": true,
    "policy": {
      "maxExpansionsTotal": 12,
      "maxExpansionsPerTerm": 4,
      "avoidOverExpansion": true,
      "dedupeExpansions": true,
      "preferDomainConsistent": true,
      "applyAbbreviationsFirst": true
    },
    "thresholds": {
      "minDomainConfidenceToApply": 0.45
    }
  },
