      "id": "effective_date",
      "label": "Effective Date",
      "labelPt": "Data de Vigência",
      "category": "date",
      "domains": [
        "finance",
        "legal",
        "medical",
        "operations"
      ],
      "extractionHints": [
        "after 'Effective Date:' or 'Data de Vigência:'",
        "date format",
        "near document start"
      ],
      "examples": {
        "en": [
          "January 1, 2026",
          "effective as of 03/15/2025"
        ],
        "pt": [
          "1 de janeiro de 2026",
          "vigente a partir de 15/03/2025"
        ]
      }
    },
