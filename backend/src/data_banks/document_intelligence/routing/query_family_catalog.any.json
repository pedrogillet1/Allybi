  "rules": [
    {
      "id": "QFC_001_high_confidence_identity",
      "trigger": "query mentions explicit doc reference and document class clues",
      "check": "context.explicitDocRef == true AND context.domainSignal.confidence > 0.65",
      "failureAction": "ROUTE_TO_FAMILY_IDENTITY",
      "severity": "high",
      "targetFamily": "document_identity"
    },
    {
      "id": "QFC_002_compute_pattern_routing",
      "trigger": "query contains numeric operators or formula-like text",
      "check": "query.hasNumericExpression == true OR query.textMatches('(calc|calculate|compute|ratio|total|sum|difference|average|%|percent|media|quanto)')",
      "failureAction": "ROUTE_TO_FAMILY_COMPUTE",
      "severity": "high",
      "targetFamily": "numeric_compute"
    },
    {
      "id": "QFC_003_compare_requires_two_docs_signal",
      "trigger": "compare operator is present",
      "check": "query.intent == 'compare' OR query.textMatches('\\b(versus|vs|vs\\.|vs\\\b|compare|against)\\b')",
      "failureAction": "ROUTE_TO_FAMILY_COMPARE",
      "severity": "high",
      "targetFamily": "cross_document_compare"
    },
    {
      "id": "QFC_004_lookup_when_no_scope_and_weak_type",
      "trigger": "query has weak domain clues and broad retrieval terms",
      "check": "context.domain == null AND context.explicitDocRef == null AND query.textMatches('\\b(find|list|locate|where is|encontre|listar|qual doc)\\b')",
      "failureAction": "ROUTE_TO_FAMILY_LOOKUP",
      "severity": "medium",
      "targetFamily": "document_retrieval"
    },
    {
      "id": "QFC_005_extract_or_quote_signal",
      "trigger": "query asks for extraction, summary, or quote",
      "check": "query.intent IN ['extract','summarize','locate_content','quote'] OR query.textMatches('(extract|sumar|resuma|quote|citar|resumo|what does it say)')",
      "failureAction": "ROUTE_TO_FAMILY_EXTRACT",
      "severity": "medium",
      "targetFamily": "content_extraction"
    },
    {
      "id": "QFC_006_everyday_fallback",
      "trigger": "query has pronouns and lacks domain anchor",
      "check": "context.domain == null AND query.ambiguitySignal > 0.45 AND context.explicitDocRef == false",
      "failureAction": "ROUTE_TO_FAMILY_CLARIFICATION",
      "severity": "medium",
      "targetFamily": "clarification_request"
    },
    {
      "id": "QFC_007_ambiguous_domain_requires_disambiguation",
      "trigger": "multiple candidate families above confidence threshold",
      "check": "context.familyCandidates.count >= 2 AND context.familyTopGap < 0.12",
      "failureAction": "EMIT_TOP2_FAMILIES_FOR_CONFIRMATION",
      "severity": "warning"
    }
  ],
  "templates": [
    {
      "id": "QUERY_FAMILY_CATALOG_GEN_TEMPLATE_001",
      "text": "Use machine-actionable policy fallback when a specific template is missing in query_family_catalog.",
      "language": "any",
      "failureAction": "APPLY_TEMPLATE_GUARD"
    }
  ],
  "patterns": [
    "\\bdocument( |-)?intelligence\\b"
  ]
}
