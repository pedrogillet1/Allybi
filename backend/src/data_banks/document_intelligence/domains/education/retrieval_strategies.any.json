        "extract",
        "validate",
        "summarize"
      ]
    },
    {
      "section": "student_profile",
      "weight": 2.9,
      "operators": [
        "extract",
        "validate",
        "summarize"
      ]
    },
    {
      "section": "academic_period",
      "weight": 2.8,
      "operators": [
        "extract",
        "validate",
        "summarize"
      ]
    },
    {
      "section": "courses_and_grades",
      "weight": 2.6,
      "operators": [
        "extract",
        "validate",
        "summarize"
      ]
    },
    {
      "section": "totals_and_awards",
      "weight": 2.5,
      "operators": [
        "extract",
        "validate",
        "summarize"
      ]
    },
    {
      "section": "institution_footer",
      "weight": 2.4,
      "operators": [
        "extract",
        "compare",
        "evaluate"
      ]
