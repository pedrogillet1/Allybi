      "operators": [
        "extract",
        "compare",
        "evaluate"
      ]
    },
    {
      "section": "signatures",
      "weight": 2,
      "operators": [
        "extract",
        "compare",
        "evaluate"
      ]
    },
    {
      "section": "attachments",
      "weight": 1.9,
      "operators": [
        "extract",
        "compare",
        "evaluate"
      ]
    }
  ],
  "boostRules": [
    {
      "id": "education_boost_001_core_fields",
      "priority": 95,
      "weight": 2.8,
      "operators": [
        "extract",
        "validate"
      ],
      "condition": "query asks key dates, amounts, status, or identifiers",
      "boostSections": [
        "summary",
        "student_profile",
        "academic_period"
      ]
    },
    {
      "id": "education_boost_002_reconciliation",
      "priority": 91,
      "weight": 2.5,
      "operators": [
        "calculate",
        "compare",
        "validate"
      ],
      "condition": "query asks totals tie-out, variance, or mismatch reasons",
      "boostSections": [
        "academic_period",
        "courses_and_grades",
        "totals_and_awards",
        "institution_footer",
        "terms_and_notes"
      ]
    },
    {
      "id": "education_boost_003_terms",
      "priority": 86,
      "weight": 2,
      "operators": [
        "summarize",
        "advise",
        "evaluate"
      ],
      "condition": "query asks policy, terms, or constraints",
      "boostSections": [
        "terms_and_notes",
        "terms_and_notes",
        "verification_block"
      ]
    },
    {
      "id": "education_boost_004_identity",
      "priority": 84,
      "weight": 1.9,
      "operators": [
        "extract",
        "locate"
      ],
      "condition": "query asks who/which account/which traveler/student/employee/property",
      "boostSections": [
        "issuer_profile",
        "recipient_profile",
        "summary"
      ]
    }
  ],
  "queryExpansion": [
    {
      "trigger": "\\bstatement\\b",
      "expansions": [
        "document",
        "record",
        "extrato",
        "relatorio"
      ]
    },
    {
      "trigger": "\\breceipt\\b",
      "expansions": [
        "proof of payment",
        "comprovante",
        "recibo"
      ]
    },
    {
      "trigger": "\\btotal\\b",
      "expansions": [
        "amount",
        "sum",
        "valor total"
      ]
    },
    {
      "trigger": "\\bdue\\b",
      "expansions": [
        "deadline",
        "due date",
        "vencimento"
      ]
    },
    {
      "trigger": "\\breference\\b",
      "expansions": [
        "id",
        "number",
        "codigo",
        "referencia"
      ]
    },
    {
      "trigger": "\\bperiod\\b",
      "expansions": [
        "date range",
        "cycle",
        "competencia"
      ]
    }
  ]
}
