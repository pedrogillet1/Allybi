  "strategies": [
    {
      "id": "comp_strategy_findings_to_action",
      "operators": [
        "extract",
        "validate",
        "advise"
      ],
      "description": "Translate control exceptions into explicit action backlog with owners and due dates.",
      "steps": [
        "load exceptions and findings section",
        "anchor each issue to control_id",
        "join remediation plan and owner",
        "return with risk and blocking status"
      ]
    },
    {
      "id": "comp_strategy_regulatory_readiness",
      "operators": [
        "compare",
        "validate",
        "summarize"
      ],
      "description": "Assess readiness for upcoming regulator expectations by linking notices and control coverage.",
      "steps": [
        "resolve regulator notice scope",
        "extract required actions with deadlines",
        "compare against control matrix and test coverage",
        "flag uncovered requirements"
      ]
    }
