  "runtimeHints": {
    "priorityOrder": [
      "comp_section_risk_scoping",
      "comp_section_control_objective",
      "comp_section_test_plan",
      "comp_section_test_result",
      "comp_section_exceptions_and_findings",
      "comp_section_remediation_plan",
      "comp_section_evidence_index",
      "comp_section_owner_governance"
    ],
    "mustAnchorCrossQueryIf": "queryType in ['compare','validate','evaluate','advise']"
  }
