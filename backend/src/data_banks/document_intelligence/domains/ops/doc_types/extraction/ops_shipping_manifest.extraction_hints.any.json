        "total weight",
        "gross weight",
        "peso total",
        "peso bruto"
      ],
      "location": "totals",
      "extractionMethod": "amount_parse"
    },
    {
      "id": "hint_10_totalItems",
      "entity": "totalItems",
      "anchors": [
        "total items",
        "total packages",
        "total volumes"
      ],
      "location": "totals",
      "extractionMethod": "amount_parse"
    },
    {
      "id": "hint_11_declaredValue",
      "entity": "declaredValue",
      "anchors": [
        "declared value",
        "cargo value",
        "valor declarado"
      ],
      "location": "totals",
      "extractionMethod": "amount_parse"
    },
    {
      "id": "hint_12_purchaseOrderNumber",
      "entity": "purchaseOrderNumber",
      "anchors": [
        "PO number",
        "purchase order",
        "ordem de compra"
      ],
      "location": "header",
      "extractionMethod": "regex_capture"
    }
