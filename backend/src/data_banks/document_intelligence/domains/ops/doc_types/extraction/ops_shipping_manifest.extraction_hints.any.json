{
  "_meta": {
    "id": "di_ops_extraction_ops_shipping_manifest",
    "version": "1.0.0",
    "description": "Extraction hints for shipping manifest documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-01",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "ops",
    "docType": "ops_shipping_manifest"
  },
  "hints": [
    {
      "id": "hint_01_docType",
      "entity": "docType",
      "anchors": [
        "shipping manifest",
        "bill of lading",
        "packing list",
        "ops_shipping_manifest"
      ],
      "location": "header",
      "extractionMethod": "classification_rule"
    },
    {
      "id": "hint_02_manifestNumber",
      "entity": "manifestNumber",
      "anchors": [
        "manifest no",
        "BOL number",
        "shipment number",
        "numero romaneio"
      ],
      "location": "header",
      "extractionMethod": "regex_capture"
    },
    {
      "id": "hint_03_shipmentDate",
      "entity": "shipmentDate",
      "anchors": [
        "ship date",
        "date shipped",
        "data embarque"
      ],
      "location": "header",
      "extractionMethod": "date_parse"
    },
    {
      "id": "hint_04_expectedDeliveryDate",
      "entity": "expectedDeliveryDate",
      "anchors": [
        "expected delivery",
        "ETA",
        "previsao entrega"
      ],
      "location": "header",
      "extractionMethod": "date_parse"
    },
    {
      "id": "hint_05_shipperName",
      "entity": "shipperName",
      "anchors": [
        "shipper",
        "consignor",
        "from",
        "remetente"
      ],
      "location": "shipper_consignee",
      "extractionMethod": "heading_proximity"
    },
    {
      "id": "hint_06_consigneeName",
      "entity": "consigneeName",
      "anchors": [
        "consignee",
        "receiver",
        "ship to",
        "destinatario"
      ],
      "location": "shipper_consignee",
      "extractionMethod": "heading_proximity"
    },
    {
      "id": "hint_07_carrierName",
      "entity": "carrierName",
      "anchors": [
        "carrier",
        "transport company",
        "transportadora"
      ],
      "location": "routing",
      "extractionMethod": "heading_proximity"
    },
    {
      "id": "hint_08_vehicleId",
      "entity": "vehicleId",
      "anchors": [
        "vehicle",
        "plate",
        "container",
        "vessel",
        "placa"
