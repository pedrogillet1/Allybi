  "boostRules": [
    {
      "id": "billing_boost_001_due_date",
      "priority": 95,
      "weight": 2.8,
      "operators": [
        "extract",
        "summarize"
      ],
      "condition": "query asks when or how much to pay",
      "boostSections": [
        "balance_and_due",
        "summary"
      ]
    },
    {
      "id": "billing_boost_002_fee_dispute",
      "priority": 92,
      "weight": 2.5,
      "operators": [
        "compare",
        "evaluate"
      ],
      "condition": "query challenges extra charges or fees",
      "boostSections": [
        "charges_and_fees",
        "adjustments_and_disputes",
        "notices_and_terms"
      ]
    },
    {
      "id": "billing_boost_003_usage_variance",
      "priority": 90,
      "weight": 2.4,
      "operators": [
        "calculate",
        "monitor"
      ],
      "condition": "query asks about spike in consumption or data usage",
      "boostSections": [
        "usage_or_activity",
        "summary"
      ]
    },
    {
      "id": "billing_boost_004_tax_breakdown",
      "priority": 88,
      "weight": 2.2,
      "operators": [
        "extract",
        "validate"
      ],
      "condition": "query asks tax component",
