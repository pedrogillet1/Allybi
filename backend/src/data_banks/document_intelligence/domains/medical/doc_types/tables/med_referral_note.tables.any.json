        "provider_role": [
          "role",
          "role type"
        ],
        "phone": [
          "phone",
          "telefone"
        ],
        "facility": [
          "facility",
          "service",
          "site"
        ],
        "contact_note": [
          "note",
          "comments"
        ]
      },
      "unitsRules": [
        {
          "unitId": "unitless",
