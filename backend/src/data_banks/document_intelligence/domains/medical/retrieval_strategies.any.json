  "strategies": [
    {
      "id": "medical_strategy_evidence_first",
      "operators": [
        "extract",
        "summarize",
        "validate"
      ],
      "description": "Always extract objective fields with units and reference ranges before narrative summary.",
      "steps": [
        "detect doc type",
        "collect objective findings",
        "preserve unit + reference range",
        "attach citations",
        "summarize without diagnosis advice"
      ]
    },
    {
      "id": "medical_strategy_safety_guarded",
      "operators": [
        "advise",
        "evaluate",
        "monitor"
      ],
      "description": "For risk or severity queries, provide document-grounded explanation and clinician referral cue.",
      "steps": [
        "locate relevant findings",
        "avoid diagnosis claims",
        "state uncertainty",
        "add clinician escalation line"
      ]
    }
  ]
}
