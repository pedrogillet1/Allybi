      "id": "medical_detect_001",
      "priority": 120,
      "weight": 3.1,
      "signal": "heading_or_content",
      "patterns": [
        "\\bsoap\\b",
        "\\bassessment[ -]?plan\\b"
      ],
      "negativePatterns": [
        "\\bmaster service agreement\\b",
        "\\bgoverning law\\b",
        "\\bboard resolution\\b"
      ],
      "description": "Medical signal: soap + assessment plan"
    },
