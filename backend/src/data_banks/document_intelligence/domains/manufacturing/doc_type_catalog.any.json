  "domain": "manufacturing",
  "docTypes": [
    {
      "id": "mfg_work_order",
      "name": {
        "en": "Work Order",
        "pt": "Ordem de Produção"
      },
      "description": "Discrete plan execution records with routing and quantity targets.",
      "detectionPatterns": [
        "\\bwork order\\b",
        "\\bordem de produção\\b",
        "\\bordem\\s+de\\s+fabricação\\b",
        "\\bwo\\b"
      ],
      "commonSections": [
        "work_item",
        "routing",
        "planned_qty",
        "due_date",
        "status"
      ],
      "extractionPriority": 140
    },
    {
      "id": "mfg_bom_pack",
