{
  "_meta": {
    "id": "di_manufacturing_doc_type_catalog",
    "version": "1.0.0",
    "description": "Manufacturing doc type catalog for execution, yield, and quality-critical interpretation.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "domain-brain",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts",
