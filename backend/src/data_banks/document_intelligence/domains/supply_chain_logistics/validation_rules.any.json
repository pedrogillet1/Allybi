{
  "_meta": {
    "id": "supply_chain_logistics_validation_rules",
    "version": "1.0.0",
    "description": "Logistics validation rules for timing, route, and inventory integrity.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "domain-brain",
    "usedBy": [
      "services/core/validation/claimValidator.service.ts",
      "services/core/orchestration/answerPlanner.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts",
      "tests/document-intelligence/domain-validation.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "deterministic": true,
    "domain": "supply_chain_logistics"
  },
  "runtimeUsageNotes": {
    "selectionStage": "claim validation before service-level and delay explanations",
    "consumer": "supply chain validator",
    "intent": "Block weak delay, cost, and stock claims that mix plans and actuals."
  },
  "exactnessContract": {
    "forbiddenSubstitutions": [
      "on_time_without_actual_timestamps",
      "delay_without_planned_arrival",
      "stock_status_without_snapshot_date",
      "customs_status_without_reference_document"
    ],
    "requiredAnchors": [
      "shipment_id",
      "document_scope",
      "event_time",
      "unit",
      "currency_if_cost"
    ]
  },
  "validationRules": [
    {
      "id": "SCL_VAL_001_shipment_time_lock",
      "severity": "high",
      "applies": [
        "compare",
        "validate",
        "monitor"
      ],
      "check": "planned_and_actual_times_are_period_aligned",
      "description": "Do not discuss delay before planned and actual time anchors are reconciled.",
      "failureAction": "BLOCK_AND_REQUEST_SCOPE"
    },
    {
      "id": "SCL_VAL_002_route_resolution",
      "severity": "medium",
      "applies": [
        "extract",
        "compare",
        "evaluate"
      ],
      "check": "route_has_origin_and_destination",
      "description": "Route claims must include both origin and destination context.",
      "failureAction": "ANNOTATE_AND_ASK_ROUTE_FIX"
    },
    {
      "id": "SCL_VAL_003_inventory_tie_out",
      "severity": "high",
      "applies": [
        "validate",
        "calculate"
      ],
      "check": "inventory_qty_and_reserved_fields_tie",
      "description": "Stock statements should include snapshot date and at least one availability measure.",
      "failureAction": "BLOCK_AND_LIST_REQUIRED_FIELDS"
    },
    {
      "id": "SCL_VAL_004_exception_trace",
      "severity": "medium",
      "applies": [
        "extract",
        "evaluate",
        "summarize"
      ],
      "check": "exception_has_impact_and_mitigation",
      "description": "Exception claims must show impact magnitude and owner response.",
      "failureAction": "WARN_AND_REQUEST_MITIGATION"
    },
    {
      "id": "SCL_VAL_005_freight_cost_currency",
      "severity": "medium",
      "applies": [
        "calculate",
        "compare"
      ],
      "check": "freight_cost_values_have_consistent_currency_or_fx_rate",
      "description": "Freight math is blocked when mixed currencies are compared without conversion method.",
      "failureAction": "BLOCK_AND_EXPLAIN"
    },
    {
      "id": "SCL_VAL_006_sla_claim_guard",
      "severity": "low",
      "applies": [
        "validate",
        "compare"
      ],
      "check": "sla_claim_links_to_timeframe",
      "description": "SLA claims should include period, service level, and measured window.",
      "failureAction": "WARN_AND_ADD_TIME_SCOPE"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "scl_validation_blocks_unanchored_delay",
        "input": {
          "queryType": "monitor",
          "candidate": "shipment delayed"
        },
        "expect": {
          "action": "BLOCK_AND_REQUEST_SCOPE"
        }
      },
      {
        "id": "scl_validation_requires_route_endpoints",
        "input": {
          "scenario": "route_without_origin_or_destination"
        },
        "expect": {
          "action": "ANNOTATE_AND_ASK_ROUTE_FIX"
        }
      }
    ]
  }
}
