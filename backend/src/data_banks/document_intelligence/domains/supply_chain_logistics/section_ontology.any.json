{
  "_meta": {
    "id": "di_supply_chain_logistics_section_ontology",
    "version": "1.0.0",
    "description": "Logistics section ontology for route-critical, stock, and fulfillment interpretation.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "domain-brain",
    "usedBy": [
      "services/core/orchestration/sectionResolver.service.ts",
      "services/core/orchestration/answerPlanner.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts",
      "tests/document-intelligence/section-detection.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "supply_chain_logistics"
  },
  "domain": "supply_chain_logistics",
  "sections": [
    {
      "id": "scl_section_shipment",
      "name": {
        "en": "Shipment Header",
        "pt": "Cabeçalho de Envio"
      },
      "aliases": [
        "manifesto",
        "shipment details",
        "caminho"
      ],
      "canonicalPurpose": "Capture shipper, consignee, carriers, and route identifiers."
    },
    {
      "id": "scl_section_inbound",
      "name": {
        "en": "Inbound Receipt",
        "pt": "Entrada de Materiais"
      },
      "aliases": [
        "recebimento",
        "entrada",
        "incoming"
      ],
      "canonicalPurpose": "Quantifies arrived quantity, condition, and storage destination."
    },
    {
      "id": "scl_section_outbound",
      "name": {
        "en": "Outbound Dispatch",
        "pt": "Saída de Mercadorias"
      },
      "aliases": [
        "ship out",
        "despacho",
        "entrega"
      ],
      "canonicalPurpose": "Tracks fulfilled volume and dispatch time against SLA."
    },
    {
      "id": "scl_section_eta",
      "name": {
        "en": "ETA/ETD",
        "pt": "Previsão de Chegada/Partida"
      },
      "aliases": [
        "estimated arrival",
        "estimated departure",
        "eta",
        "etd"
      ],
      "canonicalPurpose": "Provides expected and actual timing for delivery delay checks."
    },
    {
      "id": "scl_section_exception_log",
      "name": {
        "en": "Exception Log",
        "pt": "Registro de Exceções"
      },
      "aliases": [
        "incidents",
        "delay log",
        "problemas"
      ],
      "canonicalPurpose": "Records delays, damage events, and operational mitigation."
    },
    {
      "id": "scl_section_inventory_state",
      "name": {
        "en": "Inventory State",
        "pt": "Estado do Estoque"
      },
      "aliases": [
        "stock snapshot",
        "inventory position",
        "posições"
      ],
      "canonicalPurpose": "Provides available, reserved, and at-risk quantities."
    },
    {
      "id": "scl_section_customs",
      "name": {
        "en": "Customs and Clearance",
        "pt": "Aduana e Liberação"
      },
      "aliases": [
        "tariff",
        "clearance",
        "despacho"
      ],
      "canonicalPurpose": "Documents jurisdiction and border-release dependencies."
    },
    {
      "id": "scl_section_cost_breakdown",
      "name": {
        "en": "Freight Cost Breakdown",
        "pt": "Detalhamento de Custos de Frete"
      },
      "aliases": [
        "shipping cost",
        "tarifa",
        "cost components"
      ],
      "canonicalPurpose": "Isolates base freight, surcharge, and surcharge-policy assumptions."
    }
  ],
  "sectionAliases": {
    "carrier": [
      "transportadora",
      "frete",
      "transportador"
    ],
    "lead_time": [
      "tempo de trânsito",
      "lead time",
      "ciclo de entrega"
    ]
  },
  "runtimeHints": {
    "priorityOrder": [
      "scl_section_shipment",
      "scl_section_eta",
      "scl_section_exception_log",
      "scl_section_inbound",
      "scl_section_inventory_state",
      "scl_section_cost_breakdown",
      "scl_section_customs"
    ],
    "mustAnchorCrossQueryIf": "queryType in ['monitor','evaluate','calculate']"
  }
}
