  "redactionRules": [
    {
      "id": "fin_redact_ssn",
      "dataType": "SSN",
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "action": "REDACT",
      "replacement": "[SSN REDACTED]"
    },
    {
      "id": "fin_redact_tax_id",
      "dataType": "tax_id",
      "pattern": "\\bd{2}.d{3}.d{3}/d{4}-d{2}\\b",
      "action": "REDACT",
      "replacement": "[TAX_ID REDACTED]"
    },
    {
      "id": "fin_redact_cnpj",
      "dataType": "cnpj",
      "pattern": "\\bd{2}.d{3}.d{3}/d{4}-d{2}\\b",
      "action": "REDACT",
      "replacement": "[TAX_ID REDACTED]"
    },
    {
      "id": "fin_redact_bank_account",
      "dataType": "bank_account",
      "pattern": "\\b(?:account|conta)\\s*(?:no.?|n[úu]mero|#)\\s*:?s*[0-9A-Za-z._-]{6,30}\\b",
      "action": "REDACT",
      "replacement": "[BANK_ACCOUNT REDACTED]"
    },
    {
      "id": "fin_redact_card",
      "dataType": "credit_card",
      "pattern": "\\b(?:4\\d{3}|5[1-5]\\d{2}|3[47]\\d{2}|6011)[-\\s]?\\d{4}[-\\s]?\\d{4}[-\\s]?\\d{4}\\b",
      "action": "REDACT",
      "replacement": "[CARD REDACTED]"
    },
    {
      "id": "fin_redact_iban",
      "dataType": "iban",
      "pattern": "\\b[A-Z]{2}[0-9]{2}[A-Z0-9]{11,30}\\b",
      "action": "REDACT",
      "replacement": "[IBAN REDACTED]"
    },
    {
      "id": "fin_redact_swift",
      "dataType": "swift",
      "pattern": "\\b[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}(?:[A-Z0-9]{3})?\\b",
      "action": "REDACT",
      "replacement": "[SWIFT REDACTED]"
    },
    {
