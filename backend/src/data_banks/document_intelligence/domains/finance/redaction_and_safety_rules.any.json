  "safetyRules": [
    {
      "id": "fin_safety_investment_advice",
      "severity": "error",
      "description": "Do not issue investment recommendations; provide analysis only.",
      "trigger": "buy/sell/hold recommendation requested",
      "action": "BLOCK_WITH_DISCLAIMER"
    },
    {
      "id": "fin_safety_tax_advice",
      "severity": "warning",
      "description": "Do not provide personalized tax advice.",
      "trigger": "tax planning or advice request",
      "action": "DISCLAIMER"
    },
    {
      "id": "fin_safety_mnpi",
      "severity": "error",
      "description": "Suppress material non-public information if marked confidential/draft.",
      "trigger": "confidential or draft with forward-looking claims",
      "action": "WARN_AND_RESTRICT"
    },
