      "synonyms": [
        "period",
        "fiscal period",
        "mes",
        "trimestre",
        "periodo"
      ]
    },
    {
      "canonicalHeader": "revenue",
      "synonyms": [
        "revenue",
        "sales",
        "receita",
        "faturamento"
      ]
    },
    {
      "canonicalHeader": "gross_profit",
      "synonyms": [
        "gross profit",
        "gross margin value",
        "lucro bruto"
      ]
    },
    {
      "canonicalHeader": "ebitda",
      "synonyms": [
        "ebitda",
        "lajida"
      ]
    },
    {
      "canonicalHeader": "operating_income",
      "synonyms": [
        "operating income",
        "resultado operacional"
      ]
    },
    {
      "canonicalHeader": "net_income",
      "synonyms": [
        "net income",
        "profit after tax",
        "lucro liquido"
      ]
    },
    {
      "canonicalHeader": "cash",
      "synonyms": [
        "cash",
        "cash position",
        "caixa"
      ]
    },
    {
      "canonicalHeader": "capex",
      "synonyms": [
        "capex",
        "capital expenditure",
        "investimento"
      ]
    },
    {
      "canonicalHeader": "opex",
      "synonyms": [
        "opex",
        "operating expense",
        "despesa operacional"
      ]
    },
    {
      "canonicalHeader": "currency",
      "synonyms": [
        "currency",
        "moeda"
      ]
    },
    {
      "canonicalHeader": "unit_scale",
      "synonyms": [
        "in thousands",
        "in millions",
        "em milhares",
        "em milhoes"
      ]
    },
    {
      "canonicalHeader": "variance",
      "synonyms": [
        "variance",
