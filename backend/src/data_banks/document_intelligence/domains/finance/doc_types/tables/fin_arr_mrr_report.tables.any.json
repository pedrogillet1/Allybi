{
  "_meta": {
    "id": "di_finance_tables_fin_arr_mrr_report",
    "version": "2.0.0",
    "description": "Table patterns for fin_arr_mrr_report with header mappings and units rules.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "finance",
    "docType": "fin_arr_mrr_report"
  },
  "tables": [
    {
      "id": "summary_table",
      "name": {
        "en": "Summary Financial Table",
        "pt": "Tabela Financeira Resumo"
      },
      "section": "tables_primary",
      "expectedColumns": [
        "metric",
        "period",
        "value",
        "unit"
      ],
      "keyRows": [
        "arr",
        "mrr",
        "nrr",
        "churn"
      ]
    },
    {
      "id": "detail_table",
      "name": {
        "en": "Detailed Breakdown",
        "pt": "Detalhamento"
      },
      "section": "tables_primary",
      "expectedColumns": [
        "line_item",
        "period",
        "actual",
        "plan",
        "variance"
      ],
      "keyRows": [
        "gross_profit",
        "opex",
        "capex"
      ]
    },
    {
      "id": "trend_table",
      "name": {
        "en": "Trend Table",
        "pt": "Tabela de Tendencia"
      },
      "section": "variance_and_drivers",
      "expectedColumns": [
        "metric",
        "current_period",
        "prior_period",
        "yoy_change"
      ],
      "keyRows": [
        "revenue",
        "ebitda",
        "cash"
      ]
    },
    {
      "id": "support_table",
      "name": {
        "en": "Supporting Schedule",
        "pt": "Cronograma de Suporte"
      },
      "section": "appendix",
      "expectedColumns": [
        "item",
        "date",
        "amount",
        "note_ref"
      ],
      "keyRows": [
        "total"
      ]
    }
  ],
  "tableHeaderMappings": [
    {
