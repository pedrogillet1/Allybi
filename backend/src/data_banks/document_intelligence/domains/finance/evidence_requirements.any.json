    {
      "rank": 1,
      "type": "audited_statement",
      "label": {
        "en": "Audited statement",
        "pt": "Demonstracao auditada"
      },
      "trustLevel": "high"
    },
    {
      "rank": 2,
      "type": "regulatory_filing",
      "label": {
        "en": "Regulatory filing",
        "pt": "Arquivo regulatorio"
