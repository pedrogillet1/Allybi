      "trustLevel": "high"
    },
    {
      "rank": 3,
      "type": "board_approved_pack",
      "label": {
        "en": "Board approved pack",
        "pt": "Pacote aprovado pelo conselho"
      },
      "trustLevel": "medium"
    },
    {
      "rank": 4,
