  "config": {
    "enabled": true,
    "domain": "finance",
    "minCitationsPerClaim": 1,
    "maxClaimsWithoutEvidence": 0,
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "domain": "finance",
  "evidenceHierarchy": [
    {
      "rank": 1,
      "type": "audited_statement",
