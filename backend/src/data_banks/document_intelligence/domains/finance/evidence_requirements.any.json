{
  "_meta": {
    "id": "di_finance_evidence_requirements",
    "version": "2.1.0",
    "description": "Finance evidence requirements with strict numeric-context rules for financial claims.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "data-bank-governance",
