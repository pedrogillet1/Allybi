{
  "_meta": {
    "id": "di_accounting_domain_detection_rules_v2",
    "version": "2.0.0",
    "description": "Accounting domain detection rules with high-precision discrimination for trial balance, general ledger, and journal-entry support docs.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "minScore": 0.66,
    "maxRulesPerDocument": 28,
    "aggregation": "weighted_max",
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "domain": "accounting",
  "rules": [
    {
      "id": "acct_detect_tb_001_core",
      "priority": 100,
      "weight": 4.5,
      "signal": "heading_or_content",
      "patterns": [
        "\\btrial\\s+balance\\b",
        "\\btrial\\s+balance\\s+sheet\\b",
        "\\bbalancete\\s+de\\s+verifica(?:c|ç)[aã]o\\b",
        "\\bbalancete\\b"
      ],
      "docTypeHint": [
        "acct_trial_balance"
      ],
      "negativeContext": [
        "\\bgeneral\\s+ledger\\b",
        "\\brazao\\s+geral\\b",
        "\\bjournal\\s+entry\\b",
        "\\bjournal\\s+entries?\\b"
      ],
      "description": "Strong explicit trial balance indicator."
    },
    {
      "id": "acct_detect_tb_002_tb_header",
      "priority": 98,
      "weight": 3.8,
      "signal": "table_header",
      "patterns": [
        "\\b(?:account\\s+code|c[oô]digo\\s+cont[aá]bil|conta)\\b.*\\b(?:ending|final|saldo(?:\\s+final)?|debito|credito|d[eé]bito|cr[eé]dito|atual|initial|opening|closing)\\b",
        "\\b(?:debit|credit)\\s+(?:balance|saldo)\\b"
      ],
      "description": "Header shape matching TB line format."
    },
    {
      "id": "acct_detect_tb_003_tb_balance_check",
      "priority": 96,
      "weight": 3.6,
      "signal": "content",
      "patterns": [
        "\\btotal\\s+debit\\b.*\\btotal\\s+credit\\b",
        "\\bsoma\\s+dos\\s+d[ée]bitos\\b",
        "\\bsoma\\s+dos\\s+cr[eé]ditos\\b"
      ],
      "description": "Explicit debit-credit equality language points to TB-style evidence."
    },
    {
      "id": "acct_detect_gl_001_core",
      "priority": 100,
      "weight": 4.4,
      "signal": "heading_or_content",
      "patterns": [
        "\\bgeneral\\s+ledger\\b",
        "\\bgl\\b",
        "\\brazao\\s+geral\\b",
        "\\blivro\\s+razao\\b",
        "\\braz[aã]o\\s+geral\\b"
      ],
      "docTypeHint": [
        "acct_general_ledger",
        "acct_gl_export"
      ],
      "negativeContext": [
        "\\btrial\\s+balance\\b",
        "\\bbalancete\\b"
      ],
      "description": "General ledger indicators requiring ledger-style context."
    },
    {
      "id": "acct_detect_gl_002_gl_headers",
      "priority": 98,
      "weight": 3.7,
      "signal": "table_header",
      "patterns": [
        "\\b(entry|posting)\\s+date\\b",
        "\\btransaction\\s+date\\b",
        "\\bjournal\\s+entry\\s+id\\b",
        "\\b(voucher|document)\\s+(?:no|n[oº]|id)\\b",
        "\\baccount\\s+description\\b",
        "\\bdebit\\s+amount\\b",
        "\\bcredit\\s+amount\\b"
      ],
      "description": "Table header pattern expected in account-level ledger exports."
    },
    {
      "id": "acct_detect_gl_003_ledger_page",
      "priority": 96,
      "weight": 3.3,
      "signal": "content",
      "patterns": [
        "\\bopening\\s+balance\\b.*\\bclosing\\s+balance\\b",
        "\\bbalance\\s+forward\\b",
        "\\brunning\\s+balance\\b"
      ],
      "description": "Ledger pages often contain running/ending balance progression."
    },
    {
      "id": "acct_detect_je_001_core",
      "priority": 99,
      "weight": 4.2,
      "signal": "heading_or_content",
      "patterns": [
        "\\bjournal\\s+entries?\\b",
        "\\bjournal\\s+entry\\b",
        "\\bJE\\s+support\\b",
        "\\bJE\\s+\\d{1,8}\\b",
        "\\blan[cç]amento(?:s)?\\s+cont[aá]beis?\\b",
        "\\blan[cç]amento\\s+cont[aá]bil\\b"
      ],
      "docTypeHint": [
        "acct_journal_entry_support",
        "acct_journal_entry_adjusting"
      ],
      "negativeContext": [
        "\\bbalancete\\b",
        "\\bstatement\\s+of\\s+cash\\s+flows\\b"
      ],
      "description": "Journal entry support signals."
    },
    {
      "id": "acct_detect_je_002_je_table",
      "priority": 97,
      "weight": 3.8,
      "signal": "table_header",
      "patterns": [
        "\\b(?:journal\\s+entry|transaction)\\s+number\\b",
        "\\b(?:debit\\s+account|cr[eé]dito\\s+conta|d[eé]bito\\s+conta)\\b",
        "\\b(?:credit\\s+account|d[eé]bito\\s+valor|cr[eé]dito\\s+valor)\\b",
        "\\b(?:approved|approved\\s+by|prepared\\s+by|autorizad[oa]|aprovad[oa])\\b"
      ],
      "description": "Requires explicit account mapping fields seen in JE schedules."
    },
    {
      "id": "acct_detect_je_003_adjusting_entries",
      "priority": 94,
      "weight": 3.4,
      "signal": "content",
      "patterns": [
        "\\badjusting\\s+entries?\\b",
        "\\breversal\\s+entries?\\b",
        "\\bestornos?\\b",
        "\\baccrual\\s+entries?\\b",
        "\\bperiod[- ]end\\s+adjustments?\\b"
      ],
      "description": "Adjusting/reversing context disambiguates from TB/GL."
    },
    {
      "id": "acct_detect_rec_001_bank",
      "priority": 92,
      "weight": 3.2,
      "signal": "heading_or_content",
      "patterns": [
        "\\bbank\\s+reconciliation\\b",
        "\\bbank\\s+recon\\b",
        "\\breconcilia[cç][aã]o\\s+banc[áa]ria\\b",
        "\\breconcilia[cç][aã]o\\s+financeira\\b"
      ],
      "docTypeHint": [
        "acct_bank_reconciliation",
        "acct_cashbook"
      ],
      "description": "Bank reconciliation indicator."
    },
    {
      "id": "acct_detect_rec_002_stmts",
      "priority": 90,
      "weight": 3,
      "signal": "content",
      "patterns": [
        "\\bstatement\\s+balance\\b",
        "\\bbank\\s+statement\\b",
        "\\blivro\\s+bancario\\b",
        "\\bdeposits?\\s+in\\s+transit\\b",
        "\\boutstanding\\s+checks\\b"
      ],
      "description": "Pairing with statement/cheques confirms reconciliation context."
    },
    {
      "id": "acct_detect_aging_001",
      "priority": 89,
      "weight": 2.8,
      "signal": "heading_or_content",
      "patterns": [
        "\\baging\\b",
        "\\baccounts\\s+receivable\\s+aging\\b",
        "\\baging\\s+schedule\\b",
        "\\bvencimento\\b",
        "\\bandamento\\s+de\\s+inadimplencia\\b"
      ],
      "docTypeHint": [
        "acct_ar_aging",
        "acct_ap_aging"
      ],
      "description": "Aging reports for AR/AP schedules."
    },
    {
      "id": "acct_detect_fixed_assets",
      "priority": 88,
      "weight": 2.4,
      "signal": "heading_or_content",
      "patterns": [
        "\\bfixed\\s+asset\\s+register\\b",
        "\\basset\\s+register\\b",
        "\\bativo\\s+imobilizado\\b",
        "\\breconciliation\\s+of\\s+depreciation\\b"
      ]
    },
    {
      "id": "acct_detect_cashflow",
      "priority": 84,
      "weight": 2.2,
      "signal": "heading_or_content",
      "patterns": [
        "\\bcash\\s+flow\\b",
        "\\bfluxo\\s+de\\s+caixa\\b",
        "\\bstatement\\s+of\\s+cash\\s+flows\\b"
      ]
    },
    {
      "id": "acct_detect_controls",
      "priority": 82,
      "weight": 2,
      "signal": "content",
      "patterns": [
        "\\binternal\\s+controls?\\b",
        "\\bcontrols?\\s+narrative\\b",
        "\\bcontroles\\s+internos\\b",
        "\\bsegregation\\s+of\\s+duties\\b"
      ]
    },
    {
      "id": "acct_detect_controls_001",
      "priority": 81,
      "weight": 2.1,
      "signal": "content",
      "patterns": [
        "\\bmateriality\\b",
        "\\bcutoff\\b",
        "\\bcompetencia\\b",
        "\\bcaixa\\b"
      ],
      "description": "Discriminates accrual vs cash review context."
    },
    {
      "id": "acct_detect_audit_workpaper",
      "priority": 80,
      "weight": 2.3,
      "signal": "heading_or_content",
      "patterns": [
        "\\baudit\\s+workpaper\\b",
        "\\bworking\\s+paper\\b",
        "\\bpapel\\s+de\\s+trabalho\\b",
        "\\bprepared\\s+by\\s+client\\b"
      ]
    }
  ]
}
