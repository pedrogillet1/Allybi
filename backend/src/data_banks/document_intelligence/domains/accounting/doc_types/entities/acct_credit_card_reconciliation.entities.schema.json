{
  "_meta": {
    "id": "di_accounting_entities_acct_credit_card_reconciliation",
    "version": "1.1.0",
    "description": "Entity extraction schema for credit card reconciliation documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_credit_card_reconciliation"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "statementDate",
      "type": "date",
      "required": true,
      "description": "Card statement date"
    },
    {
      "id": "cardProgram",
      "type": "string",
      "required": false,
      "description": "Card issuer/program"
    },
    {
      "id": "bookBalance",
      "type": "currency",
      "required": true,
      "description": "Book balance for card account"
    },
    {
      "id": "statementBalance",
      "type": "currency",
      "required": true,
      "description": "Statement balance"
    },
    {
      "id": "unreconciledDifference",
      "type": "currency",
      "required": false,
      "description": "Unreconciled difference"
    },
    {
      "id": "transactionCount",
      "type": "number",
      "required": false,
      "description": "Number of statement transactions"
    }
  ]
}
