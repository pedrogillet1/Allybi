{
  "_meta": {
    "id": "di_accounting_entities_acct_prepaids_amortization_schedule",
    "version": "1.1.0",
    "description": "Entity extraction schema for prepaids amortization schedule documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_prepaids_amortization_schedule"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "scheduleDate",
      "type": "date",
      "required": true,
      "description": "Schedule date"
    },
    {
      "id": "openingPrepaidBalance",
      "type": "currency",
      "required": true,
      "description": "Opening prepaid balance"
    },
    {
      "id": "amortizationExpense",
      "type": "currency",
      "required": true,
      "description": "Amortization expense recognized"
    },
    {
      "id": "closingPrepaidBalance",
      "type": "currency",
      "required": true,
      "description": "Closing prepaid balance"
    },
    {
      "id": "itemCount",
      "type": "number",
      "required": false,
      "description": "Count of prepaid items"
    }
  ]
}
