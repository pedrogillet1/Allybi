{
  "_meta": {
    "id": "di_accounting_entities_acct_trial_balance",
    "version": "1.1.0",
    "description": "Entity extraction schema for trial balance documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_trial_balance"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "asOfDate",
      "type": "date",
      "required": true,
      "description": "Trial balance as-of date"
    },
    {
      "id": "totalDebits",
      "type": "currency",
      "required": true,
      "description": "Total debits"
    },
    {
      "id": "totalCredits",
      "type": "currency",
      "required": true,
      "description": "Total credits"
    },
    {
      "id": "outOfBalanceAmount",
      "type": "currency",
      "required": false,
      "description": "Difference between total debits and credits"
    },
    {
      "id": "accountCount",
      "type": "number",
      "required": false,
      "description": "Number of listed accounts"
    }
  ]
}
