{
  "_meta": {
    "id": "di_accounting_entities_acct_depreciation_schedule",
    "version": "1.1.0",
    "description": "Entity extraction schema for depreciation schedule documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_depreciation_schedule"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "scheduleDate",
      "type": "date",
      "required": true,
      "description": "Schedule date"
    },
    {
      "id": "depreciationExpense",
      "type": "currency",
      "required": true,
      "description": "Period depreciation expense"
    },
    {
      "id": "accumulatedDepreciation",
      "type": "currency",
      "required": true,
      "description": "Accumulated depreciation balance"
    },
    {
      "id": "endingNetBookValue",
      "type": "currency",
      "required": true,
      "description": "Ending net book value"
    },
    {
      "id": "usefulLifeMethod",
      "type": "string",
      "required": false,
      "description": "Depreciation method"
    }
  ]
}
