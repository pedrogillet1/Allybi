{
  "_meta": {
    "id": "di_accounting_entities_acct_fixed_asset_register",
    "version": "1.1.0",
    "description": "Entity extraction schema for fixed asset register documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_fixed_asset_register"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "assetCount",
      "type": "number",
      "required": true,
      "description": "Number of assets in register"
    },
    {
      "id": "grossCost",
      "type": "currency",
      "required": true,
      "description": "Total gross asset cost"
    },
    {
      "id": "accumulatedDepreciation",
      "type": "currency",
      "required": true,
      "description": "Accumulated depreciation"
    },
    {
      "id": "netBookValue",
      "type": "currency",
      "required": true,
      "description": "Net book value"
    },
    {
      "id": "lastCapitalizationDate",
      "type": "date",
      "required": false,
      "description": "Most recent capitalization date"
    }
  ]
}
