{
  "_meta": {
    "id": "di_accounting_entities_acct_je_support",
    "version": "1.1.0",
    "description": "Entity extraction schema for journal entry support.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_je_support"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "je_number",
      "type": "string",
      "required": true,
      "description": "Journal entry number"
    },
    {
      "id": "je_date",
      "type": "date",
      "required": true,
      "description": "Journal entry date"
    },
    {
      "id": "posting_period",
      "type": "string",
      "required": true,
      "description": "Posting period"
    },
    {
      "id": "total_debits",
      "type": "currency",
      "required": true,
      "description": "Total debits"
    },
    {
      "id": "total_credits",
      "type": "currency",
      "required": true,
      "description": "Total credits"
    },
    {
      "id": "line_count",
      "type": "number",
      "required": false,
      "description": "Number of JE lines"
    },
    {
      "id": "prepared_by",
      "type": "string",
      "required": false,
      "description": "Preparer name"
    },
    {
      "id": "reviewed_by",
      "type": "string",
      "required": false,
      "description": "Reviewer name"
    },
    {
      "id": "approved_by",
      "type": "string",
      "required": false,
      "description": "Approver name"
    },
    {
      "id": "supporting_reference",
      "type": "string",
      "required": false,
      "description": "Reference to supporting schedule or ticket"
    },
    {
      "id": "posting_status",
      "type": "string",
      "required": false,
      "description": "Posting status if available"
    },
    {
      "id": "batch_id",
      "type": "string",
      "required": false,
      "description": "Batch identifier used for posting"
    }
  ]
}
