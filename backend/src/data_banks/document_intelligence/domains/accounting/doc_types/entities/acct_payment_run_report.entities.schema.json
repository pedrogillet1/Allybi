{
  "_meta": {
    "id": "di_accounting_entities_acct_payment_run_report",
    "version": "1.1.0",
    "description": "Entity extraction schema for payment run report documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_payment_run_report"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "paymentRunId",
      "type": "string",
      "required": true,
      "description": "Payment run identifier"
    },
    {
      "id": "paymentDate",
      "type": "date",
      "required": true,
      "description": "Payment execution date"
    },
    {
      "id": "paymentCount",
      "type": "number",
      "required": true,
      "description": "Number of payments in run"
    },
    {
      "id": "totalPayments",
      "type": "currency",
      "required": true,
      "description": "Total payments value"
    },
    {
      "id": "failedPayments",
      "type": "currency",
      "required": false,
      "description": "Amount failed or rejected"
    }
  ]
}
