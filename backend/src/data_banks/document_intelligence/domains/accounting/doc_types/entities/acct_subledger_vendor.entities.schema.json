        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "totalRows",
      "type": "number",
      "required": false,
      "description": "Total row count extracted from the main tables"
    },
    {
      "id": "lineCount",
      "type": "number",
      "required": false,
      "description": "Total count of detail lines"
