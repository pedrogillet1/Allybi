      "type": "string",
      "required": true,
      "description": "Reporting entity or legal entity name"
    },
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Period label captured from document"
    },
    {
      "id": "periodStart",
      "type": "date",
      "required": false,
      "description": "Period start date"
    },
    {
      "id": "periodEnd",
      "type": "date",
      "required": false,
      "description": "Period end date"
    },
    {
      "id": "asOfDate",
      "type": "date",
      "required": false,
      "description": "As-of date for balances"
