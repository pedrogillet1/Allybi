{
  "_meta": {
    "id": "di_accounting_entities_acct_chart_of_accounts",
    "version": "1.1.0",
    "description": "Entity extraction schema for chart of accounts documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_chart_of_accounts"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "effectiveDate",
      "type": "date",
      "required": true,
      "description": "Effective date of the account listing"
    },
    {
      "id": "accountCount",
      "type": "number",
      "required": true,
      "description": "Number of accounts in the listing"
    },
    {
      "id": "activeAccountCount",
      "type": "number",
      "required": false,
      "description": "Number of active accounts"
    },
    {
      "id": "lowestAccountCode",
      "type": "string",
      "required": false,
      "description": "Lowest account code in range"
    },
    {
      "id": "highestAccountCode",
      "type": "string",
      "required": false,
      "description": "Highest account code in range"
    }
  ]
}
