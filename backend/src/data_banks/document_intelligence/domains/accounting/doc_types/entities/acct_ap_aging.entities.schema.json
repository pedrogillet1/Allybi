{
  "_meta": {
    "id": "di_accounting_entities_acct_ap_aging",
    "version": "1.1.0",
    "description": "Entity extraction schema for AP aging documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_ap_aging"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "asOfDate",
      "type": "date",
      "required": true,
      "description": "Aging report date"
    },
    {
      "id": "totalApBalance",
      "type": "currency",
      "required": true,
      "description": "Total accounts payable balance"
    },
    {
      "id": "bucketCurrent",
      "type": "currency",
      "required": true,
      "description": "Current bucket total"
    },
    {
      "id": "bucket1_30",
      "type": "currency",
      "required": true,
      "description": "1-30 day aging bucket"
    },
    {
      "id": "bucket31_60",
      "type": "currency",
      "required": false,
      "description": "31-60 day aging bucket"
    },
    {
      "id": "bucket61_90",
      "type": "currency",
      "required": false,
      "description": "61-90 day aging bucket"
    },
    {
      "id": "bucketOver90",
      "type": "currency",
      "required": true,
      "description": "Over 90 day aging bucket"
    },
    {
      "id": "vendorCount",
      "type": "number",
      "required": false,
      "description": "Number of vendors with open AP balances"
    }
  ]
}
