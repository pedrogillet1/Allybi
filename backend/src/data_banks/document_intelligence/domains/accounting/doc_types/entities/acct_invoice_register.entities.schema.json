{
  "_meta": {
    "id": "di_accounting_entities_acct_invoice_register",
    "version": "1.1.0",
    "description": "Entity extraction schema for invoice register documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_invoice_register"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "invoiceCount",
      "type": "number",
      "required": true,
      "description": "Number of invoices listed"
    },
    {
      "id": "totalInvoiceAmount",
      "type": "currency",
      "required": true,
      "description": "Total invoiced amount"
    },
    {
      "id": "paidAmount",
      "type": "currency",
      "required": false,
      "description": "Total paid amount"
    },
    {
      "id": "unpaidAmount",
      "type": "currency",
      "required": false,
      "description": "Total unpaid amount"
    },
    {
      "id": "oldestInvoiceDate",
      "type": "date",
      "required": false,
      "description": "Oldest invoice issue date"
    }
  ]
}
