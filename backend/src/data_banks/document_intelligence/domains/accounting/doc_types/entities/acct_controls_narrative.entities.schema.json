{
  "_meta": {
    "id": "di_accounting_entities_acct_controls_narrative",
    "version": "1.1.0",
    "description": "Entity extraction schema for controls narrative documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_controls_narrative"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "processArea",
      "type": "string",
      "required": true,
      "description": "Process area covered by narrative"
    },
    {
      "id": "controlCount",
      "type": "number",
      "required": true,
      "description": "Total number of controls documented"
    },
    {
      "id": "keyControlCount",
      "type": "number",
      "required": false,
      "description": "Number of key controls"
    },
    {
      "id": "deficiencyCount",
      "type": "number",
      "required": false,
      "description": "Number of identified deficiencies"
    },
    {
      "id": "lastTestDate",
      "type": "date",
      "required": false,
      "description": "Most recent control testing date"
    }
  ]
}
