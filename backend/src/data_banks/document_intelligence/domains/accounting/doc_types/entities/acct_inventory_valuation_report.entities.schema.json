{
  "_meta": {
    "id": "di_accounting_entities_acct_inventory_valuation_report",
    "version": "1.1.0",
    "description": "Entity extraction schema for inventory valuation report documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_inventory_valuation_report"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "valuationDate",
      "type": "date",
      "required": true,
      "description": "Inventory valuation date"
    },
    {
      "id": "inventoryQuantity",
      "type": "number",
      "required": true,
      "description": "Total inventory quantity"
    },
    {
      "id": "inventoryValue",
      "type": "currency",
      "required": true,
      "description": "Total inventory value"
    },
    {
      "id": "reserveAmount",
      "type": "currency",
      "required": false,
      "description": "Inventory reserve/obsolescence amount"
    },
    {
      "id": "costingMethod",
      "type": "string",
      "required": false,
      "description": "Inventory costing method"
    }
  ]
}
