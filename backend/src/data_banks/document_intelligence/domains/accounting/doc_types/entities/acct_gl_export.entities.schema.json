{
  "_meta": {
    "id": "di_accounting_entities_acct_gl_export",
    "version": "1.1.0",
    "description": "Entity extraction schema for general ledger export documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_gl_export"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "periodStart",
      "type": "date",
      "required": true,
      "description": "Start date of report period"
    },
    {
      "id": "periodEnd",
      "type": "date",
      "required": true,
      "description": "End date of report period"
    },
    {
      "id": "exportDate",
      "type": "date",
      "required": false,
      "description": "Date the ledger export was generated"
    },
    {
      "id": "totalDebits",
      "type": "currency",
      "required": false,
      "description": "Total debits in report"
    },
    {
      "id": "totalCredits",
      "type": "currency",
      "required": false,
      "description": "Total credits in report"
    },
    {
      "id": "closingBalance",
      "type": "currency",
      "required": false,
      "description": "Ending balance for report period"
    },
    {
      "id": "multiCurrencyTotal",
      "type": "currency",
      "required": false,
      "description": "Total across all currencies if present"
    },
    {
      "id": "journalCount",
      "type": "number",
      "required": false,
      "description": "Total number of journal lines"
    }
  ]
}
