{
  "_meta": {
    "id": "di_accounting_entities_acct_revenue_recognition_schedule",
    "version": "1.1.0",
    "description": "Entity extraction schema for revenue recognition schedule documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_revenue_recognition_schedule"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "scheduleDate",
      "type": "date",
      "required": true,
      "description": "Schedule date"
    },
    {
      "id": "deferredRevenueOpening",
      "type": "currency",
      "required": true,
      "description": "Opening deferred revenue"
    },
    {
      "id": "revenueRecognized",
      "type": "currency",
      "required": true,
      "description": "Revenue recognized during period"
    },
    {
      "id": "deferredRevenueClosing",
      "type": "currency",
      "required": true,
      "description": "Closing deferred revenue"
    },
    {
      "id": "contractCount",
      "type": "number",
      "required": false,
      "description": "Number of active contracts"
    }
  ]
}
