{
  "_meta": {
    "id": "di_accounting_entities_acct_intercompany_reconciliation",
    "version": "1.1.0",
    "description": "Entity extraction schema for intercompany reconciliation documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_intercompany_reconciliation"
  },
  "entities": [
    {
      "id": "period",
      "type": "string",
      "required": true,
      "description": "Accounting period represented in the document"
    },
    {
      "id": "entity",
      "type": "string",
      "required": true,
      "description": "Legal entity, business unit, or reporting entity"
    },
    {
      "id": "currency",
      "type": "string",
      "required": true,
      "description": "Functional or presentation currency"
    },
    {
      "id": "basis",
      "type": "enum",
      "required": true,
      "description": "Accounting basis used in the document",
      "values": [
        "accrual",
        "cash",
        "ifrs",
        "gaap",
        "local_statutory",
        "tax"
      ]
    },
    {
      "id": "sourceSystem",
      "type": "string",
      "required": true,
      "description": "Source ERP/system of record for extracted data"
    },
    {
      "id": "counterpartyEntity",
      "type": "string",
      "required": true,
      "description": "Counterparty legal entity"
    },
    {
      "id": "reconciliationDate",
      "type": "date",
      "required": true,
      "description": "Reconciliation date"
    },
    {
      "id": "dueFromBalance",
      "type": "currency",
      "required": true,
      "description": "Due from balance"
    },
    {
      "id": "dueToBalance",
      "type": "currency",
      "required": true,
      "description": "Due to balance"
    },
    {
      "id": "unmatchedDifference",
      "type": "currency",
      "required": false,
      "description": "Unmatched recon difference"
    },
    {
      "id": "unmatchedItemCount",
      "type": "number",
      "required": false,
      "description": "Count of unmatched line items"
    }
  ]
}
