{
  "_meta": {
    "id": "di_accounting_tables_acct_controls_narrative",
    "version": "1.1.0",
    "description": "Expected table patterns for controls narrative documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_controls_narrative"
  },
  "tableHeaderSynonyms": {
    "debit": [
      "debit",
      "debits",
      "dr",
      "dr.",
      "debit amount"
    ],
    "credit": [
      "credit",
      "credits",
      "cr",
      "cr.",
      "credit amount"
    ],
    "control": [
      "control",
      "control id",
      "control number"
    ],
    "owner": [
      "owner",
      "control owner",
      "responsavel",
      "responsible"
    ]
  },
  "tables": [
    {
      "id": "acct_controls_narrative_matrix_table",
      "name": {
        "en": "Control Matrix",
        "pt": "Matriz de Controles"
      },
      "section": "control_matrix",
      "expectedColumns": [
        "control_id",
        "control_description",
        "process_area",
        "control_owner",
        "frequency",
        "status"
      ],
      "keyRows": [
        "total"
      ],
      "unitsRules": [
        {
          "unitId": "unitless",
          "appliesToColumns": [
            "frequency"
          ],
          "scale": 1
        }
      ],
      "debitCreditConventions": {
        "metricColumns": [
          "frequency"
        ]
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "BRL",
        "$",
        "R$"
      ],
      "extractionNotes": [
        "Handle merged header rows where control_id and control_description are split",
        "Accept tables where status column is placed before frequency or ownership columns"
      ]
    },
    {
      "id": "acct_controls_narrative_testing_table",
      "name": {
        "en": "Control Testing Execution",
        "pt": "Execucao de Testes"
      },
      "section": "control_testing",
      "expectedColumns": [
        "test_id",
        "control_id",
        "sample_size",
        "debit",
        "credit",
        "status",
        "test_date"
      ],
      "keyRows": [
        "subtotal",
        "grand_total"
      ],
      "unitsRules": [
        {
          "unitId": "unitless",
          "appliesToColumns": [
            "sample_size"
          ],
          "scale": 1
        },
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "debit",
            "credit"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "debit",
            "credit"
          ],
          "scale": 1000000,
          "aliases": [
            "m"
          ]
        }
      ],
      "debitCreditConventions": {
        "debitColumns": [
          "debit"
        ],
        "creditColumns": [
          "credit"
        ],
        "notes": "Some exports use effect columns instead of explicit debit/credit names"
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "GBP",
        "BRL",
        "$",
        "R$"
      ],
      "extractionNotes": [
        "Handle control testing tables that drop a header row in CSV exports",
        "Handle shifted sample columns where sample_size appears after test status"
      ]
    },
    {
      "id": "acct_controls_narrative_deficiency_table",
      "name": {
        "en": "Control Deficiencies",
        "pt": "Deficiencias de Controle"
      },
      "section": "deficiencies",
      "expectedColumns": [
        "finding_id",
        "control_id",
        "description",
        "severity",
        "debit",
        "credit",
        "remediation_due"
      ],
      "keyRows": [
        "open",
        "closed"
      ],
      "unitsRules": [
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "debit",
            "credit"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "debit",
            "credit"
          ],
          "scale": 1000000,
          "aliases": [
            "m"
          ]
        }
      ],
      "debitCreditConventions": {
        "debitColumns": [
          "debit"
        ],
        "creditColumns": [
          "credit"
        ]
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "BRL",
        "$",
        "R$"
      ]
    },
    {
      "id": "acct_controls_narrative_summary_table",
      "name": {
        "en": "Controls Summary",
        "pt": "Resumo de Controles"
      },
      "section": "summary",
      "expectedColumns": [
        "metric",
        "value"
      ],
      "keyRows": [
        "total",
        "difference"
      ],
      "unitsRules": [
        {
          "unitId": "unitless",
          "appliesToColumns": [
            "metric"
          ],
          "scale": 1
        }
      ],
      "debitCreditConventions": {
        "metricColumns": [
          "metric"
        ],
        "valueColumns": [
          "value"
        ]
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "BRL",
        "$",
        "R$"
      ],
      "extractionNotes": [
        "Accept summary key-value rows in any order",
        "Accept locale decimals and currency prefixes"
      ]
    }
  ]
}
