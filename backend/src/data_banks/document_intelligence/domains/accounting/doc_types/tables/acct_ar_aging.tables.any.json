{
  "_meta": {
    "id": "di_accounting_tables_acct_ar_aging",
    "version": "1.1.0",
    "description": "Expected table patterns for AR aging documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "accounting",
    "docType": "acct_ar_aging"
  },
  "tableHeaderSynonyms": {
    "debit": [
      "debit",
      "dr",
      "debit amount",
      "debito"
    ],
    "credit": [
      "credit",
      "cr",
      "credit amount",
      "credito"
    ]
  },
  "tables": [
    {
      "id": "acct_ar_aging_detail_table",
      "name": {
        "en": "AR Aging Detail",
        "pt": "Detalhe de Envelhecimento AR"
      },
      "section": "line_items",
      "expectedColumns": [
        "customer_id",
        "customer_name",
        "invoice_no",
        "invoice_date",
        "due_date",
        "days_outstanding",
        "bucket",
        "amount"
      ],
      "keyRows": [
        "subtotal"
      ],
      "unitsRules": [
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "amount"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "amount"
          ],
          "scale": 1000000,
          "aliases": [
            "m"
          ]
        }
      ],
      "debitCreditConventions": {
        "notes": "AR aging amounts usually represent receivable balances and are usually debit-balance signed positive"
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "GBP",
        "BRL"
      ]
    },
    {
      "id": "acct_ar_aging_bucket_table",
      "name": {
        "en": "AR Aging Buckets",
        "pt": "Faixas de Envelhecimento AR"
      },
      "section": "buckets",
      "expectedColumns": [
        "bucket",
        "bucket_amount"
      ],
      "keyRows": [
        "current",
        "bucket_1_30",
        "bucket_31_60",
        "bucket_61_90",
        "bucket_over_90",
        "grand_total"
      ],
      "unitsRules": [
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "bucket_amount"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "bucket_amount"
          ],
          "scale": 1000000,
          "aliases": [
            "m"
          ]
        }
      ],
      "debitCreditConventions": {
        "valueColumns": [
          "bucket_amount"
        ]
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "BRL",
        "R$"
      ]
    },
    {
      "id": "acct_ar_aging_summary_table",
      "name": {
        "en": "AR Aging Summary",
        "pt": "Resumo de Envelhecimento AR"
      },
      "section": "summary",
      "expectedColumns": [
        "metric",
        "value"
      ],
      "keyRows": [
        "total_ar_balance",
        "customer_count",
        "max_days"
      ],
      "unitsRules": [
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "value"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "value"
          ],
          "scale": 1000000,
          "aliases": [
            "m"
          ]
        }
      ],
      "debitCreditConventions": {
        "metricColumns": [
          "metric"
        ],
        "debitColumns": [
          "total_ar_balance"
        ],
        "creditColumns": [
          "max_days"
        ],
        "notes": "Normalize AR summary metrics where needed; treat total_ar_balance as debit-side exposure and remaining metrics as metadata."
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "GBP",
        "BRL",
        "$",
        "€",
        "£",
        "R$"
      ]
    }
  ]
}
