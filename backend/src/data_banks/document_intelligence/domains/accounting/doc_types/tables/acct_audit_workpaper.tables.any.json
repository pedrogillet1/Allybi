      "credit amount",
      "credit qty"
    ],
    "currency": [
      "currency",
      "currency code",
      "moeda",
      "ccy"
    ]
  },
  "tables": [
    {
      "id": "acct_audit_workpaper_testing_table",
      "name": {
        "en": "Audit Workpaper Testing Steps",
        "pt": "Passos de Teste da Auditoria"
      },
      "section": "testing_steps",
      "expectedColumns": [
        "test_id",
        "assertion",
        "population",
        "sample_size",
        "exceptions",
        "debit",
        "credit",
        "status"
      ],
      "keyRows": [
        "subtotal",
        "grand_total"
      ],
      "headerSynonyms": {
        "test_id": [
          "test id",
          "procedure id",
          "test id"
        ],
        "assertion": [
          "assertion",
          "objective",
          "audit objective"
        ],
        "population": [
          "population",
          "sample population"
        ],
        "sample_size": [
          "sample size",
          "samples",
          "sample count"
        ],
        "exceptions": [
          "exceptions",
          "exceptions found"
        ],
        "status": [
          "status",
          "result"
        ]
      },
      "unitsRules": [
        {
          "unitId": "unitless",
          "appliesToColumns": [
            "sample_size",
            "exceptions"
          ],
          "scale": 1
        },
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "debit",
            "credit"
          ],
          "scale": 1000,
          "aliases": [
            "k",
            "000"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "debit",
            "credit"
          ],
          "scale": 1000000,
          "aliases": [
            "m",
            "mm"
          ]
        }
      ],
      "debitCreditConventions": {
        "debitColumns": [
          "debit"
        ],
        "creditColumns": [
          "credit"
        ],
        "balanceColumns": [
          "exceptions"
        ],
        "notes": "Some exports place debit and credit columns in opposite order for the same test"
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "GBP",
        "BRL",
        "USD",
        "$",
        "€",
        "R$"
      ],
      "extractionNotes": [
        "Support shifted column order where sample_size appears after status",
        "Allow for exports where headers wrap onto two rows"
      ]
    },
    {
      "id": "acct_audit_workpaper_tieout_table",
      "name": {
        "en": "Audit Workpaper Tie-outs",
        "pt": "Conciliacao de Trabalho de Auditoria"
      },
      "section": "tie_outs",
      "expectedColumns": [
        "account_code",
        "account_name",
        "book_balance",
        "subledger_balance",
        "debit_adjustment",
        "credit_adjustment",
        "difference"
      ],
      "keyRows": [
        "grand_total"
      ],
      "unitsRules": [
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "book_balance",
            "subledger_balance",
            "debit_adjustment",
            "credit_adjustment",
            "difference"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "book_balance",
            "subledger_balance",
            "debit_adjustment",
            "credit_adjustment",
            "difference"
          ],
          "scale": 1000000,
          "aliases": [
            "m"
          ]
        }
      ],
      "debitCreditConventions": {
        "debitColumns": [
          "debit_adjustment"
        ],
        "creditColumns": [
          "credit_adjustment"
        ],
        "balanceColumns": [
          "book_balance",
          "subledger_balance",
          "difference"
        ]
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "GBP",
        "BRL",
        "$",
        "R$",
        "JPY",
        "CHF"
      ],
      "extractionNotes": [
        "Handle pages where tie-out tables are concatenated without explicit section headings",
        "Handle column swaps between book and subledger balances"
      ]
    },
    {
      "id": "acct_audit_workpaper_summary_table",
      "name": {
        "en": "Audit Workpaper Summary",
        "pt": "Resumo de Trabalho de Auditoria"
      },
      "section": "summary",
      "expectedColumns": [
        "metric",
        "value",
        "currency"
      ],
      "keyRows": [
        "issue_count",
        "sample_size",
        "conclusion",
        "out_of_balance"
      ],
      "unitsRules": [
        {
          "unitId": "unitless",
          "appliesToColumns": [
            "metric"
          ],
          "scale": 1
        },
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "value"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        }
      ],
      "debitCreditConventions": {
        "metricColumns": [
          "metric"
        ],
        "valueColumns": [
          "value"
        ]
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "BRL",
        "$",
        "R$"
      ],
      "extractionNotes": [
        "Accept summary rows appearing in different order",
        "Handle summary tables where totals appear in merged cells"
      ]
    }
  ]
}
