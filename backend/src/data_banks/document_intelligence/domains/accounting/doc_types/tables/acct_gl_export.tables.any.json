  "tables": [
    {
      "id": "acct_gl_export_main_table",
      "name": {
        "en": "General Ledger Export Main",
        "pt": "Exportacao do Razao Geral Principal"
      },
      "section": "line_items",
      "expectedColumns": [
        "posting_date",
        "journal_id",
        "account_code",
        "account_name",
        "description",
        "currency_code",
        "debit",
        "credit",
        "balance"
      ],
      "keyRows": [
        "grand_total",
        "subtotal",
        "end_of_file"
      ],
      "headerSynonyms": {
        "posting_date": [
          "posting date",
          "journal date",
          "transaction date",
          "date"
        ],
        "journal_id": [
          "journal id",
          "journal number",
          "je",
          "entry id"
        ],
        "account_code": [
          "account",
          "account code",
          "account no",
          "acct"
        ],
        "currency_code": [
          "currency",
          "ccy",
          "moeda"
        ],
        "debit": [
          "dr",
          "debit",
          "debit amount"
        ],
        "credit": [
          "cr",
          "credit",
          "credit amount"
        ],
        "balance": [
          "balance",
          "running balance",
          "saldo"
        ]
      },
      "debitCreditConventions": {
        "debitColumns": [
          "debit"
        ],
        "creditColumns": [
          "credit"
        ],
        "notes": "when both debit and credit are populated, compute net movement from signed sum"
      },
      "unitsRules": [
        {
          "unitId": "unitless",
          "appliesToColumns": [
            "journal_id"
          ],
          "scale": 1
        },
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "debit",
            "credit",
            "balance"
          ],
          "scale": 1000,
          "aliases": [
            "k",
            "000"
          ]
        },
        {
          "unitId": "millions",
          "appliesToColumns": [
            "debit",
            "credit",
            "balance"
          ],
          "scale": 1000000,
          "aliases": [
            "m"
          ]
        }
      ],
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "GBP",
        "JPY",
        "BRL",
        "$",
        "€",
        "£"
      ]
    },
