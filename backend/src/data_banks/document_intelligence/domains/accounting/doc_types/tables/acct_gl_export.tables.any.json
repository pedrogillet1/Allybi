          "metric"
        ],
        "debitMetrics": [
          "total_debits"
        ],
        "creditMetrics": [
          "total_credits",
          "difference"
        ],
        "notes": "Summary rows that use total_debits/total_credits should be treated as debit- versus credit-style totals even when flattened."
      },
      "multiCurrencyPatterns": [
        "USD",
        "EUR",
        "GBP",
        "BRL",
        "$",
        "€",
        "£",
        "R$"
      ],
      "extractionNotes": [
        "Handle summary rows that may appear in merged cells or multiple spacing styles",
        "Allow both native and translated labels like 'Totais' and 'Summary'"
      ]
    }
