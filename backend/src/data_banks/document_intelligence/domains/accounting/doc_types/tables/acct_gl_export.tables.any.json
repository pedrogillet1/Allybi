    {
      "id": "acct_gl_export_summary_table",
      "name": {
        "en": "General Ledger Export Summary",
        "pt": "Resumo de Exportacao do Razao Geral"
      },
      "section": "totals",
      "expectedColumns": [
        "metric",
        "value"
      ],
      "keyRows": [
        "total",
        "difference",
        "total_debits",
        "total_credits"
      ],
      "unitsRules": [
        {
          "unitId": "thousands",
          "appliesToColumns": [
            "value"
          ],
          "scale": 1000,
          "aliases": [
            "k"
          ]
        },
