      ]
    },
    {
      "section": "proc_section_award_rationale",
      "weight": 9,
      "operators": [
        "extract",
        "compare",
        "evaluate",
        "validate"
      ]
    },
    {
      "section": "proc_section_contract_obligations",
      "weight": 7.5,
      "operators": [
        "extract",
        "summarize",
        "validate",
        "navigate"
      ]
    },
    {
      "section": "proc_section_delivery_plan",
      "weight": 6.8,
      "operators": [
        "extract",
        "compare",
        "monitor",
        "summarize"
      ]
    },
    {
      "section": "proc_section_invoice_reconciliation",
      "weight": 7.9,
      "operators": [
        "extract",
