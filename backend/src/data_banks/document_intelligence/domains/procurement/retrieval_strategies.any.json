    }
  ],
  "tablePriority": [
    {
      "table": "proc_table_bid_comparison",
      "weight": 9.1,
      "operators": [
        "compare",
        "extract",
        "summarize"
      ]
    },
    {
      "table": "proc_table_line_items",
      "weight": 8.7,
      "operators": [
        "extract",
        "calculate",
        "validate"
      ]
    },
    {
      "table": "proc_table_contract_milestones",
      "weight": 8.2,
      "operators": [
        "extract",
        "monitor",
