  "queryExpansion": [
    "vendor evaluation score",
    "award criteria",
    "delivery date",
    "PO number",
    "invoice mismatch",
    "SLA penalties",
    "preferred supplier",
    "contract term",
    "escolha de fornecedor",
    "adjudicação"
  ],
  "strategies": [
    {
      "id": "proc_strategy_tie_out",
      "operators": [
        "validate",
        "compare"
      ],
      "description": "Tie bid claims to source sections before ranking or score comparison.",
      "steps": [
        "resolve the active sourcing document",
        "load evaluation matrix and award rationale",
        "extract bid-level evidence with weights",
        "recompute winner only if formulas are explicit"
      ]
    },
    {
      "id": "proc_strategy_recon",
      "operators": [
        "extract",
        "calculate",
        "validate"
      ],
      "description": "Prioritize invoice reconciliation tables for variance and exception reporting.",
      "steps": [
        "pull PO and delivery context",
        "match invoice quantities and prices",
        "separate approved versus blocked exceptions",
        "quote variance basis and owner"
      ]
    }
  ]
}
