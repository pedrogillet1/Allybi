  "runtimeHints": {
    "priorityOrder": [
      "cre_section_property_profile",
      "cre_section_lease_terms",
      "cre_section_tenant_summary",
      "cre_section_rent_roll",
      "cre_section_valuation_inputs",
      "cre_section_occupancy_risk",
      "cre_section_title_and_encumbrances",
      "cre_section_compliance_and_inspection",
      "cre_section_capex_plan"
    ],
    "mustAnchorCrossQueryIf": "queryType in ['compare','evaluate','calculate','validate']"
  }
}
