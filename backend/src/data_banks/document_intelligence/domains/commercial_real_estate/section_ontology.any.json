      "aliases": [
        "title",
        "encumbrance",
        "liens"
      ],
      "canonicalPurpose": "Preserves ownership certainty and legal risk boundaries."
    },
    {
      "id": "cre_section_compliance_and_inspection",
      "name": {
        "en": "Compliance and Inspection",
        "pt": "Compliance e Inspeção"
      },
      "aliases": [
        "inspection",
        "compliance",
        "building condition"
      ],
      "canonicalPurpose": "Captures structural, environmental, and operational condition status."
    },
    {
      "id": "cre_section_capex_plan",
      "name": {
        "en": "CapEx Plan",
        "pt": "Plano de CAPEX"
      },
      "aliases": [
        "capex",
        "capital expenditure",
        "maintenance plan"
      ],
      "canonicalPurpose": "Tracks planned/required maintenance and renewal cost exposure."
    }
