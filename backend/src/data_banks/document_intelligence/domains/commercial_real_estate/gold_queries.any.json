{
  "_meta": {
    "id": "eval_gold_queries_commercial_real_estate_domain",
    "version": "1.0.0",
    "description": "Commercial real estate gold queries for lease reliability, occupancy analysis, and valuation grounding.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "eval-domain-brain",
    "usedBy": [
      "services/eval/goldQueryRunner.service.ts",
      "services/core/orchestration/answerPlanner.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts",
      "tests/document-intelligence/docint-eval-pack.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "commercial_real_estate",
    "scenarioType": "property_investment_reasoning"
  },
  "runtimeUsageNotes": {
    "selectionStage": "commercial real estate eval pack generation",
    "consumer": "goldQueryRunner",
    "intent": "Catch tenant-scope leaks, assumption omissions, and mixed-property blending."
  },
  "goldQueries": [
    {
      "id": "cre_gold_001",
      "lang": "en",
      "query": "For each tenant with expiry in next 18 months, show leased area, monthly rent, and renewal posture.",
      "expected": {
        "mustReadSource": [
          "rent roll",
          "lease terms",
          "tenant summary"
        ],
        "mustExtract": [
          "tenant_name",
          "lease_expiry",
          "gross_leasable_area",
          "monthly_rent",
          "renewal"
        ],
        "mustPreservePeriod": true,
        "failureConditions": [
          "tenant_aggregation_without_expiry",
          "missing_area_unit",
          "missing_rent_basis"
        ]
      }
    },
    {
      "id": "cre_gold_002",
      "lang": "en",
      "query": "Calculate occupancy risk concentration by tenant and show top-3 tenants by lease revenue share.",
      "expected": {
        "mustFindSection": [
          "rent roll",
          "occupancy and risk",
          "property profile"
        ],
        "mustExtract": [
          "property_id",
          "tenant",
          "occupancy_rate",
          "monthly_rent"
        ],
        "mustPreserveMethod": true,
        "failureConditions": [
          "concentration_derived_without_property_scope",
          "missing_method",
          "no_risk_ranking"
        ]
      }
    },
    {
      "id": "cre_gold_003",
      "lang": "en",
      "query": "Summarize valuation assumptions, comp basis, and any deviations from standard cap-rate assumptions.",
      "expected": {
        "mustFindSection": [
          "valuation inputs",
          "compliance and inspection",
          "due diligence pack"
        ],
        "mustExtract": [
          "cap_rate",
          "assumptions",
          "comparison_basis",
          "adjustments"
        ],
        "mustPreserveAssumption": true,
        "failureConditions": [
          "no_assumption",
          "no_cap_rate",
          "missing_adjustment_discclosure"
        ]
      }
    },
    {
      "id": "cre_gold_004",
      "lang": "pt",
      "query": "Mostre os riscos imediatos de vencimento e despesas de manutenção com owner e prazo por imóvel.",
      "expected": {
        "mustInclude": [
          "vencimento",
          "despesa de manutenção",
          "proprietário",
          "prazo",
          "imóvel"
        ],
        "mustPreserveTimeWindow": true,
        "failureConditions": [
          "sem_imovel",
          "sem_proprietario",
          "sem_prazo"
        ]
      }
    }
  ],
  "qualityGuards": {
    "maxAllowedInferenceRate": 0.11,
    "requiredAnchorDensity": 2.5,
    "penalties": {
      "missing_tenant_scope": -38,
      "missing_assumptions": -35,
      "missing_property_id": -40
    }
  },
  "tests": {
    "cases": [
      {
        "id": "cre_gold_requires_property_tenant",
        "input": {
          "query": "cre_gold_001"
        },
        "expect": {
          "mustCheck": [
            "mustExtract",
            "mustPreserveMethod"
          ]
        }
      }
    ]
  }
}
