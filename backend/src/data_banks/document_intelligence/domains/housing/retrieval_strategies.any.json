  "boostRules": [
    {
      "id": "housing_boost_001_core_fields",
      "priority": 95,
      "weight": 2.8,
      "operators": [
        "extract",
        "validate"
      ],
      "condition": "query asks key dates, amounts, status, or identifiers",
