  "strategies": [
    {
      "id": "rs_strategy_endpoint_guarded_compare",
      "operators": [
        "compare",
        "evaluate"
      ],
      "description": "Compare outcomes only when endpoint and population are held constant.",
      "steps": [
        "extract endpoint definitions",
        "load cohort criteria",
        "align sample sizes and arms",
        "validate p-value and CI from same table"
      ]
    },
    {
      "id": "rs_strategy_reproducibility_check",
      "operators": [
        "validate",
        "summarize"
      ],
      "description": "Surface reproducibility and sensitivity limitations before high-confidence claims.",
      "steps": [
        "load methods and protocol versions",
        "extract deviations and missingness",
        "load sensitivity scenarios",
        "report claim confidence and caveats"
      ]
    }
  ]
