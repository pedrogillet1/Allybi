{
  "_meta": {
    "id": "di_research_scientific_doc_type_catalog",
    "version": "1.0.0",
    "description": "Scientific document catalog for protocols, trials, datasets, analyses, and publication-grade interpretation.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "domain-brain",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts",
      "services/core/retrieval/domainIntentRouter.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts",
      "tests/document-intelligence/docint-eval-pack.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "research_scientific"
  },
  "domain": "research_scientific",
  "docTypes": [
    {
      "id": "research_protocol",
      "name": {
        "en": "Study Protocol",
        "pt": "Protocolo do Estudo"
      },
      "description": "Design and rationale defining hypotheses, endpoints, and inclusion/exclusion.",
      "detectionPatterns": [
        "\\bstudy protocol\\b",
        "\\bprotocol\\b",
        "\\bprotocolo do estudo\\b",
        "\\bhypothesis\\b"
      ],
      "canonicalSections": [
        "hypothesis",
        "population",
        "endpoints",
        "method",
        "sample criteria"
      ],
      "extractionPriority": 142,
      "riskTier": "high"
    },
    {
      "id": "research_inclusion_criteria",
      "name": {
        "en": "Inclusion/Exclusion Criteria",
        "pt": "Critérios de Inclusão/Exclusão"
      },
      "description": "Population eligibility and exclusions that define inference scope.",
      "detectionPatterns": [
        "\\binclusion criteria\\b",
        "\\bexclusion criteria\\b",
        "\\bcriterios de inclusão\\b",
        "\\beligibility\\b"
      ],
      "canonicalSections": [
        "population",
        "inclusion",
        "exclusion",
        "special groups"
      ],
      "extractionPriority": 137,
      "riskTier": "critical"
    },
    {
      "id": "research_dataset_dictionary",
      "name": {
        "en": "Dataset Dictionary",
        "pt": "Dicionário de Dados"
      },
      "description": "Variable definitions, coding, units, and accepted value domains.",
      "detectionPatterns": [
        "\\bdataset dictionary\\b",
        "\\bvariable dictionary\\b",
        "\\bdicionário de dados\\b",
        "\\bdata dictionary\\b"
      ],
      "canonicalSections": [
        "variables",
        "units",
        "coding",
        "missingness"
      ],
      "extractionPriority": 136,
      "riskTier": "high"
    },
    {
      "id": "research_experiment_log",
      "name": {
        "en": "Experiment Log",
        "pt": "Registro Experimental"
      },
      "description": "Chronological test operations and protocol deviation notes.",
