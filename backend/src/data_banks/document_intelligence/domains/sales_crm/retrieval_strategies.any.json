  "strategies": [
    {
      "id": "crm_strategy_stage_safe_compare",
      "operators": [
        "compare",
        "summarize"
      ],
      "description": "Compare opportunities only when stages, close dates, and owner are explicit.",
      "steps": [
        "resolve stages with canonical labels",
        "lock owner and period",
        "compare metrics on same stage family",
        "append caveat if approval differs"
      ]
    },
    {
      "id": "crm_strategy_renewal_diagnostic",
      "operators": [
        "monitor",
        "advise",
        "evaluate"
      ],
      "description": "Surface renewal risk with immediate actions and dependency on close-date and owner context.",
      "steps": [
        "extract renewal candidates",
        "find churn or risk flags",
        "produce next-best-actions",
        "link each suggestion to owner and date"
      ]
    }
  ]
