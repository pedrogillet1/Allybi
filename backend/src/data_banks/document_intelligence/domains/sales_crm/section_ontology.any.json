  "runtimeHints": {
    "priorityOrder": [
      "crm_section_account_summary",
      "crm_section_funnel_position",
      "crm_section_pricing_matrix",
      "crm_section_activity_log",
      "crm_section_risk_register",
      "crm_section_renewal_path",
      "crm_section_winloss"
    ]
