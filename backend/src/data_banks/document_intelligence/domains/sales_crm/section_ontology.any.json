{
  "_meta": {
    "id": "di_sales_crm_section_ontology",
    "version": "1.0.0",
    "description": "CRM section ontology for opportunity, pricing, and retention reasoning.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "domain-brain",
