        "en": "Account Summary",
        "pt": "Resumo da Conta"
      },
      "aliases": [
        "customer",
        "account",
        "perfil do cliente"
      ],
      "canonicalPurpose": "Anchor for ownership, geography, and segment context."
    },
    {
      "id": "crm_section_funnel_position",
      "name": {
        "en": "Funnel Position",
        "pt": "Posição no Funil"
      },
      "aliases": [
        "stage",
        "pipeline stage",
        "etapa"
      ],
      "canonicalPurpose": "Represents progress and conversion probability."
    },
    {
      "id": "crm_section_pricing_matrix",
      "name": {
        "en": "Pricing Matrix",
        "pt": "Matriz de Preços"
      },
      "aliases": [
        "quote table",
        "preço",
        "margem"
      ],
      "canonicalPurpose": "Captures unit price, discount, approval limit, and commercial terms."
    },
    {
      "id": "crm_section_risk_register",
      "name": {
        "en": "CRM Risk Register",
        "pt": "Registro de Riscos Comerciais"
