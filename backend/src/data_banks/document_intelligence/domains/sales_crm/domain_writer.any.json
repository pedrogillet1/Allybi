{
  "_meta": {
    "id": "sales_crm_domain_writer",
    "version": "1.0.0",
    "description": "Sales CRM writer profile for owner-safe, stage-anchored commercial synthesis.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-13",
    "owner": "domain-brain",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts",
      "services/core/orchestration/answerPlanner.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts",
      "tests/document-intelligence/docint-eval-pack.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "deterministic": true,
    "domain": "sales_crm",
    "interpretationMode": "owner_and_stage_aware",
    "requireStageNormalization": true
  },
  "runtimeUsageNotes": {
    "selectionStage": "before final sales/CRM narrative generation",
    "consumer": "sales CRM writer",
    "intent": "Convert extracted pipeline and quotes into decision-ready recommendations with clear assumptions.",
    "emittedSignals": [
      "salesPipelineMode",
      "crmOwnerBound",
      "salesPricingMode",
      "salesRenewalMode"
    ]
  },
  "writingProfile": {
    "audience": "sales manager, revenue operations, account executive",
    "goal": "Produce concise summaries with stage precision and owner accountability.",
    "allowedAnswerForms": [
      "funnel_health_readout",
      "risk_action_matrix",
      "quote_validation_report",
      "renewal_readiness_readout"
    ],
    "forbiddenAnswerForms": [
      "winner-likelihood without stage lock",
      "discount claim without approval evidence",
      "owner-agnostic aggregation when owners conflict"
    ],
    "docTypeAnchors": [
      "sales_opportunity_pack",
      "sales_quote_proposal",
      "sales_pipeline_report",
      "sales_renewal_pack",
      "sales_winloss_review",
      "sales_pricing_pack"
    ],
    "sectionPriority": [
      "funnel_position",
      "account_summary",
      "pricing_matrix",
      "risk_register",
      "activity_log",
      "renewal_path"
    ]
  },
  "interpretiveRules": [
    {
      "id": "CRM_WRITER_001_stage_guard",
      "description": "State stage definitions before ranking cross-opportunity.",
      "requiredFor": "compare"
    },
    {
      "id": "CRM_WRITER_002_owner_first",
      "description": "Every recommendation includes owner and explicit next action owner handoff."
    },
    {
      "id": "CRM_WRITER_003_currency_period_guard",
      "description": "Show currency and period whenever quoting/revenue figures are present."
    },
    {
      "id": "CRM_WRITER_004_renewal_window_guard",
      "description": "For churn risk or renewal actions, include expiry window and responsible owner."
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "crm_writer_calls_out_stage_basis",
        "input": {
          "query": "Compare stage transition performance"
        },
        "expect": {
          "mustInclude": [
            "stage"
          ]
        }
      },
      {
        "id": "crm_writer_owner_visibility",
        "input": {
          "query": "Show at-risk accounts and next steps"
        },
        "expect": {
          "mustInclude": [
            "owner",
            "next action"
          ]
        }
      }
    ]
  }
}
