{
  "_meta": {
    "id": "di_everyday_entities_every_identity_document",
    "version": "1.0.0",
    "description": "Entity schema for every_identity_document.",
    "languages": ["any"],
    "lastUpdated": "2026-03-03"
  },
  "config": {
    "enabled": true,
    "domain": "everyday",
    "docType": "every_identity_document"
  },
  "schemaVersion": "2026-03-03",
  "entities": [
    {
      "id": "document_type",
      "type": "string",
      "required": true,
      "description": "Type of identity document.",
      "section": "document_header",
      "evidence": {
        "minCitations": 1,
        "anchors": ["passport", "identity", "driver license", "rg", "id", "document type"],
        "disallowInference": true,
        "preferredSources": ["document_header"]
      }
    },
    {
      "id": "document_number",
      "type": "string",
      "required": true,
      "description": "Raw document identifier.",
      "section": "identity_fields",
      "evidence": {
        "minCitations": 1,
        "anchors": ["document number", "id number", "documento", "numero", "numero do documento"],
        "disallowInference": true,
        "preferredSources": ["identity_fields"]
      }
    },
    {
      "id": "document_number_redacted",
      "type": "string",
      "required": false,
      "description": "Redacted/masked document number for safe output.",
      "section": "identity_fields",
      "evidence": {
        "minCitations": 0,
        "anchors": ["redacted id", "masked", "xxxx", "redacted number"],
        "disallowInference": true,
        "preferredSources": ["security_features", "verification"]
      }
    },
    {
      "id": "full_name",
      "type": "string",
      "required": true,
      "description": "Full legal name.",
      "section": "identity_fields",
      "evidence": {
        "minCitations": 1,
        "anchors": ["name", "nome", "full name", "nome completo"],
        "disallowInference": true,
        "preferredSources": ["identity_fields", "issuer_and_validity"]
      }
    },
    {
      "id": "full_name_redacted",
      "type": "string",
      "required": false,
      "description": "Masked full name for safe exposure.",
      "section": "identity_fields",
      "evidence": {
        "minCitations": 0,
        "anchors": ["redacted name", "masked name", "initials only"],
        "disallowInference": true,
        "preferredSources": ["verification", "security_features"]
      }
    },
    {
      "id": "date_of_birth",
      "type": "date",
      "required": true,
      "description": "Date of birth.",
      "section": "identity_fields",
      "evidence": {
        "minCitations": 1,
        "anchors": ["date of birth", "nascimento", "born", "birth date"],
        "disallowInference": true,
        "preferredSources": ["identity_fields"]
      }
    },
    {
      "id": "sex",
      "type": "enum",
      "values": ["male", "female", "non_binary", "unknown"],
      "required": false,
      "description": "Biological sex, if present.",
      "section": "identity_fields",
      "evidence": {
        "minCitations": 1,
        "anchors": ["sex", "gender", "sexo"],
        "disallowInference": false,
        "preferredSources": ["identity_fields"]
      }
    },
    {
      "id": "nationality",
      "type": "string",
      "required": false,
      "description": "Document holder nationality.",
      "section": "identity_fields",
      "evidence": {
        "minCitations": 1,
        "anchors": ["nationality", "nacionalidade", "national", "country"],
        "disallowInference": false,
        "preferredSources": ["identity_fields", "issue"]
      }
    },
    {
      "id": "issue_date",
      "type": "date",
      "required": true,
      "description": "Date issued.",
      "section": "issuer_and_validity",
      "evidence": {
        "minCitations": 1,
        "anchors": ["issue date", "issued", "emissao", "data de emissao"],
        "disallowInference": true,
        "preferredSources": ["issuer_and_validity"]
      }
    },
    {
      "id": "expiry_date",
      "type": "date",
      "required": true,
      "description": "Expiry date.",
      "section": "issuer_and_validity",
      "evidence": {
        "minCitations": 1,
        "anchors": ["expiry", "valid until", "validade", "vencimento", "expira"],
        "disallowInference": true,
        "preferredSources": ["issuer_and_validity"]
      }
    },
    {
      "id": "issuing_authority",
      "type": "string",
      "required": false,
      "description": "Issuing authority.",
      "section": "issuer_and_validity",
      "evidence": {
        "minCitations": 1,
        "anchors": ["authority", "issuing authority", "orgao expedidor"],
        "disallowInference": false,
        "preferredSources": ["issuer_and_validity"]
      }
    },
    {
      "id": "issuing_country",
      "type": "string",
      "required": false,
      "description": "Issuing country.",
      "section": "issuer_and_validity",
      "evidence": {
        "minCitations": 1,
        "anchors": ["country", "issued by", "pais", "country of issue"],
        "disallowInference": false,
        "preferredSources": ["issuer_and_validity"]
      }
    },
    {
