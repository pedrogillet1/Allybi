      "type": "enum",
      "values": ["yes", "no", "unknown"],
      "required": false,
      "description": "Photo field presence.",
      "section": "photograph_or_biometric",
      "evidence": {
        "minCitations": 1,
        "anchors": ["photo", "picture", "foto", "image"],
        "disallowInference": false,
        "preferredSources": ["photograph_or_biometric"]
      }
    },
    {
      "id": "biometric_present",
      "type": "enum",
      "values": ["yes", "no", "unknown"],
      "required": false,
      "description": "Biometric markers present.",
      "section": "photograph_or_biometric",
      "evidence": {
        "minCitations": 1,
        "anchors": ["biometric", "fingerprint", "irises", "biometria"],
        "disallowInference": false,
        "preferredSources": ["photograph_or_biometric", "security_features"]
      }
    },
    {
      "id": "mrz_line",
      "type": "string",
      "required": false,
      "description": "Machine Readable Zone line when visible.",
      "section": "photograph_or_biometric",
      "evidence": {
        "minCitations": 1,
        "anchors": ["mrz", "machine readable", "linha mrz"],
        "disallowInference": true,
        "preferredSources": ["photograph_or_biometric"]
      }
    },
    {
      "id": "security_features",
      "type": "array_string",
      "required": false,
      "description": "Observed physical security features.",
      "section": "security_features",
      "evidence": {
        "minCitations": 1,
        "anchors": ["hologram", "watermark", "uv", "barcode", "security"],
        "disallowInference": false,
        "preferredSources": ["security_features"]
      }
    },
    {
      "id": "signature_present",
      "type": "enum",
      "values": ["yes", "no", "unknown"],
      "required": false,
      "description": "Whether signature field exists.",
      "section": "signatures_or_validity",
      "evidence": {
        "minCitations": 1,
        "anchors": ["signature", "assinatura", "assinado"],
        "disallowInference": false,
        "preferredSources": ["signatures_or_validity"]
      }
    },
    {
      "id": "verification_status",
      "type": "enum",
      "values": ["valid", "expired", "revoked", "suspended", "unknown"],
      "required": false,
      "description": "Observed validity state from document data.",
      "section": "verification",
      "evidence": {
        "minCitations": 1,
        "anchors": ["valid", "expired", "revoked", "revogado", "status"],
        "disallowInference": true,
        "preferredSources": ["verification", "issuer_and_validity"]
      }
    },
    {
      "id": "safety_notes",
      "type": "string",
      "required": false,
      "description": "Internal safety/restriction notes.",
      "section": "restrictions_or_notes",
      "evidence": {
        "minCitations": 1,
        "anchors": ["notes", "alerts", "restrictions", "limitations"],
        "disallowInference": false,
        "preferredSources": ["restrictions_or_notes"]
      }
    }
  ]
}
