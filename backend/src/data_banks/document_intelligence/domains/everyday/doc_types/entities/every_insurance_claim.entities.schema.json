      "required": false,
      "description": "Amount still outstanding.",
      "section": "payments_and_status",
      "evidence": {
        "minCitations": 1,
        "anchors": ["outstanding", "balance", "saldo", "remaining"],
        "disallowInference": true,
        "preferredSources": ["payments_and_status"]
      }
    },
    {
      "id": "deductible_applied",
      "type": "currency",
      "required": false,
      "description": "Deductible applied to the claim.",
      "section": "coverage_check",
