        "anchors": ["policy", "policy number", "apolice"],
        "disallowInference": true,
        "preferredSources": ["claim_identity"]
      }
    },
    {
      "id": "claim_type",
      "type": "string",
      "required": true,
      "description": "Type of claim.",
