{
  "_meta": {
    "id": "di_everyday_entities_every_insurance_claim",
    "version": "1.0.0",
    "description": "Entity schema for every_insurance_claim.",
    "languages": ["any"],
    "lastUpdated": "2026-03-03"
  },
  "config": {
    "enabled": true,
    "domain": "everyday",
    "docType": "every_insurance_claim"
  },
