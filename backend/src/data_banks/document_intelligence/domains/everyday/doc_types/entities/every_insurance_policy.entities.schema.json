    {
      "id": "premium_amount",
      "type": "currency",
      "required": true,
      "description": "Scheduled premium amount.",
      "section": "premium_schedule",
      "evidence": {
        "minCitations": 1,
        "anchors": ["premium", "premio", "valor do premio"],
        "disallowInference": true,
        "preferredSources": ["premium_schedule"]
      }
