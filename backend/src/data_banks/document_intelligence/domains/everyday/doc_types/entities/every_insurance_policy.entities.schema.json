      "evidence": {
        "minCitations": 1,
        "anchors": ["monthly", "anual", "quarterly", "semestral", "frequency"],
        "disallowInference": false,
        "preferredSources": ["premium_schedule"]
      }
    },
    {
      "id": "policy_status",
      "type": "enum",
      "values": ["active", "lapsed", "pending", "cancelled", "expired", "unknown"],
      "required": true,
      "description": "Current policy status.",
      "section": "renewal_terms",
      "evidence": {
        "minCitations": 1,
        "anchors": ["status", "active", "cancelled", "vencida", "cancelada"],
        "disallowInference": false,
        "preferredSources": ["renewal_terms"]
      }
    },
    {
      "id": "next_renewal_date",
      "type": "date",
      "required": false,
      "description": "Next renewal date if listed.",
      "section": "renewal_terms",
      "evidence": {
        "minCitations": 1,
        "anchors": ["renewal", "renovacao", "next renewal", "revisao"],
        "disallowInference": true,
        "preferredSources": ["renewal_terms"]
      }
    },
    {
      "id": "benefit_notes",
      "type": "string",
      "required": false,
      "description": "Key benefit notes and summaries.",
      "section": "benefits_or_addons",
      "evidence": {
        "minCitations": 1,
        "anchors": ["benefits", "coverage", "addons", "extras"],
        "disallowInference": false,
        "preferredSources": ["benefits_or_addons"]
      }
    },
    {
      "id": "exclusions_summary",
      "type": "string",
      "required": false,
      "description": "Key exclusions summary.",
      "section": "exclusions",
      "evidence": {
        "minCitations": 1,
        "anchors": ["exclusions", "not covered", "excluido"],
        "disallowInference": false,
        "preferredSources": ["exclusions"]
      }
