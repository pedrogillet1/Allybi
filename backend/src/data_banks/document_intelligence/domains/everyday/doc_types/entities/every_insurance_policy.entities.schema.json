      "evidence": {
        "minCitations": 1,
        "anchors": ["end date", "expiration", "fim", "vigencia fim"],
        "disallowInference": true,
        "preferredSources": ["coverage_details"]
      }
    },
    {
      "id": "coverage_limit",
