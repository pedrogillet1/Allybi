    {
      "id": "claim_reference",
      "type": "string",
      "required": false,
      "description": "Most recent claim identifier if present.",
      "section": "claim_reference",
      "evidence": {
        "minCitations": 1,
        "anchors": ["claim", "sinistro", "claim id"],
        "disallowInference": true,
        "preferredSources": ["claim_reference"]
      }
