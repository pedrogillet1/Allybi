      "evidence": {
        "minCitations": 1,
        "anchors": ["policy", "policy number", "apolice", "apolice numero"],
        "disallowInference": true,
        "preferredSources": ["header", "policy_holder"]
      }
    },
    {
      "id": "policy_type",
      "type": "string",
      "required": true,
      "description": "Policy type.",
      "section": "coverage_details",
      "evidence": {
        "minCitations": 1,
        "anchors": ["policy type", "coverage type", "seguro", "tipo"],
        "disallowInference": false,
        "preferredSources": ["coverage_details"]
      }
    },
    {
      "id": "insurer_name",
      "type": "string",
      "required": true,
      "description": "Insurance carrier name.",
      "section": "header",
      "evidence": {
        "minCitations": 1,
        "anchors": ["insurer", "seguradora", "company"],
        "disallowInference": true,
        "preferredSources": ["header", "policy_holder"]
      }
    },
    {
      "id": "insurer_tax_id",
      "type": "string",
      "required": false,
      "description": "Insurer tax id.",
      "section": "header",
      "evidence": {
        "minCitations": 1,
        "anchors": ["insurer id", "cnpj", "tax id"],
        "disallowInference": true,
        "preferredSources": ["header"]
      }
    },
    {
      "id": "policy_holder_name",
      "type": "string",
      "required": true,
      "description": "Policyholder name.",
      "section": "policy_holder",
      "evidence": {
        "minCitations": 1,
        "anchors": ["holder", "tomador", "policy holder", "nome"],
        "disallowInference": true,
        "preferredSources": ["policy_holder"]
      }
    },
    {
      "id": "insured_name",
      "type": "string",
      "required": false,
      "description": "Insured person or entity.",
      "section": "policy_holder",
      "evidence": {
        "minCitations": 1,
        "anchors": ["insured", "segurado", "insured person", "beneficiary"],
        "disallowInference": true,
        "preferredSources": ["policy_holder"]
      }
    },
    {
      "id": "beneficiary_name",
      "type": "string",
      "required": false,
