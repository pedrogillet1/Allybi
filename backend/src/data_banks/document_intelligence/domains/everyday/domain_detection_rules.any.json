{
  "_meta": {
    "id": "di_everyday_domain_detection_rules",
    "version": "1.0.0",
    "description": "Detection logic for everyday documents with strong negative discrimination between billing, tax, and identity documents.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "everyday",
    "minScore": 0.64,
    "maxRulesPerDocument": 80,
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "domain": "everyday",
  "rules": [
    {
      "id": "every_detect_001_tax_return",
      "priority": 140,
      "weight": 4.2,
      "signal": "heading_or_content",
      "patterns": [
        "\\btax return\\b",
        "\\bannual return\\b",
        "\\bdeclaracao\\s+de\\s+imposto\\b",
        "\\birs number\\b"
      ],
      "negativePatterns": [
        "\\bretail receipt\\b",
        "\\binvoice\\b",
        "\\blojas\\b",
        "\\bpatient\\b",
        "\\bdiagnostic\\b",
        "\\blab\\s+result\\b"
      ],
      "docTypeHint": "every_tax_return",
      "description": "Tax return markers"
    },
    {
      "id": "every_detect_002_tax_notice",
      "priority": 139,
      "weight": 4,
      "signal": "heading_or_content",
      "patterns": [
        "\\btax notice\\b",
        "\\bassessment notice\\b",
        "\\bnotice of assessment\\b",
        "\\bnotificacao\\s+de\\s+lancamento\\b"
      ],
      "negativePatterns": [
        "\\breceipt\\b",
        "\\binvoice\\b",
        "\\bmedical\\b"
      ],
      "docTypeHint": "every_tax_notice",
      "description": "Tax notice markers"
    },
    {
      "id": "every_detect_003_phone_bill",
      "priority": 138,
      "weight": 3.9,
      "signal": "heading_or_content",
      "patterns": [
        "\\bphone bill\\b",
        "\\bcell phone bill\\b",
        "\\bmobile bill\\b",
        "\\bconta\\s+de\\s+telefone\\b"
      ],
      "negativePatterns": [
        "\\bpatient\\b",
        "\\blab\\b",
        "\\bgenerated by physician\\b",
        "\\bhospital\\b",
        "\\blab result\\b"
      ],
      "docTypeHint": "every_phone_bill",
      "description": "Phone bill markers"
    },
    {
      "id": "every_detect_004_electricity_bill",
      "priority": 137,
      "weight": 3.9,
      "signal": "heading_or_content",
      "patterns": [
        "\\belectricity bill\\b",
        "\\butility bill\\b",
        "\\bmeter reading\\b",
        "\\bconta\\s+de\\s+energia\\b"
      ],
      "negativePatterns": [
        "\\bhemoglobin\\b",
        "\\breference range\\b",
        "\\bhospital\\b"
      ],
      "docTypeHint": "every_electricity_bill",
      "description": "Electricity bill markers"
    },
    {
      "id": "every_detect_005_internet_bill",
      "priority": 136,
      "weight": 3.9,
      "signal": "heading_or_content",
      "patterns": [
        "\\binternet bill\\b",
        "\\bisp bill\\b",
        "\\bbroadband\\b",
        "\\bconta\\s+de\\s+internet\\b"
      ],
      "negativePatterns": [
        "\\bretail\\b",
        "\\binvoice\\b",
        "\\blaboratory\\b"
      ],
      "docTypeHint": "every_internet_bill",
      "description": "Internet bill markers"
    },
    {
      "id": "every_detect_006_rent_receipt",
      "priority": 135,
      "weight": 3.8,
      "signal": "heading_or_content",
      "patterns": [
        "\\brent receipt\\b",
        "\\blease receipt\\b",
        "\\brecibo de aluguel\\b"
      ],
      "negativePatterns": [
        "\\bbank statement\\b",
        "\\bcredit card\\b",
        "\\bmedical\\b"
      ],
      "docTypeHint": "every_rent_receipt",
      "description": "Rent receipt markers"
    },
    {
      "id": "every_detect_007_retail_receipt",
      "priority": 134,
      "weight": 3.8,
      "signal": "heading_or_content",
      "patterns": [
        "\\bretail receipt\\b",
        "\\bstore receipt\\b",
        "\\breceipt\\b",
        "\\bnota fiscal\\b"
      ],
      "negativePatterns": [
        "\\btax return\\b",
        "\\btax notice\\b",
        "\\bpolicy\\b",
        "\\bclaim\\b"
      ],
      "docTypeHint": "every_retail_receipt",
      "description": "Retail receipt markers"
    },
    {
      "id": "every_detect_008_invoice",
      "priority": 133,
      "weight": 3.8,
      "signal": "heading_or_content",
      "patterns": [
        "\\binvoice\\b",
        "\\binvoice number\\b",
        "\\baccounting invoice\\b",
        "\\bfatura\\b"
      ],
      "negativePatterns": [
        "\\breceipt\\b",
        "\\bclaim\\b",
        "\\blab report\\b",
        "\\blaudo\\b"
      ],
      "docTypeHint": "every_invoice",
      "description": "Invoice markers"
    },
    {
      "id": "every_detect_009_bank_statement",
      "priority": 132,
      "weight": 4,
      "signal": "heading_or_content",
      "patterns": [
        "\\bbank statement\\b",
        "\\bstatement period\\b",
        "\\baccount balance\\b",
        "\\bextracto bancario\\b",
        "\\bsaldo\\b"
      ],
      "negativePatterns": [
        "\\breceipt\\b",
        "\\binternet bill\\b",
        "\\bidentity document\\b"
      ],
      "docTypeHint": "every_bank_statement",
      "description": "Bank statement markers"
    },
    {
      "id": "every_detect_010_insurance_policy",
      "priority": 131,
      "weight": 4,
      "signal": "heading_or_content",
      "patterns": [
        "\\binsurance policy\\b",
        "\\bpolicy number\\b",
        "\\bcoverage\\b",
        "\\bseguro\\b"
      ],
      "negativePatterns": [
        "\\blab\\b",
        "\\bmedical\\b",
        "\\bbank statement\\b",
        "\\breceipt\\b"
      ],
      "docTypeHint": "every_insurance_policy",
      "description": "Insurance policy markers"
    },
    {
      "id": "every_detect_011_insurance_claim",
      "priority": 130,
      "weight": 4,
      "signal": "heading_or_content",
      "patterns": [
        "\\binsurance claim\\b",
        "\\bclaim number\\b",
        "\\badjuster\\b",
        "\\bsiniestro\\b"
      ],
      "negativePatterns": [
        "\\bcoverage section\\b",
        "\\bpolicy statement\\b",
        "\\binvoice\\b",
        "\\blab\\b"
      ],
      "docTypeHint": "every_insurance_claim",
      "description": "Insurance claim markers"
    },
    {
      "id": "every_detect_012_identity_document",
      "priority": 129,
      "weight": 3.9,
      "signal": "heading_or_content",
      "patterns": [
        "\\bidentity document\\b",
        "\\bidentification\\b",
        "\\bdriver license\\b",
        "\\bpassaporte\\b",
        "\\bidentity card\\b"
      ],
      "negativePatterns": [
        "\\binvoice\\b",
        "\\bbill\\b",
        "\\bbank statement\\b",
        "\\bmedical\\b"
      ],
      "docTypeHint": "every_identity_document",
      "description": "Identity document markers"
    },
    {
      "id": "every_detect_013_phone_vs_internet_disambig",
      "priority": 200,
      "weight": -5,
      "signal": "negative_doctype_disambiguation",
      "positivePatterns": [
        "\\bmobile\\b|\\bcell\\b|\\bvoice\\b|\\bsms\\b|\\bmsisdn\\b|\\bimei\\b"
      ],
      "negativePatterns": [
        "\\bmegabit\\b|\\bmb\\b|\\bgbps\\b|\\bdownload\\b|\\bupload\\b|\\bbandwidth\\b|\\binternet usage\\b"
      ],
      "appliesToDocTypes": [
        "every_phone_bill"
      ],
      "description": "Disambiguate phone vs internet utilities"
    },
    {
      "id": "every_detect_014_internet_vs_phone_disambig",
      "priority": 199,
      "weight": -5,
      "signal": "negative_doctype_disambiguation",
      "positivePatterns": [
        "\\binternet\\b|\\bbroadband\\b|\\bfiber\\b|\\bwifi\\b|\\bdownload\\b|\\bupload\\b"
      ],
      "negativePatterns": [
        "\\bcalls\\b|\\bsms\\b|\\bminutes\\b|\\bimei\\b"
      ],
      "appliesToDocTypes": [
        "every_internet_bill"
      ],
      "description": "Disambiguate internet vs phone bills"
    },
    {
      "id": "every_detect_015_lab_or_medical_lockout",
      "priority": 300,
      "weight": -8,
      "signal": "negative_global",
      "patterns": [
        "\\blab result\\b",
        "\\blaboratory\\b",
        "\\breference range\\b",
        "\\bhemoglobin\\b",
        "\\bdiagnosis\\b",
        "\\bexam\\b",
        "\\blaudo\\b",
        "\\bmedic\\b"
      ],
      "description": "Suppress everyday classification when medical-lab semantics are dominant"
    },
    {
      "id": "every_detect_016_signature_cues",
      "priority": 88,
      "weight": 2,
      "signal": "content",
      "patterns": [
        "\\bsignature\\b",
        "\\bpolicyholder\\b",
        "\\bour policy\\b",
        "\\bassinado por\\b"
      ],
      "description": "Signature cues in identity, policy, and insurance documents"
    },
    {
      "id": "every_detect_017_currency_pattern",
      "priority": 82,
      "weight": 1.8,
      "signal": "table_header",
      "patterns": [
        "\\btotal\\b",
        "\\bbalance\\s+due\\b",
        "\\bamount\\b",
        "\\bcurrency\\b",
        "\\bvalor\\b"
      ],
      "description": "Monetary row cues"
    },
    {
      "id": "every_detect_018_period_pattern",
      "priority": 81,
      "weight": 1.6,
      "signal": "content",
      "patterns": [
        "\\bbilling period\\b",
        "\\bstatement period\\b",
        "\\bperiodo de cobranca\\b",
        "\\bmes de refer\\b"
      ],
      "description": "Period cues"
    },
    {
      "id": "every_detect_019_installment_pattern",
      "priority": 80,
      "weight": 1.6,
      "signal": "content",
      "patterns": [
        "\\binstallment\\b",
        "\\bparcela\\b",
        "\\bpayment schedule\\b",
        "\\bdue\\s+date\\b"
      ],
      "description": "Installment cues for invoices, bank statements, and taxes"
    },
    {
      "id": "every_detect_020_rental_term_pattern",
      "priority": 79,
      "weight": 1.7,
      "signal": "content",
      "patterns": [
        "\\blease\\b",
        "\\brental\\b",
        "\\btenant\\b",
        "\\blease term\\b",
        "\\bmorador\\b",
        "\\blocador\\b"
      ],
      "description": "Rental term cues"
    },
    {
      "id": "every_detect_021_claim_status_pattern",
      "priority": 78,
      "weight": 1.9,
      "signal": "content",
      "patterns": [
        "\\bclaim status\\b",
        "\\bclaim number\\b",
        "\\badjudication\\b",
        "\\bajuste\\b",
        "\\breserva\\b"
      ],
      "description": "Claim status cues"
    }
  ]
}
