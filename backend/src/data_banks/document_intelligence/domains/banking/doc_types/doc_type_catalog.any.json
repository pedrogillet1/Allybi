      "name": {
        "en": "Bank Statement",
        "pt": "Extrato Bancario"
      },
      "description": "Deposit account statement with transactions, balances, and period totals.",
      "detectionPatterns": [
        "\\bbank statement\\b",
        "\\baccount statement\\b",
        "\\bextrato bancario\\b",
        "\\bopening balance\\b",
        "\\bclosing balance\\b"
      ],
      "priority": 100
    },
