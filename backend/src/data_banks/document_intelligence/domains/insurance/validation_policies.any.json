{
  "_meta": {
    "id": "di_insurance_validation_policies",
    "version": "1.0.0",
    "description": "Validation policies for insurance domain with consistency and quality checks.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "insurance"
  },
  "domain": "insurance",
  "policies": [
    {
      "id": "ins_val_001_amount_reconciliation",
      "severity": "error",
      "description": "Line-item billed/allowed/paid amounts must reconcile to reported totals.",
      "applies": [
        "extract",
        "calculate",
        "validate"
      ],
      "check": "amount_reconciliation",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "ins_val_002_policy_claim_link",
      "severity": "error",
      "description": "Claims must reference a valid policy identifier in the same document set.",
      "applies": [
        "extract",
        "validate",
        "evaluate"
      ],
      "check": "policy_claim_link",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "ins_val_003_timeline_alignment",
      "severity": "error",
      "description": "Service/incident dates must align with coverage effective window unless documented exception exists.",
      "applies": [
        "evaluate",
        "validate",
        "compare"
      ],
      "check": "timeline_alignment",
      "failureAction": "WARN_AND_EXPLAIN"
    },
    {
      "id": "ins_val_004_denial_reason_presence",
      "severity": "warning",
      "description": "Denied or reduced claims should include a reason code/text.",
      "applies": [
        "extract",
        "summarize",
        "validate"
      ],
      "check": "denial_reason_presence",
      "failureAction": "ANNOTATE"
    },
    {
      "id": "ins_val_005_currency_consistency",
      "severity": "warning",
      "description": "Mixed currencies in claim calculations require explicit conversion.",
      "applies": [
        "calculate",
        "compare"
      ],
      "check": "currency_match",
      "failureAction": "WARN_AND_EXPLAIN"
    },
    {
      "id": "ins_val_006_missing_critical_guard",
      "severity": "error",
      "description": "Do not output inferred values for missing critical fields.",
      "applies": [
        "extract",
        "evaluate",
        "validate"
      ],
      "check": "critical_field_presence",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "ins_val_007_stale_document",
      "severity": "warning",
      "description": "Old policies/EOBs should be flagged as potentially stale.",
      "applies": [
        "monitor",
        "summarize",
        "evaluate"
      ],
      "check": "data_freshness",
      "failureAction": "ANNOTATE"
    },
    {
      "id": "ins_val_008_scope_lock",
      "severity": "error",
      "description": "Output must remain scoped to attached documents.",
      "applies": [
        "all"
      ],
      "check": "wrong_doc_scope_lock",
      "failureAction": "BLOCK_AND_FLAG"
    }
  ]
}
