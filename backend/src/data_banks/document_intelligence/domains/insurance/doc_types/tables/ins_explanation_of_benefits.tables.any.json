  "unitsRules": [
    {
      "id": "unit_rule_currency_required",
      "appliesToHeaders": [
        "amount",
        "base_amount",
        "value"
      ],
      "rule": "currency_must_be_explicit_or_inherited_from_header_context"
    },
    {
      "id": "unit_rule_header_context",
      "appliesToHeaders": [
        "all"
      ],
      "rule": "table_cell_value_requires_header_and_row_context_before_use"
    },
    {
      "id": "unit_rule_mixed_currency_guard",
      "appliesToHeaders": [
        "all"
      ],
      "rule": "block_calculation_when_mixed_currencies_without_conversion_rate"
    },
    {
      "id": "unit_rule_negative_style",
      "appliesToHeaders": [
        "amount",
        "base_amount",
        "value"
      ],
      "rule": "support_parentheses_and_minus_as_negative"
    },
    {
      "id": "unit_rule_percent_fields",
      "appliesToHeaders": [
        "threshold"
      ],
      "rule": "percent_fields_must_use_percent_unit_not_currency"
    },
    {
      "id": "unit_rule_period_alignment",
      "appliesToHeaders": [
        "all"
      ],
      "rule": "comparisons_require_same_period_granularity"
    },
    {
      "id": "unit_rule_rounding",
      "appliesToHeaders": [
        "amount",
        "value"
      ],
      "rule": "round_only_for_display_keep_raw_precision"
    },
    {
      "id": "unit_rule_scale_normalization",
      "appliesToHeaders": [
        "amount",
        "base_amount",
        "value"
      ],
      "rule": "normalize_k_m_b_thousands_millions_billions_and_record_scale"
    }
  ],
  "headerContextRules": [
    {
      "id": "ctx_annex_anchor_required",
      "check": "annex_or_footnote_values_require_reference_anchor"
    },
    {
      "id": "ctx_period_header_required",
      "check": "period_header_required_for_time_series_claims"
    },
    {
      "id": "ctx_row_header_required",
      "check": "row_and_column_headers_required_for_numeric_extraction"
    },
    {
      "id": "ctx_total_reconcile",
      "check": "line_items_should_reconcile_to_total_when_total_row_present"
    },
    {
      "id": "ctx_unit_header_required",
      "check": "unit_or_scale_header_required_for_currency_values"
    }
  ]
