{
  "_meta": {
    "id": "di_insurance_domain_detection_rules",
    "version": "2.0.0",
    "description": "Insurance domain detection rules with explicit negative disambiguation.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "insurance",
    "minScore": 0.65,
    "maxRulesPerDocument": 64,
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "domain": "insurance",
  "rules": [
    {
      "id": "insurance_detect_pos_policy_markers",
      "priority": 220,
      "weight": 2.6,
      "signal": "heading_or_content",
      "ruleType": "positive",
      "patterns": [
        "\\bpolicy\\s+document\\b",
        "\\bpolicy\\s+number\\b",
        "\\bapolice\\b|\\bnumero\\s+da\\s+apolice\\b"
      ],
      "description": "Insurance policy markers."
    },
    {
      "id": "insurance_detect_pos_eob_markers",
      "priority": 219,
      "weight": 2.5,
      "signal": "heading_or_content",
      "ruleType": "positive",
      "patterns": [
        "\\bexplanation\\s+of\\s+benefits\\b",
        "\\beob\\b",
        "\\bdemonstrativo\\s+de\\s+beneficios\\b"
      ],
      "description": "EOB markers."
    },
    {
      "id": "insurance_detect_pos_claim_markers",
      "priority": 218,
      "weight": 2.4,
      "signal": "heading_or_content",
      "ruleType": "positive",
      "patterns": [
        "\\bclaim\\s+submission\\b",
        "\\bclaim\\s+number\\b",
        "\\bsinistro\\b|\\bprotocolo\\s+de\\s+sinistro\\b"
      ],
      "description": "Claim submission markers."
    },
    {
      "id": "insurance_detect_pos_premium_invoice_markers",
      "priority": 217,
      "weight": 2.3,
      "signal": "content",
      "ruleType": "positive",
      "patterns": [
        "\\bpremium\\s+invoice\\b",
        "\\bpremium\\s+due\\b",
        "\\bfatura\\s+de\\s+premio\\b"
      ],
      "description": "Premium invoice markers."
    },
    {
      "id": "insurance_detect_pos_coverage_markers",
      "priority": 216,
      "weight": 2.2,
      "signal": "content",
      "ruleType": "positive",
      "patterns": [
        "\\bcoverage\\b|\\bdeductible\\b|\\bcoinsurance\\b",
        "\\bcobertura\\b|\\bfranquia\\b|\\bcoparticipacao\\b"
      ],
      "description": "Coverage and cost-share markers."
    },
    {
      "id": "insurance_detect_pos_payer_provider_markers",
      "priority": 215,
      "weight": 2.1,
      "signal": "table_header_cluster",
      "ruleType": "positive",
      "patterns": [
        "\\bpayer\\b|\\bprovider\\b|\\bmember\\s+id\\b",
        "\\bseguradora\\b|\\bprestador\\b|\\bcarteirinha\\b"
      ],
      "description": "Payer/provider/member context markers."
    },
    {
      "id": "insurance_detect_pos_ctx_context_coverage_amount_01",
      "priority": 214,
      "weight": 1.6,
      "signal": "table_header_cluster",
      "ruleType": "positive",
      "patterns": [
        "\\b(allowed|paid|billed|responsibility|approved)\\b",
        "\\b(amount|value|valor|montante)\\b"
      ],
      "description": "Coverage and amounts context."
    },
    {
      "id": "insurance_detect_pos_ctx_context_claim_status_02",
      "priority": 213,
      "weight": 1.5,
      "signal": "content",
      "ruleType": "positive",
      "patterns": [
        "\\b(status|denial|appeal|review)\\b",
        "\\b(claim|sinistro|autorizacao)\\b"
      ],
      "description": "Claim status context."
    },
    {
      "id": "insurance_detect_pos_ctx_context_period_03",
      "priority": 212,
      "weight": 1.3,
      "signal": "table_header_cluster",
      "ruleType": "positive",
      "patterns": [
        "\\b(effective|expiration|renewal|vigencia|validade)\\b",
        "\\b(date|data|period|periodo)\\b"
      ],
      "description": "Coverage period context."
    },
    {
      "id": "insurance_detect_neg_tax_conflict",
      "priority": 211,
      "weight": -2,
      "signal": "heading_or_content",
      "ruleType": "negative",
      "patterns": [
        "\\btax\\s+return\\b|\\bassessment\\s+notice\\b",
        "\\bdeclaracao\\s+de\\s+imposto\\b|\\bnotificacao\\s+de\\s+lancamento\\b"
      ],
      "description": "Negative disambiguation against tax documents."
    },
    {
      "id": "insurance_detect_neg_identity_only_conflict",
      "priority": 210,
      "weight": -1.9,
      "signal": "content",
      "ruleType": "negative",
      "patterns": [
        "\\bpassport\\b|\\bdriver\\s+license\\b|\\bproof\\s+of\\s+address\\b",
        "\\bpassaporte\\b|\\bcnh\\b|\\bcomprovante\\s+de\\s+endereco\\b"
      ],
      "description": "Negative disambiguation against identity-only documents."
    },
    {
      "id": "insurance_detect_neg_legal_conflict",
      "priority": 209,
      "weight": -1.8,
      "signal": "heading_or_content",
      "ruleType": "negative",
      "patterns": [
        "\\bagreement\\b|\\bgoverning\\s+law\\b|\\bindemnification\\b",
        "\\bcontrato\\b|\\blei\\s+aplicavel\\b|\\bindenizacao\\s+contratual\\b"
      ],
      "description": "Negative disambiguation against legal contracts."
    }
  ]
}
