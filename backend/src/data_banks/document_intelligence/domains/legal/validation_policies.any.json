{
  "_meta": {
    "id": "legal_validation_policies",
    "version": "2.1.0",
    "description": "Legal validation policies focused on evidence-bound obligations and non-hallucinated interpretation.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "legal"
  },
  "domain": "legal",
  "policies": [
    {
      "id": "legal_val_001_doc_type_gate",
      "severity": "error",
      "description": "Require legal subtype lock for downstream extraction plans.",
      "applies": [
        "extract",
        "locate",
        "validate"
      ],
      "check": "doc_type_detected",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "legal_val_002_clause_anchor_gate",
      "severity": "error",
      "description": "Reject clause claims without section heading and source location.",
      "applies": [
        "extract",
        "compare",
        "validate"
      ],
      "check": "clause_anchor_present",
      "failureAction": "BLOCK_AND_FLAG",
      "requires": {
        "minClauseAnchors": 1,
        "requireExactClauseText": true
      }
    },
    {
      "id": "legal_val_003_obligation_quote_gate",
      "severity": "error",
      "description": "Obligations and rights must be emitted with exact quotation and clause location.",
      "applies": [
        "extract",
        "extract_entity",
        "validate",
        "compare"
      ],
      "check": "obligation_quote_required",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "legal_val_004_definition_link_gate",
      "severity": "warning",
      "description": "Warn when a definition/exception is referenced without resolved source.",
      "applies": [
        "extract",
        "locate",
        "validate"
      ],
      "check": "definition_reference_resolution",
      "failureAction": "WARN_AND_EXPLAIN"
    },
    {
      "id": "legal_val_005_party_role_gate",
      "severity": "warning",
      "description": "Party names and role assignments require at least one clause-anchored evidence source.",
      "applies": [
        "extract",
        "compare",
        "validate"
      ],
      "check": "party_role_completeness",
      "failureAction": "WARN_AND_EXPLAIN"
    },
    {
      "id": "legal_val_006_term_gov_law_gate",
      "severity": "error",
      "description": "Governing law and jurisdiction outputs require explicit source location and no inference.",
      "applies": [
        "extract",
        "summarize",
        "evaluate"
      ],
      "check": "governing_law_anchored",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "legal_val_007_liability_precision_gate",
      "severity": "error",
      "description": "Liability and indemnity caps must include exception scope and source line reference.",
      "applies": [
        "extract",
        "validate",
        "evaluate"
      ],
      "check": "liability_cap_structure",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "legal_val_008_termination_gate",
      "severity": "warning",
      "description": "Terminate/duration outputs must include cure period and notice trigger source when present.",
      "applies": [
        "extract",
        "evaluate",
        "validate"
      ],
      "check": "termination_context_anchored",
      "failureAction": "WARN_AND_EXPLAIN"
    },
    {
      "id": "legal_val_009_advice_guard",
      "severity": "error",
      "description": "Block legal advice-style language when only document interpretation is supported.",
      "applies": [
        "advise",
        "evaluate"
      ],
      "check": "no_unlicensed_legal_advice",
      "failureAction": "BLOCK_AND_FLAG"
    },
    {
      "id": "legal_val_010_cross_reference_gate",
      "severity": "info",
      "description": "Annotate unresolved references to sections or exhibits for operator follow-up.",
      "applies": [
        "extract",
        "compare",
        "validate"
      ],
      "check": "unresolved_reference_annotation",
      "failureAction": "ANNOTATE"
    },
    {
      "id": "legal_val_011_section_shift_detection",
      "severity": "warning",
      "description": "Detect inconsistent definitions across sections and annotate precedence basis.",
      "applies": [
        "compare",
        "evaluate",
        "validate"
      ],
      "check": "section_conflict_resolution",
      "failureAction": "WARN_AND_EXPLAIN"
    },
    {
      "id": "legal_val_012_draft_status_visibility",
      "severity": "info",
      "description": "When source is draft/redline, annotate extraction confidence and treat as potentially non-final.",
      "applies": [
        "summarize",
        "locate",
        "validate"
      ],
      "check": "draft_status_annotation",
      "failureAction": "ANNOTATE"
    }
  ]
}
