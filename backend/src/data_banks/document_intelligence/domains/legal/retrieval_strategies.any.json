  "strategies": [
    {
      "id": "legal_strategy_clause_first",
      "operators": [
        "extract",
        "compare",
        "validate"
      ],
      "description": "Prioritize clause text and definitions before summaries.",
      "steps": [
        "detect target clause family",
        "retrieve exact clause span",
        "resolve cross-references",
        "extract structured entities",
        "emit citation-backed output"
      ]
    },
    {
      "id": "legal_strategy_policy_matrix",
      "operators": [
        "summarize",
        "evaluate",
        "advise"
      ],
      "description": "For policy docs, build requirement matrix by section and control owner.",
      "steps": [
        "identify policy controls",
        "map obligations to owner",
        "check review cadence",
        "flag missing control evidence",
        "summarize policy gaps"
      ]
    },
    {
      "id": "legal_strategy_dispute_path",
      "operators": [
        "locate",
        "evaluate",
        "advise"
      ],
      "description": "For litigation docs, prioritize timeline, relief sought, and procedural posture.",
      "steps": [
        "extract procedural posture",
        "index requested relief",
        "collect deadline/order dates",
        "identify risks",
        "produce action checklist"
      ]
    }
  ]
