  "strategies": [
    {
      "id": "legal_strategy_clause_first",
      "operators": [
        "extract",
        "compare",
        "validate"
      ],
      "description": "Prioritize clause text, then resolve cross-references and emit cited obligations.",
      "steps": [
        "Identify all candidate clause headings",
        "Retrieve exact clause spans and line positions",
        "Resolve definitions referenced by each clause",
        "Emit obligations with exact citation location",
        "Flag unresolved references before summarizing"
      ]
    },
    {
      "id": "legal_strategy_termination_liability",
      "operators": [
        "extract",
        "evaluate",
        "summarize"
      ],
      "description": "Prioritize termination and liability sections in risk assessments.",
      "steps": [
        "Collect all termination events and triggers",
        "Collect all liability limits and indemnity formulations",
        "Map each to clause-level evidence and source position",
        "Produce risk matrix with textual anchors and unresolved gaps"
      ]
    }
  ]
