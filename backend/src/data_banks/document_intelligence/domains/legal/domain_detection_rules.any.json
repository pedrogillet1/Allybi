{
  "_meta": {
    "id": "legal_domain_detection_rules",
    "version": "2.1.0",
    "description": "Legal domain detection with explicit doc-type signatures and clause-driven legal signaling.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03"
  },
  "config": {
    "enabled": true,
    "domain": "legal",
    "minScore": 0.68,
    "maxRulesPerDocument": 80
  },
  "domain": "legal",
  "rules": [
    {
      "id": "legal_detect_nda_signature",
      "priority": 220,
      "ruleType": "positive",
      "weight": 4.5,
      "signal": "doc_type_signature",
      "docType": "legal_nda",
      "patterns": [
        "\\bnon[- ]disclosure\\s+agreement\\b",
        "\\bconfidential\\s+information\\s+agreement\\b",
        "\\bconfidentiality\\s+and\\s+non[- ]disclosure\\b",
        "\\bNDA\\b"
      ],
      "negativePatterns": [
        "\\bcourt\\s+order\\b",
        "\\bsettlement\\s+agreement\\b",
        "\\bterms\\s+of\\s+service\\b",
        "\\bprivacy\\s+policy\\b"
      ],
      "description": "Identify Non-Disclosure Agreements as primary legal subtype."
    },
    {
      "id": "legal_detect_msa_signature",
      "priority": 219,
      "ruleType": "positive",
      "weight": 4.4,
      "signal": "doc_type_signature",
      "docType": "legal_msa",
      "patterns": [
        "\\bmaster\\s+services\\s+agreement\\b",
        "\\bmsa\\b",
        "\\bmaster\\s+service\\s+agreement\\b",
        "\\bagreement\\s+governing\\s+future\\s+services\\b"
      ],
      "negativePatterns": [
        "\\bstatement\\s+of\\s+work\\b",
        "\\bstandalone\\s+supplier\\s+agreement\\b",
        "\\bterms\\s+of\\s+service\\b"
      ],
      "description": "Identify Master Services Agreements via template and role markers."
    },
    {
      "id": "legal_detect_sow_signature",
      "priority": 218,
      "ruleType": "positive",
      "weight": 4.3,
      "signal": "doc_type_signature",
      "docType": "legal_sow",
      "patterns": [
        "\\bstatement\\s+of\\s+work\\b",
        "\\bso[wW]\\b",
        "\\bwork\\s+order\\b",
        "\\bscope\\s+of\\s+work\\b"
      ],
      "negativePatterns": [
        "\\bmaster\\s+services\\s+agreement\\b",
        "\\bmaster\\s+service\\s+agreement\\b",
        "\\brental\\s+agreement\\b"
      ],
      "description": "Identify Statement-of-Work documents and distinguish from master framework agreements."
    },
    {
      "id": "legal_detect_dpa_signature",
      "priority": 217,
      "ruleType": "positive",
      "weight": 4.2,
      "signal": "doc_type_signature",
      "docType": "legal_dpa",
      "patterns": [
        "\\bdata\\s+processing\\s+agreement\\b",
        "\\bDPA\\b",
        "\\bcontroller\\b",
        "\\bprocessor\\b",
        "\\bprocessor\\s+obligations\\b",
        "\\bgdpr\\b",
        "\\bLGPD\\b"
      ],
      "negativePatterns": [
        "\\bprivacy\\s+policy\\b",
        "\\bprivacy\\s+notice\\b",
        "\\bcookie\\s+policy\\b",
        "\\bsecurity\\s+standards\\b"
      ],
      "description": "Identify Data Processing Agreements by processing language and controller/processor structure."
    },
    {
      "id": "legal_detect_legal_core_001",
      "priority": 140,
      "ruleType": "positive",
      "weight": 2.8,
      "signal": "heading_or_content",
      "patterns": [
        "\\bgoverning\\s+law\\b",
        "\\blimitation\\s+of\\s+liability\\b"
      ],
      "negativePatterns": [
        "\\bsoap note\\b",
        "\\bradiology report\\b",
        "\\blab result\\b",
        "\\bhemoglobin\\b"
      ],
      "description": "General legal-domain anchor: clauses on law and liability."
    },
    {
      "id": "legal_detect_legal_core_002",
      "priority": 139,
      "ruleType": "positive",
      "weight": 2.7,
      "signal": "heading_or_content",
      "patterns": [
        "\\btermination\\b",
        "\\bterm\\s+and\\s+renewal\\b",
        "\\bnotice\\s+period\\b"
      ],
      "negativePatterns": [
        "\\bsoap note\\b",
        "\\bradiology report\\b",
        "\\blab result\\b",
        "\\bhemoglobin\\b"
      ],
      "description": "Detect legal term/termination language for extraction routing."
    },
    {
      "id": "legal_detect_legal_core_003",
      "priority": 138,
      "ruleType": "positive",
      "weight": 2.6,
      "signal": "heading_or_content",
      "patterns": [
        "\\bconfidential\\s+information\\b",
        "\\bnon[- ]?disclosure\\b",
        "\\bconfidentiality\\b"
      ],
      "negativePatterns": [
        "\\bsoap note\\b",
        "\\bradiology report\\b",
        "\\blab result\\b",
        "\\bhemoglobin\\b"
      ],
      "description": "Detect confidentiality-heavy contracts and clauses."
    },
    {
      "id": "legal_detect_legal_core_004",
      "priority": 137,
      "ruleType": "positive",
      "weight": 2.5,
      "signal": "heading_or_content",
      "patterns": [
        "\\bindemnify\\b",
        "\\blimit\\s+liability\\b",
        "\\bliability\\s+cap\\b"
      ],
      "negativePatterns": [
        "\\bsoap note\\b",
        "\\bradiology report\\b",
        "\\blab result\\b",
        "\\bhemoglobin\\b"
      ],
      "description": "Detect indemnity/loss allocation sections."
    },
    {
      "id": "legal_detect_legal_core_005",
      "priority": 136,
      "ruleType": "positive",
      "weight": 2.4,
      "signal": "heading_or_content",
      "patterns": [
        "\\bdefinition\\b",
        "\\bdefinitions\\b",
        "\\bfor\\s+avoidance\\s+of\\s+doubt\\b"
      ],
      "negativePatterns": [
        "\\bsoap note\\b",
        "\\bradiology report\\b",
        "\\blab result\\b",
        "\\bhemoglobin\\b"
      ],
      "description": "Prioritize documents with explicit definition sections."
    }
  ]
}
