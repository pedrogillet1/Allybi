    {
      "id": "public_tender_notice",
      "name": {
        "en": "Tender Notice",
        "pt": "Aviso de Licitação"
      },
      "description": "Public tender publication and award notice information.",
      "detectionPatterns": [
        "\\btender notice\\b",
        "\\blicitação\\b",
        "\\bchamada\\s+publica\\b",
        "\\bedital\\b"
      ],
      "commonSections": [
        "object",
        "eligibility",
        "evaluation",
        "timeline",
        "awarding authority",
        "legal basis"
      ],
      "extractionPriority": 140
    },
    {
      "id": "public_budget_allocation",
      "name": {
        "en": "Budget Allocation",
        "pt": "Alocação Orçamentária"
      },
