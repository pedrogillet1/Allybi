  "strategies": [
    {
      "id": "gov_strategy_tied_award_compare",
      "operators": [
        "compare",
        "validate"
      ],
      "description": "Compare award candidates only after legal basis and supplier eligibility are explicit.",
      "steps": [
        "anchor tender notice and legal basis",
        "load award matrix and justification",
        "validate evaluation dimensions are same across offers",
        "show winner rationale + exception notes"
      ]
    },
    {
      "id": "gov_strategy_execution_health",
      "operators": [
        "monitor",
        "evaluate",
        "summarize"
      ],
      "description": "Generate an execution-health readout from budget, milestones, and audit signals.",
      "steps": [
        "resolve grant or program and period",
        "collect budget execution and disbursement status",
        "join audit defects and mitigation owner",
        "surface service impact with confidence intervals where available"
      ]
    }
  ]
