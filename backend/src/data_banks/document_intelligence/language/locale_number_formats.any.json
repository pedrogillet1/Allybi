  "ambiguities": [
    {
      "id": "lna_001",
      "pattern": "(?<!\\d)[+-]?(?:\\\\d{1,3}(?:[\\\\.,]\\\\d{3})+)(?:[\\\\.,]\\\\d+)?(?!\\d)",
      "description": "Digit groups with both separators are ambiguous unless context specifies locale.",
      "ambiguous": true,
      "signals": {
        "pt": [
          "currency_symbol_is_R$",
          "keyword_de",
          "keyword_fatura",
          "locale_hint_pt"
        ],
        "en": [
          "currency_symbol_is_$",
          "keyword_amount",
          "currency_word"
        ],
        "fallback": "both"
      },
      "resolvedBy": [
        "locale_hint",
        "currency_symbol",
        "document_language",
        "neighbored_dates"
      ]
    },
    {
      "id": "lna_002",
      "pattern": "(?<!\\d)(\\d{1,2})[\\.,](\\d{1,2})(?!\\d)",
      "description": "Short integer+separator+integer groups may be decimal or id fragment in noisy OCR.",
      "ambiguous": true,
      "policy": {
        "ifBothDigitsBelow12": "prefer_contextual",
        "ifThirdDigitPresent": "treatAsDecimal",
        "default": "leaveNumericAsRaw"
      }
    },
    {
      "id": "lna_003",
      "pattern": "(?<!\\w)(?:R\\$|r\\$)\\s*\\d",
      "description": "R$ strongly indicates pt-BR decimal interpretation unless explicit locale says otherwise.",
      "ambiguous": false,
      "signals": {
        "strong": [
          "R$"
        ],
        "weak": [
          "Reais",
          "cents",
          "mil"
        ]
      }
    },
    {
      "id": "lna_004",
      "pattern": "\\bUSD\\b|\\$|\\bUS\\$\\b",
      "description": "US currency markers bias parse toward en-US separators unless explicit locale is provided.",
      "ambiguous": false,
      "signals": {
        "strong": [
          "USD",
          "US$",
          "dollar"
        ],
        "weak": [
          "invoice",
          "net",
          "tax"
        ]
      }
    },
    {
      "id": "lna_005",
      "pattern": "\\b(?:(?:jan|fev|mar|abr|mai|jun|jul|ago|set|out|nov|dez)|(?:jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec))\\b",
      "description": "Date-heavy documents provide locale bias through month spelling when tokens share numbers.",
      "ambiguous": true,
      "signals": {
        "pt": [
          "jan",
          "fev",
          "mar",
          "abr",
          "mai",
          "jun",
          "jul",
          "ago",
          "set",
          "out",
          "nov",
          "dez"
        ],
        "en": [
          "jan",
          "feb",
          "mar",
          "apr",
          "may",
          "jun",
          "jul",
          "aug",
          "sep",
          "oct",
          "nov",
          "dec"
        ]
      }
    },
    {
      "id": "lna_006",
      "pattern": "(?<!\\d)(?:\\d{1,3}\\.\\d{3})(?:,\\d{2,4})?(?!\\d)",
      "ambiguous": true,
      "description": "Dot-thousand pattern that can match en-US if locale hint is missing.",
      "signals": {
        "pt": [
          "thousands_dot",
          "comma_decimal"
        ],
        "en": [
          "thousands_dot_ambiguous"
        ],
        "fallback": "context"
      },
      "resolvedBy": [
        "currency_symbol",
        "locale_hint",
        "section_language"
      ]
    },
    {
      "id": "lna_007",
      "pattern": "(?<!\\d)(?:\\d{1,3},\\d{3})(?:\\.\\d{2,4})?(?!\\d)",
      "ambiguous": true,
      "description": "Comma-thousands pattern ambiguous when followed by small decimals.",
      "signals": {
        "en": [
          "thousands_comma",
          "dollar_context"
        ],
        "pt": [
          "comma_as_decimal"
        ],
        "fallback": "context"
      },
      "resolvedBy": [
        "currency_symbol",
        "locale_hint",
        "section_language"
      ]
    },
    {
      "id": "lna_008",
      "pattern": "(?<!\\d)\\$?\\s*\\d{1,3}(?:[\\.,]\\d{3})+(?:[\\.,]\\d{2})?(?!\\d)",
      "ambiguous": true,
      "description": "Generic currency-like number with mixed separators and OCR noise.",
      "signals": {
        "mixedSeparators": true
      },
      "resolvedBy": [
        "currency_symbol",
        "date_context",
        "document_locale_confidence"
      ]
    },
    {
      "id": "lna_009",
      "pattern": "(?<!\\d)\\d{1,2}[\\/.-]\\d{1,2}(?!\\d)",
      "ambiguous": true,
      "description": "Date-like short fragments that can be numeric IDs.",
      "signals": {
        "mayBeDate": true,
        "mayBeId": true
      },
      "resolvedBy": [
        "context_window",
        "neighbor_dates"
      ]
    },
    {
      "id": "lna_010",
      "pattern": "(?<!\\d)\\d{2}(?:[\\.,]d{1,3})?(?!\\d)",
      "ambiguous": true,
      "description": "Invoice fragments can be short decimals or codes.",
      "policy": {
        "whenContextHasDateLike": "leave_raw",
        "whenContextHasAmountKeywords": "prefer_decimal",
        "default": "leave_raw"
      }
    },
    {
      "id": "lna_011",
      "pattern": "(?<![A-Z])( | | )\\d{1,3}(?:[., ]\\d{3})*(?:[.,]\\d{2})?(?!\\d)",
      "ambiguous": true,
      "description": "Narrow-space separators from OCR tables.",
      "signals": {
        "ocrArtifact": true
      },
      "resolvedBy": [
        "normalize_space",
        "locale_policy"
      ]
    },
    {
      "id": "lna_012",
      "pattern": "(?<!\\w)(?:R\\$|r\\$|\\$|US\\$|USD|EUR|€)\\s*(?:\\d{1,3}(?:[.,]\\d{3})+|\\d+)(?:[.,]\\d+)?(?!\\d)",
      "ambiguous": true,
      "description": "Currency symbol present but separator interpretation ambiguous.",
      "signals": {
        "strong": [
          "currency_symbol"
        ],
        "pt": [
          "R$"
        ],
        "en": [
          "USD",
          "$",
          "EUR",
          "€"
        ]
      },
      "resolvedBy": [
        "symbol_locale",
        "adjacent_month_token"
      ]
    }
  ],
  "fallback": {
    "preferLocale": "document_language",
    "ifNoHint": "no_transform_preserve_original",
    "ifConflict": "emit_both_candidates_with_low_confidence"
  }
