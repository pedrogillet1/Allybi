{
  "_meta": {
    "id": "di_normalization_rules",
    "bankId": "di_normalization_rules",
    "version": "2.0.0",
    "owner": "document_intelligence",
    "languages": [
      "en",
      "pt"
    ],
    "lastUpdated": "2026-03-03",
    "description": "Expanded real-text normalization: quotes, punctuation, diacritics, and locale number formats."
  },
  "config": {
    "enabled": true,
    "caseInsensitive": true,
    "applyOrder": "sequential"
  },
  "rules": [
    {
      "id": "norm_001",
      "category": "quotes",
      "language": "any",
      "pattern": "[窶懌敖ｫﾂｻ]",
      "replacement": "\"",
      "description": "Normalize smart quotes to straight double quote",
      "priority": 100
    },
    {
      "id": "norm_002",
      "category": "quotes",
      "language": "any",
      "pattern": "[窶倪兢",
      "replacement": "'",
      "description": "Normalize smart apostrophes",
      "priority": 99
    },
    {
      "id": "norm_003",
      "category": "punctuation",
      "language": "any",
      "pattern": "\\s{2,}",
      "replacement": " ",
      "description": "Collapse whitespace",
      "priority": 95
    },
    {
      "id": "norm_004",
      "category": "diacritics",
      "language": "any",
      "pattern": "[ﾃﾃ｡ﾃ｢ﾃ｣ﾃ､ﾃ･]",
      "replacement": "a",
      "description": "Normalize a accent variants",
      "priority": 90
    },
    {
      "id": "norm_005",
      "category": "diacritics",
      "language": "any",
      "pattern": "[ﾃｨﾃｩﾃｪﾃｫ]",
      "replacement": "e",
      "description": "Normalize e accent variants",
      "priority": 90
    },
    {
      "id": "norm_006",
      "category": "diacritics",
      "language": "any",
      "pattern": "[ﾃｬﾃｭﾃｮﾃｯ]",
      "replacement": "i",
      "description": "Normalize i accent variants",
      "priority": 90
    },
    {
      "id": "norm_007",
      "category": "diacritics",
      "language": "any",
      "pattern": "[ﾃｲﾃｳﾃｴﾃｵﾃｶ]",
      "replacement": "o",
      "description": "Normalize o accent variants",
      "priority": 90
    },
    {
      "id": "norm_008",
      "category": "diacritics",
      "language": "any",
      "pattern": "[ﾃｹﾃｺﾃｻﾃｼ]",
      "replacement": "u",
      "description": "Normalize u accent variants",
      "priority": 90
    },
    {
      "id": "norm_009",
      "category": "diacritics",
      "language": "any",
      "pattern": "[ﾃｧﾃⅩ",
      "replacement": "c",
      "description": "Normalize cedilla",
      "priority": 90
    },
    {
      "id": "norm_010",
      "category": "number_locale",
      "language": "any",
      "pattern": "(?<!d)\\.(?=\\d{3}(?:[.,]d{3})*(?:[.,]d+)?(?!\\d))",
      "replacement": ",",
      "description": "Canonicalize thousands separators where mixed",
      "priority": 85
    },
    {
      "id": "norm_011",
      "category": "currency_format",
      "language": "en",
      "pattern": "R\\s*\\$",
      "replacement": "R$",
      "description": "Normalize BRL currency prefix spacing",
      "priority": 88
    },
    {
      "id": "norm_012",
      "category": "currency_format",
      "language": "en",
      "pattern": "\\bUS\\s*\\$",
      "replacement": "$",
      "description": "Normalize USD symbol spacing",
      "priority": 88
    },
    {
      "id": "norm_013",
      "category": "dates",
      "language": "en",
      "pattern": "(\\d{2})/(\\d{2})/(\\d{4})",
      "replacement": "\\3-\\2-\\1",
      "description": "Normalize mm/dd/yyyy to yyyy-mm-dd",
      "priority": 80
    },
    {
      "id": "norm_014",
      "category": "dates",
      "language": "pt",
      "pattern": "(\\d{2})[\\./](\\d{2})[\\./](\\d{4})",
      "replacement": "\\3-\\2-\\1",
      "description": "Normalize dd/mm/yyyy and dd.mm.yyyy",
      "priority": 80
    },
    {
      "id": "norm_015",
      "category": "dates",
      "language": "any",
      "pattern": "(\\d{4})/(\\d{2})/(\\d{2})",
      "replacement": "\\1-\\2-\\3",
      "description": "Normalize yyyy/mm/dd",
      "priority": 80
    },
    {
      "id": "norm_016",
      "category": "token",
      "language": "any",
      "pattern": "\\binc.?\\b",
      "replacement": "incorporated",
      "description": "Normalize inc.",
      "priority": 76
    },
    {
      "id": "norm_017",
      "category": "token",
      "language": "any",
      "pattern": "\\bltd.?\\b",
      "replacement": "limited",
      "description": "Normalize ltd.",
      "priority": 76
    },
    {
      "id": "norm_018",
      "category": "token",
      "language": "any",
      "pattern": "\\bco.?\\b",
      "replacement": "company",
      "description": "Normalize co.",
      "priority": 76
    },
    {
      "id": "norm_019",
      "category": "token",
      "language": "any",
      "pattern": "\\bN/A\\b",
      "replacement": "not available",
      "description": "Normalize N/A token",
      "priority": 65
    },
    {
      "id": "norm_020",
      "category": "token",
      "language": "any",
      "pattern": "\\bTBD\\b",
      "replacement": "to be determined",
      "description": "Normalize TBD token",
      "priority": 65
    },
    {
      "id": "norm_021",
      "category": "punctuation",
      "language": "any",
      "pattern": "\\s,",
      "replacement": ",",
      "description": "Trim spacing before comma",
      "priority": 57
    },
    {
      "id": "norm_022",
      "category": "punctuation",
      "language": "any",
      "pattern": "\\s\\.",
      "replacement": ".",
      "description": "Trim spacing before dot",
      "priority": 57
    },
    {
      "id": "norm_023",
      "category": "table",
      "language": "any",
      "pattern": "\\n{3,}",
      "replacement": "\n\n",
      "description": "Collapse excessive newlines",
      "priority": 72
    },
    {
      "id": "norm_024",
      "category": "table",
      "language": "any",
      "pattern": "\\t+",
      "replacement": " ",
      "description": "Normalize tabs to spaces",
      "priority": 73
    },
    {
      "id": "norm_025",
      "category": "case",
      "language": "any",
      "pattern": "(?i)\\b([a-z])\\1{2,}\\b",
      "replacement": "$1$1",
      "description": "Reduce elongated chars from OCR",
      "priority": 62
    }
  ]
}
