{
  "_meta": {
    "id": "di_stopwords_and_noise",
    "bankId": "di_stopwords_and_noise",
    "version": "2.1.0",
    "owner": "document_intelligence",
    "languages": [
      "en",
      "pt"
    ],
    "lastUpdated": "2026-03-03",
    "description": "Retrieval-safe stopword, boilerplate, and noise-filtering rules for document extraction.",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "mode": "retrieval-safe",
    "maxConsecutiveNoiseTokens": 6,
    "preserveIdentifiers": true,
    "preserveNumbers": true,
    "preserveDates": true,
    "preserveMoneyLike": true,
    "minInformationDensity": 0.22
  },
