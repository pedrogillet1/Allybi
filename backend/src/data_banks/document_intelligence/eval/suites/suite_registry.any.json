{
  "_meta": {
    "id": "docint_eval_suite_registry",
    "version": "3.2.0",
    "description": "Registry for document-intelligence evaluation suites with CI/nightly assignments and minimum case thresholds.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "docint-eval",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "src/tests/document-intelligence/docint-eval-pack.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "enforceAtBoot": false,
    "failOnMissingCases": true,
    "requireUniqueCaseIds": true,
    "requireJsonlParse": true,
    "minimumNegativeRatio": 0.2,
    "parityTolerancePercent": 5,
    "governanceThresholds": {
      "minQueryFamilies": 4,
      "minDomains": 15,
      "minNegativeRatio": 0.2,
      "maxParityGap": 0.05,
      "maxUnregisteredFiles": 0
    }
  },
  "schema": {
    "required": [
      "id",
      "lang",
      "domain",
      "docTypeId",
      "queryFamily",
      "query",
      "expected"
    ]
  },
  "ci_suites": [
    {
      "id": "retrieval_precision_ci",
      "path": "document_intelligence/eval/retrieval_precision.qa.jsonl",
      "maxCases": 280,
      "description": "Cross-domain retrieval precision gate."
    },
    {
      "id": "section_detection_ci",
      "path": "document_intelligence/eval/section_detection.qa.jsonl",
      "maxCases": 280,
      "description": "Cross-domain section targeting gate."
    },
    {
      "id": "abbreviation_resolution_ci",
      "path": "document_intelligence/eval/abbreviation_resolution.qa.jsonl",
      "maxCases": 240,
      "description": "Abbreviation disambiguation gate."
    },
    {
      "id": "answer_format_ci",
      "path": "document_intelligence/eval/answer_format.qa.jsonl",
      "maxCases": 240,
      "description": "Answer-format and citation constraints gate."
    },
    {
      "id": "scope_lock_ci",
      "path": "document_intelligence/eval/crossdoc.qa.jsonl",
      "maxCases": 190,
      "description": "Cross-document scope lock gate."
    },
    {
      "id": "wrong_doc_traps_ci",
      "path": "document_intelligence/eval/wrong_doc_traps.qa.jsonl",
      "maxCases": 50,
      "description": "Wrong-document trap and lock contamination gate."
    }
  ],
