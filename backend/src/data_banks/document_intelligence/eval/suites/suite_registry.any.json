{
  "_meta": {
    "id": "docint_eval_suite_registry",
    "version": "3.1.0",
    "description": "Registry for document-intelligence evaluation suites with CI and nightly partitions.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "docint-eval"
  },
  "config": {
    "enabled": true,
    "enforceAtBoot": false,
    "failOnMissingCases": true,
    "requireUniqueCaseIds": true,
    "requireJsonlParse": true,
    "minimumNegativeRatio": 0.2,
    "parityTolerancePercent": 25
  },
  "schema": {
    "required": [
      "id",
      "lang",
      "domain",
      "docTypeId",
      "queryFamily",
      "query",
      "expected"
    ]
  },
  "ci_suites": [
    {
      "id": "retrieval_precision_ci",
      "path": "document_intelligence/eval/retrieval_precision.qa.jsonl",
      "maxCases": 300,
      "description": "Fast detection + collision smoke coverage."
    },
    {
      "id": "section_detection_ci",
      "path": "document_intelligence/eval/section_detection.qa.jsonl",
      "maxCases": 300,
      "description": "Fast section-target smoke coverage."
    },
    {
      "id": "abbreviation_resolution_ci",
      "path": "document_intelligence/eval/abbreviation_resolution.qa.jsonl",
      "maxCases": 240,
      "description": "Fast abbreviation resolution smoke coverage."
    },
    {
      "id": "answer_format_ci",
      "path": "document_intelligence/eval/answer_format.qa.jsonl",
      "maxCases": 240,
      "description": "Fast answer-shape contract smoke coverage."
    },
    {
      "id": "scope_lock_ci",
      "path": "document_intelligence/eval/crossdoc.qa.jsonl",
      "maxCases": 260,
      "description": "Fast wrong-doc scope-lock smoke coverage."
    }
  ],
  "nightly_suites": [
