{
  "_meta": {
    "id": "response_templates",
    "version": "1.1.0",
    "description": "Composable response templates for doc-grounded, comparison, extraction, location, and clarification outputs.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-05",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "strictPlaceholders": true,
    "defaultLanguage": "en",
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "templates": [
    {
      "id": "TML_DOC_SINGLE_SUMMARY",
      "domain": "any",
      "intent": "summary",
      "language": "en",
      "tone": "concise",
      "template": "From {{document}}, I found {{evidenceCount}} evidence item(s). {{result}} {{confidence}}",
      "requiredParts": [
        "document",
        "result",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_DOC_SINGLE_SUMMARY_PT",
      "domain": "any",
      "intent": "summary",
      "language": "pt",
      "tone": "conciso",
      "template": "Em {{document}}, encontrei {{evidenceCount}} evidencias. {{result}} {{confidence}}",
      "requiredParts": [
        "document",
        "result",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_DOC_SINGLE_SUMMARY_ES",
      "domain": "any",
      "intent": "summary",
      "language": "es",
      "tone": "conciso",
      "template": "En {{document}}, encontre {{evidenceCount}} evidencias. {{result}} {{confidence}}",
      "requiredParts": [
        "document",
        "result",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_DOC_EXTRACT_RESULT",
      "domain": "any",
      "intent": "extract",
      "language": "en",
      "tone": "direct",
      "template": "In {{document}}, the extracted result is {{result}}. Evidence count: {{evidenceCount}}. {{confidence}}",
      "requiredParts": [
        "document",
        "result",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_DOC_EXTRACT_RESULT_PT",
      "domain": "any",
      "intent": "extract",
      "language": "pt",
      "tone": "direto",
      "template": "Em {{document}}, o resultado extraido e {{result}}. Evidencias: {{evidenceCount}}. {{confidence}}",
      "requiredParts": [
        "document",
        "result",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_DOC_EXTRACT_RESULT_ES",
      "domain": "any",
      "intent": "extract",
      "language": "es",
      "tone": "directo",
      "template": "En {{document}}, el resultado extraido es {{result}}. Evidencias: {{evidenceCount}}. {{confidence}}",
      "requiredParts": [
        "document",
        "result",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_COMPARE_RESULT",
      "domain": "any",
      "intent": "compare",
      "language": "en",
      "tone": "structured",
      "template": "I compared {{leftDoc}} and {{rightDoc}} on {{topic}}. Key diff: {{differences}}. Evidence footprint: {{evidenceCount}}. {{confidence}}",
      "requiredParts": [
        "leftDoc",
        "rightDoc",
        "topic",
        "differences",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_COMPARE_RESULT_PT",
      "domain": "any",
      "intent": "compare",
      "language": "pt",
      "tone": "estruturado",
      "template": "Comparei {{leftDoc}} e {{rightDoc}} em {{topic}}. Diferencas-chave: {{differences}}. Evidencias: {{evidenceCount}}. {{confidence}}",
      "requiredParts": [
        "leftDoc",
        "rightDoc",
        "topic",
        "differences",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_COMPARE_RESULT_ES",
      "domain": "any",
      "intent": "compare",
      "language": "es",
      "tone": "estructurado",
      "template": "Compare {{leftDoc}} y {{rightDoc}} en {{topic}}. Diferencias clave: {{differences}}. Evidencias: {{evidenceCount}}. {{confidence}}",
      "requiredParts": [
        "leftDoc",
        "rightDoc",
        "topic",
        "differences",
        "evidenceCount",
        "confidence"
      ]
    },
    {
      "id": "TML_QUESTION_CLARIFY",
      "domain": "any",
      "intent": "clarify",
      "language": "en",
      "tone": "helpful",
      "template": "I need one clarification to answer safely: {{question}}",
      "requiredParts": [
        "question"
      ]
    },
    {
      "id": "TML_QUESTION_CLARIFY_PT",
      "domain": "any",
      "intent": "clarify",
      "language": "pt",
      "tone": "ajudavel",
      "template": "Preciso de uma clarificacao para responder com seguranca: {{question}}",
      "requiredParts": [
        "question"
      ]
    },
    {
      "id": "TML_QUESTION_CLARIFY_ES",
      "domain": "any",
      "intent": "clarify",
      "language": "es",
      "tone": "servicial",
      "template": "Necesito una aclaracion para responder con seguridad: {{question}}",
      "requiredParts": [
        "question"
      ]
    },
    {
      "id": "TML_LOCATE_CONTEXT",
      "domain": "any",
      "intent": "locate_content",
      "language": "en",
      "tone": "structured",
      "template": "I found this in {{document}} at {{location}}. Nearby context: {{contextSummary}}.",
      "requiredParts": [
        "document",
        "location",
        "contextSummary"
      ]
    },
    {
      "id": "TML_LOCATE_CONTEXT_PT",
      "domain": "any",
      "intent": "locate_content",
      "language": "pt",
      "tone": "estruturado",
      "template": "Encontrei isso em {{document}} em {{location}}. Contexto proximo: {{contextSummary}}.",
      "requiredParts": [
        "document",
        "location",
        "contextSummary"
      ]
    },
    {
      "id": "TML_LOCATE_CONTEXT_ES",
      "domain": "any",
      "intent": "locate_content",
      "language": "es",
      "tone": "estructurado",
      "template": "Encontre esto en {{document}} en {{location}}. Contexto cercano: {{contextSummary}}.",
      "requiredParts": [
        "document",
        "location",
        "contextSummary"
      ]
    },
    {
      "id": "TML_SCOPED_NOT_FOUND",
      "domain": "any",
      "intent": "not_found",
      "language": "en",
      "tone": "direct",
      "template": "I could not find matching evidence in {{documentScope}}. {{nextStep}}",
      "requiredParts": [
        "documentScope",
        "nextStep"
      ]
    },
    {
      "id": "TML_SCOPED_NOT_FOUND_PT",
      "domain": "any",
      "intent": "not_found",
      "language": "pt",
      "tone": "direto",
      "template": "Nao encontrei evidencia correspondente em {{documentScope}}. {{nextStep}}",
      "requiredParts": [
        "documentScope",
        "nextStep"
      ]
    },
    {
      "id": "TML_SCOPED_NOT_FOUND_ES",
      "domain": "any",
      "intent": "not_found",
      "language": "es",
      "tone": "directo",
      "template": "No encontre evidencia coincidente en {{documentScope}}. {{nextStep}}",
      "requiredParts": [
        "documentScope",
        "nextStep"
      ]
    }
  ],
  "rules": [
    {
      "id": "RT_001_required_parts_enforced",
      "trigger": "template selected but required parts missing",
      "check": "context.templateSelected == true AND output.missingRequiredParts == true",
      "failureAction": "REJECT_TEMPLATE_RENDER"
    },
    {
      "id": "RT_002_compare_template_requires_two_docs",
      "trigger": "compare intent resolves to compare template without both docs",
      "check": "context.intent == 'compare' AND context.templateId LIKE 'TML_COMPARE_RESULT' AND (context.leftDocId == null OR context.rightDocId == null)",
      "failureAction": "ASK_FOR_COMPARISON_DOCS"
    },
    {
      "id": "RT_003_language_template_alignment",
      "trigger": "template language not aligned with user language",
      "check": "context.userLanguage IN ['pt','es'] AND context.templateLanguage != context.userLanguage",
      "failureAction": "SWITCH_TEMPLATE_LANGUAGE_FOR_USER"
    },
    {
      "id": "RT_004_evidence_confidence_binding",
      "trigger": "template output has low evidence count but no confidence tag",
      "check": "output.evidenceCount <= 0 AND output.confidence == null",
      "failureAction": "INJECT_LOW_CONFIDENCE_GUARD"
    },
    {
      "id": "RT_005_summary_style_guard",
      "trigger": "summary intent with long narrative length",
      "check": "context.intent == 'summary' AND output.wordCount > 360",
      "failureAction": "CONDENSE_TO_SUMMARY_TEMPLATE"
    }
  ],
  "patterns": [
    "\\b(query|document|evidence)\\b"
  ]
}

