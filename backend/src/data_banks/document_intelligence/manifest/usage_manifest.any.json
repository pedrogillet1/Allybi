{
  "_meta": {
    "id": "document_intelligence_usage_manifest",
    "version": "1.1.0",
    "description": "Runtime usage manifest for document intelligence banks. Declares consumer wiring and coverage rules used to prevent orphan runtime banks.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-02",
    "owner": "koda-document-intelligence",
    "dependsOn": [
      "bank_registry",
      "document_intelligence_bank_map"
    ],
    "usedBy": [
      "src/services/core/banks/documentIntelligenceBanks.service.ts",
      "src/services/core/banks/documentIntelligenceIntegrity.service.ts",
      "src/services/core/retrieval/retrievalEngine.service.ts",
      "src/services/core/scope/documentReferenceResolver.service.ts",
      "src/services/core/enforcement/qualityGateRunner.service.ts",
      "src/services/core/scope/scopeGate.service.ts",
      "src/services/chat/turnRoutePolicy.service.ts",
      "src/services/chat/turnRouter.service.ts"
    ],
    "tests": [
      "src/tests/document-intelligence/docint-orphan-detection.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "enforceAtBoot": true,
    "failOnOrphanInStrict": true,
    "enforceFacadeOnly": true
  },
  "runtimeConsumers": [
    {
      "id": "document_intelligence_banks_service",
      "path": "src/services/core/banks/documentIntelligenceBanks.service.ts",
      "uses": [
        "boost_rules_*",
        "di_*_ontology",
        "di_abbreviation_global",
        "di_normalization_rules",
        "doc_aliases_*",
        "doc_archetypes_*",
        "document_intelligence_*",
        "legal_*",
        "medical_*",
        "operator_playbook_*",
        "query_rewrites_*",
        "section_priority_*"
      ]
    },
    {
      "id": "document_intelligence_integrity",
      "path": "src/services/core/banks/documentIntelligenceIntegrity.service.ts",
      "uses": [
        "document_intelligence_bank_map",
        "document_intelligence_dependency_graph",
        "document_intelligence_orphan_allowlist",
        "document_intelligence_runtime_wiring_gates",
        "document_intelligence_schema_registry",
        "document_intelligence_usage_manifest"
      ]
    },
    {
      "id": "document_reference_resolver",
      "path": "src/services/core/scope/documentReferenceResolver.service.ts",
      "uses": [
        "doc_aliases_*"
      ]
    },
    {
      "id": "quality_gate_runner",
      "path": "src/services/core/enforcement/qualityGateRunner.service.ts",
      "uses": [
        "ambiguity_questions",
        "numeric_integrity",
        "source_policy",
        "wrong_doc_lock"
      ]
    },
    {
      "id": "retrieval_engine",
      "path": "src/services/core/retrieval/retrievalEngine.service.ts",
      "uses": [
        "boost_rules_*",
        "query_rewrites_*",
        "section_priority_*"
      ]
    },
    {
      "id": "scope_gate",
      "path": "src/services/core/scope/scopeGate.service.ts",
      "uses": [
        "doc_aliases_*",
        "doc_taxonomy"
      ]
    },
    {
      "id": "turn_route_policy",
      "path": "src/services/chat/turnRoutePolicy.service.ts",
      "uses": [
        "connectors_routing",
        "email_routing"
      ]
    },
    {
      "id": "turn_router",
      "path": "src/services/chat/turnRouter.service.ts",
      "uses": [
        "file_action_operators"
      ]
    }
  ],
  "consumedBankIds": [
