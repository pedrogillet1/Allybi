{
  "_meta": {
    "id": "language_triggers",
    "version": "1.0.0",
    "description": "Deterministic language trigger rules for Koda. Detects explicit user language requests and strong language cues to set or bias processing language (en/pt/es) without forcing a language when ambiguous. Complements language_indicators by handling explicit directives (\"respond in Portuguese\") and mixed-language cases safely.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-01-26",
    "owner": "koda-triggers",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added explicit language directive triggers (respond in X / em X / en X)",
      "Added guarded implicit cues and mixed-language handling (do not force when ambiguous)",
      "Added tests for multilingual directives and ambiguity regressions"
    ],
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "pre_routing",
    "doNotForceWhenAmbiguous": true,
    "defaultLanguage": "any",
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_highest_confidence_then_apply",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": false
      },
      "thresholds": {
        "explicitDirectiveConfidence": 0.95,
        "implicitCueConfidence": 0.75,
        "minConfidenceGapToForce": 0.15
      },
      "conflictResolution": {
        "ifMultipleDirectives": "prefer_latest_explicit",
        "ifDirectiveAndIndicatorsConflict": "directive_wins",
        "ifMixedLanguageDetected": "return_any_unless_explicit"
      }
    },
    "emitsSignals": [
      "languageRequested",
      "languageSelected",
      "mixedLanguageDetected"
    ],
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "rules": [
    {
      "id": "explicit_request_portuguese",
      "scope": "global",
      "description": "Detect explicit request to respond in Portuguese.",
      "appliesTo": [
        "user_inputs"
      ],
      "triggerPatterns": {
        "en": [
          "\\b(reply|respond|answer)\\s+(in)\\s+(portuguese|pt-br|pt)\\b"
        ],
        "pt": [
          "\\b(responda|responder|resposta)\\s+(em)\\s+(portugu[eÃŠ]s|pt-br|pt)\\b"
        ],
        "es": [
          "\\b(responde|responder)\\s+(en)\\s+(portugu[eÃŠ]s|pt-br|pt)\\b"
        ]
      },
      "action": {
        "type": "set_language",
        "language": "pt",
        "confidence": 0.95,
        "emitSignals": [
          "languageRequested",
          "languageSelected"
        ]
      },
      "reasonCode": "language_directive_pt",
      "severity": "high"
    },
    {
      "id": "explicit_request_english",
      "scope": "global",
      "description": "Detect explicit request to respond in English.",
      "appliesTo": [
        "user_inputs"
      ],
      "triggerPatterns": {
        "en": [
          "\\b(reply|respond|answer)\\s+(in)\\s+(english|en)\\b"
        ],
        "pt": [
          "\\b(responda|responder|resposta)\\s+(em)\\s+(ingl[eÃŠ]s|en)\\b"
        ],
        "es": [
          "\\b(responde|responder)\\s+(en)\\s+(ingl[eÃĐ]s|english|en)\\b"
        ]
      },
      "action": {
        "type": "set_language",
        "language": "en",
        "confidence": 0.95,
        "emitSignals": [
          "languageRequested",
          "languageSelected"
        ]
      },
      "reasonCode": "language_directive_en",
      "severity": "high"
    },
    {
      "id": "explicit_request_spanish",
      "scope": "global",
      "description": "Detect explicit request to respond in Spanish.",
      "appliesTo": [
        "user_inputs"
      ],
      "triggerPatterns": {
        "en": [
          "\\b(reply|respond|answer)\\s+(in)\\s+(spanish|es)\\b"
        ],
        "pt": [
          "\\b(responda|responder|resposta)\\s+(em)\\s+(espanhol|es)\\b"
        ],
        "es": [
          "\\b(responde|responder)\\s+(en)\\s+(espa[nÃą]ol|es)\\b"
        ]
      },
      "action": {
        "type": "set_language",
        "language": "es",
        "confidence": 0.95,
        "emitSignals": [
          "languageRequested",
          "languageSelected"
        ]
      },
      "reasonCode": "language_directive_es",
      "severity": "high"
    },
    {
      "id": "implicit_strong_pt_cues",
      "scope": "global",
      "description": "Detect strong Portuguese cues to bias language when no explicit directive exists.",
      "appliesTo": [
        "user_inputs"
      ],
      "triggerPatterns": {
        "en": [
          "\\b(vocÃŠ|nÃĢo|aÃ§ÃĢo|pÃĄgina|relatÃģrio|trimestre|receita|despesa)\\b"
        ],
        "pt": [
          "\\b(vocÃŠ|nÃĢo|aÃ§ÃĢo|pÃĄgina|relatÃģrio|trimestre|receita|despesa)\\b"
        ],
        "es": [
          "\\b(vocÃŠ|nÃĢo|aÃ§ÃĢo|pÃĄgina|relatÃģrio|trimestre|receita|despesa)\\b"
        ]
      },
      "when": {
        "all": [
          {
            "path": "signals.languageRequested",
            "op": "neq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "bias_language",
        "language": "pt",
        "confidence": 0.75
      },
      "reasonCode": "language_cue_pt",
      "severity": "medium"
    },
    {
      "id": "implicit_strong_es_cues",
      "scope": "global",
      "description": "Detect strong Spanish cues to bias language when no explicit directive exists.",
      "appliesTo": [
        "user_inputs"
      ],
      "triggerPatterns": {
        "en": [
          "\\b(Âŋ|ÂĄ|dÃģnde|quÃĐ|cuÃĄnto|ingresos|gastos|pÃĄgina)\\b"
        ],
        "pt": [
          "\\b(Âŋ|ÂĄ|dÃģnde|quÃĐ|cuÃĄnto|ingresos|gastos|pÃĄgina)\\b"
        ],
        "es": [
          "\\b(Âŋ|ÂĄ|dÃģnde|quÃĐ|cuÃĄnto|ingresos|gastos|pÃĄgina)\\b"
        ]
      },
      "when": {
        "all": [
          {
            "path": "signals.languageRequested",
            "op": "neq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "bias_language",
        "language": "es",
        "confidence": 0.75
      },
      "reasonCode": "language_cue_es",
      "severity": "medium"
    },
    {
      "id": "implicit_strong_en_cues",
      "scope": "global",
      "description": "Detect strong English cues to bias language when no explicit directive exists.",
      "appliesTo": [
        "user_inputs"
      ],
      "triggerPatterns": {
        "en": [
          "\\b(the|and|could you|would you|please|summary|revenue|expenses)\\b"
        ],
        "pt": [
          "\\b(the|and|could you|would you|please|summary|revenue|expenses)\\b"
        ],
        "es": [
          "\\b(the|and|could you|would you|please|summary|revenue|expenses)\\b"
        ]
      },
      "when": {
        "all": [
          {
            "path": "signals.languageRequested",
            "op": "neq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "bias_language",
        "language": "en",
        "confidence": 0.75
      },
      "reasonCode": "language_cue_en",
      "severity": "medium"
    },
    {
      "id": "mixed_language_detection",
      "scope": "global",
      "description": "Detect mixed-language inputs and avoid forcing a language unless explicit directive exists.",
      "appliesTo": [
        "language_detection"
      ],
      "triggerPatterns": {
        "en": [
          ".+"
        ],
        "pt": [
          ".+"
        ],
        "es": [
          ".+"
        ]
      },
      "when": {
        "all": [
          {
            "path": "metrics.detectedLanguageCount",
            "op": "gte",
            "value": 2
          },
          {
            "path": "signals.languageRequested",
            "op": "neq",
            "value": true
          }
        ]
      },
      "action": {
        "type": "set_language",
        "language": "any",
        "emitSignals": [
          "mixedLanguageDetected",
          "languageSelected"
        ]
      },
      "reasonCode": "language_mixed_any",
      "severity": "high"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "LTG_0001_explicit_pt",
        "input": "Please respond in Portuguese",
        "expect": {
          "languageSelected": "pt",
          "signalsAny": [
            "languageRequested"
          ]
        }
      },
      {
        "id": "LTG_0002_explicit_es",
        "input": "Responde en espaÃąol",
        "expect": {
          "languageSelected": "es",
          "signalsAny": [
            "languageRequested"
          ]
        }
      },
      {
        "id": "LTG_0003_explicit_en",
        "input": "Responda em inglÃŠs",
        "expect": {
          "languageSelected": "en",
          "signalsAny": [
            "languageRequested"
          ]
        }
      },
      {
        "id": "LTG_0004_implicit_pt_bias",
        "input": "VocÃŠ pode resumir o relatÃģrio?",
        "expect": {
          "languageBias": "pt"
        }
      },
      {
        "id": "LTG_0005_mixed_language_any",
        "context": {
          "metrics": {
            "detectedLanguageCount": 2
          },
          "signals": {
            "languageRequested": false
          }
        },
        "input": "por favor open the file",
        "expect": {
          "languageSelected": "any",
          "signalsAny": [
            "mixedLanguageDetected"
          ]
        }
      }
    ]
  }
}
