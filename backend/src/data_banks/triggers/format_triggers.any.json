{
  "_meta": {
    "id": "format_triggers",
    "version": "1.0.0",
    "description": "Deterministic format trigger rules for Koda. Detects user intent for bullets, tables, quotes, steps, brevity, and detail. Emits stable signals consumed by formatting_overlays and render policies, preventing unwanted tables/bullets and ensuring ChatGPT-like adaptive formatting without hardcoded copy.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-triggers",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added deterministic actionsContract and collision handling between format intents",
      "Added guarded triggers for table/quote/steps vs generic list language",
      "Added tests for multilingual triggers and regressions (table spam, quote misuse)"
    ]
  },
  "config": {
    "enabled": true,
    "applyStage": "pre_formatting_overlays",
    "preferExplicitRequests": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "sum_then_cap_then_select",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": false,
        "redirectPreferencePriority": "over_penalty"
      },
      "thresholds": {
        "minTriggerConfidence": 0.7,
        "explicitTriggerConfidence": 0.9,
        "collisionGap": 0.15
      },
      "conflictResolution": {
        "ifQuoteAndSummary": "prefer_quote",
        "ifTableAndBullets": "prefer_table_when_comparison_or_numbers",
        "ifStepsAndBullets": "prefer_steps_when_procedural",
        "ifBrevityAndDetail": "prefer_user_latest_explicit"
      }
    },
    "emitsSignals": [
      "userAskedForBullets",
      "userAskedForTable",
      "userAskedForQuote",
      "userAskedForSteps",
      "userAskedForShort",
      "userAskedForMoreDetail",
      "userAskedForJson",
      "isListIntent"
    ]
  },
  "rules": [
    {
      "id": "trigger_bullets_explicit",
      "scope": "global",
      "description": "Detect explicit request for bullet points or a bulleted list.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(bullets?|bullet points?|in bullet points|as a list)\\b"],
        "pt": ["\\b(bullets?|em bullets|em t[oó]picos|lista com t[oó]picos)\\b"],
        "es": ["\\b(vi[nñ]etas?|en vi[nñ]etas|puntos|como lista)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "userAskedForBullets",
        "confidence": 0.9
      },
      "reasonCode": "format_bullets_explicit",
      "severity": "low"
    },
    {
      "id": "trigger_table_explicit",
      "scope": "global",
      "description": "Detect explicit request for a table.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(in a table|as a table|table format|tabulate)\\b"],
        "pt": ["\\b(em tabela|como tabela|formato de tabela|tabelar)\\b"],
        "es": ["\\b(en tabla|como tabla|formato de tabla|tabular)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "userAskedForTable",
        "confidence": 0.9
      },
      "reasonCode": "format_table_explicit",
      "severity": "medium"
    },
    {
      "id": "trigger_quote_explicit",
      "scope": "global",
      "description": "Detect explicit request for verbatim quote or exact wording.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(quote|verbatim|exact wording|word for word)\\b"],
        "pt": ["\\b(citar|literalmente|palavras exatas|texto exato)\\b"],
        "es": ["\\b(citar|textualmente|palabras exactas|texto exacto)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "userAskedForQuote",
        "confidence": 0.92
      },
      "reasonCode": "format_quote_explicit",
      "severity": "high"
    },
    {
      "id": "trigger_steps_explicit",
      "scope": "global",
      "description": "Detect explicit request for steps/instructions structure.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(steps|step-by-step|walk me through|how to)\\b"],
        "pt": ["\\b(passos|passo a passo|me guia|como fazer)\\b"],
        "es": ["\\b(pasos|paso a paso|gu[ií]ame|c[oó]mo hacer)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "userAskedForSteps",
        "confidence": 0.88
      },
      "reasonCode": "format_steps_explicit",
      "severity": "low"
    },
    {
      "id": "trigger_brevity",
      "scope": "global",
      "description": "Detect request for shorter output.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(shorter|brief|concise|tl;dr)\\b"],
        "pt": ["\\b(mais curto|resumido|conciso|tl;dr)\\b"],
        "es": ["\\b(m[aá]s corto|breve|conciso|tl;dr)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "userAskedForShort",
        "confidence": 0.85
      },
      "reasonCode": "format_brevity",
      "severity": "low"
    },
    {
      "id": "trigger_more_detail",
      "scope": "global",
      "description": "Detect request for more detail or deeper explanation.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(more detail|go deeper|expand|in depth)\\b"],
        "pt": ["\\b(mais detalhe|aprofundar|expandir|em profundidade)\\b"],
        "es": ["\\b(m[aá]s detalle|profundiza|ampl[ií]a|en profundidad)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "userAskedForMoreDetail",
        "confidence": 0.85
      },
      "reasonCode": "format_more_detail",
      "severity": "low"
    },
    {
      "id": "trigger_json_request",
      "scope": "global",
      "description": "Detect request for JSON output formatting (only when explicitly requested).",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(in json|as json|json format)\\b"],
        "pt": ["\\b(em json|como json|formato json)\\b"],
        "es": ["\\b(en json|como json|formato json)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "userAskedForJson",
        "confidence": 0.9
      },
      "reasonCode": "format_json_explicit",
      "severity": "medium"
    },
    {
      "id": "infer_list_intent_without_bullets",
      "scope": "global",
      "description": "Infer list intent from phrasing even when bullets aren't explicitly requested.",
      "appliesTo": ["user_inputs"],
      "triggerPatterns": {
        "en": ["\\b(list|top\\s*\\d+|key points|takeaways)\\b"],
        "pt": ["\\b(lista(r)?|top\\s*\\d+|pontos principais|conclus[oõ]es)\\b"],
        "es": ["\\b(lista(r)?|top\\s*\\d+|puntos clave|conclusiones)\\b"]
      },
      "action": {
        "type": "emit_signal",
        "signal": "isListIntent",
        "confidence": 0.75
      },
      "reasonCode": "format_list_intent",
      "severity": "low"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "FT_0001_table_explicit_en",
        "input": "Put it in a table",
        "expect": { "signalsAny": ["userAskedForTable"] }
      },
      {
        "id": "FT_0002_quote_explicit_es",
        "input": "Cita textualmente",
        "expect": { "signalsAny": ["userAskedForQuote"] }
      },
      {
        "id": "FT_0003_steps_explicit_pt",
        "input": "Passo a passo",
        "expect": { "signalsAny": ["userAskedForSteps"] }
      },
      {
        "id": "FT_0004_collision_quote_vs_summary_prefers_quote",
        "input": "Summarize and quote the exact wording",
        "context": { "signals": { "isQuoteIntent": true } },
        "expect": { "preferredSignal": "userAskedForQuote" }
      },
      {
        "id": "FT_0005_infer_list_intent",
        "input": "List the key takeaways",
        "expect": { "signalsAny": ["isListIntent"] }
      }
    ]
  }
}
