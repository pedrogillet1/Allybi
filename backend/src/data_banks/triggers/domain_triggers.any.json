{
  "_meta": {
    "id": "domain_triggers",
    "version": "2.0.0",
    "description": "Domain trigger bank for Koda. Emits domain hints + domain-related signals from user query and (optionally) doc title/snippets. This bank should be high-signal and conservative: it should strongly trigger only when domain-specific vocabulary is present. It does NOT generate answers and must not override explicit doc scope.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "useRegex": true,
    "caseInsensitive": true,
    "stripDiacritics": true,
    "collapseWhitespace": true,
    "maxDomainsToReturn": 3,
    "minConfidenceToEmit": 0.55,
    "capMaxConfidence": 0.98,
    "weights": {
      "strong": 0.18,
      "medium": 0.10,
      "weak": 0.06,
      "titleBoost": 0.08,
      "snippetBoost": 0.06,
      "exactPhraseBoost": 0.06
    },
    "lexiconBankId": "terminology_domains",
    "tieBreakers": [
      "mostStrongMatches",
      "titleBoostApplied",
      "snippetBoostApplied"
    ]
  },
  "inputs": {
    "_comment": "Runtime may pass any/all of these. If docTitle/docSnippets are absent, scoring uses queryText only.",
    "queryText": true,
    "docTitle": true,
    "docSnippets": true
  },
  "outputs": {
    "_comment": "Consumed by domain_detection + formatting/retrieval profiles.",
    "shape": {
      "topDomain": "string",
      "domains": "array",
      "domainsItem": {
        "id": "string",
        "confidence": "number",
        "signals": "string[]",
        "evidence": {
          "strongMatches": "string[]",
          "mediumMatches": "string[]",
          "weakMatches": "string[]",
          "fromTitle": "boolean",
          "fromSnippets": "boolean"
        }
      }
    }
  },
  "signals": {
    "_comment": "Signals that downstream systems can rely on. Keep this list stable.",
    "catalog": [
      "domainDetected",
      "numericHeavy",
      "quoteFriendly",
      "ocrLikely",
      "fieldExtractionLikely",
      "spreadsheetLikely",
      "contractLikely",
      "medicalLikely",
      "taxLikely",
      "bankingLikely",
      "invoiceLikely",
      "insuranceLikely",
      "identityLikely"
    ]
  },
