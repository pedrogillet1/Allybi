{
  "bankId": "chart_blueprints",
  "version": "1.0.0",
  "localeSupport": ["en", "pt"],
  "description": "Reusable chart templates for Sheets chart creation/update (line/bar/pie/scatter) with guardrails and recommended defaults.",
  "updatedAt": "2026-02-07T00:00:00.000Z",
  "schemaVersion": 1,

  "_meta": {
    "id": "chart_blueprints",
    "version": "1.0.0",
    "description": "Chart blueprints for Sheets chart creation. Provides type defaults, required entities, and safety constraints for misleading chart types.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07"
  },

  "config": {
    "enabled": true,
    "defaults": {
      "theme": "match_sheet",
      "legendPosition": "RIGHT",
      "titleMaxChars": 80,
      "preferAxisLabels": true,
      "preferDataLabels": false
    },
    "guardrails": {
      "pie": {
        "allowOnlyFor": "part_to_whole",
        "maxSlices": 8,
        "requireNonNegative": true,
        "requireSumNear100PctOrExplain": true
      },
      "scatter": {
        "requireTwoNumericColumns": true,
        "preferTrendline": false
      }
    }
  },

  "blueprints": [
    {
      "id": "revenue_over_time_line",
      "chartType": "LINE",
      "labels": { "en": "Revenue Over Time", "pt": "Receita ao Longo do Tempo" },
      "requiredEntities": ["rangeA1", "xAxis", "series"],
      "optionalEntities": ["title", "currency", "legendPosition"],
      "defaults": {
        "xAxis": { "type": "CATEGORY", "inferFrom": "first_column" },
        "series": { "inferFrom": "remaining_columns" },
        "title": { "en": "Revenue over time", "pt": "Receita ao longo do tempo" }
      },
      "constraints": {
        "requiresHeaderRow": true,
        "minRows": 3,
        "minColumns": 2
      }
    },

    {
      "id": "category_breakdown_bar",
      "chartType": "BAR",
      "labels": { "en": "Category Breakdown", "pt": "Quebra por Categoria" },
      "requiredEntities": ["rangeA1", "xAxis", "series"],
      "optionalEntities": ["title", "stacked"],
      "defaults": {
        "xAxis": { "type": "CATEGORY", "inferFrom": "first_column" },
        "series": { "inferFrom": "numeric_columns" },
        "stacked": false,
        "title": { "en": "Category breakdown", "pt": "Quebra por categoria" }
      },
      "constraints": {
        "requiresHeaderRow": true,
        "minRows": 3,
        "minColumns": 2
      }
    },

    {
      "id": "part_to_whole_pie",
      "chartType": "PIE",
      "labels": { "en": "Part-to-Whole", "pt": "Parte do Todo" },
      "requiredEntities": ["rangeA1", "labelsColumn", "valuesColumn"],
      "optionalEntities": ["title"],
      "defaults": {
        "title": { "en": "Breakdown", "pt": "Distribuição" },
        "maxSlices": 8
      },
      "constraints": {
        "requiresHeaderRow": true,
        "minRows": 3,
        "minColumns": 2,
        "nonNegativeValuesOnly": true
      }
    },

    {
      "id": "correlation_scatter",
      "chartType": "SCATTER",
      "labels": { "en": "Correlation", "pt": "Correlação" },
      "requiredEntities": ["rangeA1", "xAxis", "yAxis"],
      "optionalEntities": ["title", "trendline"],
      "defaults": {
        "trendline": false,
        "title": { "en": "Correlation", "pt": "Correlação" }
      },
      "constraints": {
        "requiresHeaderRow": true,
        "minRows": 4,
        "minColumns": 2,
        "xMustBeNumeric": true,
        "yMustBeNumeric": true
      }
    }
  ],

  "specContract": {
    "shape": {
      "type": "BAR|LINE|PIE|AREA|SCATTER",
      "rangeA1": "string",
      "series": "array|optional",
      "title": "string|optional",
      "placement": "object|optional"
    }
  },

  "tests": {
    "cases": [
      { "id": "CB_001_has_line", "assert": "blueprints.any(id == 'revenue_over_time_line')" },
      { "id": "CB_002_pie_has_guard", "assert": "config.guardrails.pie.maxSlices <= 10" }
    ]
  }
}
