{
  "_meta": {
    "id": "admin_controls_policy",
    "version": "1.0.0",
    "description": "Policy contract for administrative controls. Restricts who can change sensitive configuration (policies, security, connector settings) and defines required verification signals for admin actions (owner-only + adminKey + optional IP allowlist).",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07",
    "owner": "koda-policies",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "block",
    "adminActions": [
      "POLICY_UPDATE",
      "POLICY_DELETE",
      "POLICY_ENV_OVERRIDE_UPDATE",
      "CONNECTOR_ALLOWLIST_UPDATE",
      "CONNECTOR_RETENTION_UPDATE",
      "SECURITY_CONFIG_UPDATE"
    ],
    "ownerPolicy": {
      "ownerOnly": true,
      "requireAdminKeyInProduction": true,
      "requireAdminKeyInStaging": true,
      "requireAdminKeyInDev": false,
      "requireAdminKeyInLocal": false
    },
    "ipAllowlist": {
      "enabled": false,
      "allowedCidrs": []
    },
    "protectedPolicyIds": [
      "global_system_policies",
      "safety_policy",
      "privacy_policy",
      "logging_policy",
      "pii_policy",
      "privacy_redaction_policy",
      "editing_policy",
      "connectors_policy",
      "creative_policy"
    ]
  },
  "integrationHooks": {
    "dependsOn": ["logging_policy", "privacy_policy"],
    "signalsExpected": [
      "sessionEnv",
      "actionType",
      "actorUserId",
      "ownerUserId",
      "isOwner",
      "adminKeyValid",
      "requestIp",
      "ipAllowlistEnabled",
      "ipAllowed",
      "targetPolicyId",
      "policyChangeRequested"
    ],
    "emitsSignals": ["admin_action_blocked", "admin_action_allowed"]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "only_owner_can_do_admin_actions",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.actionType", "op": "in", "value": ["POLICY_UPDATE", "POLICY_DELETE", "POLICY_ENV_OVERRIDE_UPDATE", "CONNECTOR_ALLOWLIST_UPDATE", "CONNECTOR_RETENTION_UPDATE", "SECURITY_CONFIG_UPDATE"] },
            { "path": "signals.isOwner", "op": "neq", "value": true }
          ]
        },
        "then": { "action": "block", "emitSignals": ["admin_action_blocked"] },
        "reasonCode": "admin_owner_required"
      },
      {
        "ruleId": "require_admin_key_in_prod_for_sensitive_changes",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.sessionEnv", "op": "eq", "value": "production" },
            { "path": "signals.actionType", "op": "in", "value": ["POLICY_UPDATE", "POLICY_DELETE", "POLICY_ENV_OVERRIDE_UPDATE", "SECURITY_CONFIG_UPDATE"] },
            { "path": "signals.adminKeyValid", "op": "neq", "value": true }
          ]
        },
        "then": { "action": "block", "emitSignals": ["admin_action_blocked"] },
        "reasonCode": "admin_key_required"
      },
      {
        "ruleId": "block_when_ip_not_allowlisted",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.ipAllowlistEnabled", "op": "eq", "value": true },
            { "path": "signals.ipAllowed", "op": "neq", "value": true }
          ]
        },
        "then": { "action": "block", "emitSignals": ["admin_action_blocked"] },
        "reasonCode": "admin_ip_not_allowed"
      },
      {
        "ruleId": "protected_policy_changes_require_admin_key_in_prod",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.sessionEnv", "op": "eq", "value": "production" },
            { "path": "signals.policyChangeRequested", "op": "eq", "value": true },
            { "path": "signals.targetPolicyId", "op": "in", "value": ["global_system_policies", "safety_policy", "privacy_policy", "logging_policy", "pii_policy", "privacy_redaction_policy", "editing_policy", "connectors_policy", "creative_policy"] },
            { "path": "signals.adminKeyValid", "op": "neq", "value": true }
          ]
        },
        "then": { "action": "block", "emitSignals": ["admin_action_blocked"] },
        "reasonCode": "protected_policy_admin_key_required"
      },
      {
        "ruleId": "allow_admin_action",
        "severity": "info",
        "when": {
          "all": [
            { "path": "signals.actionType", "op": "in", "value": ["POLICY_UPDATE", "POLICY_DELETE", "POLICY_ENV_OVERRIDE_UPDATE", "CONNECTOR_ALLOWLIST_UPDATE", "CONNECTOR_RETENTION_UPDATE", "SECURITY_CONFIG_UPDATE"] },
            { "path": "signals.isOwner", "op": "eq", "value": true }
          ]
        },
        "then": { "action": "allow", "emitSignals": ["admin_action_allowed"] },
        "reasonCode": "admin_allowed"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "admin_owner_required",
        "action": "block",
        "constraints": { "logEvent": "admin_controls_violation", "redactSecrets": true }
      },
      {
        "matchReasonCode": "admin_key_required",
        "action": "block",
        "constraints": { "logEvent": "admin_key_missing", "redactSecrets": true }
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "ACP_0001_non_owner_blocked",
        "runtime": { "signals": { "actionType": "POLICY_UPDATE", "actorUserId": "u2", "ownerUserId": "u1" } },
        "expect": { "reasonCode": "admin_owner_required", "action": "block" }
      },
      {
        "id": "ACP_0002_owner_prod_without_admin_key_blocked",
        "runtime": { "signals": { "sessionEnv": "production", "actionType": "SECURITY_CONFIG_UPDATE", "actorUserId": "u1", "ownerUserId": "u1", "adminKeyValid": false } },
        "expect": { "reasonCode": "admin_key_required", "action": "block" }
      },
      {
        "id": "ACP_0003_owner_allowed",
        "runtime": { "signals": { "actionType": "POLICY_UPDATE", "actorUserId": "u1", "ownerUserId": "u1" } },
        "expect": { "reasonCode": "admin_allowed", "action": "allow" }
      }
    ]
  }
}
