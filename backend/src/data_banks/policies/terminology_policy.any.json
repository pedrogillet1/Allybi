{
  "_meta": {
    "id": "terminology_policy",
    "version": "1.0.0",
    "description": "ChatGPT-like terminology policy for Koda. Governs how domain terminology is used for detection, query expansion, retrieval boosting, and formatting cues—without becoming hardcoded answers. Ensures terminology stays consistent across domain_detection, domain_ontology, synonym_expansion, abbreviations, and retrieval profiles.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "integrationHooks": {
      "domainDetectionBankId": "domain_detection",
      "domainOntologyBankId": "domain_ontology",
      "terminologyLexiconBankId": "terminology_domains",
      "abbreviationsBankId": "abbreviations",
      "synonymExpansionBankId": "synonym_expansion",
      "semanticSearchConfigBankId": "semantic_search_config",
      "qualityGatesBankId": "quality_gates"
    }
  },
  "principles": {
    "_comment": "Terminology is a hint system, not an answer generator.",
    "terminologyIsForSignalsNotResponses": true,
    "neverInjectFactsFromTerminology": true,
    "preferDocumentEvidenceOverTerminology": true,
    "domainTerminologyMustMatchDomainIds": true,
    "supportRegionalVocabularyUSAndBR": true
  },
  "sourcesOfTerminology": {
    "_comment": "Where the system can pull terminology from.",
    "lexicon": {
      "bankId": "terminology_domains",
      "required": true,
      "purpose": ["domain_detection", "retrieval_boosting", "field_extraction_hints"]
    },
    "abbreviations": {
      "bankId": "abbreviations",
      "required": true,
      "purpose": ["query_normalization", "expansion", "exact_match_rescue"]
    },
    "synonyms": {
      "bankId": "synonym_expansion",
      "required": true,
      "purpose": ["query_variants", "recall_boost"]
    }
  },
  "normalizationRules": {
    "_comment": "Canonical normalization behavior so banks behave consistently.",
    "caseInsensitive": true,
    "stripDiacritics": true,
    "collapseWhitespace": true,
    "treatHyphenUnderscoreAsSpace": true,
    "normalizeQuotes": true,
    "normalizePunctuation": true,
    "tokenization": {
      "splitOn": [" ", "_", "-", ".", "—", "–", "(", ")", "[", "]", "{", "}", "/", "\\", "|", ",", ":", ";"],
      "minTokenLength": 2,
      "dropStopwordsWhen": ["docTitleMatching", "filenameMatching"],
      "stopwordsBankId": "stopwords_docnames"
    }
  },
  "usagePolicy": {
    "_comment": "How terminology is applied across the pipeline.",
    "domainDetection": {
      "enabled": true,
      "useLexicon": true,
      "useDocTitles": true,
      "useDocSnippets": true,
      "weights": {
        "strong": 0.16,
        "medium": 0.09,
        "weak": 0.05,
        "titleBoost": 0.08,
        "docTextBoost": 0.06
      },
      "antiCollision": {
        "_comment": "Avoid common term collisions (e.g., 'invoice' vs 'statement').",
        "enabled": true,
        "preferHighSignalFieldsOverGenericDocWords": true,
        "requireStrongOrMultipleMediumForHighConfidence": true
      }
    },
    "queryExpansion": {
      "_comment": "Expansion is bounded to avoid drifting meaning.",
      "enabled": true,
      "maxExpandedTermsTotal": 18,
      "maxPerCategory": 6,
      "onlyIf": {
        "domainConfidenceGte": 0.45
      },
      "expansionSourcesOrder": ["abbreviations", "synonyms", "domain_terms"],
      "safety": {
        "neverExpandIntoDifferentDomainIfExplicitDocLock": true,
        "neverExpandWithBannedTerms": true,
        "denylistBankId": "denylist_terms"
      }
    },
    "retrievalBoosting": {
      "_comment": "Boosting changes ranking only, never scope allowlists.",
      "enabled": true,
      "boostTargets": ["docTitle", "chunkText", "tableCells", "headings"],
      "maxTotalBoost": 0.18,
      "boostRules": {
        "exactFieldLabelMatch": 0.08,
        "domainHighSignalMatch": 0.06,
        "abbreviationExpandedMatch": 0.04
      },
      "neverOverrideHardScope": true
    },
    "formattingCues": {
      "_comment": "Terminology can influence formatting profile selection via domain_ontology only.",
      "enabled": true,
      "useDomainOntologyFormattingProfile": true,
      "neverCreateDomainSpecificAnswerTemplates": true
    }
  },
  "consistencyChecks": {
    "_comment": "Boot-time checks. These are validated by bank loaders/tests.",
    "requireTerminologyKeyForEachDomainInOntology": true,
    "requireDomainIdsMatchAcross": ["domain_detection", "domain_ontology", "terminology_domains"],
    "requireNoDuplicateHighSignalAcrossDomainsUnlessAllowed": {
      "enabled": true,
      "allowedSharedTerms": [
        "due date",
        "vencimento",
        "total",
        "subtotal",
        "document number",
        "número do documento"
      ]
    }
  },
  "actions": {
    "_comment": "Runtime actions.",
    "definitions": [
      {
        "id": "block_expansion_on_drift_risk",
        "type": "transform",
        "notes": "If expansion introduces cross-domain drift risk, drop expansions and proceed with base query."
      },
      {
        "id": "retry_retrieval_with_exact_match_boost",
        "type": "route",
        "notes": "If numeric/field extraction fails, retry retrieval using abbreviation/field label exact matching boosts."
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "TP_0001_domain_ids_align",
        "input": {
          "domainOntology.domainIds": ["finance", "excel", "legal"],
          "terminologyDomains.domains[*].id": ["finance", "excel", "legal"]
        },
        "expect": { "noUnknownDomainIds": true }
      },
      {
        "id": "TP_0002_expansion_bounded",
        "input": { "query": "show me the danfe chave de acesso", "domain": { "topDomain": "invoices_billing", "confidence": 0.8 } },
        "expect": { "expandedTermsMaxLte": 18 }
      },
      {
        "id": "TP_0003_never_override_hard_scope",
        "input": {
          "scope": { "hard": { "docIdAllowlist": ["doc:locked"] } },
          "query": "bank statement overdraft fee",
          "domain": { "topDomain": "banking_statements", "confidence": 0.9 }
        },
        "expect": { "scopeAllowlistUnchanged": true }
      }
    ]
  }
}
