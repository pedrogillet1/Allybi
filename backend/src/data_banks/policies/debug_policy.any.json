{
  "_meta": {
    "id": "debug_policy",
    "version": "1.0.0",
    "description": "Policy contract for debug behavior in Koda. Controls whether debug traces/state snapshots may be produced and where they may appear (logs only, never user-visible), with strict environment gating. Ensures production/staging are clean, dev/local allow controlled debug, and user-visible outputs never contain debug or internal mechanics.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-policies",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added deterministic env gating for debug traces and state snapshots",
      "Added hard blocks for user-visible debug leakage",
      "Aligned with state_debug_policy and privacy policies for redaction"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "allow",
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_most_restrictive_then_commit",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_transform"
      },
      "thresholds": {
        "prodDebugAllowed": 0,
        "stagingDebugAllowed": 0,
        "devDebugAllowed": 1,
        "localDebugAllowed": 1
      },
      "conflictResolution": {
        "ifUserVisibleAndDebug": "hard_block",
        "ifProdOrStaging": "strip_debug",
        "ifDevLocal": "allow_logs_only_redacted"
      }
    },
    "envPolicy": {
      "production": { "debugEnabled": false, "debugChannel": "none", "stateSnapshots": "none" },
      "staging": { "debugEnabled": false, "debugChannel": "none", "stateSnapshots": "none" },
      "dev": { "debugEnabled": true, "debugChannel": "logs_only", "stateSnapshots": "redacted" },
      "local": { "debugEnabled": true, "debugChannel": "logs_only", "stateSnapshots": "full_safe" }
    },
    "userVisibleGuards": {
      "neverExposeDebug": true,
      "forbiddenTextPatterns": {
        "en": ["\\bdebug\\b", "\\btrace\\b", "\\bstack\\b", "\\bconfidence score\\b", "\\brouting decision\\b"],
        "pt": ["\\bdepura[cç][aã]o\\b", "\\brastro\\b", "\\bstack\\b", "\\bpontua[cç][aã]o de confian[cç]a\\b", "\\bdecis[aã]o de roteamento\\b"],
        "es": ["\\bdepuraci[oó]n\\b", "\\brastro\\b", "\\bstack\\b", "\\bpuntuaci[oó]n de confianza\\b", "\\bdecisi[oó]n de enrutamiento\\b"]
      }
    },
    "debugOutputControls": {
      "redactInternalIds": true,
      "redactPii": true,
      "stripRawEvidence": true,
      "stripRawStateInNonLocal": true
    }
  },
  "integrationHooks": {
    "dependsOn": [
      "state_debug_policy",
      "privacy_policy",
      "banned_phrases",
      "ui_contracts",
      "conversation_state_schema"
    ],
    "signalsExpected": [
      "sessionEnv",
      "userVisibleChannel",
      "logChannel",
      "containsDebugTrace",
      "containsInternalIds",
      "containsPii",
      "containsRawStateDump",
      "containsRawEvidenceDump"
    ]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "hard_block_user_visible_debug",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.userVisibleChannel", "op": "eq", "value": true },
            { "path": "signals.containsDebugTrace", "op": "eq", "value": true }
          ]
        },
        "then": { "action": "block" },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "strip_debug_in_prod_and_staging",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "in", "value": ["production", "staging"] },
            { "path": "signals.containsDebugTrace", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [{ "type": "strip_debug_fields" }]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "dev_local_allow_debug_logs_only",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "in", "value": ["dev", "local"] },
            { "path": "signals.containsDebugTrace", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "redact_internal_ids" },
            { "type": "redact_pii_spans", "mode": "mask_partial" },
            { "type": "strip_raw_evidence_arrays" }
          ]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "block_raw_state_dump_outside_local",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "in", "value": ["production", "staging", "dev"] },
            { "path": "signals.containsRawStateDump", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [{ "type": "strip_keys", "keys": ["fullState", "conversationState"] }]
        },
        "reasonCode": "privacy_redaction_required"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "privacy_redaction_required",
        "action": "transform",
        "constraints": {
          "stripDebug": true,
          "redactInternalIds": true,
          "redactPii": true,
          "stripRawEvidence": true,
          "stripRawStateInNonLocal": true
        }
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "DBGP_0001_user_visible_debug_blocked",
        "input": { "text": "debug: state dump" },
        "runtime": { "signals": { "userVisibleChannel": true, "containsDebugTrace": true, "sessionEnv": "dev" } },
        "expect": { "action": "block", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "DBGP_0002_prod_logs_strip_debug",
        "input": { "text": "trace: ..." },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "production", "containsDebugTrace": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "DBGP_0003_dev_logs_redacted_debug_allowed",
        "input": { "text": "debug trace with docId=abc email test@example.com evidence=[...]" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "dev", "containsDebugTrace": true, "containsInternalIds": true, "containsPii": true, "containsRawEvidenceDump": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "DBGP_0004_local_allows_more_but_still_redacts_ids",
        "input": { "text": "debug docId=abc123" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "local", "containsDebugTrace": true, "containsInternalIds": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "DBGP_0005_block_raw_state_dump_in_dev",
        "input": { "text": "{\"fullState\":{...}}" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "dev", "containsRawStateDump": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "DBGP_0006_staging_debug_disabled",
        "input": { "text": "debug: ..." },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "staging", "containsDebugTrace": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      }
    ]
  }
}
