{
  "_meta": {
    "id": "hallucination_policy",
    "version": "1.0.0",
    "description": "Policy contract for evidence grounding in Koda. Enforces doc-grounded-only behavior for document operators, prevents claims without evidence, routes insufficient evidence to fallback or clarification, and ensures scope compliance. Delegates detection to doc_grounding_checks, retrieval_negatives, and evidence_packaging; enforces deterministic actions with shared reason codes.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-policies",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added strict doc-grounded enforcement for document operators",
      "Added scope-aware grounding actions and retry_retrieval_then_regen path",
      "Added tests for evidence absence, scope lock, and ambiguity handling"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "allow",
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_severe_then_apply",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_transform"
      },
      "thresholds": {
        "minEvidenceSufficiencyToAnswer": 0.7,
        "minEvidenceSufficiencyToProceedWithHedge": 0.55,
        "minTopScore": 0.58,
        "maxRetries": 1
      },
      "conflictResolution": {
        "ifScopeLockAndNoEvidence": "route_fallback_scope_empty_or_not_found",
        "ifRetryAndFallback": "retry_once_then_fallback",
        "ifDisambiguationAndEvidenceSufficient": "answer_without_disambiguation"
      }
    },
    "groundingModes": {
      "doc_grounded_required_families": ["documents", "doc_stats"],
      "allowedNonDocFamilies": ["help", "conversation", "file_actions"]
    }
  },
  "integrationHooks": {
    "dependsOn": [
      "doc_grounding_checks",
      "retrieval_negatives",
      "evidence_packaging",
      "fallback_processing",
      "fallback_scope_empty",
      "fallback_not_found_scope",
      "clarification_policy",
      "scope_hints",
      "followup_indicators",
      "ui_contracts"
    ],
    "signalsExpected": [
      "intentFamily",
      "operatorFamily",
      "hasEvidence",
      "explicitDocLock",
      "hardScopeActive",
      "searchExecuted",
      "retrievedChunks",
      "topScore",
      "evidenceSufficiency",
      "scopeViolation"
    ]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "doc_grounded_required_for_document_families",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.operatorFamily", "op": "in", "value": ["documents", "doc_stats"] },
            { "path": "signals.hasEvidence", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_processing",
          "emitSignals": ["grounding_fail_soft"]
        },
        "reasonCode": "grounding_fail_soft"
      },
      {
        "ruleId": "answer_allowed_when_evidence_sufficient",
        "severity": "info",
        "when": {
          "all": [
            { "path": "signals.hasEvidence", "op": "eq", "value": true },
            { "path": "metrics.evidenceSufficiency", "op": "gte", "value": 0.7 }
          ]
        },
        "then": {
          "action": "allow"
        },
        "reasonCode": "grounding_ok"
      },
      {
        "ruleId": "retry_retrieval_when_borderline_evidence",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.operatorFamily", "op": "in", "value": ["documents", "doc_stats"] },
            { "path": "signals.hasEvidence", "op": "eq", "value": true },
            { "path": "metrics.evidenceSufficiency", "op": "lt", "value": 0.7 },
            { "path": "metrics.evidenceSufficiency", "op": "gte", "value": 0.55 }
          ]
        },
        "then": {
          "action": "retry_retrieval_then_regen",
          "constraints": {
            "tightenScope": true,
            "disableExpansion": true,
            "increaseAnchors": true,
            "maxRetries": 1
          }
        },
        "reasonCode": "grounding_fail_soft"
      },
      {
        "ruleId": "scope_empty_routes_scope_fallback",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.hardScopeActive", "op": "eq", "value": true },
            { "path": "metrics.retrievedChunks", "op": "eq", "value": 0 }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_scope_empty",
          "emitSignals": ["scope_hard_constraints_empty"]
        },
        "reasonCode": "scope_hard_constraints_empty"
      },
      {
        "ruleId": "scoped_not_found_routes_not_found_scope",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.searchExecuted", "op": "eq", "value": true },
            { "path": "metrics.retrievedChunks", "op": "eq", "value": 0 },
            { "path": "metrics.searchConfidence", "op": "gte", "value": 0.7 },
            { "path": "signals.hardScopeActive", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_not_found_scope",
          "emitSignals": ["no_relevant_chunks_in_scoped_docs"]
        },
        "reasonCode": "no_relevant_chunks_in_scoped_docs"
      },
      {
        "ruleId": "wrong_doc_scope_violation_blocks",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.scopeViolation", "op": "eq", "value": true },
            { "path": "signals.operatorFamily", "op": "in", "value": ["documents", "doc_stats"] }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["wrong_doc_detected"]
        },
        "reasonCode": "wrong_doc_detected"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "grounding_fail_soft",
        "action": "retry_retrieval_then_regen",
        "constraints": {
          "disableExpansion": true,
          "preferAnchors": true,
          "maxRetries": 1
        }
      },
      {
        "matchReasonCode": "scope_hard_constraints_empty",
        "action": "route",
        "routeTo": "fallback_scope_empty"
      },
      {
        "matchReasonCode": "no_relevant_chunks_in_scoped_docs",
        "action": "route",
        "routeTo": "fallback_not_found_scope"
      },
      {
        "matchReasonCode": "wrong_doc_detected",
        "action": "block"
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "GP_0001_doc_family_no_evidence_routes_processing",
        "input": { "text": "Summarize the document" },
        "runtime": { "signals": { "operatorFamily": "documents", "hasEvidence": false } },
        "expect": { "action": "route", "routeTo": "fallback_processing", "reasonCode": "grounding_fail_soft" }
      },
      {
        "id": "GP_0002_evidence_sufficient_allows",
        "input": { "text": "What is NOI?" },
        "runtime": { "signals": { "hasEvidence": true }, "metrics": { "evidenceSufficiency": 0.8 } },
        "expect": { "action": "allow", "reasonCode": "grounding_ok" }
      },
      {
        "id": "GP_0003_borderline_evidence_retries",
        "input": { "text": "Extract total revenue" },
        "runtime": { "signals": { "operatorFamily": "documents", "hasEvidence": true }, "metrics": { "evidenceSufficiency": 0.6 } },
        "expect": { "action": "retry_retrieval_then_regen", "reasonCode": "grounding_fail_soft" }
      },
      {
        "id": "GP_0004_scope_empty_routes_scope_fallback",
        "input": { "text": "Find ROI in this file" },
        "runtime": { "signals": { "hardScopeActive": true }, "metrics": { "retrievedChunks": 0 } },
        "expect": { "action": "route", "routeTo": "fallback_scope_empty", "reasonCode": "scope_hard_constraints_empty" }
      },
      {
        "id": "GP_0005_scoped_not_found_routes_not_found_scope",
        "input": { "text": "Find EBITDA" },
        "runtime": { "signals": { "searchExecuted": true, "hardScopeActive": true }, "metrics": { "retrievedChunks": 0, "searchConfidence": 0.85 } },
        "expect": { "action": "route", "routeTo": "fallback_not_found_scope", "reasonCode": "no_relevant_chunks_in_scoped_docs" }
      },
      {
        "id": "GP_0006_wrong_doc_violation_blocks",
        "input": { "text": "Summarize it" },
        "runtime": { "signals": { "scopeViolation": true, "operatorFamily": "documents" } },
        "expect": { "action": "block", "reasonCode": "wrong_doc_detected" }
      }
    ]
  }
}
