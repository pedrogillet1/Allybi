{
  "_meta": {
    "id": "compliance_policy",
    "version": "1.0.0",
    "description": "ChatGPT-like compliance policy for Koda. Defines cross-cutting runtime constraints: privacy, source handling, no JSON output, no debug leakage, truthfulness/grounding, and consistent domain usage. This bank is enforcement logic only (no microcopy).",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "integrationHooks": {
      "bankRegistryId": "bank_registry",
      "globalSystemPoliciesId": "global_system_policies",
      "renderPolicyBankId": "render_policy",
      "answerStylePolicyBankId": "answer_style_policy",
      "qualityGatesBankId": "quality_gates",
      "docGroundingChecksBankId": "doc_grounding_checks",
      "hallucinationGuardsBankId": "hallucination_guards",
      "privacyMinimalRulesBankId": "privacy_minimal_rules",
      "numericIntegrityRulesBankId": "numeric_integrity_rules",
      "bannedPhrasesBankId": "banned_phrases",
      "domainOntologyBankId": "domain_ontology",
      "domainDetectionBankId": "domain_detection",
      "terminologyDomainsBankId": "terminology_domains"
    }
  },
  "constraints": {
    "output": {
      "_comment": "What may appear in the user-visible message body.",
      "noRawJson": true,
      "noCodeBlocks": true,
      "noRawHtml": true,
      "noInternalIds": true,
      "noDebugSections": true,
      "sourcesInBodyForbidden": true,
      "sourcesViaAttachmentsOnly": true
    },
    "grounding": {
      "_comment": "Truthfulness + grounding invariants.",
      "explicitDocRefMustBeHardScope": true,
      "hardLockedActiveDocMustBeRespected": true,
      "neverAnswerFromDocsOutsideHardAllowlist": true,
      "numericClaimsRequireEvidence": true,
      "quotesMustBeVerbatimIfProvided": true
    },
    "privacy": {
      "_comment": "Privacy constraints for both output and logs.",
      "redactSensitiveInDebug": true,
      "noSensitiveEchoInFallbacks": true,
      "neverProvideSensitiveExtractionIfDisallowed": true,
      "avoidStoringSensitivePreferences": true
    },
    "copyright": {
      "_comment": "Avoid reproducing copyrighted text beyond small excerpts.",
      "maxVerbatimWordsPerSource": 25,
      "lyricsMaxWords": 10,
      "preferSummaryOverVerbatim": true,
      "preferShortExcerptThenExplanation": true
    },
    "domainConsistency": {
      "_comment": "Domain IDs must match domain_ontology; domain detection should emit only known domains.",
      "strictDomainIds": true,
      "defaultDomain": "general",
      "maxDomainsToUse": 3,
      "domainStyleAllowed": true
    }
  },
  "enforcementRules": {
    "_comment": "These are checks your runtime should run every turn (or as part of quality_gates).",
    "rules": [
      {
        "id": "CP_001_block_json_output",
        "severity": "error",
        "when": "answerText.looksLikeJson == true",
        "then": "quality_gates.convert_json_to_table_or_bullets"
      },
      {
        "id": "CP_002_block_sources_in_body",
        "severity": "error",
        "when": "answerText.matchesAny(['Sources:','Fontes:','Fuentes:']) == true",
        "then": "quality_gates.strip_inline_sources"
      },
      {
        "id": "CP_003_nav_pills_body_contract",
        "severity": "error",
        "when": "answerMode == 'nav_pills' AND (answerText.sentenceCount > 1 OR answerText.containsListOrTable == true)",
        "then": "quality_gates.strip_body_keep_intro"
      },
      {
        "id": "CP_004_block_wrong_doc_if_explicit_ref",
        "severity": "error",
        "when": "context.explicitDocRef.present == true AND context.chosenDocs.allMatchExplicit != true",
        "then": "quality_gates.fail_hard_wrong_doc"
      },
      {
        "id": "CP_005_numeric_integrity",
        "severity": "error",
        "when": "output.hasCurrency == true AND source.containsExactCurrency != true",
        "then": "quality_gates.retry_retrieval_then_regen"
      },
      {
        "id": "CP_006_privacy_minimal_no_debug",
        "severity": "error",
        "when": "env.isProd == true AND answerText.containsDebugTrace == true",
        "then": "quality_gates.strip_debug_sections"
      },
      {
        "id": "CP_007_domain_id_must_be_known",
        "severity": "error",
        "when": "domain.topDomain exists AND domain.topDomain not_in domain_ontology.domainIds",
        "then": "quality_gates.emit_adaptive_failure_message"
      }
    ]
  },
  "requiredRuntimeSignals": {
    "_comment": "Signals the runtime must provide for deterministic enforcement.",
    "signals": [
      "env.isProd",
      "answerMode",
      "answerText.looksLikeJson",
      "answerText.sentenceCount",
      "answerText.containsListOrTable",
      "answerText.containsDebugTrace",
      "context.explicitDocRef.present",
      "context.chosenDocs.allMatchExplicit",
      "output.hasCurrency",
      "source.containsExactCurrency",
      "domain.topDomain"
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "CPT_0001_no_sources_in_body",
        "input": { "answerText": "Answer...\n\nSources: X", "answerMode": "doc_grounded_single" },
        "expect": { "mustTrigger": "CP_002_block_sources_in_body" }
      },
      {
        "id": "CPT_0002_nav_pills_too_long",
        "input": { "answerMode": "nav_pills", "answerText": "Here it is:\n\nMore text." },
        "expect": { "mustTrigger": "CP_003_nav_pills_body_contract" }
      },
      {
        "id": "CPT_0003_wrong_doc_blocked",
        "input": { "context": { "explicitDocRef": { "present": true }, "chosenDocs": { "allMatchExplicit": false } } },
        "expect": { "mustTrigger": "CP_004_block_wrong_doc_if_explicit_ref" }
      },
      {
        "id": "CPT_0004_json_blocked",
        "input": { "answerText": "{ \"a\": 1 }", "answerText_looksLikeJson": true },
        "expect": { "mustTrigger": "CP_001_block_json_output" }
      }
    ]
  }
}
