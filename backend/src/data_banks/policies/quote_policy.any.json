{
  "_meta": {
    "id": "quote_policy",
    "version": "1.0.0",
    "description": "Policy contract for quote/verbatim behavior in Koda. Ensures explicit quote intent routes to doc_grounded_quote, requires evidence-backed excerpts, enforces quote length limits, and prevents quote hallucination. Delegates formatting constraints to quote_styles and evidence_packaging, and routes failures to retry_retrieval_then_regen or to fallbacks (no user-facing copy).",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-policies",
    "compat": ">=1.0.0",
    "changeLog": [
      "Enforced quote intent -> doc_grounded_quote routing",
      "Added quote length and exactness requirements tied to evidence",
      "Added tests for collisions (quote vs summarize), missing evidence, and truncation behavior"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "allow",
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_severe_then_apply",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_transform"
      },
      "thresholds": {
        "maxQuoteCharsHard": 800,
        "maxQuoteLinesHard": 10,
        "minEvidenceForQuote": 0.7,
        "maxRetries": 1
      },
      "conflictResolution": {
        "ifQuoteAndSummarize": "prefer_quote",
        "ifQuoteAndNoEvidence": "route_fallback_processing",
        "ifQuoteTooLong": "truncate_then_validate"
      }
    },
    "quoteGuarantees": {
      "requireExactEvidenceExcerpt": true,
      "requireProvenance": true,
      "noFabricatedQuotes": true,
      "enforceLengthCaps": true
    }
  },
  "integrationHooks": {
    "dependsOn": [
      "format_triggers",
      "intent_semantics",
      "operator_negatives",
      "routing_overlays",
      "quote_styles",
      "evidence_packaging",
      "grounding_policy",
      "hallucination_policy",
      "retrieval_overlays",
      "retrieval_negatives",
      "fallback_processing",
      "fallback_scope_empty",
      "fallback_not_found_scope"
    ],
    "signalsExpected": [
      "userAskedForQuote",
      "isQuoteIntent",
      "answerMode",
      "operator",
      "hasEvidence",
      "evidenceSufficiency",
      "quoteMismatchDetected",
      "quoteTooLongDetected",
      "explicitDocLock",
      "hardScopeActive",
      "retrievedChunks"
    ]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "quote_intent_forces_quote_mode",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.isQuoteIntent", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "set": [
            { "path": "signals.preferredOperator", "value": "quote" },
            { "path": "signals.preferredAnswerMode", "value": "doc_grounded_quote" }
          ],
          "emitSignals": ["quote_required"]
        },
        "reasonCode": "quote_required"
      },
      {
        "ruleId": "quote_requires_evidence",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.preferredAnswerMode", "op": "eq", "value": "doc_grounded_quote" },
            { "path": "signals.hasEvidence", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_processing",
          "emitSignals": ["grounding_fail_soft"]
        },
        "reasonCode": "grounding_fail_soft"
      },
      {
        "ruleId": "quote_requires_sufficient_evidence",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.preferredAnswerMode", "op": "eq", "value": "doc_grounded_quote" },
            { "path": "metrics.evidenceSufficiency", "op": "lt", "value": 0.7 },
            { "path": "signals.hasEvidence", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "retry_retrieval_then_regen",
          "constraints": {
            "quoteStrict": true,
            "disableExpansion": true,
            "preferExactSpanMatches": true,
            "maxRetries": 1
          }
        },
        "reasonCode": "grounding_fail_soft"
      },
      {
        "ruleId": "quote_mismatch_triggers_retry",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.quoteMismatchDetected", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "retry_retrieval_then_regen",
          "constraints": {
            "quoteStrict": true,
            "disableExpansion": true,
            "tightenScope": true,
            "maxRetries": 1
          }
        },
        "reasonCode": "hallucination_risk_high"
      },
      {
        "ruleId": "quote_length_caps_enforced",
        "severity": "error",
        "when": {
          "any": [
            { "path": "signals.quoteTooLongDetected", "op": "eq", "value": true },
            { "path": "metrics.quoteChars", "op": "gt", "value": 800 }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "truncate_quote_to_limits", "maxChars": 800, "maxLines": 10, "preserve": ["start", "end"], "ellipsis": true }
          ]
        },
        "reasonCode": "quote_too_long"
      },
      {
        "ruleId": "quote_scope_empty_routes_scope_fallback",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.hardScopeActive", "op": "eq", "value": true },
            { "path": "metrics.retrievedChunks", "op": "eq", "value": 0 },
            { "path": "signals.isQuoteIntent", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_scope_empty",
          "emitSignals": ["scope_hard_constraints_empty"]
        },
        "reasonCode": "scope_hard_constraints_empty"
      },
      {
        "ruleId": "quote_scoped_not_found_routes_not_found_scope",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.searchExecuted", "op": "eq", "value": true },
            { "path": "metrics.retrievedChunks", "op": "eq", "value": 0 },
            { "path": "metrics.searchConfidence", "op": "gte", "value": 0.7 },
            { "path": "signals.hardScopeActive", "op": "eq", "value": true },
            { "path": "signals.isQuoteIntent", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_not_found_scope",
          "emitSignals": ["no_relevant_chunks_in_scoped_docs"]
        },
        "reasonCode": "no_relevant_chunks_in_scoped_docs"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "quote_required",
        "action": "transform",
        "constraints": {
          "forceOperator": "quote",
          "forceAnswerMode": "doc_grounded_quote"
        }
      },
      {
        "matchReasonCode": "hallucination_risk_high",
        "action": "retry_retrieval_then_regen",
        "constraints": {
          "quoteStrict": true,
          "disableExpansion": true,
          "tightenScope": true,
          "maxRetries": 1
        }
      },
      {
        "matchReasonCode": "grounding_fail_soft",
        "action": "route",
        "routeTo": "fallback_processing"
      },
      {
        "matchReasonCode": "scope_hard_constraints_empty",
        "action": "route",
        "routeTo": "fallback_scope_empty"
      },
      {
        "matchReasonCode": "no_relevant_chunks_in_scoped_docs",
        "action": "route",
        "routeTo": "fallback_not_found_scope"
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "QPOL_0001_quote_intent_forces_quote_mode",
        "input": { "text": "Quote the exact wording" },
        "runtime": { "signals": { "isQuoteIntent": true } },
        "expect": { "action": "transform", "reasonCode": "quote_required", "set": { "signals.preferredAnswerMode": "doc_grounded_quote" } }
      },
      {
        "id": "QPOL_0002_quote_requires_evidence_routes_processing",
        "input": { "text": "Quote the paragraph about NOI" },
        "runtime": { "signals": { "isQuoteIntent": true, "preferredAnswerMode": "doc_grounded_quote", "hasEvidence": false } },
        "expect": { "action": "route", "routeTo": "fallback_processing", "reasonCode": "grounding_fail_soft" }
      },
      {
        "id": "QPOL_0003_quote_borderline_evidence_retries",
        "input": { "text": "Quote the exact wording about capex" },
        "runtime": { "signals": { "isQuoteIntent": true, "preferredAnswerMode": "doc_grounded_quote", "hasEvidence": true }, "metrics": { "evidenceSufficiency": 0.6 } },
        "expect": { "action": "retry_retrieval_then_regen", "reasonCode": "grounding_fail_soft" }
      },
      {
        "id": "QPOL_0004_quote_mismatch_retries",
        "input": { "text": "Quote it verbatim" },
        "runtime": { "signals": { "isQuoteIntent": true, "quoteMismatchDetected": true } },
        "expect": { "action": "retry_retrieval_then_regen", "reasonCode": "hallucination_risk_high" }
      },
      {
        "id": "QPOL_0005_quote_too_long_truncates",
        "input": { "text": "Quote the whole section" },
        "runtime": { "signals": { "isQuoteIntent": true, "quoteTooLongDetected": true }, "metrics": { "quoteChars": 1200 } },
        "expect": { "action": "transform", "reasonCode": "quote_too_long" }
      },
      {
        "id": "QPOL_0006_quote_scope_empty_routes_scope_fallback",
        "input": { "text": "Quote the line about ROI in this file" },
        "runtime": { "signals": { "isQuoteIntent": true, "hardScopeActive": true }, "metrics": { "retrievedChunks": 0 } },
        "expect": { "action": "route", "routeTo": "fallback_scope_empty", "reasonCode": "scope_hard_constraints_empty" }
      },
      {
        "id": "QPOL_0007_quote_scoped_not_found_routes_not_found_scope",
        "input": { "text": "Quote EBITDA in this file" },
        "runtime": { "signals": { "isQuoteIntent": true, "searchExecuted": true, "hardScopeActive": true }, "metrics": { "retrievedChunks": 0, "searchConfidence": 0.85 } },
        "expect": { "action": "route", "routeTo": "fallback_not_found_scope", "reasonCode": "no_relevant_chunks_in_scoped_docs" }
      }
    ]
  }
}
