{
  "_meta": {
    "id": "domain_policy",
    "version": "1.0.0",
    "description": "ChatGPT-like domain policy for Koda. Defines how detected domains influence retrieval profiles, formatting profiles, terminology hooks, and allowable behaviors without causing hallucination or wrong-doc drift. Policy-only: no user-facing templates.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "integrationHooks": {
      "domainDetectionBankId": "domain_detection",
      "domainOntologyBankId": "domain_ontology",
      "terminologyDomainsBankId": "terminology_domains",
      "semanticSearchConfigBankId": "semantic_search_config",
      "answerStylePolicyBankId": "answer_style_policy",
      "renderPolicyBankId": "render_policy",
      "qualityGatesBankId": "quality_gates"
    }
  },
  "principles": {
    "_comment": "Domain must help, never harm. It cannot override scope or grounding.",
    "domainNeverOverridesHardScope": true,
    "domainIsHintNotTruth": true,
    "domainControlsProfilesNotFacts": true,
    "preferEvidenceOverDomainGuess": true,
    "ifDomainLowConfidenceTreatAsGeneral": true
  },
  "domainResolution": {
    "_comment": "How domains are selected and stabilized across turns.",
    "maxDomainsToReturn": 3,
    "minConfidenceToApply": 0.55,
    "minConfidenceToSwitchActiveDomain": 0.74,
    "capMaxConfidence": 0.98,
    "tieBreakers": [
      "mostStrongMatches",
      "titleBoost",
      "docTextBoost",
      "previousActiveDomainBoost"
    ],
    "stateInteraction": {
      "storeActiveDomain": true,
      "activeDomainTTLTurns": 10,
      "reuseOnFollowupIfNoNewStrongSignals": true,
      "doNotSwitchIfDocIsHardLockedAndDomainWouldConflict": true
    }
  },
  "effects": {
    "_comment": "What a domain can change in the pipeline.",
    "allowed": {
      "retrievalProfile": true,
      "formattingProfile": true,
      "terminologyKey": true,
      "synonymExpansionBias": true,
      "numericStrictness": true,
      "quotePreference": true,
      "ocrTolerance": true
    },
    "forbidden": {
      "overrideDocAllowlist": true,
      "inventMissingEvidence": true,
      "forceAnswerWhenNoEvidence": true
    }
  },
  "retrievalProfiles": {
    "_comment": "Domain→retrieval tuning. Must align with semantic_search_config profiles.",
    "mapping": [
      {
        "domainId": "excel",
        "profile": "structure_first",
        "notes": ["Prefer tables/cells/sheets; boost structure signals; reduce semantic drift."]
      },
      {
        "domainId": "accounting",
        "profile": "numeric_strict",
        "notes": ["Exact numbers must be grounded; prioritize ledger/table matches."]
      },
      {
        "domainId": "finance",
        "profile": "numeric_leaning",
        "notes": ["Blend lexical/structure for KPIs; emphasize payback/NOI/CapEx tables."]
      },
      {
        "domainId": "legal",
        "profile": "quote_friendly",
        "notes": ["Prefer clause/heading matches; support quoting with attribution."]
      },
      {
        "domainId": "medical",
        "profile": "ocr_tolerant",
        "notes": ["High OCR tolerance; prefer field extraction and lab reference ranges."]
      },
      {
        "domainId": "personal_docs",
        "profile": "field_extraction",
        "notes": ["IDs and forms: prefer key-value and short snippets; avoid speculation."]
      },
      {
        "domainId": "invoices_billing",
        "profile": "field_extraction",
        "notes": ["Invoices: prefer totals/due date/line items; prioritize exact matches."]
      },
      {
        "domainId": "general",
        "profile": "balanced",
        "notes": ["Default behavior."]
      }
    ],
    "fallbackProfile": "balanced"
  },
  "formattingProfiles": {
    "_comment": "Domain→formatting style. Must align with answer_style_policy + render_policy.",
    "mapping": [
      {
        "domainId": "finance",
        "profile": "numbers_first",
        "rules": {
          "preferTablesForNumeric": true,
          "preferBulletsForAssumptions": true,
          "avoidLongNarratives": true
        }
      },
      {
        "domainId": "accounting",
        "profile": "numbers_first",
        "rules": {
          "preferTablesForLineItems": true,
          "requireExactLabelsIfPresent": true,
          "warnOnMissingPeriod": true
        }
      },
      {
        "domainId": "excel",
        "profile": "tables_first",
        "rules": {
          "preferTableOrBullets": true,
          "preferCellLocationsIfAvailable": true,
          "avoidParagraphWalls": true
        }
      },
      {
        "domainId": "legal",
        "profile": "bullets_first",
        "rules": {
          "preferShortBullets": true,
          "preferQuoteWhenUserAsks": true,
          "avoidOverInterpretation": true
        }
      },
      {
        "domainId": "medical",
        "profile": "fields_first",
        "rules": {
          "preferKeyFields": true,
          "preferRangesAndUnits": true,
          "avoidDiagnosisGuessing": true
        }
      },
      {
        "domainId": "personal_docs",
        "profile": "fields_first",
        "rules": {
          "preferKeyFields": true,
          "avoidRepeatingSensitiveIdsInFull": true,
          "preferPartialMaskingIfRequestedByPrivacyPolicy": true
        }
      },
      {
        "domainId": "invoices_billing",
        "profile": "fields_first",
        "rules": {
          "preferDueDateTotal": true,
          "preferLineItemTableIfAsked": true
        }
      },
      {
        "domainId": "general",
        "profile": "default",
        "rules": { "preferShortParagraphs": true }
      }
    ],
    "fallbackProfile": "default"
  },
  "terminologyHooks": {
    "_comment": "Domain→terminology key used by retrieval boosting, expansion, and grounding cues.",
    "useTerminologyDomainsLexicon": true,
    "mapping": [
      { "domainId": "finance", "terminologyKey": "finance" },
      { "domainId": "accounting", "terminologyKey": "accounting" },
      { "domainId": "excel", "terminologyKey": "excel" },
      { "domainId": "legal", "terminologyKey": "legal" },
      { "domainId": "medical", "terminologyKey": "medical" },
      { "domainId": "personal_docs", "terminologyKey": "personal_docs" },
      { "domainId": "invoices_billing", "terminologyKey": "invoices_billing" },
      { "domainId": "general", "terminologyKey": "general" }
    ],
    "fallbackTerminologyKey": "general"
  },
  "guardrails": {
    "_comment": "Prevent domain from causing unsafe or wrong outputs.",
    "ifNoEvidenceInScopedDocs": {
      "action": "route_to_adaptive_fallback",
      "reasonCodes": [
        "scope_empty",
        "no_relevant_chunks_in_scoped_docs",
        "extraction_failed",
        "indexing_in_progress"
      ]
    },
    "ifNumericDomainAndUngroundedNumber": {
      "action": "retry_retrieval_then_regen",
      "delegateTo": "quality_gates.numeric_integrity"
    },
    "ifMedicalDomainAndSpeculation": {
      "action": "hedge_or_ask_for_exact_section",
      "notes": ["Do not invent diagnosis or recommendations; stick to document content."]
    }
  },
  "actions": {
    "_comment": "Runtime actions to implement in orchestrator/retrieval/quality gates.",
    "definitions": [
      {
        "id": "route_to_adaptive_fallback",
        "type": "route",
        "notes": "Choose fallback from fallback_processing/fallback_extraction_recovery/fallback_scope_empty/fallback_not_found_scope/no_docs_messages based on reason codes."
      },
      {
        "id": "retry_retrieval_then_regen",
        "type": "route",
        "notes": "Rerun retrieval with numeric exact-match boosting, then regenerate with strict numeric preservation instructions."
      },
      {
        "id": "hedge_or_ask_for_exact_section",
        "type": "transform_or_route",
        "notes": "If evidence is weak, hedge and ask one crisp question for the correct section/page."
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "DP_0001_domain_does_not_override_scope",
        "input": {
          "scope": { "hard": { "docIdAllowlist": ["doc:only"] } },
          "domain": { "topDomain": "finance", "confidence": 0.9 }
        },
        "expect": { "docsSearchedMustOnlyInclude": ["doc:only"] }
      },
      {
        "id": "DP_0002_low_confidence_domain_falls_back_to_general",
        "input": { "domain": { "topDomain": "medical", "confidence": 0.52 } },
        "expect": { "effectiveDomain": "general" }
      },
      {
        "id": "DP_0003_excel_prefers_structure_first_profile",
        "input": { "domain": { "topDomain": "excel", "confidence": 0.82 } },
        "expect": { "retrievalProfile": "structure_first", "formattingProfile": "tables_first" }
      }
    ]
  }
}
