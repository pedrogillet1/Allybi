{
  "_meta": {
    "id": "allybi_connector_permissions",
    "version": "1.0.0",
    "description": "Connector and external-action permissions for editor mode safety.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-12",
    "owner": "allybi-editing",
    "reviewCadenceDays": 30,
    "criticality": "medium",
    "changeLog": [
      "Metadata governance baseline upgrade (2026-03-03)"
    ],
    "usedBy": [
      "services/llm/core/llmRequestBuilder.service.ts"
    ],
    "tests": [
      "tests/certification/prompt-mode-coverage.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "viewerModeBlocksConnectorFallback": true,
    "requireExplicitSendClick": true,
    "configModeOnly": true
  },
  "actions": {
    "CONNECTOR_READ_LIST": {
      "allowedInViewerMode": false,
      "requiresExplicitActivation": true
    },
    "CONNECTOR_DRAFT": {
      "allowedInViewerMode": false,
      "requiresExplicitActivation": true
    },
    "CONNECTOR_SEND_CONFIRM": {
      "allowedInViewerMode": false,
      "requiresExplicitActivation": true,
      "requiresSendClick": true
    }
  },
  "tests": {
    "cases": [
      {
        "id": "ACP_T_0001_send_requires_click",
        "input": {
          "action": "CONNECTOR_SEND_CONFIRM"
        },
        "expect": {
          "requiresSendClick": true,
          "allowedInViewerMode": false
        }
      },
      {
        "id": "ACP_T_0002_read_blocked_in_viewer",
        "input": {
          "action": "CONNECTOR_READ_LIST"
        },
        "expect": {
          "allowedInViewerMode": false
        }
      },
      {
        "id": "ACP_T_0003_draft_requires_activation",
        "input": {
          "action": "CONNECTOR_DRAFT"
        },
        "expect": {
          "requiresExplicitActivation": true
        }
      },
      {
        "id": "ACP_T_0004_global_explicit_send_click",
        "input": {
          "action": "CONNECTOR_SEND_CONFIRM"
        },
        "expect": {
          "requireExplicitSendClick": true
        }
      }
    ]
  }
}
