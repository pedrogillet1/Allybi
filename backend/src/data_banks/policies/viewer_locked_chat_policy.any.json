{
  "_meta": {
    "id": "viewer_locked_chat_policy",
    "version": "1.0.0",
    "description": "Policy contract for Ask Allybi in document viewer. Keeps answers grounded to the active document by default and defines scope relax behavior.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-02",
    "owner": "allybi-viewer",
    "reviewCadenceDays": 30,
    "criticality": "medium",
    "changeLog": [
      "Metadata governance baseline upgrade (2026-03-03)"
    ],
    "usedBy": [
      "services/llm/core/llmRequestBuilder.service.ts"
    ],
    "tests": [
      "tests/certification/prompt-mode-coverage.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "configModeOnly": true
  },
  "policy": {
    "defaultViewerIntent": "qa_locked",
    "defaultAnswerMode": "doc_grounded_single",
    "scope": {
      "lockToActiveDocument": true,
      "allowCrossDocumentWhen": [
        "explicit_user_request",
        "source_click_cross_document"
      ],
      "emitScopeSignals": [
        "explicitDocLock",
        "singleDocIntent",
        "hardScopeActive"
      ]
    },
    "citations": {
      "requireSourceButtons": true,
      "dedupeBy": "document_plus_location",
      "includeLocationMetadata": [
        "page",
        "slide",
        "sheet",
        "cell",
        "section",
        "locationKey",
        "locationLabel",
        "snippet"
      ]
    },
    "fallback": {
      "onMissingLocation": "open_document_top",
      "onUnknownFileType": "disable_editor_actions_but_allow_chat"
    }
  },
  "tests": {
    "cases": [
      {
        "id": "VLCP_0001_default_locked_mode",
        "input": {},
        "expect": {
          "defaultViewerIntent": "qa_locked",
          "defaultAnswerMode": "doc_grounded_single"
        }
      },
      {
        "id": "VLCP_0002_lock_to_active_document",
        "input": {},
        "expect": {
          "lockToActiveDocument": true
        }
      },
      {
        "id": "VLCP_0003_strict_enabled",
        "input": {},
        "expect": {
          "strict": true,
          "enabled": true
        }
      },
      {
        "id": "VLCP_0004_scope_signals_present",
        "input": {},
        "expect": {
          "defaultViewerIntent": "qa_locked"
        }
      }
    ]
  }
}
