{
  "_meta": {
    "id": "formatting_policy",
    "version": "1.0.0",
    "description": "ChatGPT-like formatting policy for Koda. Enforces readability (short paragraphs), structure (intro → body → conclusion), bullet hygiene (1–3 sentences per bullet), table hygiene (strict GFM), and output constraints. Policy-only: no canned user-facing text; routes to microcopy banks when needed.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "integrationHooks": {
      "answerStylePolicyBankId": "answer_style_policy",
      "renderPolicyBankId": "render_policy",
      "listStylesBankId": "list_styles",
      "tableStylesBankId": "table_styles",
      "quoteStylesBankId": "quote_styles",
      "citationStylesBankId": "citation_styles",
      "truncationBankId": "truncation_and_limits",
      "bannedPhrasesBankId": "banned_phrases",
      "qualityGatesBankId": "quality_gates"
    }
  },
  "contracts": {
    "_comment": "These are hard UX contracts for ChatGPT-parity.",
    "noCodeBlocks": true,
    "noJsonOutput": true,
    "sourcesInBody": false,
    "sourcesViaAttachmentsOnly": true,
    "maxQuestionsPerAnswer": 1,
    "blockSeparator": "\n\n",
    "bulletMarker": "-",
    "tableStrictGfm": true
  },
  "defaults": {
    "_comment": "Baseline caps. Domain policies may add additional constraints, but should not relax these unless explicitly allowed.",
    "paragraphs": {
      "maxSentencesPerParagraph": 2,
      "maxCharsPerParagraph": 260,
      "splitLongParagraphs": true,
      "splitStrategy": "sentence_boundary_then_length",
      "preserveBlocks": ["table", "quote", "list"],
      "neverMergeParagraphs": true
    },
    "bullets": {
      "minWordsPerBullet": 6,
      "maxSentencesPerBullet": 3,
      "maxCharsPerBullet": 320,
      "splitLongBullets": true,
      "splitIntoMultipleBulletsIfOverLimit": true,
      "avoidMultiIdeaBullets": true,
      "maxBulletsDefault": 8
    },
    "tables": {
      "maxTablesPerAnswer": 3,
      "maxColumnsBeforeWrap": 6,
      "alignNumericColumnsRight": true,
      "mustHaveSeparatorRow": true,
      "mustStartOnNewLine": true
    },
    "quotes": {
      "maxQuoteLinesDefault": 8,
      "requireAttribution": true,
      "attributionPlacement": "before_quote"
    },
    "introConclusion": {
      "requireIntroForDocGrounded": true,
      "requireConclusionForNonMicro": true,
      "introMaxSentences": 2,
      "introMaxChars": 220,
      "conclusionMaxSentences": 2,
      "conclusionMaxChars": 260
    }
  },
  "rules": [
    {
      "id": "FMT_1000_no_json",
      "priority": 1000,
      "when": {
        "any": [
          { "path": "answerText.detectJsonLike", "op": "eq", "value": true },
          { "path": "signals.userAskedForJson", "op": "eq", "value": true }
        ]
      },
      "then": {
        "action": "convert_json_to_natural_format",
        "mapTo": { "numericOrTabular": "table", "listLike": "bullets", "otherwise": "paragraph" },
        "reasonCode": "json_denied"
      },
      "terminal": false
    },
    {
      "id": "FMT_980_no_code_blocks",
      "priority": 980,
      "when": { "path": "answerText.containsCodeFence", "op": "eq", "value": true },
      "then": {
        "action": "remove_code_fences_and_reformat",
        "reasonCode": "code_fences_disallowed"
      },
      "terminal": false
    },
    {
      "id": "FMT_950_short_paragraphs",
      "priority": 950,
      "when": { "path": "answerText.hasLongParagraph", "op": "eq", "value": true },
      "then": {
        "action": "split_long_paragraphs",
        "limits": {
          "maxSentencesPerParagraph": "@defaults.paragraphs.maxSentencesPerParagraph",
          "maxCharsPerParagraph": "@defaults.paragraphs.maxCharsPerParagraph"
        },
        "reasonCode": "paragraph_readability"
      },
      "terminal": false
    },
    {
      "id": "FMT_940_bullet_hygiene",
      "priority": 940,
      "when": { "path": "answerStructure.bullets.present", "op": "eq", "value": true },
      "then": {
        "action": "enforce_bullet_rules",
        "rules": {
          "bulletMarker": "@contracts.bulletMarker",
          "minWordsPerBullet": "@defaults.bullets.minWordsPerBullet",
          "maxSentencesPerBullet": "@defaults.bullets.maxSentencesPerBullet",
          "maxCharsPerBullet": "@defaults.bullets.maxCharsPerBullet",
          "splitLongBullets": "@defaults.bullets.splitLongBullets",
          "splitIntoMultipleBulletsIfOverLimit": "@defaults.bullets.splitIntoMultipleBulletsIfOverLimit"
        },
        "reasonCode": "bullet_hygiene"
      },
      "terminal": false
    },
    {
      "id": "FMT_930_table_hygiene",
      "priority": 930,
      "when": { "path": "answerStructure.tables.present", "op": "eq", "value": true },
      "then": {
        "action": "repair_or_convert_tables",
        "rules": {
          "strictGfm": "@contracts.tableStrictGfm",
          "mustHaveSeparatorRow": "@defaults.tables.mustHaveSeparatorRow",
          "mustStartOnNewLine": "@defaults.tables.mustStartOnNewLine",
          "alignNumericRight": "@defaults.tables.alignNumericColumnsRight"
        },
        "fallbackIfUnrepairable": "convert_table_to_kv_or_bullets",
        "reasonCode": "table_hygiene"
      },
      "terminal": false
    },
    {
      "id": "FMT_900_intro_conclusion_doc_grounded",
      "priority": 900,
      "_comment": "Only for doc-grounded modes and non-micro profiles. nav_pills is handled by nav_pills_policy.",
      "when": {
        "all": [
          { "path": "answerMode", "op": "startsWith", "value": "doc_grounded" },
          { "path": "profile", "op": "neq", "value": "micro" }
        ]
      },
      "then": {
        "action": "ensure_intro_and_conclusion_blocks",
        "limits": {
          "introMaxSentences": "@defaults.introConclusion.introMaxSentences",
          "introMaxChars": "@defaults.introConclusion.introMaxChars",
          "conclusionMaxSentences": "@defaults.introConclusion.conclusionMaxSentences",
          "conclusionMaxChars": "@defaults.introConclusion.conclusionMaxChars"
        },
        "reasonCode": "intro_conclusion_required"
      },
      "terminal": false
    },
    {
      "id": "FMT_880_max_one_question",
      "priority": 880,
      "when": { "path": "answerText.questionCount", "op": "gt", "value": 1 },
      "then": { "action": "reduce_questions_to_one", "reasonCode": "too_many_questions" },
      "terminal": false
    },
    {
      "id": "FMT_860_spacing_normalization",
      "priority": 860,
      "when": { "path": "answerText.hasExcessNewlines", "op": "eq", "value": true },
      "then": {
        "action": "normalize_spacing",
        "maxConsecutiveNewlines": 2,
        "blockSeparator": "@contracts.blockSeparator",
        "reasonCode": "spacing_normalization"
      },
      "terminal": false
    }
  ],
  "actions": {
    "_comment": "Runtime actions. Implement in AnswerComposer/MarkdownNormalizer/QualityGates.",
    "definitions": [
      {
        "id": "convert_json_to_natural_format",
        "type": "transform",
        "notes": "Convert JSON-like output into table/bullets/paragraph based on content. Never show JSON code blocks."
      },
      {
        "id": "remove_code_fences_and_reformat",
        "type": "transform",
        "notes": "Remove ``` fences and reformat content into allowed markdown shapes."
      },
      {
        "id": "split_long_paragraphs",
        "type": "transform",
        "notes": "Split paragraphs to max 2 sentences / 260 chars per paragraph, preserving tables/quotes/lists."
      },
      {
        "id": "enforce_bullet_rules",
        "type": "transform",
        "notes": "Ensure '-' bullets; split bullets that exceed 3 sentences; avoid multi-idea bullets."
      },
      {
        "id": "repair_or_convert_tables",
        "type": "transform",
        "notes": "Repair broken GFM tables; if cannot repair, convert to key/value lines or bullets."
      },
      {
        "id": "convert_table_to_kv_or_bullets",
        "type": "transform",
        "notes": "Fallback transformation when a table is too broken: convert to key/value rows or bullets."
      },
      {
        "id": "ensure_intro_and_conclusion_blocks",
        "type": "transform_or_route",
        "notes": "Ensure intro and conclusion exist for doc-grounded non-micro answers. Intro = 1–2 sentences. Conclusion = 1–2 sentences."
      },
      {
        "id": "reduce_questions_to_one",
        "type": "transform",
        "notes": "Keep the most relevant follow-up question; remove others."
      },
      {
        "id": "normalize_spacing",
        "type": "transform",
        "notes": "Collapse excessive blank lines; ensure predictable block spacing."
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "FMT_T_0001_splits_long_paragraph",
        "input": { "answerText_paragraphChars": 900, "answerText_sentenceCount": 8 },
        "expect": { "mustApplyAny": ["split_long_paragraphs"] }
      },
      {
        "id": "FMT_T_0002_bullet_max_3_sentences",
        "input": { "answerStructure": { "bullets": { "present": true, "itemCount": 5, "maxSentencesPerItem": 5 } } },
        "expect": { "mustApplyAny": ["enforce_bullet_rules"] }
      },
      {
        "id": "FMT_T_0003_table_hygiene",
        "input": { "answerStructure": { "tables": { "present": true, "missingHeader": true } } },
        "expect": { "mustApplyAny": ["repair_or_convert_tables"] }
      },
      {
        "id": "FMT_T_0004_no_json_output",
        "input": { "answerText": { "detectJsonLike": true } },
        "expect": { "mustApplyAny": ["convert_json_to_natural_format"] }
      },
      {
        "id": "FMT_T_0005_no_code_fences",
        "input": { "answerText": { "containsCodeFence": true } },
        "expect": { "mustApplyAny": ["remove_code_fences_and_reformat"] }
      },
      {
        "id": "FMT_T_0006_max_one_question",
        "input": { "answerText": { "questionCount": 3 } },
        "expect": { "mustApplyAny": ["reduce_questions_to_one"] }
      }
    ]
  }
}
