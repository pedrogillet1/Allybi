{
  "_meta": {
    "id": "memory_policy_tests",
    "version": "1.0.0",
    "description": "High-coverage validation corpus for Allybi memory policy behavior. Covers scope continuity, follow-up reuse, explicit switches, semantic signal extraction, and drift prevention across EN/PT/ES.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-02-19"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "minimumCaseCounts": {
      "total": 45,
      "perLanguage": {
        "en": 12,
        "pt": 12,
        "es": 12
      }
    }
  },
  "suites": [
    {
      "id": "memory_scope_locking",
      "description": "Active doc lock and explicit switch correctness.",
      "weight": 0.3
    },
    {
      "id": "memory_followups",
      "description": "Follow-up continuity and anti-drift behavior.",
      "weight": 0.25
    },
    {
      "id": "memory_semantic_signals",
      "description": "Semantic signal extraction parity and precision.",
      "weight": 0.2
    },
    {
      "id": "memory_decay_and_reset",
      "description": "Decay, cooldown, and stale-state protections.",
      "weight": 0.15
    },
    {
      "id": "memory_multilingual_regressions",
      "description": "Cross-language regression checks for continuity behavior.",
      "weight": 0.1
    }
  ],
  "cases": [
    {
      "id": "MPT_EN_001_explicit_filename_sets_scope",
      "suite": "memory_scope_locking",
      "language": "en",
      "input": "Use report_q4_2024.pdf and summarize NOI.",
      "context": { "activeDocId": null, "isFollowup": false },
      "expect": { "explicitDocRef": true, "shouldSetActiveDoc": true, "shouldNotSearchCorpus": true }
    },
    {
      "id": "MPT_EN_002_followup_reuses_active_doc",
      "suite": "memory_followups",
      "language": "en",
      "input": "Now extract CAPEX from that file.",
      "context": { "activeDocId": "doc_q4_2024", "isFollowup": true },
      "expect": { "shouldReuseActiveDoc": true, "shouldNotSwitchDoc": true }
    },
    {
      "id": "MPT_EN_003_unlock_enables_global",
      "suite": "memory_scope_locking",
      "language": "en",
      "input": "Stop using this file and search all documents for churn.",
      "context": { "activeDocId": "doc_q4_2024", "hardDocLock": true },
      "expect": { "shouldUnlock": true, "shouldAllowCorpusSearch": true }
    },
    {
      "id": "MPT_EN_004_short_ack_keeps_context",
      "suite": "memory_followups",
      "language": "en",
      "input": "ok",
      "context": { "activeDocId": "doc_q4_2024", "isFollowup": true },
      "expect": { "isFollowup": true, "shouldKeepContextAlive": true }
    },
    {
      "id": "MPT_EN_005_quote_signal_detection",
      "suite": "memory_semantic_signals",
      "language": "en",
      "input": "Give me the exact quote for \"net operating income\".",
      "expect": { "userAskedForQuote": true, "hasQuotedText": true }
    },
    {
      "id": "MPT_EN_006_table_signal_detection",
      "suite": "memory_semantic_signals",
      "language": "en",
      "input": "Return this in a table with rows and columns.",
      "expect": { "userAskedForTable": true, "tableExpected": true }
    },
    {
      "id": "MPT_EN_007_sheet_and_range_detection",
      "suite": "memory_semantic_signals",
      "language": "en",
      "input": "Check sheet Revenue tab range B2:F18.",
      "expect": { "sheetHintPresent": true, "rangeExplicit": true }
    },
    {
      "id": "MPT_EN_008_time_constraint_detection",
      "suite": "memory_semantic_signals",
      "language": "en",
      "input": "Compare Q2 2024 versus Q2 2023 margin.",
      "expect": { "timeConstraintsPresent": true, "explicitYearOrQuarterComparison": true }
    },
    {
      "id": "MPT_EN_009_decay_clears_stale_followup",
      "suite": "memory_decay_and_reset",
      "language": "en",
      "context": { "hardDocLock": false, "turnsSinceLastContentTurn": 9, "isFollowup": true },
      "expect": { "shouldExpireFollowupContinuity": true }
    },
    {
      "id": "MPT_EN_010_hard_lock_not_decayed",
      "suite": "memory_decay_and_reset",
      "language": "en",
      "context": { "hardDocLock": true, "turnsSinceLastContentTurn": 40 },
      "expect": { "shouldPreserveHardLock": true }
    },
    {
      "id": "MPT_EN_011_no_false_filename_from_greeting",
      "suite": "memory_multilingual_regressions",
      "language": "en",
      "input": "hello there",
      "expect": { "hasFilename": false, "isFollowup": false }
    },
    {
      "id": "MPT_EN_012_low_entropy_query_not_forced_global",
      "suite": "memory_multilingual_regressions",
      "language": "en",
      "input": "roi?",
      "expect": { "shouldBlockGlobalSearchWhenBelowMinChars": true }
    },

