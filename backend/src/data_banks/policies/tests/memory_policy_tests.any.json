    {
      "id": "MPT_ANY_001_explicit_doc_overrides_followup",
      "suite": "memory_scope_locking",
      "language": "any",
      "context": { "activeDocId": "doc_prev", "isFollowup": true },
      "input": "Switch to contracts_2024.pdf",
      "expect": { "shouldSwitchDoc": true, "shouldIgnoreCarryover": true }
    },
    {
      "id": "MPT_ANY_002_followup_without_explicit_ref_prefers_active_doc",
      "suite": "memory_followups",
      "language": "any",
      "context": { "activeDocId": "doc_prev", "isFollowup": true },
      "input": "and now summarize risk section",
      "expect": { "shouldReuseActiveDoc": true }
    },
    {
      "id": "MPT_ANY_003_unlock_then_followup_allows_multi_doc",
      "suite": "memory_scope_locking",
