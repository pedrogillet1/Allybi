{
  "_meta": {
    "id": "formatting_policy_tests",
    "version": "1.0.0",
    "description": "Regression + contract tests for Koda formatting policies and rendering. Ensures ChatGPT-like structure: short paragraphs (1–2 sentences), bullet hygiene (1–3 sentences per bullet), strict GFM tables, no JSON, no inline sources, and correct nav_pills behavior.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "stopOnFirstFailure": false,
    "severityToFailBuild": "error",
    "integrationHooks": {
      "formattingPolicyId": "formatting_policy",
      "navPillsPolicyId": "nav_pills_policy",
      "answerStylePolicyId": "answer_style_policy",
      "renderPolicyId": "render_policy",
      "qualityGatesId": "quality_gates",
      "bannedPhrasesId": "banned_phrases",
      "truncationLimitsId": "truncation_and_limits"
    }
  },
  "contracts": {
    "_comment": "These define what 'ChatGPT-like formatting' means for Koda.",
    "paragraphs": {
      "maxSentencesPerParagraph": 2,
      "maxCharsPerParagraph": 260,
      "mustSplitLongParagraphs": true,
      "mustUseDoubleNewlineBetweenParagraphs": true
    },
    "bullets": {
      "marker": "-",
      "maxSentencesPerBullet": 3,
      "maxCharsPerBullet": 320,
      "minWordsPerBullet": 6,
      "noAsteriskBullets": true
    },
    "tables": {
      "strictGfm": true,
      "mustHaveHeaderSeparator": true,
      "mustStartOnNewLine": true,
      "maxColumnsBeforeWrap": 6
    },
    "json": {
      "neverOutputJsonToUser": true,
      "mustConvertJsonToTableOrBullets": true
    },
    "sources": {
      "noInlineSourcesLabel": true,
      "sourcesViaAttachmentsOnly": true
    },
    "navPills": {
      "bodyMaxSentences": 1,
      "bodyMaxChars": 90,
      "noInlineFileLists": true,
      "hideSourcesLabel": true,
      "hideDivider": true,
      "pillsOnly": true,
      "noMessageActionsInFrontend": true
    }
  },
  "staticCases": [
    {
      "id": "FP_STATIC_0001_answer_style_policy_has_paragraph_rules",
      "severity": "error",
      "type": "static_assert",
      "assert": "answer_style_policy.config.globalRules.paragraphRules.maxSentencesPerParagraph <= 2 AND answer_style_policy.config.globalRules.paragraphRules.splitLongParagraphs == true",
      "onFail": {
        "reasonCode": "paragraph_rules_missing_or_weak",
        "hint": "Set paragraphRules.maxSentencesPerParagraph<=2 and enable splitLongParagraphs in answer_style_policy."
      }
    },
    {
      "id": "FP_STATIC_0002_answer_style_policy_has_bullet_rules",
      "severity": "error",
      "type": "static_assert",
      "assert": "answer_style_policy.config.globalRules.bulletItemRules.maxSentencesPerBullet <= 3 AND answer_style_policy.config.globalRules.bulletItemRules.minWordsPerBullet >= 6",
      "onFail": {
        "reasonCode": "bullet_rules_missing_or_weak",
        "hint": "Enforce maxSentencesPerBullet<=3 and minWordsPerBullet>=6 in answer_style_policy."
      }
    },
    {
      "id": "FP_STATIC_0003_render_policy_nav_pills_contract",
      "severity": "error",
      "type": "static_assert",
      "assert": "render_policy.config.sourcesUIContract.nav_pills.pillsOnly == true AND render_policy.config.sourcesUIContract.nav_pills.showSourcesLabel == false AND render_policy.config.sourcesUIContract.nav_pills.showDivider == false",
      "onFail": {
        "reasonCode": "nav_pills_ui_contract_missing",
        "hint": "Ensure render_policy.config.sourcesUIContract.nav_pills disables label/divider and uses pillsOnly."
      }
    },
    {
      "id": "FP_STATIC_0004_quality_gates_blocks_json",
      "severity": "error",
      "type": "static_assert",
      "assert": "quality_gates.gates.format_enforcement.enabled == true",
      "onFail": {
        "reasonCode": "quality_gate_json_not_enforced",
        "hint": "Enable quality_gates.gates.format_enforcement and ensure QG_FMT_001 exists."
      }
    }
  ],
  "runtimeCases": [
    {
      "id": "FP_RUN_0001_split_long_paragraphs",
      "severity": "error",
      "type": "runtime_sim",
      "input": {
        "answerText": "This is sentence one. This is sentence two. This is sentence three. This is sentence four.",
        "answerMode": "doc_grounded_single"
      },
      "expect": {
        "mustApplyAny": ["SPLIT_LONG_PARAGRAPHS", "NORMALIZED_SPACING"],
        "maxSentencesPerParagraphLte": 2,
        "mustContainDoubleNewlines": true
      }
    },
    {
      "id": "FP_RUN_0002_bullets_use_dash_marker",
      "severity": "error",
      "type": "runtime_sim",
      "input": {
        "answerText": "* Item one\n* Item two\n* Item three",
        "answerMode": "doc_grounded_single"
      },
      "expect": {
        "outputMustStartWith": "- ",
        "mustNotContain": "\n* ",
        "mustApplyAny": ["NORMALIZED_BULLETS"]
      }
    },
    {
      "id": "FP_RUN_0003_split_long_bullet_into_multiple_bullets",
      "severity": "warning",
      "type": "runtime_sim",
      "input": {
        "answerText": "- This bullet is way too long and has multiple sentences. It keeps going with extra detail that should be separated. It continues even more, which breaks readability.",
        "answerMode": "doc_grounded_single"
      },
      "expect": {
        "maxSentencesPerBulletLte": 3,
        "mayApplyAction": "splitLongBullets",
        "mustRemainBulletList": true
      }
    },
    {
      "id": "FP_RUN_0004_table_has_separator_and_newline",
      "severity": "error",
      "type": "runtime_sim",
      "input": {
        "answerText": "Here is the table: | A | B |\n| 1 | 2 |",
        "answerMode": "doc_grounded_table"
      },
      "expect": {
        "mustContain": "\n\n| A | B |",
        "mustContainAny": ["| --- | --- |", "|---|---|"],
        "mustApplyAny": ["TABLE_REPAIR_01_MISSING_SEPARATOR", "TABLE_REPAIR_02_INLINE_TABLE"]
      }
    },
    {
      "id": "FP_RUN_0005_json_is_converted",
      "severity": "error",
      "type": "runtime_sim",
      "input": {
        "answerText": "```json\n{ \"a\": 1, \"b\": 2 }\n```",
        "answerMode": "doc_grounded_single"
      },
      "expect": {
        "qualityGates.actionsAny": ["convert_json_to_table_or_bullets"],
        "outputMustNotContain": "```json",
        "outputMustContainAny": ["|", "- "]
      }
    },
    {
      "id": "FP_RUN_0006_sources_not_in_body",
      "severity": "error",
      "type": "runtime_sim",
      "input": {
        "answerText": "Answer text.\n\nSources:\n- file.pdf",
        "answerMode": "doc_grounded_single"
      },
      "expect": {
        "qualityGates.actionsAny": ["strip_inline_sources"],
        "outputMustNotContain": "Sources:"
      }
    },
    {
      "id": "FP_RUN_0007_nav_pills_body_is_one_sentence_and_no_sources_label",
      "severity": "error",
      "type": "runtime_sim",
      "input": {
        "answerMode": "nav_pills",
        "answerText": "Here it is: This is extra sentence that should not be here.\n\nSources:\nfile.pdf",
        "attachments": { "source_buttons": { "count": 1 } }
      },
      "expect": {
        "qualityGates.actionsAny": ["strip_body_keep_intro", "strip_inline_sources"],
        "navPills.bodySentenceCountLte": 1,
        "navPills.mustHideSourcesLabel": true,
        "navPills.mustHideDivider": true
      }
    }
  ],
  "postRules": {
    "requireUniqueCaseIds": true,
    "requireSeverityOnEveryCase": true,
    "requireHintOnErrorCases": true
  }
}
