{
  "_meta": {
    "id": "refusal_policy",
    "version": "1.0.0",
    "description": "ChatGPT-like refusal policy for Koda. Defines when to refuse, how to refuse (short, non-lecturing, actionable), and which fallback path to take. No user-facing templates live here; this policy routes to refusal_phrases + safe alternatives.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-01-26",
    "owner": "platform-safety",
    "reviewCadenceDays": 30,
    "criticality": "critical",
    "changeLog": [
      "Metadata governance baseline upgrade (2026-03-03)"
    ],
    "usedBy": [
      "services/llm/core/llmRequestBuilder.service.ts"
    ],
    "tests": [
      "tests/certification/prompt-mode-coverage.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "maxRefusalSentences": 2,
    "maxFollowupQuestions": 1,
    "avoidPhrases": [
      "as an ai",
      "as a language model",
      "i can't access",
      "i do not have access",
      "i'm unable to access"
    ],
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "taxonomy": {
    "_comment": "Normalized refusal categories used across the system.",
    "categories": [
      "self_harm",
      "sexual_minors",
      "instructions_for_wrongdoing",
      "weapons_and_violence",
      "privacy_sensitive_extraction",
      "credential_theft_or_bypass",
      "medical_or_legal_high_stakes_instruction",
      "copyright_violation",
      "harassment_or_hate",
      "malware_or_exploitation",
      "other"
    ]
  },
  "rules": [
    {
      "id": "RP_1000_self_harm",
      "priority": 1000,
      "when": {
        "any": [
          {
            "path": "signals.policy.selfHarm",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.policy.suicide",
            "op": "eq",
            "value": true
          }
        ]
      },
      "then": {
        "action": "refuse_and_redirect",
        "category": "self_harm",
        "responseBank": "refusal_phrases",
        "responseType": "self_harm_safe",
        "includeSafeAlternative": true,
        "includeOneQuestionMax": true
      },
      "terminal": true
    },
    {
      "id": "RP_990_sexual_minors",
      "priority": 990,
      "when": {
        "path": "signals.policy.sexualMinors",
        "op": "eq",
        "value": true
      },
      "then": {
        "action": "refuse",
        "category": "sexual_minors",
        "responseBank": "refusal_phrases",
        "responseType": "sexual_minors",
        "includeSafeAlternative": false
      },
      "terminal": true
    },
    {
      "id": "RP_970_malware_exploitation",
      "priority": 970,
      "when": {
        "any": [
          {
            "path": "signals.policy.malware",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.policy.exploitation",
            "op": "eq",
            "value": true
          }
        ]
      },
      "then": {
        "action": "refuse_and_offer_safe_alternative",
        "category": "malware_or_exploitation",
        "responseBank": "refusal_phrases",
        "responseType": "malware_or_exploitation",
        "safeAlternatives": [
          "defensive_security_best_practices",
          "how_to_secure_account",
          "how_to_remove_malware"
        ]
      },
      "terminal": true
    },
    {
      "id": "RP_960_credentials_bypass",
      "priority": 960,
      "when": {
        "any": [
          {
            "path": "signals.policy.credentialTheft",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.policy.bypass",
            "op": "eq",
            "value": true
          }
        ]
      },
      "then": {
        "action": "refuse_and_offer_safe_alternative",
        "category": "credential_theft_or_bypass",
        "responseBank": "refusal_phrases",
        "responseType": "credential_or_bypass",
        "safeAlternatives": [
          "account_recovery_official_steps",
          "security_hardening",
          "password_manager_tips"
        ]
      },
      "terminal": true
    },
    {
      "id": "RP_940_weapons",
      "priority": 940,
      "when": {
        "path": "signals.policy.weapons",
        "op": "eq",
        "value": true
      },
      "then": {
        "action": "refuse",
        "category": "weapons_and_violence",
        "responseBank": "refusal_phrases",
        "responseType": "weapons"
      },
      "terminal": true
    },
    {
      "id": "RP_920_instructions_for_wrongdoing",
      "priority": 920,
      "when": {
        "any": [
          {
            "path": "signals.policy.illicitInstructions",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.policy.illegalActivity",
            "op": "eq",
            "value": true
          }
        ]
      },
      "then": {
        "action": "refuse_and_offer_safe_alternative",
        "category": "instructions_for_wrongdoing",
        "responseBank": "refusal_phrases",
        "responseType": "wrongdoing_instructions",
        "safeAlternatives": [
          "lawful_overview",
          "risk_awareness",
          "legal_compliance_general"
        ]
      },
      "terminal": true
    },
    {
      "id": "RP_900_privacy_sensitive_extraction",
      "priority": 900,
      "when": {
        "any": [
          {
            "path": "signals.policy.sensitivePersonalDataExtraction",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.policy.doxxing",
            "op": "eq",
            "value": true
          }
        ]
      },
      "then": {
        "action": "refuse_and_offer_safe_alternative",
        "category": "privacy_sensitive_extraction",
        "responseBank": "refusal_phrases",
        "responseType": "privacy_sensitive",
        "safeAlternatives": [
          "summarize_without_sensitive_fields",
          "redact_then_extract",
          "explain_where_to_find_in_doc"
        ]
      },
      "terminal": true
    },
    {
      "id": "RP_880_copyright",
      "priority": 880,
      "when": {
        "path": "signals.policy.copyright",
        "op": "eq",
        "value": true
      },
      "then": {
        "action": "refuse_and_offer_safe_alternative",
        "category": "copyright_violation",
        "responseBank": "refusal_phrases",
        "responseType": "copyright",
        "safeAlternatives": [
          "summary",
          "short_excerpt_with_context",
          "analysis_or_discussion"
        ]
      },
      "terminal": true
    },
    {
      "id": "RP_860_high_stakes_instruction",
      "priority": 860,
      "when": {
        "any": [
          {
            "path": "signals.policy.highStakesMedicalInstruction",
            "op": "eq",
            "value": true
          },
          {
            "path": "signals.policy.highStakesLegalInstruction",
            "op": "eq",
            "value": true
          }
        ]
      },
      "then": {
        "action": "refuse_and_redirect",
        "category": "medical_or_legal_high_stakes_instruction",
        "responseBank": "refusal_phrases",
        "responseType": "high_stakes",
        "includeSafeAlternative": true,
        "safeAlternatives": [
          "general_information_only",
          "suggest_professional",
          "ask_for_context_non_actionable"
        ]
      },
      "terminal": true
    },
    {
      "id": "RP_200_fallback_other",
      "priority": 200,
      "when": {
        "path": "signals.policyRefusalRequired",
        "op": "eq",
        "value": true
      },
      "then": {
        "action": "refuse",
        "category": "other",
        "responseBank": "refusal_phrases",
        "responseType": "generic_refusal"
      },
      "terminal": true
    }
  ],
  "responseGuidelines": {
    "_comment": "Contract for the runtime when rendering a refusal.",
    "mustDo": [
      "be_short",
      "state_boundary_once",
      "offer_safe_alternative_if_possible",
      "ask_at_most_one_question_if_needed"
    ],
    "mustNotDo": [
      "lecture",
      "blame_user",
      "include_internal_policy_ids",
      "include_debug_info",
      "repeat_refusal_multiple_times"
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "RPT_0001_self_harm_routes_refusal",
        "input": {
          "signals": {
            "policy": {
              "selfHarm": true
            }
          }
        },
        "expect": {
          "category": "self_harm",
          "action": "refuse_and_redirect"
        }
      },
      {
        "id": "REFUSE_T_002",
        "input": {
          "signals": {
            "policy": {
              "selfHarm": true
            }
          }
        },
        "expect": {
          "category": "self_harm",
          "action": "refuse_and_redirect"
        }
      },
      {
        "id": "REFUSE_T_003",
        "input": {
          "signals": {
            "policy": {
              "selfHarm": true
            }
          }
        },
        "expect": {
          "category": "self_harm",
          "action": "refuse_and_redirect"
        }
      },
      {
        "id": "REFUSE_T_004",
        "input": {
          "signals": {
            "policy": {
              "selfHarm": true
            }
          }
        },
        "expect": {
          "category": "self_harm",
          "action": "refuse_and_redirect"
        }
      }
    ]
  }
}
