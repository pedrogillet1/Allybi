{
  "_meta": {
    "id": "global_system_policies",
    "version": "1.0.0",
    "description": "Cross-cutting system constraints that must hold regardless of operator or domain. Enforces output contract invariants, anti-hardcoding rules, grounding requirements, and fallback behavior. This bank MUST NOT contain user-facing microcopy.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-policies",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added output contract enforcement rules",
      "Added anti-hardcoding constraints",
      "Added grounding and evidence requirements",
      "Added fallback routing policies",
      "Added domain consistency rules"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "category": "core",
    "priority": 0,
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_all_non_conflicting",
        "capMaxPenalty": 1.0,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_transform"
      },
      "thresholds": {
        "minGroundingConfidence": 0.7,
        "maxHallucinationRisk": 0.2,
        "minEvidenceRequired": 1,
        "maxOutputLength": 4000
      },
      "conflictResolution": {
        "ifSafetyAndOutputConflict": "safety_wins",
        "ifGroundingAndSpeedConflict": "grounding_wins",
        "ifDomainAndGenericConflict": "domain_specific_wins"
      }
    }
  },
  "integrationHooks": {
    "dependsOn": [
      "answer_style_policy",
      "render_policy",
      "quality_gates",
      "doc_grounding_checks",
      "hallucination_guards",
      "domain_ontology",
      "domain_detection",
      "terminology_domains",
      "banned_phrases"
    ],
    "signalsExpected": [
      "hasEvidence",
      "evidenceCount",
      "groundingScore",
      "hallucinationRisk",
      "domainDetected",
      "domainConfidence",
      "outputLength",
      "containsHardcodedCopy",
      "containsBannedPhrase",
      "languageDetected",
      "languageMatch",
      "answerMode",
      "intentFamily",
      "hasFallbackTriggered"
    ],
    "emitsSignals": [
      "policy_violation",
      "grounding_required",
      "domain_enforcement",
      "language_enforcement",
      "fallback_required",
      "quality_gate_failed"
    ]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "require_evidence_for_doc_claims",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.intentFamily", "op": "in", "value": ["documents", "doc_qa", "doc_analysis"] },
            { "path": "signals.hasEvidence", "op": "eq", "value": false }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["grounding_required"]
        },
        "reasonCode": "grounding_required"
      },
      {
        "ruleId": "block_low_grounding_answers",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.intentFamily", "op": "in", "value": ["documents", "doc_qa"] },
            { "path": "metrics.groundingScore", "op": "lt", "value": 0.5 }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_low_confidence",
          "emitSignals": ["quality_gate_failed"]
        },
        "reasonCode": "grounding_required"
      },
      {
        "ruleId": "block_high_hallucination_risk",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "metrics.hallucinationRisk", "op": "gt", "value": 0.4 }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_uncertain",
          "emitSignals": ["quality_gate_failed"]
        },
        "reasonCode": "hallucination_risk"
      },
      {
        "ruleId": "enforce_language_match",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.languageDetected", "op": "neq", "value": null },
            { "path": "signals.languageMatch", "op": "eq", "value": false }
          ]
        },
        "then": {
          "action": "transform",
          "set": [
            { "path": "signals.forceLanguageMatch", "value": true }
          ],
          "emitSignals": ["language_enforcement"]
        },
        "reasonCode": "language_mismatch"
      },
      {
        "ruleId": "block_hardcoded_copy_in_output",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.containsHardcodedCopy", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "replace_with_token_lookup" }
          ],
          "emitSignals": ["policy_violation"]
        },
        "reasonCode": "hardcoded_copy_violation"
      },
      {
        "ruleId": "block_banned_phrases",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.containsBannedPhrase", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "strip_banned_phrases" }
          ],
          "emitSignals": ["policy_violation"]
        },
        "reasonCode": "banned_phrase_detected"
      },
      {
        "ruleId": "enforce_domain_terminology",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.domainDetected", "op": "neq", "value": null },
            { "path": "metrics.domainConfidence", "op": "gte", "value": 0.8 },
            { "path": "signals.usesDomainTerminology", "op": "eq", "value": false }
          ]
        },
        "then": {
          "action": "transform",
          "set": [
            { "path": "signals.applyDomainTerminology", "value": true }
          ],
          "emitSignals": ["domain_enforcement"]
        },
        "reasonCode": "domain_terminology_required"
      },
      {
        "ruleId": "cap_output_length",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "metrics.outputLength", "op": "gt", "value": 4000 }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "truncate_with_continuation" }
          ]
        },
        "reasonCode": "output_length_exceeded"
      },
      {
        "ruleId": "require_answer_mode_consistency",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.answerMode", "op": "neq", "value": null },
            { "path": "signals.answerModeViolation", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "set": [
            { "path": "signals.enforceAnswerMode", "value": true }
          ]
        },
        "reasonCode": "answer_mode_violation"
      },
      {
        "ruleId": "route_to_fallback_on_empty_response",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "metrics.outputLength", "op": "eq", "value": 0 },
            { "path": "signals.intentFamily", "op": "neq", "value": "greeting" }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "fallback_empty_response",
          "emitSignals": ["fallback_required"]
        },
        "reasonCode": "empty_response"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "grounding_required",
        "action": "route",
        "routeTo": "fallback_no_evidence",
        "constraints": {
          "requireEvidenceRetry": true,
          "maxRetries": 1
        }
      },
      {
        "matchReasonCode": "hallucination_risk",
        "action": "route",
        "routeTo": "fallback_uncertain",
        "constraints": {
          "stripUnsupportedClaims": true,
          "addUncertaintyQualifier": true
        }
      },
      {
        "matchReasonCode": "language_mismatch",
        "action": "transform",
        "constraints": {
          "forceOutputLanguage": true,
          "useDetectedLanguage": true
        }
      },
      {
        "matchReasonCode": "hardcoded_copy_violation",
        "action": "transform",
        "constraints": {
          "lookupTokenFromBank": true,
          "fallbackToGeneric": true
        }
      },
      {
        "matchReasonCode": "banned_phrase_detected",
        "action": "transform",
        "constraints": {
          "stripPhrase": true,
          "logViolation": true
        }
      },
      {
        "matchReasonCode": "domain_terminology_required",
        "action": "transform",
        "constraints": {
          "applyDomainGlossary": true,
          "preferDomainSynonyms": true
        }
      },
      {
        "matchReasonCode": "output_length_exceeded",
        "action": "transform",
        "constraints": {
          "truncateAt": 4000,
          "addContinuationOffer": true
        }
      },
      {
        "matchReasonCode": "answer_mode_violation",
        "action": "transform",
        "constraints": {
          "enforceStyleFromMode": true
        }
      },
      {
        "matchReasonCode": "empty_response",
        "action": "route",
        "routeTo": "fallback_generic"
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "GSP_0001_doc_claim_without_evidence_blocked",
        "input": { "text": "What does the report say about revenue?" },
        "runtime": {
          "signals": { "intentFamily": "doc_qa", "hasEvidence": false }
        },
        "expect": { "action": "block", "reasonCode": "grounding_required" }
      },
      {
        "id": "GSP_0002_low_grounding_routes_fallback",
        "input": { "text": "Summarize the contract" },
        "runtime": {
          "signals": { "intentFamily": "documents" },
          "metrics": { "groundingScore": 0.3 }
        },
        "expect": { "action": "route", "routeTo": "fallback_low_confidence", "reasonCode": "grounding_required" }
      },
      {
        "id": "GSP_0003_high_hallucination_risk_routes",
        "input": { "text": "What are the exact figures?" },
        "runtime": {
          "metrics": { "hallucinationRisk": 0.6 }
        },
        "expect": { "action": "route", "routeTo": "fallback_uncertain", "reasonCode": "hallucination_risk" }
      },
      {
        "id": "GSP_0004_language_mismatch_transforms",
        "input": { "text": "Qual é o total?" },
        "runtime": {
          "signals": { "languageDetected": "pt", "languageMatch": false }
        },
        "expect": { "action": "transform", "reasonCode": "language_mismatch" }
      },
      {
        "id": "GSP_0005_hardcoded_copy_transforms",
        "input": { "text": "Help me" },
        "runtime": {
          "signals": { "containsHardcodedCopy": true }
        },
        "expect": { "action": "transform", "reasonCode": "hardcoded_copy_violation" }
      },
      {
        "id": "GSP_0006_banned_phrase_transforms",
        "input": { "text": "Tell me about X" },
        "runtime": {
          "signals": { "containsBannedPhrase": true }
        },
        "expect": { "action": "transform", "reasonCode": "banned_phrase_detected" }
      },
      {
        "id": "GSP_0007_domain_terminology_enforced",
        "input": { "text": "Calculate the return" },
        "runtime": {
          "signals": { "domainDetected": "finance", "usesDomainTerminology": false },
          "metrics": { "domainConfidence": 0.9 }
        },
        "expect": { "action": "transform", "reasonCode": "domain_terminology_required" }
      },
      {
        "id": "GSP_0008_output_length_truncated",
        "input": { "text": "Explain everything" },
        "runtime": {
          "metrics": { "outputLength": 5000 }
        },
        "expect": { "action": "transform", "reasonCode": "output_length_exceeded" }
      },
      {
        "id": "GSP_0009_empty_response_routes_fallback",
        "input": { "text": "Find X" },
        "runtime": {
          "signals": { "intentFamily": "documents" },
          "metrics": { "outputLength": 0 }
        },
        "expect": { "action": "route", "routeTo": "fallback_empty_response", "reasonCode": "empty_response" }
      },
      {
        "id": "GSP_0010_valid_grounded_answer_passes",
        "input": { "text": "What is the total revenue?" },
        "runtime": {
          "signals": { "intentFamily": "doc_qa", "hasEvidence": true, "languageMatch": true },
          "metrics": { "groundingScore": 0.85, "hallucinationRisk": 0.1, "outputLength": 200 }
        },
        "expect": { "action": "allow" }
      }
    ]
  }
}
