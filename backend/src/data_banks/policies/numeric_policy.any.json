{
  "_meta": {
    "id": "numeric_policy",
    "version": "1.0.0",
    "description": "Numeric integrity policy for Koda. Ensures numbers extracted from documents are preserved exactly, prevents hallucinated calculations, enforces formatting consistency for currencies/percentages/dates, and validates numeric claims against evidence.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-policies",
    "compat": ">=1.0.0",
    "changeLog": [
      "Initial numeric integrity policy",
      "Added exact preservation rules for doc-grounded numbers",
      "Added formatting rules for currencies, percentages, dates",
      "Added validation against evidence sources"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_restrictive",
        "capMaxPenalty": 0.9,
        "hardBlockIsTerminal": true
      },
      "thresholds": {
        "minConfidenceForNumericClaim": 0.85,
        "maxDecimalPlacesDefault": 2,
        "toleranceForRounding": 0.005
      },
      "conflictResolution": {
        "ifNumericMismatch": "use_evidence_value",
        "ifMultipleSourceValues": "prefer_most_recent_or_explicit"
      }
    },
    "integrationHooks": {
      "dependsOn": [
        "evidence_packaging",
        "doc_grounding_checks",
        "numeric_integrity_rules",
        "domain_detection"
      ],
      "signalsExpected": [
        "numericValuesInAnswer",
        "numericValuesInEvidence",
        "currencyDetected",
        "percentageDetected",
        "dateDetected",
        "calculationAttempted",
        "operatorFamily"
      ]
    }
  },
  "formatting": {
    "currencies": {
      "preserveOriginalSymbol": true,
      "thousandsSeparator": {
        "en": ",",
        "pt": ".",
        "es": "."
      },
      "decimalSeparator": {
        "en": ".",
        "pt": ",",
        "es": ","
      },
      "commonSymbols": ["$", "R$", "€", "£", "¥", "US$", "BRL", "USD", "EUR"]
    },
    "percentages": {
      "usePercentSymbol": true,
      "maxDecimalPlaces": 2,
      "preserveOriginalPrecision": true
    },
    "dates": {
      "preserveOriginalFormat": true,
      "standardFormats": {
        "en": ["MM/DD/YYYY", "YYYY-MM-DD", "Month DD, YYYY"],
        "pt": ["DD/MM/YYYY", "DD de Month de YYYY"],
        "es": ["DD/MM/YYYY", "DD de Month de YYYY"]
      }
    },
    "largeNumbers": {
      "useAbbreviations": true,
      "abbreviations": {
        "en": { "thousand": "K", "million": "M", "billion": "B", "trillion": "T" },
        "pt": { "thousand": "mil", "million": "mi", "billion": "bi", "trillion": "tri" },
        "es": { "thousand": "K", "million": "M", "billion": "B", "trillion": "T" }
      },
      "thresholdForAbbreviation": 10000
    }
  },
  "policies": {
    "rules": [
      {
        "ruleId": "preserve_exact_doc_numbers",
        "severity": "error",
        "description": "Numbers from documents must be preserved exactly as found in evidence.",
        "when": {
          "all": [
            { "path": "signals.operatorFamily", "op": "in", "value": ["documents", "doc_stats"] },
            { "path": "signals.numericValuesInAnswer", "op": "exists", "value": true }
          ]
        },
        "then": {
          "action": "validate_against_evidence",
          "constraints": {
            "mustMatchEvidence": true,
            "toleranceForRounding": 0.005
          },
          "emitSignals": ["numeric_validated"]
        },
        "reasonCode": "numeric_preservation"
      },
      {
        "ruleId": "no_hallucinated_calculations",
        "severity": "fatal",
        "description": "Calculations not explicitly shown in document must not be performed or claimed.",
        "when": {
          "all": [
            { "path": "signals.calculationAttempted", "op": "eq", "value": true },
            { "path": "signals.calculationInEvidence", "op": "eq", "value": false }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["calculation_blocked"]
        },
        "reasonCode": "hallucinated_calculation"
      },
      {
        "ruleId": "format_currency_by_locale",
        "severity": "warning",
        "description": "Format currencies according to detected locale/language.",
        "when": {
          "all": [
            { "path": "signals.currencyDetected", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": "apply_currency_formatting",
          "preserveOriginalSymbol": true
        },
        "reasonCode": "currency_formatting"
      },
      {
        "ruleId": "format_percentages_consistently",
        "severity": "warning",
        "description": "Ensure percentages use consistent formatting with % symbol.",
        "when": {
          "all": [
            { "path": "signals.percentageDetected", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": "apply_percentage_formatting",
          "maxDecimalPlaces": 2
        },
        "reasonCode": "percentage_formatting"
      },
      {
        "ruleId": "preserve_date_format_from_doc",
        "severity": "info",
        "description": "Preserve date formats as they appear in the source document.",
        "when": {
          "all": [
            { "path": "signals.dateDetected", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "preserve_format",
          "emitSignals": ["date_preserved"]
        },
        "reasonCode": "date_formatting"
      },
      {
        "ruleId": "numeric_mismatch_uses_evidence",
        "severity": "error",
        "description": "When answer numeric value differs from evidence, use evidence value.",
        "when": {
          "all": [
            { "path": "metrics.numericMismatchDetected", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": "replace_with_evidence_value",
          "emitSignals": ["numeric_corrected"]
        },
        "reasonCode": "numeric_mismatch_corrected"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "hallucinated_calculation",
        "action": "block"
      },
      {
        "matchReasonCode": "numeric_preservation",
        "action": "transform",
        "transform": "replace_with_evidence_value"
      },
      {
        "matchReasonCode": "numeric_mismatch_corrected",
        "action": "transform",
        "transform": "replace_with_evidence_value"
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "NUM_0001_preserve_exact_number",
        "input": { "text": "What is the revenue?" },
        "runtime": {
          "signals": { "operatorFamily": "documents", "numericValuesInAnswer": ["$1,234,567.89"] },
          "evidence": { "numericValues": ["$1,234,567.89"] }
        },
        "expect": { "action": "validate_against_evidence", "reasonCode": "numeric_preservation" }
      },
      {
        "id": "NUM_0002_block_hallucinated_calc",
        "input": { "text": "Calculate the total" },
        "runtime": {
          "signals": { "calculationAttempted": true, "calculationInEvidence": false }
        },
        "expect": { "action": "block", "reasonCode": "hallucinated_calculation" }
      },
      {
        "id": "NUM_0003_format_currency_pt",
        "input": { "text": "Qual é o valor?" },
        "runtime": {
          "signals": { "currencyDetected": true },
          "language": "pt"
        },
        "expect": { "action": "transform", "transform": "apply_currency_formatting" }
      },
      {
        "id": "NUM_0004_correct_numeric_mismatch",
        "input": { "text": "What is the percentage?" },
        "runtime": {
          "signals": { "operatorFamily": "documents" },
          "metrics": { "numericMismatchDetected": true },
          "evidence": { "value": "15.5%" },
          "answer": { "value": "15%" }
        },
        "expect": { "action": "transform", "transform": "replace_with_evidence_value" }
      },
      {
        "id": "NUM_0005_preserve_date_format",
        "input": { "text": "When was it signed?" },
        "runtime": {
          "signals": { "dateDetected": true },
          "evidence": { "dateFormat": "DD/MM/YYYY", "dateValue": "15/01/2026" }
        },
        "expect": { "action": "preserve_format", "reasonCode": "date_formatting" }
      }
    ]
  }
}
