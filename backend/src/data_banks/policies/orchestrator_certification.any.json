        }
      },
      {
        "id": "ORCH_CERT_T_004",
        "input": {},
        "expect": {
          "regressionPathCount": 7
        }
      },
      {
        "id": "ORCH_CERT_T_005",
        "input": {},
        "expect": {
          "memorySemanticsCheckCount": 3
        }
      },
      {
        "id": "ORCH_CERT_T_006",
        "input": {},
        "expect": {
          "gateScoreCount": 6,
          "coverageThresholdCount": 4
        }
      }
    ]
  }
}
