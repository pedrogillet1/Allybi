{
  "_meta": {
    "id": "memory_policy",
    "version": "1.1.0",
    "description": "ChatGPT-like conversation memory policy for Koda. Governs what conversational state is stored (doc lock/time/metric/domain), how long it persists, how it decays, and how it is reused without causing silent doc drift. Policy-only: does not define user-facing copy.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-19"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "integrationHooks": {
      "conversationStateSchemaBankId": "conversation_state_schema",
      "stateUpdateRulesBankId": "state_update_rules",
      "memoryDecayRulesBankId": "memory_decay_rules",
      "scopeResolutionBankId": "scope_resolution",
      "followupDetectionBankId": "followup_detection",
      "qualityGatesBankId": "quality_gates"
    },
    "runtimeTuning": {
      "recentContextLimit": 180,
      "historyClampMax": 320,
      "inMemoryMessageCacheLimit": 240,
      "inMemoryConversationCacheLimit": 1200,
      "inMemoryCacheTtlSeconds": 900,
      "defaultStateSummary": "Conversation active.",
      "defaultStateTopic": "General inquiry",
      "memorySummaryMaxChars": 1800,
      "memoryRecallMaxItems": 6,
      "memoryRecallSnippetChars": 260,
      "evidenceSnippetMaxChars": 900,
      "queryKeywordMaxTerms": 12,
      "queryKeywordMinLength": 3,
      "queryStopWords": {
        "any": [
          "the",
          "and",
          "for",
          "with",
          "that",
          "this",
          "from",
          "have",
          "your",
          "about",
          "what",
          "when",
          "where",
          "which",
          "please",
          "could",
          "would"
        ],
        "pt": [
          "como",
          "onde",
          "qual",
          "para",
          "com",
          "sobre",
          "este",
          "esta",
          "isso",
          "por",
          "que"
        ],
        "es": [
          "como",
          "donde",
          "cual",
          "para",
          "con",
          "sobre",
          "este",
          "esta",
          "eso",
          "por",
          "que"
        ]
      },
      "memoryArtifactStore": {
        "recentMessageIdMaxItems": 48,
        "recallBufferMaxItems": 32,
        "keyTopicMaxItems": 8,
        "summaryRefreshAssistantEveryTurns": 1,
        "staleTopicDecayTurns": 18,
        "maxPersistedSourceDocumentIds": 24,
        "maxPersistedRecallBytes": 24000
      },
      "semanticSignals": {
        "regexFlags": "i",
        "patterns": {
          "hasQuotedText": [
            "\"[^\"]{2,}\"",
            "'[^']{2,}'",
            "“[^”]{2,}”",
            "‘[^’]{2,}’"
          ],
          "hasFilename": [
            "\\b\\w[\\w\\-_. ]{0,140}\\.(pdf|docx?|xlsx?|pptx?|txt|csv)\\b",
            "\\b[^\\s\"']+\\.(pdf|docx?|xlsx?|pptx?|txt|csv|md)\\b"
          ],
          "userAskedForTable": [
            "\\b(table|sheet|rows?|columns?|tabular)\\b",
            "\\b(tabela|tabla|tabular|linhas?|filas?|colunas?|columnas?)\\b"
          ],
          "userAskedForQuote": [
            "\\b(quote|exact|line|paragraph|citation)\\b",
            "\\b(cita[cç][aã]o|cita|literal|exacta|exata|par[aá]grafo|parrafo|linha|linea)\\b"
          ],
          "sheetHintPresent": [
            "\\b(sheet|tab)\\b",
            "\\b(aba|hoja|pesta[nñ]a|planilha)\\b"
          ],
          "rangeExplicit": [
            "\\b[A-Z]{1,3}\\d{1,6}:[A-Z]{1,3}\\d{1,6}\\b",
            "\\b([A-Z]{1,3}\\d{1,6})\\s*-\\s*([A-Z]{1,3}\\d{1,6})\\b"
          ],
          "timeConstraintsPresent": [
            "\\b(20\\d{2}|19\\d{2}|q[1-4])\\b",
            "\\b(fy\\s*20\\d{2}|trimestre|trimestre|quarter)\\b"
          ],
          "explicitYearOrQuarterComparison": [
            "\\b(compare|versus|vs\\.?)\\b",
            "\\b(compar(e|ar|a)|versus|contra|vs\\.?)\\b"
          ],
          "tableExpected": [
            "\\b(table|tabular)\\b",
            "\\b(tabela|tabla|tabular)\\b"
          ]
        }
      },
      "gateway": {
        "userTextCharCap": 12000,
        "systemBlockCharCap": 5000,
        "dialogueTurnLimit": 20,
        "dialogueMessageCharCap": 1600,
        "dialogueCharBudget": 12000,
        "memoryPackCharCap": 16000
      },
      "semanticRetrieval": {
        "enableGlobalEvidenceSearch": true,
        "globalSearchMinQueryChars": 12,
        "maxEvidenceItemsForAnswer": 8,
        "preferActiveScopeWhenFollowup": true,
        "staleScopePenalty": 0.12,
        "maxGlobalRetrievalsPerTurn": 1
      },
      "scopeRuntime": {
        "maxScopeDocs": 20,
        "tokenMinLength": 2,
        "docNameMinLength": 3,
        "tokenOverlapThreshold": 0.5,
        "candidatePatterns": {
          "filename": [
            "\\b[\\w][\\w\\-_. ]{0,160}\\.(pdf|docx?|xlsx?|pptx?|txt|csv|png|jpe?g|webp)\\b"
          ],
          "docReferencePhrase": [
            "(?:usando\\s+(?:o\\s+)?documento|using\\s+(?:the\\s+)?(?:document|file)|no\\s+(?:documento|arquivo)|from\\s+(?:the\\s+)?(?:document|file)|about\\s+(?:the\\s+)?(?:document|file)|(?:documento|arquivo)\\s+chamado)\\s+[\"“”']?([^\"“”'\\n]{3,120})[\"“”']?",
            "(?:(?:d|D)ocs?\\s+que\\s+(?:anexei|enviei|carreguei|subi)|(?:o|O)s\\s+documentos?\\s+(?:que\\s+)?(?:anexei|enviei|carreguei|subi))\\s*(?:[:(]\\s*)?([^\"\\u201c\\u201d\\'\\n)]{3,200})",
            "(?:(?:e|E)m\\s+rela[çc][ãa]o\\s+a[o]?s?\\s+(?:docs?|documentos?|arquivos?))\\s*(?:[:(]\\s*)?([^\"\\u201c\\u201d\\'\\n)]{3,200})",
            "(?:(?:n|N)os?\\s+(?:docs?|documentos?|arquivos?)\\s+(?:que|de|do|da)\\s+)([^\"\\u201c\\u201d\\'\\n]{3,200})",
            "(?:(?:c|C)ome[cç]a\\s+pelo|(?:a|A)gora\\s+(?:no|na|nos|nas)|(?:v|V)amos\\s+para\\s+(?:o|a)|(?:n|N)o\\s+cap[ií]tulo\\s+de|(?:n|N)as?\\s+anota[cç][oõ]es|(?:s|S)obre\\s+(?:o|a)|(?:f|F)oca\\s+no?)\\s+([^\"\\u201c\\u201d\\'\\n)]{3,180})",
            "(?:(?:s|S)tart\\s+with|(?:n|N)ow\\s+on|(?:l|L)et'?s\\s+go\\s+to|(?:f|F)ocus\\s+on|(?:a|A)bout\\s+the)\\s+([^\"\\u201c\\u201d\\'\\n)]{3,180})",
            "(?:(?:e|E)mpecemos\\s+por|(?:a|A)hora\\s+en|(?:v|V)amos\\s+a|(?:e|E)n\\s+el\\s+cap[ií]tulo\\s+de|(?:s|S)obre\\s+el)\\s+([^\"\\u201c\\u201d\\'\\n)]{3,180})",
            "(?:(?:l|L)os?\\s+documentos?\\s+que\\s+(?:adjunt[ée]|sub[ií]|envi[ée]|cargu[ée]))\\s*(?:[:(]\\s*)?([^\"\\u201c\\u201d\\'\\n)]{3,200})",
            "(?:(?:t|T)he\\s+(?:docs?|documents?|files?)\\s+(?:I\\s+)?(?:attached|uploaded|sent))\\s*(?:[:(]\\s*)?([^\"\\u201c\\u201d\\'\\n)]{3,200})"
          ]
        },
        "clearScopePatterns": [
          "\\b(clear|reset|remove)\\s+(scope|context|attachments?)\\b",
          "\\b(use|search)\\s+(all|entire)\\s+(documents?|library)\\b",
          "\\b(limpar|remover|resetar)\\s+(escopo|contexto|anexos?)\\b",
          "\\b(usar|pesquisar)\\s+(todos|toda)\\s+(documentos?|biblioteca)\\b",
          "\\b(limpiar|quitar|restablecer)\\s+(alcance|contexto|adjuntos?)\\b",
          "\\b(usar|buscar)\\s+(todos|toda)\\s+(documentos?|biblioteca)\\b"
        ],
        "docStatusesAllowed": [
          "ready",
          "indexed",
          "available",
          "enriching",
          "completed"
        ],
        "docStopWords": [
          "file",
          "document",
          "doc",
          "report",
          "spreadsheet",
          "sheet",
          "arquivo",
          "documento",
          "relatorio",
          "planilha",
          "usando",
          "using",
          "from",
          "about",
          "the",
          "no",
          "el",
          "la",
          "de",
          "del",
          "archivo"
        ]
      },
      "evidenceGate": {
        "factRequiringPatterns": {
          "dates": [
            "\\b(when|quando|em que ano|what year|founded|fundad[oa]|surgiu|criou|started)\\b",
            "\\b(in|em|en)\\s+\\d{4}\\b"
          ],
          "numbers": [
            "\\b(how much|quanto|custo|price|valor|amount|quantidad)\\b",
            "\\b(percentage|percentual|porcentagem|%)\\b"
          ],
          "names": [
            "\\b(who|quem|founder|fundador|owner|dono|ceo|presidente)\\b",
            "\\b(where|onde|location|localiza[çc][ãa]o|endere[çc]o|address)\\b"
          ],
          "specifics": [
            "\\b(exactly|exatamente|specifically|especificamente)\\b",
            "\\b(precise|preciso|exact|exato)\\b"
          ]
        },
        "narrativeRiskPatterns": [
          "\\b(history|historia|story|trajetoria)\\b",
          "\\b(evolution|evolu[çc][ãa]o|growth|crescimento)\\b",
          "\\b(mission|missao|vision|visao|values|valores)\\b",
          "\\b(culture|cultura|philosophy|filosofia)\\b"
        ],
        "evidenceKeywords": {
          "dates": "\\b(19|20)\\d{2}\\b",
          "numbers": "\\b\\d+([.,]\\d+)?(%|R\\$|\\$|€|£)?\\b",
          "names": "\\b[A-Z][a-z]+\\s+[A-Z][a-z]+\\b",
          "quotes": "[\"“”][^\"“”]+[\"“”]",
          "specifics": "\\b(artigo|clausula|secao|slide|pagina|row|column|cell)\\s+\\d+\\b"
        },
        "richContentMinWords": 100,
        "strengthThresholds": {
          "strong": 0.8,
          "moderate": 0.5
        },
        "copy": {
          "clarifyQuestion": {
            "en": "I couldn't find specific details about this in your documents. Can you tell me which file I should check?",
            "pt": "Nao encontrei detalhes especificos sobre isso nos seus documentos. Voce pode me dizer qual arquivo devo verificar?",
            "es": "No encontre detalles especificos sobre esto en tus documentos. Puedes decirme que archivo debo revisar?"
          },
          "hedgePrefixWeak": {
            "en": "Based on the limited information available, ",
            "pt": "Pelos trechos encontrados, ",
            "es": "Con base en la informacion limitada disponible, "
          },
          "hedgePrefixModerateNarrative": {
            "en": "According to the available documents, ",
            "pt": "De acordo com os documentos disponiveis, ",
            "es": "Segun los documentos disponibles, "
          }
        }
      }
    }
  },
  "principles": {
    "_comment": "These are the behavioral guarantees you want for ChatGPT-parity.",
    "neverSilentlySwitchDocs": true,
    "explicitDocRefAlwaysWins": true,
    "hardLockPreventsCrossDocRetrieval": true,
    "followupsPreferActiveDoc": true,
    "neverStoreFormatPreferencesAsState": true,
    "keepStateMinimalExplainable": true
  },
  "stateModel": {
    "_comment": "Fields allowed in durable conversation state (aligned to state_update_rules schema).",
    "allowedFields": [
      "activeDocRef",
      "activeTime",
      "activeMetric",
      "activeDomain",
      "lastDisambiguation"
    ],
    "forbiddenFields": [
      "rawUserTextHistory",
      "systemPrompts",
      "fullRetrievedChunks",
      "jsonFormatPreference",
      "hiddenInternalIds"
    ]
  },
  "ttls": {
    "_comment": "Default TTLs. Actual persistence is executed by state_update_rules + memory_decay_rules.",
    "activeDocRefSoftTurns": 10,
    "activeDocRefHardTurns": 18,
    "activeTimeTurns": 8,
    "activeMetricTurns": 8,
    "activeDomainTurns": 10,
    "lastDisambiguationTurns": 6
  },
  "lockRules": {
    "_comment": "Rules for when a lock can be created/overwritten.",
    "hardLockSources": [
      "explicit_filename",
      "explicit_doc_id",
      "open_action",
      "disambiguation_choice",
      "user_lock_request"
    ],
    "softLockSources": [
      "single_source_inference",
      "followup_reuse"
    ],
    "neverOverwriteHardLockWithoutExplicitSwitch": true,
    "explicitSwitchSignals": [
      "signals.hasExplicitDocRef",
      "signals.userChoseDocThisTurn"
    ],
    "unlockBehavior": {
      "_comment": "How unlock should work if user clearly asks to 'search all files' / 'stop using this file'.",
      "supported": true,
      "unlockTriggers": [
        "signals.userRequestedUnlock",
        "signals.searchAllDocsRequested",
        "operatorIs:locate_docs"
      ],
      "effect": {
        "activeDocRef": "clear_or_downgrade_to_none",
        "activeDomain": "keep",
        "activeMetric": "keep_if_recent"
      },
      "neverAutoUnlockOnFollowup": true
    }
  },
  "followupReuse": {
    "_comment": "ChatGPT-like followup behavior.",
    "preferReuseActiveDocOnFollowup": true,
    "reuseOnlyWhenNoExplicitDocRef": true,
    "refreshTTLOnFollowup": true,
    "followupRequiresContinuitySignals": [
      "signals.isFollowup",
      "overlays.followupIndicatorsMatched"
    ],
    "ifAmbiguousFollowupAndMultipleDocs": {
      "_comment": "If follow-up is generic AND multiple docs are plausible, avoid drift.",
      "behavior": "ask_one_clarification_or_disambiguate",
      "delegateTo": "clarification_phrases"
    }
  },
  "domainMemory": {
    "_comment": "Domain memory is allowed but must never override doc scope.",
    "storeActiveDomain": true,
    "domainIsFormattingHintOnly": true,
    "domainTTLTurns": "@ttls.activeDomainTurns",
    "domainOverrideRules": {
      "explicitDomainQueryWins": true,
      "strongNewDomainCanReplaceOld": {
        "minConfidence": 0.74,
        "onlyIfNoHardDocLockConflict": true
      },
      "doNotOverrideIfDocIsHardLocked": true
    }
  },
  "privacy": {
    "_comment": "State should not store sensitive extracted values by default. Use retrieval each time.",
    "doNotPersistExtractedPIIValues": true,
    "doNotPersistRawNumbersFromDocs": true,
    "persistOnlyStructuralHints": [
      "activeDocRef",
      "activeTime",
      "activeMetric",
      "activeDomain"
    ],
    "debugTracesNotPersisted": true
  },
  "actions": {
    "_comment": "Actions are implemented by state_update_rules/memory_decay_rules and orchestrator.",
    "definitions": [
      {
        "id": "ask_one_clarification_or_disambiguate",
        "type": "route",
        "notes": "Route to clarification_phrases (one crisp question) or rank_disambiguate if candidates are close."
      },
      {
        "id": "clear_or_downgrade_to_none",
        "type": "transform",
        "notes": "Clear activeDocRef or set lockType=none depending on UX design; should be explicit to user via microcopy."
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "MP_0001_explicit_docref_overwrites_hard_lock",
        "input": {
          "state": {
            "activeDocRef": {
              "docId": "doc:old",
              "lockType": "hard"
            }
          },
          "signals": {
            "hasExplicitDocRef": true
          },
          "query": {
            "hints": {
              "docRefs": {
                "filenames": [
                  "NewFile.pdf"
                ]
              }
            }
          }
        },
        "expect": {
          "shouldAllowHardLockOverwrite": true
        }
      },
      {
        "id": "MP_0002_followup_refreshes_ttl_not_switch_docs",
        "input": {
          "signals": {
            "isFollowup": true
          },
          "state": {
            "activeDocRef": {
              "docId": "doc:x",
              "lockType": "hard",
              "ttlTurns": 3
            }
          }
        },
        "expect": {
          "refreshTtl": true,
          "shouldNotSwitchDoc": true
        }
      },
      {
        "id": "MP_0003_unlock_allows_corpus_search",
        "input": {
          "signals": {
            "searchAllDocsRequested": true
          },
          "state": {
            "activeDocRef": {
              "docId": "doc:x",
              "lockType": "hard"
            }
          }
        },
        "expect": {
          "shouldClearActiveDocRef": true
        }
      },
      {
        "id": "MP_0004_followup_keeps_active_doc_unless_explicit_switch",
        "input": {
          "signals": {
            "isFollowup": true,
            "hasExplicitDocRef": false
          },
          "state": {
            "activeDocRef": {
              "docId": "doc:x",
              "lockType": "hard",
              "ttlTurns": 8
            }
          }
        },
        "expect": {
          "shouldNotSwitchDoc": true
        }
      },
      {
        "id": "MP_0005_short_query_global_search_blocked_by_min_chars",
        "input": {
          "signals": {
            "searchAllDocsRequested": true
          },
          "query": {
            "text": "roi"
          },
          "runtimeTuning": {
            "semanticRetrieval": {
              "globalSearchMinQueryChars": 12
            }
          }
        },
        "expect": {
          "allowGlobalScope": false
        }
      },
      {
        "id": "MP_0006_quote_signal_requires_quote_mode_when_evidence_exists",
        "input": {
          "signals": {
            "userAskedForQuote": true
          },
          "retrieval": {
            "evidenceCount": 2
          }
        },
        "expect": {
          "answerMode": "doc_grounded_quote"
        }
      }
    ]
  }
}
