{
  "_meta": {
    "id": "secrets_rotation_policy",
    "version": "1.0.0",
    "description": "Secret/key rotation requirements and expiry safeguards.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "platform-security",
    "reviewCadenceDays": 30,
    "criticality": "high",
    "changeLog": [
      "Initial secrets rotation runtime policy bank"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": false
  },
  "rotation": {
    "defaultMaxAgeDays": 90,
    "criticalKeyMaxAgeDays": 30,
    "warningWindowDays": 7
  },
  "rules": [
    {
      "id": "SRP_1000_expired_critical_key",
      "priority": 1000,
      "when": {
        "all": [
          {
            "path": "signals.keyTier",
            "op": "eq",
            "value": "critical"
          },
          {
            "path": "metrics.keyAgeDays",
            "op": "gt",
            "value": 30
          }
        ]
      },
      "then": {
        "action": "rotate_now",
        "blockSensitiveOperations": true
      },
      "reasonCode": "secrets_rotation_required_critical",
      "terminal": true
    },
    {
      "id": "SRP_900_expired_standard_key",
      "priority": 900,
      "when": {
        "path": "metrics.keyAgeDays",
        "op": "gt",
        "value": 90
      },
      "then": {
        "action": "rotate_now",
        "blockSensitiveOperations": false
      },
      "reasonCode": "secrets_rotation_required",
      "terminal": true
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "SRP_T_001",
        "runtime": {
          "signals": {
            "keyTier": "critical"
          },
          "metrics": {
            "keyAgeDays": 45
          }
        },
        "expect": {
          "action": "rotate_now"
        }
      }
    ]
  }
}
