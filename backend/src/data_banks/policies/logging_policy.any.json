{
  "_meta": {
    "id": "logging_policy",
    "version": "1.0.0",
    "description": "Structured logging governance: sanitization, allowed channels, and raw-console restrictions for runtime paths.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-01",
    "owner": "platform-observability",
    "reviewCadenceDays": 30,
    "criticality": "high",
    "changeLog": [
      "Metadata governance baseline upgrade (2026-03-03)"
    ],
    "usedBy": [
      "services/llm/core/llmRequestBuilder.service.ts"
    ],
    "tests": [
      "tests/certification/prompt-mode-coverage.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "redactKeys": [
      "password",
      "token",
      "authorization",
      "apiKey",
      "secret",
      "ssn",
      "creditCard"
    ],
    "runtimePathsNoRawConsole": [
      "src/modules/chat/runtime/ChatTurnExecutor.ts",
      "src/modules/chat/runtime/ChatRuntimeOrchestrator.ts",
      "src/services/core/retrieval/evidenceGate.service.ts",
      "src/services/llm/core/llmGateway.service.ts"
    ],
    "configModeOnly": true
  },
  "tests": {
    "cases": [
      {
        "id": "LOG_POL_T_001",
        "input": {
          "password": "secret"
        },
        "expect": {
          "redacted": true
        }
      },
      {
        "id": "LOG_POL_T_002",
        "input": {
          "token": "abc"
        },
        "expect": {
          "redacted": true
        }
      },
      {
        "id": "LOG_POL_T_003",
        "input": {
          "authorization": "Bearer xyz"
        },
        "expect": {
          "redacted": true
        }
      },
      {
        "id": "LOG_POL_T_004",
        "input": {
          "nested": {
            "apiKey": "123"
          }
        },
        "expect": {
          "redacted": true
        }
      },
      {
        "id": "LOG_POL_T_005",
        "input": {
          "safe": "ok"
        },
        "expect": {
          "redacted": false
        }
      },
      {
        "id": "LOG_POL_T_006",
        "input": {
          "safe": "ok"
        },
        "expect": {
          "strict": true,
          "failClosedInProd": true
        }
      }
    ]
  }
}
