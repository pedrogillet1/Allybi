{
  "_meta": {
    "id": "logging_policy",
    "version": "1.0.0",
    "description": "Policy contract for logging posture in Koda. Enforces deterministic, environment-aware log sanitization: redact PII and internal identifiers, block debug traces in production logs, cap log payload size, and prevent raw evidence/state dumps from entering logs. Does not define user-facing copy; governs log-channel transformations and allow/block decisions.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-policies",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added env-specific sanitization and debug gating for logs",
      "Added PII and internal-id redaction rules using existing banks",
      "Added deterministic log-size caps and raw dump prevention"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "transform",
    "channels": ["logs"],
    "envDefaults": {
      "production": { "allowDebugLogs": false, "redactPii": true, "redactInternalIds": true, "maxLogBytes": 8000, "allowRawState": false, "allowRawEvidence": false },
      "staging": { "allowDebugLogs": false, "redactPii": true, "redactInternalIds": true, "maxLogBytes": 16000, "allowRawState": false, "allowRawEvidence": false },
      "dev": { "allowDebugLogs": true, "redactPii": true, "redactInternalIds": true, "maxLogBytes": 32000, "allowRawState": "redacted", "allowRawEvidence": "redacted" },
      "local": { "allowDebugLogs": true, "redactPii": false, "redactInternalIds": true, "maxLogBytes": 64000, "allowRawState": "full_safe", "allowRawEvidence": "redacted" }
    },
    "actionsContract": {
      "combination": {
        "multipleMatches": "apply_most_restrictive_then_commit",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_transform"
      },
      "thresholds": {
        "maxLogBytesProd": 8000,
        "maxLogBytesStaging": 16000,
        "maxLogBytesDev": 32000,
        "maxLogBytesLocal": 64000,
        "maxLogFieldsSoft": 64,
        "maxLogFieldsHard": 128
      },
      "conflictResolution": {
        "ifProdAndDebug": "block_or_strip",
        "ifPiiAndAny": "redact_first",
        "ifRawDumpAndAny": "strip_raw_dump",
        "ifOverSize": "truncate_with_marker"
      }
    },
    "logGuards": {
      "blockPatterns": {
        "en": ["\\b(stack trace|stacktrace)\\b"],
        "pt": ["\\b(stack trace|rastreamento de pilha)\\b"],
        "es": ["\\b(stack trace|traza de pila)\\b"]
      },
      "suppressPatterns": {
        "en": ["\\b(confidence score|routing decision|rank weights)\\b"],
        "pt": ["\\b(pontua[cç][aã]o de confian[cç]a|decis[aã]o de roteamento|pesos de rank)\\b"],
        "es": ["\\b(puntuaci[oó]n de confianza|decisi[oó]n de enrutamiento|pesos de ranking)\\b"]
      }
    },
    "sanitization": {
      "alwaysRedactPaths": [
        "session.sessionId",
        "persistent.scope.activeDocId",
        "history.recentTokens",
        "history.recentReasonCodes"
      ],
      "stripRawDumpKeys": [
        "evidence",
        "rawEvidence",
        "docIndex",
        "docIndexDecrypted",
        "fullState",
        "conversationState"
      ],
      "truncatePolicy": {
        "enabled": true,
        "marker": "log_truncated",
        "preserveHeadChars": 6000,
        "preserveTailChars": 1000
      }
    }
  },
  "integrationHooks": {
    "dependsOn": [
      "privacy_minimal_rules",
      "pii_field_labels",
      "banned_phrases",
      "state_debug_policy",
      "conversation_state_schema"
    ],
    "signalsExpected": [
      "sessionEnv",
      "logChannel",
      "containsPii",
      "containsInternalIds",
      "containsDebugTrace",
      "containsRawEvidenceDump",
      "containsRawStateDump",
      "logBytes",
      "logFieldCount"
    ]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "prod_block_debug_trace_in_logs",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "eq", "value": "production" },
            { "path": "signals.containsDebugTrace", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "prod_strip_raw_state_and_evidence_dumps",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "eq", "value": "production" },
            {
              "path": "signals.containsRawEvidenceDump",
              "op": "eq",
              "value": true
            }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "strip_keys", "keysFrom": "config.sanitization.stripRawDumpKeys" },
            { "type": "redact_internal_ids" }
          ],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "redact_pii_in_prod_and_staging_logs",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "in", "value": ["production", "staging"] },
            { "path": "signals.containsPii", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "redact_pii_spans", "mode": "mask_full" },
            { "type": "redact_internal_ids" }
          ],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "redact_internal_ids_all_envs_logs",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.containsInternalIds", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [{ "type": "redact_internal_ids" }],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "suppress_routing_debug_phrases_in_logs",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.containsRoutingDebugPhrases", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [{ "type": "suppress_patterns", "patternsFrom": "config.logGuards.suppressPatterns" }]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "truncate_oversize_logs",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "metrics.logBytes", "op": "gt", "valueFrom": "metrics.maxLogBytesForEnv" }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            {
              "type": "truncate_text",
              "policyFrom": "config.sanitization.truncatePolicy"
            }
          ]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "cap_log_fields",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "metrics.logFieldCount", "op": "gt", "value": 128 }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [{ "type": "cap_fields", "max": 128, "strategy": "keep_whitelist_then_drop_extras" }]
        },
        "reasonCode": "privacy_redaction_required"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "privacy_redaction_required",
        "action": "transform",
        "constraints": {
          "redactInternalIds": true,
          "redactPiiInProdStaging": true,
          "stripRawDumpsInProd": true,
          "truncateOversize": true
        }
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "LOGP_0001_prod_blocks_debug_trace",
        "input": { "text": "stack trace: ..." },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "production", "containsDebugTrace": true } },
        "expect": { "action": "block", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "LOGP_0002_prod_strips_raw_evidence_dump",
        "input": { "text": "{\"evidence\":[{\"docId\":\"a\"}]}" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "production", "containsRawEvidenceDump": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "LOGP_0003_prod_redacts_pii_full",
        "input": { "text": "email test@example.com" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "production", "containsPii": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "LOGP_0004_all_envs_redact_internal_ids",
        "input": { "text": "docId=abc123 chunkId=xyz" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "dev", "containsInternalIds": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "LOGP_0005_truncate_oversize",
        "input": { "text": "X" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "staging" }, "metrics": { "logBytes": 20000, "maxLogBytesForEnv": 16000 } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "LOGP_0006_cap_log_fields",
        "input": { "text": "fields overflow" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "dev" }, "metrics": { "logFieldCount": 200 } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "LOGP_0007_suppress_routing_debug_phrases",
        "input": { "text": "routing decision confidence score rank weights" },
        "runtime": { "signals": { "logChannel": true, "sessionEnv": "dev", "containsRoutingDebugPhrases": true } },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      }
    ]
  }
}
