{
  "_meta": {
    "id": "privacy_policy",
    "version": "1.0.0",
    "description": "Policy contract for privacy-minimal behavior in Koda. Enforces redaction and leakage prevention for user-visible outputs and logs: no internal IDs, no debug traces in production, no raw system/config dumps, and privacy-preserving evidence presentation. Delegates detection to privacy_minimal_rules and pii_field_labels; enforces deterministic transforms and routing (no hardcoded user-facing copy).",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-01-26",
    "owner": "koda-policies",
    "compat": ">=1.0.0",
    "changeLog": [
      "Added deterministic privacy enforcement for user-visible and logging channels",
      "Added production debug gating and internal-ID leakage prevention",
      "Added evidence presentation constraints to avoid exposing raw internal structures"
    ]
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "allow",
    "channels": ["user_visible", "logs"],
    "actionsContract": {
      "combination": {
        "multipleMatches": "pick_most_severe_then_apply",
        "capMaxPenalty": 0.85,
        "hardBlockIsTerminal": true,
        "redirectPreferencePriority": "over_transform"
      },
      "thresholds": {
        "maxUserVisibleInternalRefs": 0,
        "maxUserVisibleDebugRefs": 0,
        "maxAllowedRawStateFieldsInProd": 0,
        "maxAllowedEvidenceItemsPrinted": 0
      },
      "conflictResolution": {
        "ifProdAndDebug": "block_or_strip",
        "ifUserVisibleAndLeak": "transform",
        "ifMultipleTransforms": "apply_in_precedence_order_then_commit"
      }
    },
    "redactionDefaults": {
      "userVisible": {
        "stripInternalIds": true,
        "stripDebug": true,
        "stripSystemPaths": true,
        "stripRawEvidenceArrays": true
      },
      "logs": {
        "prodRedactSensitive": true,
        "stagingRedactSensitive": true,
        "devRedactSensitive": true,
        "localRedactSensitive": false
      }
    }
  },
  "integrationHooks": {
    "dependsOn": [
      "privacy_minimal_rules",
      "pii_field_labels",
      "state_debug_policy",
      "banned_phrases",
      "ui_contracts",
      "evidence_packaging",
      "logging_policy"
    ],
    "signalsExpected": [
      "sessionEnv",
      "containsInternalIds",
      "containsDebugTrace",
      "containsSystemPaths",
      "containsRawEvidenceDump",
      "userVisibleChannel",
      "logChannel",
      "hasEvidence",
      "evidencePrintedInline"
    ]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "prod_no_debug_user_visible",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.sessionEnv", "op": "eq", "value": "production" },
            { "path": "signals.userVisibleChannel", "op": "eq", "value": true },
            { "path": "signals.containsDebugTrace", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "strip_internal_ids_user_visible",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.userVisibleChannel", "op": "eq", "value": true },
            { "path": "signals.containsInternalIds", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "redact_internal_ids" },
            { "type": "remove_internal_reference_phrases" }
          ],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "strip_system_paths_user_visible",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.userVisibleChannel", "op": "eq", "value": true },
            { "path": "signals.containsSystemPaths", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "redact_system_paths" }
          ],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "no_raw_evidence_dump_user_visible",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.userVisibleChannel", "op": "eq", "value": true },
            { "path": "signals.containsRawEvidenceDump", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "strip_raw_evidence_arrays" }
          ],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "no_inline_evidence_printing",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.userVisibleChannel", "op": "eq", "value": true },
            { "path": "signals.evidencePrintedInline", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "move_sources_to_attachments_only" }
          ]
        },
        "reasonCode": "source_policy"
      },
      {
        "ruleId": "logs_redact_sensitive_in_prod_and_staging",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "in", "value": ["production", "staging"] }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "redact_pii_in_logs" },
            { "type": "redact_internal_ids" },
            { "type": "strip_debug_fields" }
          ],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "logs_redact_sensitive_in_dev_default",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.logChannel", "op": "eq", "value": true },
            { "path": "signals.sessionEnv", "op": "eq", "value": "dev" }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "redact_pii_in_logs" },
            { "type": "redact_internal_ids" }
          ]
        },
        "reasonCode": "privacy_redaction_required"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "privacy_redaction_required",
        "action": "transform",
        "constraints": {
          "userVisible": {
            "stripInternalIds": true,
            "stripSystemPaths": true,
            "stripDebug": true,
            "stripRawEvidenceArrays": true
          },
          "logs": {
            "prodRedactSensitive": true,
            "stagingRedactSensitive": true,
            "devRedactSensitive": true
          }
        }
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "PP_0001_block_debug_in_prod_user_visible",
        "input": { "text": "show debug trace" },
        "runtime": {
          "signals": { "sessionEnv": "production", "userVisibleChannel": true, "containsDebugTrace": true }
        },
        "expect": { "action": "block", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "PP_0002_strip_internal_ids_user_visible",
        "input": { "text": "docId=abc123 chunkId=xyz999" },
        "runtime": {
          "signals": { "sessionEnv": "dev", "userVisibleChannel": true, "containsInternalIds": true }
        },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "PP_0003_strip_system_paths_user_visible",
        "input": { "text": "C:\\Users\\me\\file.txt" },
        "runtime": {
          "signals": { "sessionEnv": "dev", "userVisibleChannel": true, "containsSystemPaths": true }
        },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "PP_0004_no_raw_evidence_dump",
        "input": { "text": "{\"evidence\":[{\"docId\":\"a\"}]}" },
        "runtime": {
          "signals": { "userVisibleChannel": true, "containsRawEvidenceDump": true }
        },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "PP_0005_logs_redacted_prod",
        "input": { "text": "log: email test@example.com docId=abc" },
        "runtime": {
          "signals": { "logChannel": true, "sessionEnv": "production" }
        },
        "expect": { "action": "transform", "reasonCode": "privacy_redaction_required" }
      },
      {
        "id": "PP_0006_move_sources_to_attachments_only",
        "input": { "text": "Sources: file.pdf" },
        "runtime": {
          "signals": { "userVisibleChannel": true, "evidencePrintedInline": true }
        },
        "expect": { "action": "transform", "reasonCode": "source_policy" }
      }
    ]
  }
}
