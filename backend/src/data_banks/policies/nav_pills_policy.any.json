{
  "_meta": {
    "id": "nav_pills_policy",
    "version": "1.0.0",
    "description": "ChatGPT-like navigation pill policy for Koda. Defines strict rendering contracts for open/where/discover/disambiguation navigation flows: body is a single intro line, files are shown only via source_buttons pills, and the UI must hide the Sources label/divider. No message actions in nav_pills responses.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "failClosedInProd": true,
    "integrationHooks": {
      "renderPolicyBankId": "render_policy",
      "sourcePolicyBankId": "source_policy",
      "answerModeRouterBankId": "answer_mode_router",
      "clarificationBankId": "clarification_phrases",
      "microcopyNavBankId": "nav_microcopy",
      "qualityGatesBankId": "quality_gates"
    }
  },
  "contracts": {
    "_comment": "Non-negotiable UX rules for nav pills.",
    "answerModes": ["nav_pills", "rank_disambiguate"],
    "body": {
      "maxSentences": 1,
      "maxChars": 90,
      "noBullets": true,
      "noTables": true,
      "noQuotes": true,
      "noInlineFileLists": true,
      "noSourcesLabel": true,
      "noDivider": true
    },
    "attachments": {
      "mustUse": "source_buttons",
      "maxButtons": 5,
      "dedupeByDocId": true,
      "includeDocTypeIfHelpful": true,
      "includeRecencyIfHelpful": false
    },
    "ui": {
      "hideMessageActions": true,
      "alignPillsWithAssistantAvatarCenter": true,
      "pillsAppearAfterIntroLine": true
    }
  },
  "navTypes": {
    "_comment": "Supported nav intents. The microcopy itself lives in nav_microcopy bank; this policy defines behavior + required attachments.",
    "open": { "requiresButtons": true, "allowMultipleButtons": true },
    "where": { "requiresButtons": true, "allowMultipleButtons": true },
    "discover": { "requiresButtons": true, "allowMultipleButtons": true },
    "disambiguate": { "requiresButtons": true, "allowMultipleButtons": true },
    "not_found": { "requiresButtons": false, "allowMultipleButtons": false }
  },
  "rules": [
    {
      "id": "NAV_1000_enforce_pills_only",
      "priority": 1000,
      "when": { "path": "answerMode", "op": "eq", "value": "nav_pills" },
      "then": {
        "action": "enforce_nav_pills_contract",
        "limits": { "maxSentences": "@contracts.body.maxSentences", "maxChars": "@contracts.body.maxChars" },
        "reasonCode": "nav_pills_contract"
      },
      "terminal": false
    },
    {
      "id": "NAV_980_require_source_buttons",
      "priority": 980,
      "when": {
        "all": [
          { "path": "answerMode", "op": "eq", "value": "nav_pills" },
          { "path": "navType", "op": "neq", "value": "not_found" }
        ]
      },
      "then": {
        "action": "require_source_buttons_or_route_not_found",
        "minButtons": 1,
        "reasonCode": "nav_pills_requires_buttons"
      },
      "terminal": false
    },
    {
      "id": "NAV_960_hide_sources_label_divider",
      "priority": 960,
      "when": { "path": "answerMode", "op": "eq", "value": "nav_pills" },
      "then": {
        "action": "set_ui_flags_for_nav_pills",
        "uiFlags": { "hideSourcesLabel": true, "hideDivider": true, "hideMessageActions": true },
        "reasonCode": "nav_pills_ui_flags"
      },
      "terminal": false
    },
    {
      "id": "NAV_940_strip_disallowed_body_content",
      "priority": 940,
      "when": { "path": "answerMode", "op": "eq", "value": "nav_pills" },
      "then": {
        "action": "strip_body_to_intro_sentence",
        "strip": ["tables", "lists", "quotes", "inline_sources", "inline_file_lists"],
        "reasonCode": "nav_body_stripped"
      },
      "terminal": false
    },
    {
      "id": "NAV_900_cap_and_dedupe_buttons",
      "priority": 900,
      "when": { "path": "attachments.source_buttons.present", "op": "eq", "value": true },
      "then": {
        "action": "dedupe_and_cap_nav_buttons",
        "maxButtons": "@contracts.attachments.maxButtons",
        "reasonCode": "cap_dedupe_nav_buttons"
      },
      "terminal": false
    }
  ],
  "actions": {
    "_comment": "Runtime actions. Implement in render_policy + source_policy + frontend UI.",
    "definitions": [
      {
        "id": "enforce_nav_pills_contract",
        "type": "transform",
        "notes": "Ensure body is exactly one intro sentence. No lists/tables/quotes. Files only in source_buttons attachment."
      },
      {
        "id": "require_source_buttons_or_route_not_found",
        "type": "transform_or_route",
        "notes": "If navType expects buttons but none exist, route to nav not_found behavior (short intro, no buttons)."
      },
      {
        "id": "set_ui_flags_for_nav_pills",
        "type": "ui_contract",
        "notes": "Frontend must hide Sources label/divider and message actions, align pills with avatar center, and render pills after intro line."
      },
      {
        "id": "strip_body_to_intro_sentence",
        "type": "transform",
        "notes": "Keep only first sentence; remove any extra blocks, inline file lists, inline sources."
      },
      {
        "id": "dedupe_and_cap_nav_buttons",
        "type": "transform",
        "notes": "Deduplicate by documentId and keep top N. Preserve order by relevance/recency depending on navType."
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "NAV_T_0001_nav_pills_body_one_sentence",
        "input": { "answerMode": "nav_pills", "answerText_sentenceCount": 4 },
        "expect": { "mustApplyAny": ["strip_body_to_intro_sentence"] }
      },
      {
        "id": "NAV_T_0002_nav_pills_needs_buttons",
        "input": { "answerMode": "nav_pills", "navType": "open", "attachments": { "source_buttons": { "count": 0 } } },
        "expect": { "mustApplyAny": ["require_source_buttons_or_route_not_found"] }
      },
      {
        "id": "NAV_T_0003_caps_buttons_to_5",
        "input": { "answerMode": "nav_pills", "attachments": { "source_buttons": { "count": 12 } } },
        "expect": { "mustApplyAny": ["dedupe_and_cap_nav_buttons"] }
      }
    ]
  }
}
