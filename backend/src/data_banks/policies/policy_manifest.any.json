{
  "_meta": {
    "id": "policy_manifest",
    "version": "1.0.0",
    "description": "Registry + load contract for policy banks. Policies are behavioral constraints (NOT microcopy). They are evaluated by orchestrator/quality gates/rendering to enforce ChatGPT-like UX invariants across all domains and answer modes.",
    "languages": ["any"],
    "lastUpdated": "2026-01-26"
  },
  "config": {
    "enabled": true,
    "strictLoad": true,
    "failOnMissingRequired": true,
    "validateAtBoot": true,
    "envOverridesEnabled": true,
    "schemaBankId": "bank_schema",
    "defaultRequiredByEnv": {
      "production": true,
      "staging": true,
      "dev": true,
      "local": true
    }
  },
  "categories": [
    {
      "id": "core",
      "description": "Top-level system invariants (output contract, grounding rules, fallbacks, and anti-hardcoding).",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "safety_privacy",
      "description": "Safety/privacy constraints and redaction rules for logs/debug output.",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "formatting",
      "description": "Formatting invariants that must hold globally (paragraph/bullet/table rules, nav_pills constraints).",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "retrieval_grounding",
      "description": "Hard/soft scope + evidence rules used to prevent wrong-doc answers.",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "domain",
      "description": "Domain consistency policy: domain IDs, domain selection behavior, and domain-driven style preferences.",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true }
    },
    {
      "id": "observability",
      "description": "Logging/debug contracts (no user-visible debug, internal ids handling, trace suppression).",
      "requiredByEnv": { "production": true, "staging": true, "dev": false, "local": false }
    }
  ],
  "policies": [
    {
      "id": "global_system_policies",
      "category": "core",
      "filename": "global_system_policies.any.json",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true },
      "dependsOnBanks": [
        "answer_style_policy",
        "render_policy",
        "quality_gates",
        "doc_grounding_checks",
        "hallucination_guards",
        "domain_ontology",
        "domain_detection",
        "terminology_domains",
        "banned_phrases"
      ],
      "notes": [
        "This is the single place for cross-cutting constraints that must hold regardless of operator or domain.",
        "This bank MUST NOT contain user-facing microcopy."
      ]
    },
    {
      "id": "safety_policy",
      "category": "safety_privacy",
      "filename": "safety_policy.any.json",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true },
      "dependsOnBanks": [
        "unsafe_patterns",
        "banned_phrases",
        "privacy_minimal_rules",
        "refusal_phrases",
        "ui_copy_tokens",
        "routing_overlays",
        "ui_contracts",
        "state_debug_policy"
      ],
      "notes": [
        "Detects unsafe or destabilizing user requests and routes to refusal or safe alternatives.",
        "Handles prompt-injection, self-harm detail, dangerous activity, illicit instructions, explicit content, internal leakage."
      ]
    },
    {
      "id": "doc_access_policy",
      "category": "retrieval_grounding",
      "filename": "doc_access_policy.any.json",
      "requiredByEnv": { "production": true, "staging": true, "dev": true, "local": true },
      "dependsOnBanks": [
        "scope_hints",
        "followup_indicators",
        "doc_aliases",
        "filename_normalization",
        "stopwords_docnames",
        "scope_resolution",
        "candidate_filters",
        "retrieval_negatives",
        "retrieval_overlays",
        "ambiguity_rank_features",
        "disambiguation_policies",
        "disambiguation_render_policy",
        "fallback_scope_empty",
        "fallback_not_found_scope",
        "fallback_processing",
        "ui_contracts",
        "state_update_rules",
        "memory_decay_rules"
      ],
      "notes": [
        "Enforces explicit filename/docId precedence, activeDoc hard-lock behavior, discovery overrides.",
        "Prevents wrong-document answers, scope drift, and cross-doc leakage."
      ]
    }
  ],
  "envOverrides": {
    "production": {
      "config": {
        "strictLoad": true,
        "failOnMissingRequired": true,
        "validateAtBoot": true
      }
    },
    "dev": {
      "config": {
        "strictLoad": true,
        "failOnMissingRequired": true,
        "validateAtBoot": true
      }
    },
    "local": {
      "config": {
        "strictLoad": true,
        "failOnMissingRequired": false,
        "validateAtBoot": false
      }
    }
  },
  "tests": {
    "cases": [
      {
        "id": "PM_0001_unique_policy_ids",
        "assert": "all policies[].id are unique"
      },
      {
        "id": "PM_0002_required_policy_present",
        "assert": "policies contains id == 'global_system_policies'"
      },
      {
        "id": "PM_0003_categories_known",
        "assert": "all policies[].category must exist in categories[].id"
      },
      {
        "id": "PM_0004_no_microcopy_in_policies",
        "assert": "policies banks must not define user-facing templates/messages"
      }
    ]
  }
}
