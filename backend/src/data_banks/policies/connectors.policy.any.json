{
  "_meta": {
    "id": "connectors_policy",
    "version": "1.0.0",
    "description": "Policy contract for connector security and reliability. Enforces token secrecy, provider allowlist, safe sync windows, and source-grounded responses.",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07",
    "owner": "koda-policies",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "allow",
    "providersAllowed": ["gmail", "outlook", "slack"],
    "limits": {
      "defaultBackfillDays": 30,
      "maxItemsPerSyncJob": 2000,
      "maxBackfillDays": 90,
      "maxIncrementalLagDays": 30,
      "maxJobsPerUserPerHour": 12
    },
    "storage": {
      "storeFullBodies": "opt_in_only",
      "storeSnippetsByDefault": true,
      "retentionDays": {
        "metadata": 90,
        "snippets": 90,
        "fullBodies": 30
      }
    },
    "slack": {
      "requireChannelAllowlist": true,
      "defaultAllowlistMode": "deny_by_default"
    },
    "tokenHandling": {
      "requireEncryptedAtRest": true,
      "forbidPlaintextLogging": true,
      "requireRefreshForExpiredToken": true,
      "minRemainingLifetimeSec": 60
    },
    "citation": {
      "requireSourceMetadata": true,
      "requiredFields": ["sourceType", "sourceId", "timestamp"],
      "preferredFields": ["subject", "threadId", "channel", "actor"]
    }
  },
  "integrationHooks": {
    "dependsOn": [
      "connectors_routing",
      "privacy_policy",
      "logging_policy",
      "source_policy"
    ],
    "signalsExpected": [
      "provider",
      "operator",
      "connectorConnected",
      "tokenEncrypted",
      "tokenInLogsDetected",
      "syncRequested",
      "backfillDays",
      "cursorPresent",
      "sourceMetadataPresent",
      "containsPII",
      "slackAllowlistConfigured",
      "requestStoreFullBodies",
      "userOptedInFullBodyStorage",
      "userConfirmedDisconnect"
    ]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "provider_must_be_allowlisted",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.provider", "op": "not_in", "value": ["gmail", "outlook", "slack"] }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["provider_not_allowed"]
        },
        "reasonCode": "unsupported_connector_provider"
      },
      {
        "ruleId": "block_if_token_not_encrypted",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.tokenEncrypted", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["token_storage_violation"]
        },
        "reasonCode": "token_not_encrypted"
      },
      {
        "ruleId": "block_if_token_or_secret_logged",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.tokenInLogsDetected", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["secret_leak_detected"]
        },
        "reasonCode": "secret_logging_blocked"
      },
      {
        "ruleId": "sync_requires_connected_account",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.operator", "op": "eq", "value": "CONNECTOR_SYNC" },
            { "path": "signals.connectorConnected", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "connect_required",
          "emitSignals": ["connector_not_connected"]
        },
        "reasonCode": "connector_not_connected"
      },
      {
        "ruleId": "slack_requires_allowlist",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.provider", "op": "eq", "value": "slack" },
            { "path": "signals.operator", "op": "in", "value": ["CONNECTOR_SYNC", "CONNECTOR_SEARCH"] },
            { "path": "signals.slackAllowlistConfigured", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "slack_allowlist_required",
          "emitSignals": ["slack_allowlist_required"]
        },
        "reasonCode": "slack_allowlist_required"
      },
      {
        "ruleId": "cap_initial_backfill_window",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.syncRequested", "op": "eq", "value": true },
            { "path": "signals.cursorPresent", "op": "neq", "value": true },
            { "path": "signals.backfillDays", "op": "gt", "value": 90 }
          ]
        },
        "then": {
          "action": "transform",
          "set": [
            { "path": "runtime.sync.backfillDays", "value": 90 }
          ],
          "emitSignals": ["backfill_window_capped"]
        },
        "reasonCode": "backfill_window_capped"
      },
      {
        "ruleId": "disconnect_requires_confirmation",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.operator", "op": "eq", "value": "CONNECTOR_DISCONNECT" },
            { "path": "signals.userConfirmedDisconnect", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "disconnect_confirmation_required",
          "emitSignals": ["connector_disconnect_confirmation_required"]
        },
        "reasonCode": "disconnect_confirmation_required"
      },
      {
        "ruleId": "connector_answers_require_source_metadata",
        "severity": "error",
        "when": {
          "all": [
            { "path": "signals.operator", "op": "eq", "value": "CONNECTOR_SEARCH" },
            { "path": "signals.sourceMetadataPresent", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "route",
          "routeTo": "retry_with_source_metadata",
          "emitSignals": ["missing_source_metadata"]
        },
        "reasonCode": "source_metadata_required"
      },
      {
        "ruleId": "block_full_body_storage_without_opt_in",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.requestStoreFullBodies", "op": "eq", "value": true },
            { "path": "signals.userOptedInFullBodyStorage", "op": "neq", "value": true }
          ]
        },
        "then": {
          "action": "block",
          "emitSignals": ["connector_body_storage_opt_in_required"]
        },
        "reasonCode": "body_storage_opt_in_required"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "secret_logging_blocked",
        "action": "block",
        "constraints": {
          "redactSecrets": true,
          "alertSecurityChannel": true,
          "logEvent": "connector_security_violation"
        }
      },
      {
        "matchReasonCode": "connector_not_connected",
        "action": "route",
        "routeTo": "connect_required",
        "constraints": {
          "mustIncludeActionPill": "Connect",
          "includeOAuthStartUrl": true
        }
      },
      {
        "matchReasonCode": "slack_allowlist_required",
        "action": "route",
        "routeTo": "slack_allowlist_required",
        "constraints": {
          "mustIncludeActionPill": "Configure allowlist",
          "denyByDefault": true
        }
      },
      {
        "matchReasonCode": "source_metadata_required",
        "action": "retry_retrieval_then_regen",
        "constraints": {
          "forceCitationFields": ["sourceType", "sourceId", "timestamp"],
          "maxRetries": 1
        }
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "CP_0001_non_allowlisted_provider_blocked",
        "runtime": { "signals": { "provider": "imap" } },
        "expect": { "reasonCode": "unsupported_connector_provider", "action": "block" }
      },
      {
        "id": "CP_0002_sync_without_connection_routes_connect",
        "runtime": { "signals": { "operator": "CONNECTOR_SYNC", "connectorConnected": false } },
        "expect": { "reasonCode": "connector_not_connected", "action": "route" }
      },
      {
        "id": "CP_0003_token_logging_is_blocked",
        "runtime": { "signals": { "tokenInLogsDetected": true } },
        "expect": { "reasonCode": "secret_logging_blocked", "action": "block" }
      },
      {
        "id": "CP_0004_slack_sync_needs_allowlist",
        "runtime": { "signals": { "provider": "slack", "operator": "CONNECTOR_SYNC", "slackAllowlistConfigured": false } },
        "expect": { "reasonCode": "slack_allowlist_required", "action": "route" }
      },
      {
        "id": "CP_0005_full_body_storage_requires_opt_in",
        "runtime": { "signals": { "requestStoreFullBodies": true, "userOptedInFullBodyStorage": false } },
        "expect": { "reasonCode": "body_storage_opt_in_required", "action": "block" }
      }
    ]
  }
}
