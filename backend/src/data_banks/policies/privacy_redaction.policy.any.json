{
  "_meta": {
    "id": "privacy_redaction_policy",
    "version": "1.0.0",
    "description": "Policy contract for pre-LLM and pre-telemetry redaction. Focuses on secrets/tokens/credentials and high-risk identifiers. Complements pii_policy/privacy_policy/logging_policy (which handle user-visible and log channels).",
    "languages": ["any", "en", "pt"],
    "lastUpdated": "2026-02-07",
    "owner": "koda-policies",
    "compat": ">=1.0.0"
  },
  "config": {
    "enabled": true,
    "strict": true,
    "defaultAction": "transform",
    "channels": ["llm_input", "telemetry", "logs"],
    "redaction": {
      "maskToken": "[REDACTED_TOKEN]",
      "maskSecret": "[REDACTED_SECRET]",
      "maskEmail": "[REDACTED_EMAIL]",
      "maskPhone": "[REDACTED_PHONE]",
      "maskId": "[REDACTED_ID]",
      "maxUnredactedSecretOccurrences": 0
    },
    "alwaysRedactJsonPaths": [
      "headers.authorization",
      "headers.cookie",
      "headers.x-api-key",
      "oauth.access_token",
      "oauth.refresh_token",
      "oauth.id_token",
      "connector.token",
      "connector.refreshToken",
      "secrets.*",
      "env.*_KEY",
      "env.*_TOKEN",
      "env.*_SECRET",
      "env.DATABASE_URL"
    ],
    "patternGroups": {
      "secrets": [
        "-----BEGIN (?:RSA|EC|OPENSSH|DSA|PRIVATE) KEY-----",
        "\\b(eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,})\\b",
        "\\b(AIza[0-9A-Za-z\\-_]{35})\\b",
        "\\b(sk-[A-Za-z0-9]{20,})\\b",
        "\\b(xox[baprs]-[A-Za-z0-9-]{10,})\\b",
        "\\b(ghp_[A-Za-z0-9]{20,})\\b",
        "\\b(ASIA[0-9A-Z]{16})\\b",
        "\\b(AKIA[0-9A-Z]{16})\\b"
      ],
      "credentials": [
        "(?i)\\b(password|passcode|senha|secret|api\\s*key|token)\\b\\s*[:=]\\s*[^\\s]{4,}",
        "(?i)\\b(authorization)\\b\\s*[:=]\\s*(bearer|basic)\\s+[^\\s]+"
      ],
      "highRiskIds": [
        "\\b\\d{3}-\\d{2}-\\d{4}\\b",
        "\\b\\d{2}\\.\\d{3}\\.\\d{3}/\\d{4}-\\d{2}\\b",
        "\\b\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}\\b"
      ]
    },
    "connectorHandling": {
      "forbidRawBodiesInTelemetry": true,
      "forbidRawBodiesInLogs": true,
      "maxBodyCharsToSendToLlm": 8000,
      "stripQuotedEmailChainsByDefault": true
    }
  },
  "integrationHooks": {
    "dependsOn": ["pii_policy", "privacy_policy", "logging_policy"],
    "signalsExpected": [
      "channel",
      "containsSecrets",
      "containsCredentials",
      "containsHighRiskIds",
      "jsonPathsPresent",
      "connectorBodyPresent",
      "connectorBodyChars",
      "telemetryEventPresent"
    ],
    "emitsSignals": ["privacy_redaction_required", "secrets_redacted", "connector_body_truncated"]
  },
  "policies": {
    "rules": [
      {
        "ruleId": "redact_known_secret_patterns",
        "severity": "fatal",
        "when": { "any": [{ "path": "signals.containsSecrets", "op": "eq", "value": true }] },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "redact_patterns", "patternGroup": "secrets", "mask": "config.redaction.maskToken" },
            { "type": "redact_paths", "pathsFrom": "config.alwaysRedactJsonPaths", "mask": "config.redaction.maskSecret" }
          ],
          "emitSignals": ["privacy_redaction_required", "secrets_redacted"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "redact_inline_credentials_assignments",
        "severity": "error",
        "when": { "any": [{ "path": "signals.containsCredentials", "op": "eq", "value": true }] },
        "then": {
          "action": "transform",
          "transform": [{ "type": "redact_patterns", "patternGroup": "credentials", "mask": "config.redaction.maskSecret" }],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "redact_high_risk_ids",
        "severity": "error",
        "when": { "any": [{ "path": "signals.containsHighRiskIds", "op": "eq", "value": true }] },
        "then": {
          "action": "transform",
          "transform": [{ "type": "redact_patterns", "patternGroup": "highRiskIds", "mask": "config.redaction.maskId" }],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      },
      {
        "ruleId": "truncate_connector_bodies_for_llm_input",
        "severity": "warning",
        "when": {
          "all": [
            { "path": "signals.channel", "op": "eq", "value": "llm_input" },
            { "path": "signals.connectorBodyPresent", "op": "eq", "value": true },
            { "path": "signals.connectorBodyChars", "op": "gt", "value": 8000 }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [
            { "type": "truncate_fields", "maxChars": 8000, "fields": ["connector.body", "connector.text", "connector.rawBody"] }
          ],
          "emitSignals": ["connector_body_truncated"]
        },
        "reasonCode": "connector_body_truncated"
      },
      {
        "ruleId": "strip_connector_bodies_from_telemetry",
        "severity": "fatal",
        "when": {
          "all": [
            { "path": "signals.channel", "op": "eq", "value": "telemetry" },
            { "path": "signals.connectorBodyPresent", "op": "eq", "value": true }
          ]
        },
        "then": {
          "action": "transform",
          "transform": [{ "type": "strip_keys", "keys": ["connector.body", "connector.rawBody", "connector.html"] }],
          "emitSignals": ["privacy_redaction_required"]
        },
        "reasonCode": "privacy_redaction_required"
      }
    ]
  },
  "enforcement": {
    "onViolation": [
      {
        "matchReasonCode": "privacy_redaction_required",
        "action": "transform",
        "constraints": { "mustRedact": true, "failClosedInProd": true }
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "PRP_0001_jwt_is_redacted",
        "runtime": { "signals": { "containsSecrets": true } },
        "expect": { "reasonCode": "privacy_redaction_required", "action": "transform" }
      },
      {
        "id": "PRP_0002_connector_body_truncated_for_llm",
        "runtime": { "signals": { "channel": "llm_input", "connectorBodyPresent": true, "connectorBodyChars": 12000 } },
        "expect": { "reasonCode": "connector_body_truncated", "action": "transform" }
      },
      {
        "id": "PRP_0003_connector_body_stripped_from_telemetry",
        "runtime": { "signals": { "channel": "telemetry", "connectorBodyPresent": true } },
        "expect": { "reasonCode": "privacy_redaction_required", "action": "transform" }
      }
    ]
  }
}
