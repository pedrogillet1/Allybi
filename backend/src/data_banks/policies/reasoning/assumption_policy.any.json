      "id": "ASSUME_001",
      "whenAllowed": [
        "low_risk_context",
        "missing_timezone"
      ],
      "whenForbidden": [
        "legal_deadline",
        "market_close_sensitive",
        "medical_dosing"
      ],
      "labelFormat": "Assumption/Pressuposto [timezone_default]: {text}",
      "trigger": "assumption_condition_ASSUME_001",
      "check": "context.assumptionSignals?.allowed.includesAny([\"low_risk_context\",\"missing_timezone\"]) == true && (context.assumptionSignals?.forbidden || []).intersects([\"legal_deadline\",\"market_close_sensitive\",\"medical_dosing\"]) == false",
      "failureAction": "ALLOW_WITH_ASSUMPTION_LABEL"
    },
