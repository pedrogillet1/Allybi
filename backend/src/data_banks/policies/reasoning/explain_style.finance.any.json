  "templates": [
    {
      "id": "FIN_EXP_001",
      "audience": "executive",
      "depth": "executive_brief",
      "language": "en",
      "tone": "concise",
      "structure": [
        "answer",
        "top_evidence",
        "top_risks",
        "uncertainty",
        "next_step"
      ],
      "evidenceConstraints": {
        "minCitations": 1,
        "maxClaimsWithoutEvidence": 0,
        "requiredEvidenceTypes": [
          "ledger_extract",
          "signed_report",
          "approved_board_pack"
        ],
        "forbidFabrication": true,
        "requireConfidenceLabel": true
      },
      "uncertaintyStyle": "State confidence explicitly and separate facts from assumptions.",
      "template": "Audience=executive; Depth=executive_brief; Provide evidence-bounded explanation with options, risks, and what changes my mind."
    },
