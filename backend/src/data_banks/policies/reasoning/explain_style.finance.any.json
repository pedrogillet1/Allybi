{
  "_meta": {
    "id": "explain_style_finance",
    "version": "1.0.0",
    "description": "Explanation style policy for finance audiences and depth levels.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "koda-reasoning",
    "reviewCadenceDays": 30,
    "criticality": "medium",
    "changeLog": [
      "Metadata governance baseline upgrade (2026-03-03)"
    ],
    "usedBy": [
      "services/llm/core/llmRequestBuilder.service.ts"
    ],
    "tests": [
      "tests/certification/prompt-mode-coverage.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "finance",
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id"
  },
  "domain": "finance",
  "audienceStyles": [
    {
      "audience": "auditor",
      "tone": "skeptical",
      "defaultDepth": "detailed"
    },
    {
      "audience": "executive",
      "tone": "concise",
      "defaultDepth": "executive_brief"
    },
    {
      "audience": "expert",
      "tone": "precise",
      "defaultDepth": "detailed"
    },
    {
      "audience": "general",
      "tone": "clear",
      "defaultDepth": "summary"
    },
    {
      "audience": "manager",
      "tone": "pragmatic",
      "defaultDepth": "paragraph"
    },
    {
      "audience": "operator",
      "tone": "actionable",
      "defaultDepth": "paragraph"
    }
  ],
  "depthLadder": [
    "executive_brief",
    "summary",
    "paragraph",
    "detailed",
    "decision_memo",
    "audit_trail"
