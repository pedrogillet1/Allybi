{
  "_meta": {
    "id": "explain_style_legal",
    "version": "1.0.0",
    "description": "Explanation style policy for legal audiences and depth levels.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28",
    "owner": "koda-reasoning",
    "reviewCadenceDays": 30,
    "criticality": "medium",
    "changeLog": [
      "Metadata governance baseline upgrade (2026-03-03)"
    ],
    "usedBy": [
      "services/llm/core/llmRequestBuilder.service.ts"
    ],
    "tests": [
      "tests/certification/prompt-mode-coverage.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "legal",
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id",
    "configModeOnly": true
  },
  "domain": "legal",
  "audienceStyles": [
    {
      "audience": "auditor",
      "tone": "skeptical",
      "defaultDepth": "detailed"
    },
    {
      "audience": "executive",
      "tone": "concise",
      "defaultDepth": "executive_brief"
    },
    {
      "audience": "expert",
      "tone": "precise",
      "defaultDepth": "detailed"
    },
    {
      "audience": "general",
      "tone": "clear",
      "defaultDepth": "summary"
    },
    {
      "audience": "manager",
      "tone": "pragmatic",
      "defaultDepth": "paragraph"
    },
    {
      "audience": "operator",
      "tone": "actionable",
      "defaultDepth": "paragraph"
    }
  ],
  "depthLadder": [
    "executive_brief",
    "summary",
    "paragraph",
    "detailed",
    "decision_memo",
    "audit_trail"
  ],
  "templates": [
    {
      "id": "LEG_EXP_001",
      "audience": "executive",
      "depth": "executive_brief",
      "language": "en",
      "tone": "concise",
      "structure": [
        "answer",
        "top_evidence",
        "top_risks",
        "uncertainty",
        "next_step"
      ],
      "evidenceConstraints": {
        "minCitations": 1,
        "maxClaimsWithoutEvidence": 0,
        "requiredEvidenceTypes": [
          "signed_contract",
          "statute_or_clause",
          "approved_amendment"
        ],
        "forbidFabrication": true,
        "requireConfidenceLabel": true
      },
      "uncertaintyStyle": "State confidence explicitly and separate facts from assumptions.",
      "template": "Audience=executive; Depth=executive_brief; Provide evidence-bounded explanation with options, risks, and what changes my mind."
    },
