  "rules": [
    {
      "id": "LEG_EXPL_001_disclosure_first",
      "trigger": "legal explanation missing source disclosure",
      "check": "context.domain=='legal' && output.sourceDisclosure == false",
      "failureAction": "INSERT_DISCLOSURE"
    },
    {
      "id": "LEG_EXPL_002_risk_section_required",
      "trigger": "legal explanation about obligations without risk section",
      "check": "context.domain=='legal' && context.queryCategory == 'obligation' && output.riskSectionPresent == false",
      "failureAction": "INSERT_LEGAL_RISK_SECTION"
    },
    {
      "id": "LEG_EXPL_003_no_diagnostic_conclusion",
      "trigger": "legal explanation gives unsupported clause intent",
      "check": "context.domain=='legal' && output.containsClauseOpinion == true && output.supportingClauseCount == 0",
      "failureAction": "REQUEST_SUPPORTING_SECTION"
    },
    {
      "id": "LEG_EXPL_004_citation_density",
      "trigger": "legal response is long and weakly cited",
      "check": "context.domain=='legal' && output.citationCount < 2 && output.length > 320",
      "failureAction": "INCREASE_CITATION_DENSITY"
    },
    {
      "id": "LEG_EXPL_005_jurisdiction_guard",
      "trigger": "legal recommendation without jurisdiction mention",
      "check": "context.domain=='legal' && context.jurisdictionExpected == true && context.jurisdictionMentioned == false",
      "failureAction": "ASK_FOR_JURISDICTION"
    }
  ],
  "patterns": [
    "\\b(query|document|evidence)\\b"
  ],
  "tests": {
    "cases": [
      {
        "id": "EXPLAIN_STYLE_LEGAL_T_001",
        "input": {
          "language": "en",
          "depth": "summary"
        },
        "expect": {
          "requireConfidenceLabel": true
        }
      },
      {
        "id": "EXPLAIN_STYLE_LEGAL_T_002",
        "input": {
          "language": "en",
          "depth": "paragraph"
        },
        "expect": {
          "forbidFabrication": true
        }
      },
      {
        "id": "EXPLAIN_STYLE_LEGAL_T_003",
