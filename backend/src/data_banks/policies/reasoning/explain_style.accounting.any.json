{
  "_meta": {
    "id": "explain_style_accounting",
    "version": "1.0.0",
    "description": "Explanation style policy for accounting audiences and depth levels.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-02-28"
  },
  "config": {
    "enabled": true,
    "domain": "accounting"
  },
  "domain": "accounting",
  "audienceStyles": [
    {
      "audience": "auditor",
      "tone": "skeptical",
      "defaultDepth": "detailed"
    },
    {
      "audience": "executive",
      "tone": "concise",
      "defaultDepth": "executive_brief"
    },
    {
      "audience": "expert",
      "tone": "precise",
      "defaultDepth": "detailed"
    },
    {
      "audience": "general",
      "tone": "clear",
      "defaultDepth": "summary"
    },
    {
      "audience": "manager",
      "tone": "pragmatic",
      "defaultDepth": "paragraph"
    },
    {
      "audience": "operator",
      "tone": "actionable",
      "defaultDepth": "paragraph"
    }
  ],
  "depthLadder": [
    "executive_brief",
    "summary",
    "paragraph",
    "detailed",
    "decision_memo",
    "audit_trail"
  ],
  "templates": [
    {
      "id": "ACC_EXP_001",
      "audience": "executive",
      "depth": "executive_brief",
      "language": "en",
      "tone": "concise",
      "structure": [
        "answer",
        "top_evidence",
        "top_risks",
        "uncertainty",
        "next_step"
      ],
      "evidenceConstraints": {
        "minCitations": 1,
        "maxClaimsWithoutEvidence": 0,
        "requiredEvidenceTypes": [
          "trial_balance",
          "general_ledger_extract",
          "approved_workpaper"
        ],
        "forbidFabrication": true,
        "requireConfidenceLabel": true
      },
      "uncertaintyStyle": "State confidence explicitly and separate facts from assumptions.",
      "template": "Audience=executive; Depth=executive_brief; Provide accounting-governed explanation with controls, reconciliation notes, risks, and what changes my mind."
    },
