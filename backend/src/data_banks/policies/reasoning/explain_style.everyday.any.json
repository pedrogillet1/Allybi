{
  "_meta": {
    "id": "explain_style_everyday",
    "version": "1.0.0",
    "description": "Explanation style policy for everyday document queries.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-03-03",
    "owner": "koda-reasoning",
    "reviewCadenceDays": 30,
    "criticality": "medium",
    "changeLog": [
      "Added everyday explain style and machine-actionable checks"
    ],
    "usedBy": [
      "services/llm/core/llmRequestBuilder.service.ts"
    ],
    "tests": [
      "tests/certification/prompt-mode-coverage.cert.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "domain": "everyday",
    "deterministic": true,
    "dedupe": true,
    "sortBy": "id",
    "configModeOnly": true
  },
  "domain": "everyday",
  "rules": [
    {
      "id": "EVERYDAY_EXPL_001_plain_language_first",
      "trigger": "Everyday response contains technical terms with consumer-facing query",
      "check": "context.domain == 'everyday' AND context.userProfile == 'consumer' AND output.containsTechnicalTerms == true",
      "failureAction": "REWRITE_FOR_CONSUMER",
      "severity": "medium"
    },
    {
      "id": "EVERYDAY_EXPL_002_unit_visibility",
      "trigger": "Everyday numeric response omits units present in source",
      "check": "context.domain == 'everyday' AND source.unitsPresent == true AND output.unitsPresent == false",
      "failureAction": "REJECT_MISSING_UNITS",
      "severity": "error"
    },
    {
      "id": "EVERYDAY_EXPL_003_clarify_when_partial_scope",
      "trigger": "Everyday answer uses partial document scope",
      "check": "context.domain == 'everyday' AND context.scopePartial == true",
      "failureAction": "ADD_SCOPE_NOTE",
      "severity": "warning"
    },
    {
      "id": "EVERYDAY_EXPL_004_compare_disclosure",
      "trigger": "Everyday compare output merges two docs without explicit disclosure",
      "check": "context.domain == 'everyday' AND context.intent == 'compare' AND output.crossDocDisclosure == false",
      "failureAction": "REQUIRE_DISCLOSURE",
      "severity": "error"
    },
    {
      "id": "EVERYDAY_EXPL_005_no_medical_legal_overreach",
      "trigger": "Everyday query triggers legal/medical inference",
      "check": "context.domain == 'everyday' AND context.overlapDomain IN ['legal', 'medical']",
      "failureAction": "RESTRICT_TO_PROVIDED_DOCUMENT_TEXT",
      "severity": "high"
    }
  ],
  "audienceStyles": [
    {
      "audience": "consumer",
      "tone": "clear",
      "defaultDepth": "summary"
    },
    {
      "audience": "manager",
      "tone": "practical",
      "defaultDepth": "paragraph"
    },
    {
      "audience": "auditor",
      "tone": "skeptical",
      "defaultDepth": "detailed"
    }
  ],
  "depthLadder": [
    "summary",
    "paragraph",
    "detailed",
    "decision_memo"
  ],
  "templates": [
    {
      "id": "EVERYDAY_EXPL_T01",
      "audience": "consumer",
      "depth": "summary",
      "language": "en",
      "tone": "clear",
      "evidenceConstraints": {
        "requireConfidenceLabel": true
      },
      "structure": [
        "answer",
        "top_evidence",
        "uncertainty",
        "next_step"
      ],
      "template": "Here is what the document says: {answer}."
    },
    {
      "id": "EVERYDAY_EXPL_T02",
      "audience": "manager",
      "depth": "paragraph",
      "language": "en",
      "tone": "practical",
      "evidenceConstraints": {
        "forbidFabrication": true
      },
      "structure": [
        "answer",
        "risks",
        "uncertainty",
        "evidence"
      ],
      "template": "Based on the provided documents: {answer}."
    },
    {
      "id": "EVERYDAY_EXPL_T03",
      "audience": "consumer",
      "depth": "summary",
      "language": "pt",
      "tone": "clear",
      "evidenceConstraints": {
        "requireConfidenceLabel": true
      },
      "structure": [
        "answer",
        "top_evidence",
        "uncertainty",
        "next_step"
      ],
      "template": "Aqui esta o que o documento diz: {answer}."
    },
    {
      "id": "EVERYDAY_EXPL_T04",
      "audience": "auditor",
      "depth": "detailed",
      "language": "pt",
      "tone": "skeptical",
      "evidenceConstraints": {
        "minCitations": 3,
        "forbidFabrication": true
      },
      "structure": [
        "answer",
        "evidence",
        "uncertainty",
        "next_step"
      ],
      "template": "Com base apenas nos documentos fornecidos: {answer}."
    }
  ],
  "patterns": [
    "\\b(query|document|evidence)\\b"
  ],
  "tests": {
    "cases": [
      {
        "id": "EXPLAIN_STYLE_EVERYDAY_T_001",
        "input": {
          "language": "en",
          "depth": "summary"
        },
        "expect": {
          "requireConfidenceLabel": true
        }
      },
      {
        "id": "EXPLAIN_STYLE_EVERYDAY_T_002",
        "input": {
          "language": "en",
          "depth": "paragraph"
        },
        "expect": {
          "forbidFabrication": true
        }
      },
      {
        "id": "EXPLAIN_STYLE_EVERYDAY_T_003",
        "input": {
          "language": "pt",
          "depth": "summary"
        },
        "expect": {
          "depth": "summary"
        }
      },
      {
        "id": "EXPLAIN_STYLE_EVERYDAY_T_004",
        "input": {
          "language": "pt",
          "depth": "detailed"
        },
        "expect": {
          "minCitations": 3
        }
      }
    ]
  }
}
