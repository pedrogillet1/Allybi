{
  "_meta": {
    "id": "provider_capabilities",
    "version": "1.0.0",
    "description": "Provider capability matrix for Allybi routing, tool-calling, streaming, and safety behavior. Bank-driven, deterministic, no user-facing copy.",
    "languages": [
      "any"
    ],
    "lastUpdated": "2026-01-27",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "actionsContract": {
      "purpose": "Routing + feature gating based on provider/model capabilities",
      "inputs": [
        "provider",
        "model",
        "mode"
      ],
      "outputs": [
        "capabilities",
        "limits",
        "featureFlags"
      ],
      "determinism": "Pure lookup; no runtime heuristics"
    }
  },
  "defaults": {
    "draft": {
      "provider": "gemini",
      "model": "gemini-2.5-flash"
    },
    "final": {
      "provider": "openai",
      "model": "gpt-5.2"
    }
  },
  "providers": {
    "gemini": {
      "displayName": "Google Gemini",
      "capabilities": {
        "text": true,
        "vision": false,
        "streaming": true,
        "toolCalling": true,
        "jsonMode": false,
        "seededDeterminism": false,
        "logProbs": false
      },
      "limits": {
        "maxOutputTokensDefault": 1024,
        "maxToolsPerTurnDefault": 8,
        "streaming": {
          "supportsDeltaText": true,
          "supportsStructuredMarkers": false,
          "framing": "newline_json"
        }
      },
      "models": {
        "gemini-2.5-flash": {
          "tier": "flash",
          "pinnedVersion": "gemini-2.5-flash-001",
          "supportsStreaming": true,
          "supportsTools": true,
          "maxOutputTokens": 8192,
          "maxInputTokens": 1048576,
          "capabilities": {
            "lowLatency": true,
            "bestFor": [
              "intent_routing",
              "scope_resolution",
              "doc_discovery",
              "light_summaries",
              "first_pass_answers_strong_evidence",
              "retrieval_planning",
              "multi_step_decomposition"
            ]
          }
        }
      }
    },
    "openai": {
      "displayName": "OpenAI",
      "capabilities": {
        "text": true,
        "vision": false,
        "streaming": true,
        "toolCalling": true,
        "jsonMode": true,
        "seededDeterminism": true,
        "logProbs": true
      },
      "limits": {
        "maxOutputTokensDefault": 2048,
        "maxToolsPerTurnDefault": 12,
        "streaming": {
          "supportsDeltaText": true,
          "supportsStructuredMarkers": true,
          "framing": "sse"
        }
      },
      "models": {
        "gpt-5.2": {
          "tier": "authority",
          "pinnedVersion": "gpt-5.2-2026-01-15",
          "supportsStreaming": true,
          "supportsTools": true,
          "maxOutputTokens": 16384,
          "maxInputTokens": 128000,
          "capabilities": {
            "bestFor": [
              "final_compose_high_stakes",
              "numeric_integrity",
              "quote_correctness",
              "ambiguity_resolution_one_question",
              "retry_then_regen_when_shaky",
              "quality_gates_strict"
            ]
          }
        }
      }
    }
  },
  "featureFlags": {
    "preferGeminiFlashForFastStages": true,
    "preferOpenAIForHighStakesCompose": true,
    "enableStreamingEverywhere": true,
    "markerHoldRecommended": true
  },
  "tests": [
    {
      "name": "google_flash_has_streaming_and_toolcalling",
      "input": {
        "provider": "gemini",
        "model": "gemini-2.5-flash",
        "mode": "answer"
      },
      "expect": {
        "capabilities": {
          "streaming": true,
          "toolCalling": true
        },
        "providers.gemini.models.gemini-2.5-flash.tier": "flash"
      }
    },
    {
      "name": "openai_gpt52_is_authority",
      "input": {
        "provider": "openai",
        "model": "gpt-5.2",
        "mode": "answer"
      },
      "expect": {
        "providers.openai.models.gpt-5.2.tier": "authority",
        "capabilities": {
          "jsonMode": true,
          "toolCalling": true
        }
      }
    }
  ]
}
