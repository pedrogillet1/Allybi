{
  "_meta": {
    "id": "provider_capabilities",
    "version": "2.0.0",
    "description": "Canonical provider capability index with explicit routing intent, role eligibility, and policy overrides.",
    "owner": "assistant-orchestrator",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts",
      "services/llm/core/llmRouter.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts",
      "tests/llm/providerCapabilitiesBaseline.proof.test.ts"
    ],
    "languages": [
      "en"
    ],
    "lastUpdated": "2026-03-13"
  },
  "config": {
    "enabled": true,
    "sourceOfTruth": "provider_capabilities_expanded.any.json"
  },
  "defaults": {
    "draft": {
      "provider": "gemini",
      "model": "gemini-2.5-flash",
      "role": "planner"
    },
    "final": {
      "provider": "openai",
      "model": "gpt-5.2",
      "role": "synthesizer"
    }
  },
  "capabilitiesByTaskFamily": {
    "document_grounding": {
      "preferred": [
        {
          "provider": "openai",
          "model": "gpt-5.2",
          "role": "evidence_specialist"
        },
        {
          "provider": "gemini",
          "model": "gemini-2.5-flash",
          "role": "researcher"
        }
      ],
      "allowed": [
        "openai:gpt-5-mini",
        "openai:gpt-5.2",
        "gemini:gemini-2.5-flash",
        "local:local-default"
      ],
      "banOnFailure": [
        "openai:gpt-5.2"
      ]
    },
    "comparison_synthesis": {
      "preferred": [
        {
          "provider": "gemini",
          "model": "gemini-2.5-flash",
          "role": "researcher"
        },
        {
          "provider": "openai",
          "model": "gpt-5-mini",
          "role": "researcher"
        }
      ],
      "allowed": [
        "gemini:gemini-2.5-flash",
        "openai:gpt-5-mini",
        "openai:gpt-5.2"
      ]
    },
    "numeric_audit": {
      "preferred": [
        {
          "provider": "openai",
          "model": "gpt-5.2",
          "role": "numeric_specialist"
        }
      ],
      "allowed": [
        "openai:gpt-5.2",
        "openai:gpt-5-mini",
        "gemini:gemini-2.5-flash"
      ],
      "minimum": {
        "role": "numeric_specialist"
      }
    },
    "operational_workflow": {
      "preferred": [
        {
          "provider": "gemini",
          "model": "gemini-2.5-flash",
          "role": "planner"
        },
        {
          "provider": "openai",
          "model": "gpt-5-mini",
          "role": "planner"
        }
      ],
      "allowed": [
        "gemini:gemini-2.5-flash",
        "openai:gpt-5-mini",
        "openai:gpt-5.2"
      ]
    },
    "clarification_repair": {
      "preferred": [
        {
          "provider": "gemini",
          "model": "gemini-2.5-flash",
          "role": "planner"
        },
        {
          "provider": "openai",
          "model": "gpt-5-mini",
          "role": "planner"
        }
      ],
      "allowed": [
        "gemini:gemini-2.5-flash",
        "openai:gpt-5-mini",
        "local:local-default"
      ]
    }
  },
  "qualityOverrides": {
    "mustUseRole": [
      {
        "taskFamily": "numeric_audit",
        "role": "numeric_specialist"
      },
      {
        "taskFamily": "document_grounding",
        "riskLevel": "high",
        "role": "evidence_specialist"
      }
    ],
    "mustEnableShadowFor": [
      "decision_memo",
      "quote_pack"
    ]
  },
  "featureFlags": {
    "preferFastRouteForUrgent": true,
    "preferAuthorityForFinal": true,
    "requireToolAwareRouting": true
  }
}
