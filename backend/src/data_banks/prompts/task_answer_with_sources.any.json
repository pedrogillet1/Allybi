{
  "_meta": {
    "id": "task_answer_with_sources",
    "version": "1.4.0",
    "description": "Task-level answer formatting with structured sources contract.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-02",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true
  },
  "templates": [
    {
      "id": "answer_with_sources",
      "priority": 200,
      "when": {
        "answerModes": [
          "doc_grounded_single",
          "doc_grounded_multi"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": {
            "any": "Answer task contract: produce a complete, user-facing answer to the specific question. Keep structure tight, avoid generic overviews, start directly with the answer, and use concise inline anchors when the answer references a specific fact."
          }
        }
      ]
    },
    {
      "id": "answer_with_quote_sources",
      "priority": 220,
      "when": {
        "answerModes": [
          "doc_grounded_quote"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": {
            "any": "Answer task contract: produce a focused, user-facing answer. Start directly with the answer. When the user requests a quote, include exact quote text from the provided snippets."
          }
        }
      ]
    },
    {
      "id": "answer_with_table_sources",
      "priority": 210,
      "when": {
        "answerModes": [
          "doc_grounded_table"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": {
            "any": "Answer task contract: produce user-facing markdown with a compact GFM table for the requested slice. Start directly with the table or answer. Keep column counts consistent, include a separator row, and avoid empty cells. Add a source/page column when feasible."
          }
        }
      ]
    },
    {
      "id": "answer_help_steps_scoped",
      "priority": 205,
      "when": {
        "answerModes": [
          "help_steps"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": {
            "any": "Answer task contract: provide short actionable steps about the currently scoped document context. Start directly with the steps. Use this scoped product-help snippet when relevant: {{productHelpSnippet}}."
          }
        }
      ]
    },
    {
      "id": "answer_nav_pills",
      "priority": 160,
      "when": {
        "answerModes": [
          "nav_pills"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": {
            "any": "Answer task contract: return exactly one short intro sentence for navigation mode. Do not list filenames, message actions, or execution claims in the body."
          }
        }
      ]
    },
    {
      "id": "answer_without_sources",
      "priority": 100,
      "when": {
        "answerModes": [
          "general_answer",
          "action_receipt",
          "action_confirmation",
          "nav_pills",
          "rank_disambiguate",
          "rank_autopick"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": {
            "any": "Answer task contract: produce user-facing markdown only and start directly with the answer."
          }
        }
      ]
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "TAWS_1001_no_inline_sources_block",
        "input": {
          "answerMode": "doc_grounded_single"
        },
        "expect": {
          "forbidInlineSourcesSection": true,
          "requiresAttachmentBasedCitations": true
        }
      },
      {
        "id": "TAWS_1002_mode_mapping_doc_grounded_quote",
        "input": {
          "answerMode": "doc_grounded_quote"
        },
        "expect": {
          "selectedTemplateId": "answer_with_quote_sources",
          "requiresExactQuoteWhenRequested": true
        }
      },
      {
        "id": "TAWS_1003_mode_mapping_doc_grounded_table",
        "input": {
          "answerMode": "doc_grounded_table"
        },
        "expect": {
          "selectedTemplateId": "answer_with_table_sources",
          "requiresCompactTable": true
        }
      },
      {
        "id": "TAWS_1004_help_steps_uses_product_help_snippet",
        "input": {
          "answerMode": "help_steps",
          "productHelpSnippet": "Use the draft card to review recipient and subject."
        },
        "expect": {
          "selectedTemplateId": "answer_help_steps_scoped",
          "mustReferenceProductHelpSnippetSafely": true
        }
      },
      {
        "id": "TAWS_1005_general_mode_concise_no_sources",
        "input": {
          "answerMode": "general_answer"
        },
        "expect": {
          "selectedTemplateId": "answer_without_sources",
          "mustBeConcise": true,
          "forbidInlineSourcesSection": true
        }
      },
      {
        "id": "TAWS_TEST_001_no_inline_sources_section",
        "input": "Summarize the contract terms",
        "expect": {
          "promptApplied": true,
          "noInlineSourcesSection": true,
          "noSourcesHeader": true
        }
      },
      {
        "id": "TAWS_TEST_002_answer_mode_mapping",
        "input": "What is the total revenue? (mode: doc_grounded_single)",
        "expect": {
          "promptApplied": true,
          "respectsAnswerMode": true,
          "validModes": [
            "doc_grounded_single",
            "doc_grounded_multi",
            "doc_grounded_quote",
            "doc_grounded_table",
            "general"
          ]
        }
      },
      {
        "id": "TAWS_TEST_003_help_steps_uses_snippet_safely",
        "input": "How do I upload a document? (mode: help_steps)",
        "expect": {
          "promptApplied": true,
          "usesProductHelpSnippetSafely": true,
          "noRawSnippetDump": true
        }
      },
      {
        "id": "TAWS_TEST_004_concise_output_contract",
        "input": "What are the key findings?",
        "expect": {
          "promptApplied": true,
          "conciseOutput": true,
          "noFillerPhrases": true,
          "maxParagraphs": 4
        }
      },
      {
        "id": "TAWS_TEST_005_citation_via_attachments_only",
        "input": "Quote the relevant clause",
        "expect": {
          "promptApplied": true,
          "citationsDelegatedToAttachments": true,
          "noInlineBracketRefs": true,
          "noFootnotes": true
        }
      }
    ]
  }
}
