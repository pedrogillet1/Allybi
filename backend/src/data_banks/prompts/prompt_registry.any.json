{
  "_meta": {
    "id": "prompt_registry",
    "version": "2.3.0",
    "description": "Canonical runtime prompt registry. Defines layered prompt composition and deterministic task selection.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-02",
    "owner": "data-bank-governance",
    "usedBy": [
      "services/core/banks/dataBankLoader.service.ts"
    ],
    "tests": [
      "tests/patternWiringProof.test.ts"
    ]
  },
  "config": {
    "enabled": true,
    "strictLoad": true,
    "failOnMissingRequired": true,
    "enforceUniqueIds": true,
    "enforceUniquePaths": true,
    "envOverridesEnabled": true,
    "defaultLanguage": "en",
    "selection": {
      "method": "layered_priority",
      "maxCandidates": 8
    }
  },
  "promptFiles": [
    {
      "id": "system_base",
      "path": "prompts/system_base.any.json",
      "required": true,
      "purpose": "Global, always-on system constraints.",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "mode_chat",
      "path": "prompts/mode_chat.any.json",
      "required": true,
      "purpose": "Chat mode behavior.",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "mode_editing",
      "path": "prompts/mode_editing.any.json",
      "required": true,
      "purpose": "Editing mode behavior.",
      "appliesTo": {
        "operators": [
          "rewrite",
          "translate",
          "format",
          "plan_edit"
        ]
      }
    },
    {
      "id": "llm_global_guards",
      "path": "prompts/llm_global_guards.any.json",
      "required": true,
      "concerns": ["global_bans"],
      "purpose": "Universal output bans applied only through declared registry layers.",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "rag_policy",
      "path": "prompts/rag_policy.any.json",
      "required": true,
      "concerns": ["grounding"],
      "purpose": "RAG grounding and injection resistance.",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "policy_citations",
      "path": "prompts/policy_citations.any.json",
      "required": true,
      "concerns": ["citation_contract"],
      "purpose": "Attachment-based citation contract (no inline Sources block).",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "compose_style_contract",
      "path": "prompts/compose_style_contract.any.json",
      "required": true,
      "concerns": [
        "voice_selection",
        "answer_strategy",
        "anti_robotic_repair",
        "uncertainty_wording"
      ],
      "purpose": "Live composition style contract derived from runtime style decisions.",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "task_answer_with_sources",
      "path": "prompts/task_answer_with_sources.any.json",
      "required": true,
      "concerns": ["answer_shape"],
      "purpose": "Final user-answer composition contract.",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "task_plan_generation",
      "path": "prompts/task_plan_generation.any.json",
      "required": true,
      "purpose": "Schema-bound planner generation contract.",
      "appliesTo": {
        "operators": [
          "plan_edit",
          "plan_multi_intent",
          "plan_docx",
          "plan_xlsx"
        ]
      }
    },
    {
      "id": "editing_task_prompts",
      "path": "prompts/editing_task_prompts.any.json",
      "required": true,
      "concerns": ["tool_contract"],
      "purpose": "Task-specific editing prompts migrated from legacy runtime strings.",
      "appliesTo": {
        "operators": [
          "docx_bullet_enhance",
          "docx_line_rewrite",
          "docx_list_to_paragraph",
          "docx_section_to_paragraph",
          "docx_translate_batch",
          "docx_translate_retry",
          "docx_translate_single",
          "paragraph_to_bullets",
          "rewrite_paragraph",
          "rewrite_span",
          "insert_paragraph_below_list",
          "email_qa",
          "email_explain",
          "provisional_indexing_answer",
          "nav_reasoning_summary",
          "conversation_title"
        ]
      }
    },
    {
      "id": "retrieval_prompt",
      "path": "prompts/retrieval_prompt.any.json",
      "required": true,
      "concerns": ["retrieval_planner"],
      "purpose": "Retrieval planning contract.",
      "appliesTo": {
        "operators": [
          "locate_docs",
          "locate_content",
          "extract",
          "summarize",
          "compare",
          "compute",
          "quote"
        ]
      }
    },
    {
      "id": "disambiguation_prompt",
      "path": "prompts/disambiguation_prompt.any.json",
      "required": true,
      "concerns": ["clarification_render"],
      "purpose": "Single-question disambiguation prompt.",
      "appliesTo": {
        "operators": [
          "locate_docs",
          "open",
          "locate_file",
          "extract",
          "summarize",
          "compare",
          "compute",
          "quote"
        ]
      }
    },
    {
      "id": "fallback_prompt",
      "path": "prompts/fallback_prompt.any.json",
      "required": true,
      "concerns": ["fallback_render"],
      "purpose": "Adaptive fallback message template.",
      "appliesTo": {
        "allOperators": true,
        "allDomains": true
      }
    },
    {
      "id": "tool_prompts",
      "path": "prompts/tool_prompts.any.json",
      "required": false,
      "concerns": ["tool_contract"],
      "purpose": "Tool-specific helper prompts.",
      "appliesTo": {
        "operators": [
          "extract",
          "compute",
          "locate_content"
        ]
      }
    }
  ],
  "requiredConcernsByKind": {
    "compose_answer": [
      "global_bans",
      "grounding",
      "answer_shape",
      "citation_contract",
      "voice_selection",
      "answer_strategy",
      "anti_robotic_repair",
      "uncertainty_wording"
    ],
    "retrieval": [
      "global_bans",
      "grounding",
      "retrieval_planner"
    ],
    "disambiguation": [
      "global_bans",
      "clarification_render"
    ],
    "fallback": [
      "global_bans",
      "fallback_render"
    ],
    "tool": [
      "global_bans",
      "tool_contract"
    ]
  },
  "forbiddenConcernOverlaps": [
    { "left": "grounding", "right": "answer_shape" },
    { "left": "grounding", "right": "global_bans" },
    { "left": "answer_shape", "right": "citation_contract" },
    { "left": "clarification_render", "right": "fallback_render" }
  ],
  "layersByKind": {
    "system": [
      "system_base"
    ],
    "compose_answer": [
      "system_base",
      "mode_chat",
      "llm_global_guards",
      "rag_policy",
      "compose_style_contract",
      "task_answer_with_sources",
      "policy_citations"
    ],
    "retrieval": [
      "system_base",
      "mode_chat",
      "llm_global_guards",
      "rag_policy",
      "retrieval_prompt"
    ],
    "disambiguation": [
      "system_base",
      "mode_chat",
      "llm_global_guards",
      "disambiguation_prompt"
    ],
    "fallback": [
      "system_base",
      "mode_chat",
      "llm_global_guards",
      "fallback_prompt"
    ],
    "tool": [
      "system_base",
      "mode_editing",
      "llm_global_guards",
      "editing_task_prompts",
      "task_plan_generation",
      "policy_citations",
      "tool_prompts"
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "PR_1001_registry_has_no_unreachable_rules",
        "assert": "layersByKind references only existing prompt files"
      },
      {
        "id": "PR_1002_layered_compose_order",
        "input": {
          "operator": "extract",
          "answerMode": "doc_grounded_single"
        },
        "expect": {
          "layerOrder": [
            "system_base",
            "mode_chat",
            "rag_policy",
            "task_answer_with_sources",
            "policy_citations"
          ]
        }
      },
      {
        "id": "PR_1003_layered_retrieval_order",
        "input": {
          "operator": "locate_docs",
          "signals": {
            "discoveryQuery": true
          }
        },
        "expect": {
          "layerOrder": [
            "system_base",
            "mode_chat",
            "rag_policy",
            "retrieval_prompt"
          ]
        }
      }
    ]
  }
}
