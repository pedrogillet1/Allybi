{
  "_meta": {
    "id": "prompt_registry",
    "version": "2.1.0",
    "description": "Canonical runtime prompt registry. Defines layered prompt composition and deterministic task selection.",
    "languages": ["any", "en", "pt", "es"],
    "lastUpdated": "2026-02-19"
  },
  "config": {
    "enabled": true,
    "strictLoad": true,
    "failOnMissingRequired": true,
    "enforceUniqueIds": true,
    "enforceUniquePaths": true,
    "envOverridesEnabled": true,
    "defaultLanguage": "en",
    "selection": {
      "method": "layered_priority",
      "maxCandidates": 8
    }
  },
  "promptFiles": [
    {
      "id": "system_base",
      "path": "prompts/system_base.any.json",
      "required": true,
      "purpose": "Global, always-on system constraints.",
      "appliesTo": { "allOperators": true, "allDomains": true }
    },
    {
      "id": "mode_chat",
      "path": "prompts/mode_chat.any.json",
      "required": true,
      "purpose": "Chat mode behavior.",
      "appliesTo": { "allOperators": true, "allDomains": true }
    },
    {
      "id": "mode_editing",
      "path": "prompts/mode_editing.any.json",
      "required": true,
      "purpose": "Editing mode behavior.",
      "appliesTo": { "operators": ["rewrite", "translate", "format", "plan_edit"] }
    },
    {
      "id": "rag_policy",
      "path": "prompts/rag_policy.any.json",
      "required": true,
      "purpose": "RAG grounding and injection resistance.",
      "appliesTo": { "allOperators": true, "allDomains": true }
    },
    {
      "id": "policy_citations",
      "path": "prompts/policy_citations.any.json",
      "required": true,
      "purpose": "Single citation contract.",
      "appliesTo": { "allOperators": true, "allDomains": true }
    },
    {
      "id": "task_answer_with_sources",
      "path": "prompts/task_answer_with_sources.any.json",
      "required": true,
      "purpose": "Final user-answer composition contract.",
      "appliesTo": { "allOperators": true, "allDomains": true }
    },
    {
      "id": "task_plan_generation",
      "path": "prompts/task_plan_generation.any.json",
      "required": true,
      "purpose": "Schema-bound planner generation contract.",
      "appliesTo": { "operators": ["plan_edit", "plan_multi_intent", "plan_docx", "plan_xlsx"] }
    },
    {
      "id": "editing_task_prompts",
      "path": "prompts/editing_task_prompts.any.json",
      "required": true,
      "purpose": "Task-specific editing prompts migrated from legacy runtime strings.",
      "appliesTo": { "operators": ["docx_bullet_enhance", "docx_line_rewrite", "docx_list_to_paragraph", "docx_section_to_paragraph", "docx_translate_batch", "docx_translate_retry", "docx_translate_single", "paragraph_to_bullets", "rewrite_paragraph", "rewrite_span", "insert_paragraph_below_list", "email_qa", "email_explain", "provisional_indexing_answer", "nav_reasoning_summary", "conversation_title"] }
    },
    {
      "id": "retrieval_prompt",
      "path": "prompts/retrieval_prompt.any.json",
      "required": true,
      "purpose": "Retrieval planning contract.",
      "appliesTo": { "operators": ["locate_docs", "locate_content", "extract", "summarize", "compare", "compute", "quote"] }
    },
    {
      "id": "disambiguation_prompt",
      "path": "prompts/disambiguation_prompt.any.json",
      "required": true,
      "purpose": "Single-question disambiguation prompt.",
      "appliesTo": { "operators": ["locate_docs", "open", "locate_file", "extract", "summarize", "compare", "compute", "quote"] }
    },
    {
      "id": "fallback_prompt",
      "path": "prompts/fallback_prompt.any.json",
      "required": true,
      "purpose": "Adaptive fallback message template.",
      "appliesTo": { "allOperators": true, "allDomains": true }
    },
    {
      "id": "tool_prompts",
      "path": "prompts/tool_prompts.any.json",
      "required": false,
      "purpose": "Tool-specific helper prompts.",
      "appliesTo": { "operators": ["extract", "compute", "locate_content"] }
    }
  ],
  "layersByKind": {
    "system": ["system_base"],
    "compose_answer": ["system_base", "mode_chat", "rag_policy", "task_answer_with_sources", "policy_citations"],
    "retrieval": ["system_base", "mode_chat", "rag_policy", "retrieval_prompt"],
    "disambiguation": ["system_base", "mode_chat", "disambiguation_prompt"],
    "fallback": ["system_base", "mode_chat", "fallback_prompt", "policy_citations"],
    "tool": ["system_base", "mode_editing", "editing_task_prompts", "task_plan_generation", "policy_citations", "tool_prompts"]
  },
  "selectionRules": {
    "_comment": "Deterministic ordering. No unconditional catch-all before specialized rules.",
    "rulesOrder": [
      "use_disambiguation_prompt",
      "use_retrieval_prompt_for_discovery",
      "use_fallback_prompt",
      "use_compose_answer_prompt_default"
    ],
    "rules": [
      {
        "id": "use_disambiguation_prompt",
        "when": {
          "any": [
            { "path": "answerMode", "op": "eq", "value": "rank_disambiguate" },
            { "path": "signals.needsClarification", "op": "eq", "value": true }
          ]
        },
        "then": { "promptId": "disambiguation_prompt" }
      },
      {
        "id": "use_retrieval_prompt_for_discovery",
        "when": {
          "any": [
            { "path": "operator", "op": "eq", "value": "locate_docs" },
            { "path": "signals.discoveryQuery", "op": "eq", "value": true }
          ]
        },
        "then": { "promptId": "retrieval_prompt" }
      },
      {
        "id": "use_fallback_prompt",
        "when": {
          "any": [
            { "path": "answerMode", "op": "eq", "value": "no_docs" },
            { "path": "answerMode", "op": "eq", "value": "scoped_not_found" },
            { "path": "signals.forceFallback", "op": "eq", "value": true },
            { "path": "retrieval.reasonCode", "op": "in", "value": ["scope_hard_constraints_empty", "no_relevant_chunks_in_scoped_docs", "indexing_in_progress", "extraction_failed"] }
          ]
        },
        "then": { "promptId": "fallback_prompt" }
      },
      {
        "id": "use_compose_answer_prompt_default",
        "when": { "any": true },
        "then": { "promptId": "task_answer_with_sources" }
      }
    ]
  },
  "tests": {
    "cases": [
      {
        "id": "PR_1001_registry_has_no_unreachable_rules",
        "assert": "no selectionRules.rules entry appears after an unconditional any:true rule"
      },
      {
        "id": "PR_1002_layered_compose_order",
        "input": { "operator": "extract", "answerMode": "doc_grounded_single" },
        "expect": { "layerOrder": ["system_base", "mode_chat", "rag_policy", "task_answer_with_sources", "policy_citations"] }
      },
      {
        "id": "PR_1003_layered_retrieval_order",
        "input": { "operator": "locate_docs", "signals": { "discoveryQuery": true } },
        "expect": { "layerOrder": ["system_base", "mode_chat", "rag_policy", "retrieval_prompt"] }
      }
    ]
  }
}
