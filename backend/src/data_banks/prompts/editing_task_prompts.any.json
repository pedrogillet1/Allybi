{
  "_meta": {
    "id": "editing_task_prompts",
    "version": "1.1.0",
    "description": "Task-specific prompts for editing, helper generation, and utility model calls.",
    "languages": [
      "any",
      "en",
      "pt",
      "es"
    ],
    "lastUpdated": "2026-03-02"
  },
  "config": {
    "enabled": true
  },
  "templates": [
    {
      "id": "conversation_title",
      "priority": 300,
      "when": {
        "operators": [
          "conversation_title"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Generate a short chat title from `firstMessage`. Output only the title text. Constraints: 3-7 words, Title Case, no quotes/markdown/prefixes, no personal data, and no file extensions."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "email_qa",
      "priority": 300,
      "when": {
        "operators": [
          "email_qa"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Answer only from `emailContext`. Be precise and concise. If detail is missing, state it explicitly. Do not invent facts."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "email_explain",
      "priority": 300,
      "when": {
        "operators": [
          "email_explain"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Explain the provided email context clearly. Output format: 1-2 sentence summary, then bullets for key points/action items/deadlines, and a short suggested reply when helpful. Do not invent details."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "provisional_indexing_answer",
      "priority": 300,
      "when": {
        "operators": [
          "provisional_indexing_answer"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Answer only using `documentExtracts`. If information is missing, explicitly state what is missing. Never invent facts. Follow `language`."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "nav_reasoning_summary",
      "priority": 300,
      "when": {
        "operators": [
          "nav_reasoning_summary"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Use `folderTreeContext` to answer `question` in one short paragraph (2-3 sentences). No lists, no markdown lists, no raw file paths, no backticks, and no bold wrappers."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "docx_bullet_enhance",
      "priority": 200,
      "when": {
        "operators": [
          "docx_bullet_enhance"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Improve bullet clarity while preserving meaning and entities (names, numbers, dates, terms). Return JSON only: [{\"paragraphId\":\"...\",\"text\":\"...\"}] with one output per input bullet."
        }
      ],
      "outputMode": "machine_json"
    },
    {
      "id": "docx_line_rewrite",
      "priority": 200,
      "when": {
        "operators": [
          "docx_line_rewrite"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Rewrite each line independently using `instruction`. Keep one output per input paragraphId, preserve ordering and meaning, and return JSON only: [{\"paragraphId\":\"...\",\"text\":\"...\"}]."
        }
      ],
      "outputMode": "machine_json"
    },
    {
      "id": "docx_list_to_paragraph",
      "priority": 200,
      "when": {
        "operators": [
          "docx_list_to_paragraph"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Convert bullets into one cohesive paragraph. Respect `wantsSummary`. Preserve facts and entities. Do not mention instructions/tasks/headings. Return JSON only: {\"paragraph\":\"...\"}."
        }
      ],
      "outputMode": "machine_json"
    },
    {
      "id": "docx_section_to_paragraph",
      "priority": 200,
      "when": {
        "operators": [
          "docx_section_to_paragraph"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Rewrite section lines into one cohesive paragraph while preserving facts and entities. Do not mention editing mechanics. Return JSON only: {\"paragraph\":\"...\"}."
        }
      ],
      "outputMode": "machine_json"
    },
    {
      "id": "docx_translate_batch",
      "priority": 220,
      "when": {
        "operators": [
          "docx_translate_batch"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Translate each paragraph into `targetLanguage`. Preserve names, numbers, dates, acronyms, and meaning. Return JSON only: [{\"paragraphId\":\"...\",\"text\":\"...\"}]."
        }
      ],
      "outputMode": "machine_json"
    },
    {
      "id": "docx_translate_retry",
      "priority": 220,
      "when": {
        "operators": [
          "docx_translate_retry"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Retry translation with strict alignment. Return one item per input paragraph, keep paragraphId unchanged, and return JSON only: [{\"paragraphId\":\"...\",\"text\":\"...\"}]."
        }
      ],
      "outputMode": "machine_json"
    },
    {
      "id": "docx_translate_single",
      "priority": 220,
      "when": {
        "operators": [
          "docx_translate_single"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Translate `paragraph` into `targetLanguage`. Preserve entities and punctuation style. Output only translated text, with no JSON, quotes, or markdown."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "paragraph_to_bullets",
      "priority": 200,
      "when": {
        "operators": [
          "paragraph_to_bullets"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Convert `paragraph` into concise bullet lines. Each bullet should capture one key point. Output only lines prefixed with '• '."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "rewrite_paragraph",
      "priority": 200,
      "when": {
        "operators": [
          "rewrite_paragraph"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Rewrite `originalText` following `instruction`. Preserve facts and tone. Output only rewritten text, no markdown or commentary."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "rewrite_span",
      "priority": 200,
      "when": {
        "operators": [
          "rewrite_span"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Rewrite only `selectedText` using `instruction` and context from `paragraphText`. Never echo instruction text. If `strict` is true, apply tighter anti-echo behavior. Output only replacement text."
        }
      ],
      "outputMode": "user_text"
    },
    {
      "id": "insert_paragraph_below_list",
      "priority": 200,
      "when": {
        "operators": [
          "insert_paragraph_below_list"
        ]
      },
      "messages": [
        {
          "role": "system",
          "content": "Write one paragraph to insert below a bullet list using `instruction`, `section`, and `bullets`. Preserve names/numbers and do not add facts. Output only the paragraph."
        }
      ],
      "outputMode": "user_text"
    }
  ],
  "tests": {
    "cases": [
      {
        "id": "ETP_1001_conversation_title_constraints",
        "input": {
          "templateId": "conversation_title",
          "firstMessage": "summarize quarterly budget review and action items"
        },
        "expect": {
          "outputShape": "plain_text",
          "minWords": 3,
          "maxWords": 7,
          "titleCase": true,
          "forbidTokens": [
            "\"",
            "`",
            ".pdf",
            ".docx"
          ]
        }
      },
      {
        "id": "ETP_1002_rewrite_span_no_instruction_echo",
        "input": {
          "templateId": "rewrite_span",
          "instruction": "make this more formal",
          "selectedText": "send me the file asap"
        },
        "expect": {
          "outputShape": "plain_text",
          "mustNotContain": [
            "make this more formal"
          ]
        }
      },
      {
        "id": "ETP_1003_translate_batch_preserves_ids",
        "input": {
          "templateId": "docx_translate_batch",
          "targetLanguage": "pt",
          "paragraphs": [
            {
              "paragraphId": "p1",
              "text": "Hello team."
            },
            {
              "paragraphId": "p2",
              "text": "Meeting is tomorrow."
            }
          ]
        },
        "expect": {
          "outputShape": "json_array",
          "preserveParagraphIds": [
            "p1",
            "p2"
          ],
          "sameItemCountAsInput": true
        }
      },
      {
        "id": "ETP_1004_list_to_paragraph_json_contract",
        "input": {
          "templateId": "docx_list_to_paragraph",
          "bullets": [
            "Point A",
            "Point B"
          ]
        },
        "expect": {
          "outputShape": "json_object",
          "requiredKeys": [
            "paragraph"
          ],
          "forbidAdditionalWrapperText": true
        }
      },
      {
        "id": "ETP_1005_email_explain_structure",
        "input": {
          "templateId": "email_explain",
          "emailContext": "Need approval by Friday. Owner: Ana."
        },
        "expect": {
          "summarySentenceCount": {
            "min": 1,
            "max": 2
          },
          "requiresKeyPointsSection": true,
          "allowsSuggestedReply": true
        }
      },
      {
        "id": "ETP_TEST_001_conversation_title_constraints",
        "input": "Generate a conversation title for: user asked to bold the first paragraph",
        "expect": {
          "promptApplied": true,
          "maxLength": 60,
          "noSpecialChars": true,
          "formatIsPlainString": true
        }
      },
      {
        "id": "ETP_TEST_002_rewrite_span_no_instruction_echo",
        "input": "Rewrite this sentence to be more formal: 'Hey, check this out'",
        "expect": {
          "promptApplied": true,
          "noInstructionEcho": true,
          "outputIsRewrittenTextOnly": true
        }
      },
      {
        "id": "ETP_TEST_003_docx_translate_batch_preserves_ids",
        "input": "Translate paragraphs [{\"paragraphId\":\"p1\",\"text\":\"Hello\"},{\"paragraphId\":\"p2\",\"text\":\"World\"}] to Portuguese",
        "expect": {
          "promptApplied": true,
          "preservesParagraphIdMapping": true,
          "outputArrayLengthMatchesInput": true
        }
      },
      {
        "id": "ETP_TEST_004_docx_list_to_paragraph_json_only",
        "input": "Convert bullet list to paragraph",
        "expect": {
          "promptApplied": true,
          "outputIsJsonParagraphObject": true,
          "noMarkdownWrapper": true
        }
      },
      {
        "id": "ETP_TEST_005_email_explain_structure",
        "input": "Explain this email thread",
        "expect": {
          "promptApplied": true,
          "hasShortSummary": true,
          "hasKeyPoints": true,
          "hasOptionalReply": true
        }
      }
    ]
  }
}
