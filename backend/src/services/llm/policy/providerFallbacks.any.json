    {
      "primary": "openai",
      "fallbacks": ["gemini", "local"],
      "conditions": {
        "onError": true,
        "onTimeout": true,
        "onRateLimit": true
      }
    },
    {
      "primary": "local",
      "fallbacks": ["gemini", "openai"],
      "conditions": {
        "onError": true,
        "onTimeout": false,
        "onRateLimit": false
      }
    }
  ]
}
