{
  "_meta": {
    "id": "providerFallbacks",
    "version": "2.0.0",
    "description": "Fallback chains for LLM provider failures (when/try schema)",
    "lastUpdated": "2026-03-03"
  },
  "config": { "enabled": true },
  "fallbacks": [
    {
      "when": { "provider": "gemini" },
      "try": [
        { "provider": "openai", "model": "gpt-5-mini" },
        { "provider": "openai", "model": "gpt-5.2" },
        { "provider": "local", "model": "local-default" }
      ]
    },
    {
      "when": { "provider": "openai" },
      "try": [
        { "provider": "gemini", "model": "gemini-2.5-flash" },
        { "provider": "local", "model": "local-default" }
      ]
    },
    {
      "when": { "provider": "local" },
      "try": [
        { "provider": "gemini", "model": "gemini-2.5-flash" },
        { "provider": "openai", "model": "gpt-5-mini" }
      ]
    }
  ]
}
