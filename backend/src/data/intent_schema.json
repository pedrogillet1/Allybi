{
  "_meta": {
    "version": "1.0.0",
    "type": "intent_structural_definitions",
    "description": "Structural definitions for intent classification - NO keywords or patterns here",
    "do_not_add_keywords": true,
    "do_not_add_patterns": true,
    "related_files": {
      "keywords_patterns": "intent_patterns.json",
      "domain_layers": "domain_layers.json",
      "routing_priority": "routing_priority.json"
    }
  },

  "DOCUMENTS": {
    "description": "Document-level operations: navigation, structure, TOC, search within docs",
    "tier": 0,
    "states": ["idle", "scanning", "navigating", "searching", "indexing", "error"],
    "actions": ["find_section", "list_pages", "show_toc", "jump_to", "search_doc", "summarize_structure"],
    "scope": ["single_doc", "multi_doc", "collection", "page_range"],
    "depth": {
      "D1": "Surface scan - TOC, headings only",
      "D2": "Section-level navigation and summary",
      "D3": "Full document traversal with cross-references"
    },
    "evidence_controls": {
      "citation_required": true,
      "page_numbers": true,
      "section_refs": true
    },
    "output_controls": {
      "formats": ["list", "hierarchy", "flat"],
      "max_depth": 5,
      "include_metadata": true
    },
    "memory_elements": ["last_position", "search_history", "visited_sections"],
    "failure_modes": ["doc_not_found", "section_missing", "toc_unavailable", "search_timeout"]
  },

  "EXTRACTION": {
    "description": "Data extraction: pull specific values, fields, tables from documents",
    "tier": 0,
    "states": ["idle", "extracting", "parsing", "validating", "formatting", "error"],
    "actions": ["extract_field", "extract_table", "extract_list", "extract_value", "extract_all", "validate_extraction"],
    "scope": ["field", "table", "section", "page", "full_doc"],
    "depth": {
      "D1": "Single field extraction",
      "D2": "Related field group extraction",
      "D3": "Complex nested structure extraction",
      "D4": "Cross-document field correlation"
    },
    "evidence_controls": {
      "source_citation": true,
      "confidence_score": true,
      "extraction_method": true
    },
    "output_controls": {
      "formats": ["json", "table", "csv", "key_value"],
      "type_coercion": true,
      "null_handling": "explicit"
    },
    "memory_elements": ["extraction_schema", "field_mappings", "validation_rules"],
    "failure_modes": ["field_not_found", "ambiguous_match", "type_mismatch", "validation_failed"]
  },

  "REASONING": {
    "description": "Analysis, comparison, inference, decision support over document content",
    "tier": 0,
    "states": ["idle", "analyzing", "comparing", "inferring", "synthesizing", "concluding", "error"],
    "actions": ["analyze", "compare", "infer", "synthesize", "evaluate", "recommend", "explain_why"],
    "scope": ["clause", "section", "document", "multi_doc", "corpus"],
    "depth": {
      "D1": "Surface-level observation",
      "D2": "Single-hop inference",
      "D3": "Multi-hop reasoning chain",
      "D4": "Cross-document synthesis",
      "D5": "Expert-level analysis with caveats"
    },
    "evidence_controls": {
      "reasoning_chain": true,
      "confidence_levels": true,
      "uncertainty_disclosure": true,
      "counter_arguments": true
    },
    "output_controls": {
      "formats": ["narrative", "structured", "bullet_points", "decision_tree"],
      "show_work": true,
      "caveat_required": true
    },
    "memory_elements": ["analysis_context", "prior_conclusions", "reasoning_history"],
    "failure_modes": ["insufficient_evidence", "contradictory_data", "scope_exceeded", "confidence_too_low"]
  },

  "EDIT": {
    "description": "Document modification: draft, revise, redline, suggest changes",
    "tier": 1,
    "states": ["idle", "drafting", "revising", "reviewing", "applying", "error"],
    "actions": ["draft", "revise", "suggest", "redline", "rewrite", "format", "apply_changes"],
    "scope": ["word", "sentence", "paragraph", "section", "document"],
    "depth": {
      "D1": "Surface edits - typos, formatting",
      "D2": "Structural edits - reordering, clarification",
      "D3": "Substantive edits - content changes",
      "D4": "Complete rewrite with rationale"
    },
    "evidence_controls": {
      "track_changes": true,
      "edit_rationale": true,
      "original_preserved": true
    },
    "output_controls": {
      "formats": ["inline", "redline", "side_by_side", "suggestion_mode"],
      "preserve_formatting": true,
      "change_summary": true
    },
    "memory_elements": ["edit_history", "style_preferences", "revision_context"],
    "failure_modes": ["edit_conflict", "format_corruption", "scope_ambiguity", "permission_denied"]
  },

  "HELP": {
    "description": "Product help, onboarding, feature explanation, how-to guidance",
    "tier": 1,
    "states": ["idle", "explaining", "guiding", "troubleshooting", "error"],
    "actions": ["explain_feature", "show_how_to", "troubleshoot", "suggest_workflow", "list_capabilities"],
    "scope": ["feature", "workflow", "concept", "error_resolution"],
    "depth": {
      "D1": "Quick answer - one-liner",
      "D2": "Step-by-step guidance",
      "D3": "Detailed explanation with examples"
    },
    "evidence_controls": {
      "source_docs": false,
      "version_specific": true,
      "up_to_date": true
    },
    "output_controls": {
      "formats": ["steps", "narrative", "bullet_points"],
      "include_examples": true,
      "link_to_docs": true
    },
    "memory_elements": ["user_skill_level", "prior_questions", "feature_usage"],
    "failure_modes": ["feature_not_found", "outdated_info", "ambiguous_request"]
  },

  "CONVERSATION": {
    "description": "General chat, greetings, small talk, non-document queries",
    "tier": 1,
    "states": ["idle", "chatting", "clarifying", "error"],
    "actions": ["greet", "respond", "clarify", "redirect", "acknowledge"],
    "scope": ["utterance", "turn", "session"],
    "depth": {
      "D1": "Quick acknowledgment",
      "D2": "Conversational response"
    },
    "evidence_controls": {
      "citation_required": false,
      "factual_claims": false
    },
    "output_controls": {
      "formats": ["natural", "concise"],
      "personality": "professional_friendly",
      "max_length": "short"
    },
    "memory_elements": ["conversation_history", "user_name", "session_context"],
    "failure_modes": ["off_topic", "inappropriate", "redirect_needed"]
  },

  "MEMORY": {
    "description": "Context recall, session history, prior interactions",
    "tier": 2,
    "states": ["idle", "recalling", "storing", "clearing", "error"],
    "actions": ["recall", "remember", "forget", "list_history", "clear_context"],
    "scope": ["turn", "session", "document_session", "long_term"],
    "depth": {
      "D1": "Recent turn recall",
      "D2": "Session-wide recall",
      "D3": "Cross-session recall"
    },
    "evidence_controls": {
      "timestamp": true,
      "source_turn": true
    },
    "output_controls": {
      "formats": ["summary", "verbatim", "reference"],
      "include_context": true
    },
    "memory_elements": ["conversation_log", "key_decisions", "user_preferences"],
    "failure_modes": ["memory_not_found", "context_expired", "ambiguous_reference"]
  },

  "PREFERENCES": {
    "description": "User settings, personalization, configuration",
    "tier": 2,
    "states": ["idle", "reading", "updating", "resetting", "error"],
    "actions": ["get_preference", "set_preference", "reset_preference", "list_preferences"],
    "scope": ["setting", "category", "all"],
    "depth": {
      "D1": "Single setting read/write",
      "D2": "Category management"
    },
    "evidence_controls": {
      "change_log": true,
      "default_values": true
    },
    "output_controls": {
      "formats": ["confirmation", "list", "diff"],
      "show_defaults": true
    },
    "memory_elements": ["user_settings", "defaults", "change_history"],
    "failure_modes": ["invalid_value", "setting_not_found", "permission_denied"]
  },

  "FILE_ACTIONS": {
    "description": "File operations: upload, download, convert, rename, delete, spreadsheet operations",
    "tier": 2,
    "states": ["idle", "uploading", "downloading", "converting", "processing", "calculating", "error"],
    "actions": ["upload", "download", "convert", "rename", "delete", "copy", "move", "list_files", "excel_operation"],
    "scope": ["file", "folder", "batch", "spreadsheet", "worksheet"],
    "depth": {
      "D1": "Single file operation",
      "D2": "Batch operation",
      "D3": "Complex spreadsheet operation"
    },
    "evidence_controls": {
      "operation_log": true,
      "file_metadata": true,
      "cell_references": true
    },
    "output_controls": {
      "formats": ["status", "list", "confirmation", "table", "formula"],
      "include_path": true,
      "include_cell_refs": true
    },
    "memory_elements": ["recent_files", "operation_history", "active_spreadsheet"],
    "failure_modes": ["file_not_found", "permission_denied", "format_unsupported", "size_exceeded", "formula_error", "invalid_range"],

    "sub_intents": {
      "calculation": {
        "description": "All numerical operations: Excel/spreadsheet ops + financial/statistical math. Python Math Engine handles everything.",
        "triggers": [
          "calculate", "compute", "sum", "average", "total",
          "roi", "irr", "npv", "cagr", "margin", "growth rate", "variance", "depreciation", "percentile", "rollforward", "break-even",
          "column", "row", "cell", "sheet", "pivot", "formula", "filter", "vlookup", "spreadsheet", "excel"
        ],
        "actions": [
          "calculate_roi", "calculate_cagr", "calculate_npv", "calculate_irr", "calculate_margin", "calculate_break_even", "calculate_compound_interest",
          "calculate_rollforward", "calculate_variance", "verify_debits_credits", "calculate_depreciation",
          "calculate_descriptive_stats", "calculate_percentile", "calculate_quartiles", "detect_outliers",
          "aggregate_by_group", "calculate_running_total", "calculate_period_over_period",
          "convert_units", "check_tolerance", "calculate_rate",
          "calculate_date_difference", "calculate_rolling_average", "calculate_growth_rates", "calculate_days_until",
          "sum_column", "filter_rows", "pivot_table", "apply_formula", "extract_range", "group_by", "sort"
        ],
        "requires_rag": false,
        "output_mode": "result_first",
        "precision_rules": {
          "llm_never_computes": true,
          "python_does_math": true,
          "deterministic": true,
          "show_formula": true,
          "show_inputs": true,
          "show_columns": true,
          "show_row_count": true,
          "explain_result": true,
          "no_assumptions_without_warning": true
        },
        "categories": {
          "financial": ["roi", "irr", "npv", "cagr", "margin", "break-even", "compound interest"],
          "accounting": ["rollforward", "variance", "depreciation", "debits/credits", "reconciliation"],
          "statistical": ["average", "mean", "median", "percentile", "quartile", "outliers", "std dev"],
          "aggregation": ["sum", "count", "group by", "running total", "period over period"],
          "engineering": ["convert units", "tolerance", "rate"],
          "time": ["date difference", "rolling average", "growth rates", "days until"],
          "spreadsheet": ["column ops", "row ops", "cell refs", "pivot", "filter", "vlookup", "formula"]
        },
        "patterns": [
          "calculate roi", "what is the roi", "return on investment",
          "calculate cagr", "compound annual growth",
          "calculate npv", "net present value",
          "calculate irr", "internal rate of return",
          "profit margin", "gross margin", "break-even point",
          "calculate variance", "budget vs actual",
          "calculate depreciation", "rollforward",
          "what is the average", "calculate percentile", "detect outliers",
          "growth rate", "period over period",
          "convert units", "days until", "rolling average",
          "sum column", "pivot table", "filter rows",
          "excel formula", "spreadsheet column", "sheet cell",
          "apply filter", "group by column", "calculate total",
          "average of", "sort by", "vlookup", "cell range"
        ]
      }
    }
  },

  "ERROR": {
    "description": "Error handling, recovery, diagnostics",
    "tier": 2,
    "states": ["detecting", "diagnosing", "recovering", "reporting", "escalating"],
    "actions": ["diagnose", "recover", "report", "retry", "escalate", "log"],
    "scope": ["operation", "session", "system"],
    "depth": {
      "D1": "Simple error message",
      "D2": "Error with recovery suggestion",
      "D3": "Detailed diagnostic report"
    },
    "evidence_controls": {
      "error_code": true,
      "stack_trace": false,
      "user_friendly": true
    },
    "output_controls": {
      "formats": ["message", "diagnostic", "recovery_steps"],
      "technical_level": "user_appropriate"
    },
    "memory_elements": ["error_history", "recovery_attempts"],
    "failure_modes": ["unrecoverable", "escalation_required", "unknown_error"]
  }
}
