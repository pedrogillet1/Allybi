{
  "_meta": {
    "type": "output_format_definitions",
    "description": "Defines how answers are allowed to look",
    "version": "1.0",
    "related_files": {
      "depth_schema": "depth_schema.json",
      "domain_schema": "domain_schema.json"
    }
  },

  "allowed_sections": {
    "answer": {
      "required": true,
      "position": "first",
      "description": "Direct answer to the query"
    },
    "evidence": {
      "required_for": ["D2", "D3", "D4", "D5"],
      "position": "after_answer",
      "description": "Supporting citations and quotes"
    },
    "context": {
      "required_for": ["D3", "D4", "D5"],
      "position": "after_evidence",
      "description": "Additional relevant context"
    },
    "caveats": {
      "required_for": ["D4", "D5"],
      "position": "after_context",
      "description": "Limitations, uncertainties, alternative interpretations"
    },
    "disclaimer": {
      "required_for_domains": ["LEGAL", "MEDICAL", "FINANCE"],
      "position": "end",
      "description": "Domain-specific safety disclaimer"
    }
  },

  "format_rules": {
    "tables_vs_prose": {
      "use_table_when": ["multiple_comparable_items", "structured_data", "key_value_pairs"],
      "use_prose_when": ["explanation", "reasoning", "single_item", "narrative_context"],
      "max_table_columns": 6,
      "max_table_rows": 20
    },

    "quote_first_rules": {
      "required_for_domains": ["LEGAL", "MEDICAL"],
      "required_for_intents": ["EXTRACTION"],
      "format": "blockquote_with_citation",
      "max_quote_length": 500
    },

    "list_formatting": {
      "use_bullets_when": ["unordered_items", "options", "features"],
      "use_numbers_when": ["steps", "ranked_items", "sequential_process"],
      "max_items": 15,
      "nest_max_levels": 2
    }
  },

  "truncation_rules": {
    "soft_limit": {
      "D1": 150,
      "D2": 500,
      "D3": 1500,
      "D4": 3000,
      "D5": null
    },
    "hard_limit": 10000,
    "truncation_indicator": "... [truncated - request 'continue' for more]",
    "preserve_complete_sections": true
  },

  "safety_rules": {
    "no_fabrication": {
      "description": "Never invent content not in source documents",
      "action": "cite_or_decline"
    },
    "uncertainty_disclosure": {
      "description": "Explicitly state when uncertain",
      "phrases": ["I found...", "The document states...", "I could not find..."]
    },
    "source_attribution": {
      "required_for": ["EXTRACTION", "REASONING"],
      "format": "(Section X.Y, Page N)"
    }
  },

  "formatting_constraints": {
    "code_blocks": {
      "use_for": ["formulas", "code", "structured_data"],
      "language_hint": true
    },
    "emphasis": {
      "bold": ["key_terms", "warnings", "important_values"],
      "italic": ["document_titles", "defined_terms"],
      "avoid_overuse": true
    },
    "headers": {
      "use_when": "output_exceeds_500_chars",
      "max_level": 3
    }
  },

  "domain_specific_formats": {
    "LEGAL": {
      "citation_format": "Section X.Y (Page N)",
      "quote_style": "exact_with_brackets_for_edits",
      "defined_terms": "capitalize_and_quote"
    },
    "MEDICAL": {
      "values_format": "value [unit] (reference_range)",
      "date_format": "YYYY-MM-DD",
      "medication_format": "drug (dose, route, frequency)"
    },
    "FINANCE": {
      "currency_format": "$X,XXX.XX",
      "percentage_format": "X.XX%",
      "period_format": "explicit (e.g., 'FY2024 Q3')"
    },
    "EXCEL": {
      "formula_format": "code_block",
      "cell_reference_format": "A1_notation",
      "range_format": "A1:B10"
    }
  }
}
