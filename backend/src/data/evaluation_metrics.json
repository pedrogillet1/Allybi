{
  "_meta": {
    "type": "evaluation_metrics_definitions",
    "description": "Pass/fail thresholds for model evaluation",
    "version": "1.0"
  },

  "intent_classification": {
    "overall": {
      "accuracy": {
        "threshold": 0.97,
        "description": "Overall intent classification accuracy"
      },
      "macro_f1": {
        "threshold": 0.95,
        "description": "Macro F1 across all intents"
      }
    },
    "per_tier": {
      "tier_0": {
        "intents": ["DOCUMENTS", "EXTRACTION", "REASONING"],
        "accuracy": 0.98,
        "precision": 0.97,
        "recall": 0.97,
        "description": "Core intents must have highest accuracy"
      },
      "tier_1": {
        "intents": ["EDIT", "HELP", "CONVERSATION"],
        "accuracy": 0.96,
        "precision": 0.95,
        "recall": 0.95,
        "description": "Secondary intents"
      },
      "tier_2": {
        "intents": ["MEMORY", "PREFERENCES", "FILE_ACTIONS", "ERROR"],
        "accuracy": 0.94,
        "precision": 0.92,
        "recall": 0.92,
        "description": "Utility intents - lower threshold acceptable"
      }
    },
    "confusion_matrix_constraints": {
      "max_confusion_rate": 0.03,
      "critical_pairs": [
        {
          "from": "EXTRACTION",
          "to": "DOCUMENTS",
          "max_rate": 0.02,
          "reason": "Extraction vs navigation is critical distinction"
        },
        {
          "from": "REASONING",
          "to": "EXTRACTION",
          "max_rate": 0.02,
          "reason": "Analysis vs extraction affects output format"
        }
      ]
    }
  },

  "domain_classification": {
    "overall": {
      "precision": {
        "threshold": 0.99,
        "description": "Domain precision must be very high"
      },
      "recall": {
        "threshold": 0.95,
        "description": "Domain recall threshold"
      }
    },
    "per_domain": {
      "LEGAL": {
        "precision": 0.99,
        "recall": 0.97,
        "reason": "High-stakes domain - false positives costly"
      },
      "MEDICAL": {
        "precision": 0.99,
        "recall": 0.97,
        "reason": "High-stakes domain - false positives costly"
      },
      "FINANCE": {
        "precision": 0.98,
        "recall": 0.95
      },
      "ENGINEERING": {
        "precision": 0.97,
        "recall": 0.94
      },
      "EXCEL": {
        "precision": 0.95,
        "recall": 0.92
      }
    },
    "multi_label_metrics": {
      "hamming_loss_max": 0.05,
      "subset_accuracy_min": 0.90
    }
  },

  "depth_classification": {
    "accuracy": {
      "threshold": 0.95,
      "description": "Depth level classification accuracy"
    },
    "off_by_one_tolerance": {
      "allowed": true,
      "max_rate": 0.10,
      "description": "D2 classified as D3 is less critical than D1 as D4"
    }
  },

  "language_metrics": {
    "per_language": {
      "en": {
        "intent_accuracy": 0.97,
        "domain_precision": 0.99
      },
      "pt": {
        "intent_accuracy": 0.95,
        "domain_precision": 0.98
      },
      "es": {
        "intent_accuracy": 0.95,
        "domain_precision": 0.98
      }
    }
  },

  "latency_requirements": {
    "p50_ms": 50,
    "p95_ms": 100,
    "p99_ms": 200,
    "description": "Classification latency in milliseconds"
  },

  "failure_conditions": {
    "automatic_fail": [
      "intent_accuracy < 0.90",
      "domain_precision < 0.95",
      "LEGAL domain recall < 0.90",
      "MEDICAL domain recall < 0.90",
      "p99 latency > 500ms"
    ]
  },

  "reporting_format": {
    "required_sections": [
      "summary_metrics",
      "per_class_breakdown",
      "confusion_matrices",
      "error_analysis",
      "latency_percentiles"
    ],
    "comparison_to_baseline": true,
    "trend_tracking": true
  }
}
