      "C$": { "code": "CAD", "name": "Canadian Dollar" },
      "AUD": { "code": "AUD", "name": "Australian Dollar" },
      "A$": { "code": "AUD", "name": "Australian Dollar" },
      "MXN": { "code": "MXN", "name": "Mexican Peso" },
      "ARS": { "code": "ARS", "name": "Argentine Peso" },
      "CLP": { "code": "CLP", "name": "Chilean Peso" },
      "COP": { "code": "COP", "name": "Colombian Peso" },
      "PEN": { "code": "PEN", "name": "Peruvian Sol" }
    },

    "format_patterns": {
      "brazilian": {
        "pattern": "\\bR\\$\\s?([\\d\\.]+),?(\\d{2})?\\b",
        "example": "R$ 1.234,56",
        "thousands_sep": ".",
        "decimal_sep": ","
      },
      "american": {
        "pattern": "\\$\\s?([\\d,]+)\\.?(\\d{2})?\\b",
        "example": "$1,234.56",
        "thousands_sep": ",",
        "decimal_sep": "."
      },
      "european": {
        "pattern": "€\\s?([\\d\\s\\.]+),?(\\d{2})?\\b",
        "example": "€ 1.234,56 or € 1 234,56",
        "thousands_sep": ". or space",
        "decimal_sep": ","
      }
    },

    "textual_amounts": {
      "en": {
        "thousand": 1000,
        "million": 1000000,
        "billion": 1000000000,
        "trillion": 1000000000000,
        "k": 1000,
        "m": 1000000,
        "mm": 1000000,
        "b": 1000000000,
        "bn": 1000000000
      },
      "pt": {
        "mil": 1000,
        "milhão": 1000000,
        "milhões": 1000000,
        "bilhão": 1000000000,
        "bilhões": 1000000000,
        "trilhão": 1000000000000,
        "trilhões": 1000000000000,
        "mi": 1000000,
        "bi": 1000000000
      }
    },

    "percentage_formats": {
      "patterns": [
        { "regex": "([\\d,\\.]+)\\s*%", "example": "12.5%", "type": "suffix" },
        { "regex": "([\\d,\\.]+)\\s*(percent|pct|por cento|porcento)", "example": "12.5 percent", "type": "word" },
        { "regex": "([\\d,\\.]+)\\s*(bps|basis points|pontos base)", "example": "125 bps", "type": "bps", "multiplier": 0.01 }
      ]
    }
  },

  "filename_patterns": {
    "description": "Filename normalization for search and matching",
    "count": 400,

    "extension_normalization": {
      "documents": {
        "pdf": ["pdf", "PDF", ".pdf", ".PDF"],
        "doc": ["doc", "DOC", ".doc", ".DOC"],
        "docx": ["docx", "DOCX", ".docx", ".DOCX"],
        "xls": ["xls", "XLS", ".xls", ".XLS"],
        "xlsx": ["xlsx", "XLSX", ".xlsx", ".XLSX"],
        "ppt": ["ppt", "PPT", ".ppt", ".PPT"],
        "pptx": ["pptx", "PPTX", ".pptx", ".PPTX"],
        "txt": ["txt", "TXT", ".txt", ".TXT"],
        "csv": ["csv", "CSV", ".csv", ".CSV"],
        "rtf": ["rtf", "RTF", ".rtf", ".RTF"]
      },
      "images": {
        "jpg": ["jpg", "jpeg", "JPG", "JPEG", ".jpg", ".jpeg", ".JPG", ".JPEG"],
        "png": ["png", "PNG", ".png", ".PNG"],
        "gif": ["gif", "GIF", ".gif", ".GIF"],
        "bmp": ["bmp", "BMP", ".bmp", ".BMP"],
        "tiff": ["tiff", "tif", "TIFF", "TIF", ".tiff", ".tif"]
      }
    },

    "common_name_patterns": {
      "version_indicators": [
        { "regex": "[_\\-\\s]v(\\d+)", "example": "document_v2", "canonical": "_v$1" },
        { "regex": "[_\\-\\s]version[_\\-\\s]?(\\d+)", "example": "document_version_2", "canonical": "_v$1" },
        { "regex": "[_\\-\\s]final", "example": "document_final", "canonical": "_final" },
        { "regex": "[_\\-\\s]draft", "example": "document_draft", "canonical": "_draft" },
        { "regex": "[_\\-\\s]rev[_\\-\\s]?(\\d+)", "example": "document_rev2", "canonical": "_rev$1" }
      ],
      "date_patterns": [
        { "regex": "[_\\-\\s](\\d{4})[_\\-](\\d{2})[_\\-](\\d{2})", "example": "report_2024-01-15", "format": "YYYY-MM-DD" },
        { "regex": "[_\\-\\s](\\d{2})[_\\-](\\d{2})[_\\-](\\d{4})", "example": "report_15-01-2024", "format": "DD-MM-YYYY" },
        { "regex": "[_\\-\\s](\\d{2})[_\\-](\\d{2})[_\\-](\\d{2})", "example": "report_24-01-15", "format": "YY-MM-DD" }
      ]
    },

    "separator_normalization": {
      "to_underscore": [" ", "-", ".", "__", "---"],
      "description": "Normalize separators for fuzzy matching"
    },

    "case_insensitive_matching": {
      "enabled": true,
      "description": "All filename searches should be case-insensitive"
    },

    "partial_matching": {
      "min_chars": 3,
      "fuzzy_threshold": 0.7,
      "description": "Allow partial filename matches with high similarity"
    }
  },

  "date_formats": {
    "description": "Date format conversions and normalization",
    "count": 300,

    "iso_canonical": "YYYY-MM-DD",

    "regional_formats": {
      "en_US": {
        "pattern": "(\\d{1,2})/(\\d{1,2})/(\\d{2,4})",
        "order": "MM/DD/YYYY",
        "example": "01/15/2024"
      },
      "en_GB": {
        "pattern": "(\\d{1,2})/(\\d{1,2})/(\\d{2,4})",
        "order": "DD/MM/YYYY",
        "example": "15/01/2024"
      },
      "pt_BR": {
        "pattern": "(\\d{1,2})/(\\d{1,2})/(\\d{2,4})",
        "order": "DD/MM/YYYY",
        "example": "15/01/2024"
      },
      "iso": {
        "pattern": "(\\d{4})-(\\d{2})-(\\d{2})",
        "order": "YYYY-MM-DD",
        "example": "2024-01-15"
      }
    },

    "textual_dates": {
      "en": {
        "full": { "pattern": "(January|February|March|April|May|June|July|August|September|October|November|December)\\s+(\\d{1,2}),?\\s+(\\d{4})", "example": "January 15, 2024" },
        "abbrev": { "pattern": "(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\.?\\s+(\\d{1,2}),?\\s+(\\d{4})", "example": "Jan 15, 2024" },
        "ordinal": { "pattern": "(\\d{1,2})(st|nd|rd|th)\\s+(of\\s+)?(January|February|March|April|May|June|July|August|September|October|November|December),?\\s+(\\d{4})", "example": "15th of January, 2024" }
      },
      "pt": {
        "full": { "pattern": "(\\d{1,2})\\s+de\\s+(janeiro|fevereiro|março|abril|maio|junho|julho|agosto|setembro|outubro|novembro|dezembro)\\s+de\\s+(\\d{4})", "example": "15 de janeiro de 2024" },
        "abbrev": { "pattern": "(\\d{1,2})\\s+(jan|fev|mar|abr|mai|jun|jul|ago|set|out|nov|dez)\\.?\\s+(\\d{4})", "example": "15 jan 2024" }
      }
    },

    "relative_dates": {
      "en": {
        "today": { "offset": 0 },
        "yesterday": { "offset": -1 },
        "tomorrow": { "offset": 1 },
        "last week": { "offset": -7, "type": "days" },
        "last month": { "offset": -1, "type": "months" },
        "last year": { "offset": -1, "type": "years" },
        "this week": { "type": "current_week" },
        "this month": { "type": "current_month" },
        "this year": { "type": "current_year" },
        "next week": { "offset": 7, "type": "days" },
        "next month": { "offset": 1, "type": "months" }
      },
      "pt": {
        "hoje": { "offset": 0 },
        "ontem": { "offset": -1 },
        "amanhã": { "offset": 1 },
        "semana passada": { "offset": -7, "type": "days" },
        "mês passado": { "offset": -1, "type": "months" },
        "ano passado": { "offset": -1, "type": "years" },
        "esta semana": { "type": "current_week" },
        "este mês": { "type": "current_month" },
        "este ano": { "type": "current_year" },
        "próxima semana": { "offset": 7, "type": "days" },
        "próximo mês": { "offset": 1, "type": "months" }
      }
    },

    "fiscal_year": {
      "patterns": [
        { "regex": "FY\\s?(\\d{2,4})", "example": "FY2024", "type": "fiscal_year" },
        { "regex": "FY\\s?(\\d{2})/(\\d{2})", "example": "FY23/24", "type": "fiscal_year_split" },
        { "regex": "fiscal\\s+year\\s+(\\d{4})", "example": "fiscal year 2024", "type": "fiscal_year" },
        { "regex": "ano\\s+fiscal\\s+(\\d{4})", "example": "ano fiscal 2024", "type": "fiscal_year" }
      ]
    }
  },

  "number_formats": {
    "description": "Numeric format normalization across locales",
    "count": 200,

    "decimal_separators": {
      "en_US": { "thousands": ",", "decimal": ".", "example": "1,234.56" },
      "pt_BR": { "thousands": ".", "decimal": ",", "example": "1.234,56" },
      "de_DE": { "thousands": ".", "decimal": ",", "example": "1.234,56" },
      "fr_FR": { "thousands": " ", "decimal": ",", "example": "1 234,56" }
