  "currency_normalization": {
    "description": "Currency symbols and formats → canonical form",
    "count": 300,

    "symbols_to_codes": {
      "R$": { "code": "BRL", "name": "Brazilian Real", "locale": "pt-BR" },
      "$": { "code": "USD", "name": "US Dollar", "locale": "en-US", "ambiguous": true },
      "US$": { "code": "USD", "name": "US Dollar", "locale": "en-US" },
      "USD": { "code": "USD", "name": "US Dollar" },
      "€": { "code": "EUR", "name": "Euro", "locale": "eu" },
