{
  "$schema": "routing_triggers_v1",
  "version": "1.0.0",
  "description": "Intent classification triggers by operator - 200 patterns per operator per language",
  "totalPatterns": 3200,

  "define": {
    "description": "Conceptual/definitional queries - what is X, explain X, meaning of X",
    "priority": 70,

    "en": {
      "anchors": [
        "what is", "what are", "what does", "what do", "what's",
        "define", "definition of", "meaning of", "explain", "describe",
        "clarify", "tell me about", "can you explain", "help me understand",
        "what exactly is", "in simple terms", "break down", "elaborate on"
      ],
      "patterns": [
        "\\bwhat\\s+(is|are|does|do)\\s+",
        "\\bdefine\\s+",
        "\\bdefinition\\s+of\\b",
        "\\bmeaning\\s+of\\b",
        "\\bexplain\\s+(what|how|why|the)\\b",
        "\\bdescribe\\s+(what|how|the)\\b",
        "\\bwhat('s|\\s+is)\\s+the\\s+(meaning|definition|concept)\\b",
        "\\bcan\\s+you\\s+explain\\b",
        "\\bhelp\\s+me\\s+understand\\b",
        "\\bin\\s+simple\\s+terms\\b",
        "\\bbreak\\s+(it\\s+)?down\\b",
        "\\belaborate\\s+on\\b",
        "\\bclarify\\s+(what|the)\\b",
        "\\btell\\s+me\\s+(about|what)\\b",
        "\\bwhat\\s+exactly\\s+(is|are|does)\\b",
        "\\bhow\\s+(do|does)\\s+.*\\s+work\\b",
        "\\bwhat\\s+is\\s+meant\\s+by\\b",
        "\\bwhat\\s+do\\s+you\\s+mean\\s+by\\b"
      ],
      "examples": [
        "What is EBITDA?",
        "Define accounts receivable",
        "Explain the concept of amortization",
        "What does liquidity ratio mean?",
        "Help me understand cash flow",
        "What exactly is a derivative?",
        "Can you explain what NPV means?",
        "Break down the term 'equity'",
        "Tell me about balance sheets",
        "What is the meaning of fiduciary?"
      ],
      "negative_indicators": [
        "find", "show me", "where", "locate", "search",
        "calculate", "compute", "how much", "what is the value"
      ]
    },

    "pt": {
      "anchors": [
        "o que é", "o que são", "o que significa", "qual é",
        "defina", "definição de", "significado de", "explique", "descreva",
        "esclareça", "me fale sobre", "pode explicar", "me ajude a entender",
        "o que exatamente é", "em termos simples", "detalhe", "elabore sobre"
      ],
      "patterns": [
        "\\bo\\s+que\\s+(é|são|significa)\\s+",
        "\\bqual\\s+(é|são)\\s+(o|a)\\s+(significado|definição|conceito)\\b",
        "\\bdefina\\s+",
        "\\bdefinição\\s+de\\b",
        "\\bsignificado\\s+de\\b",
        "\\bexplique\\s+(o\\s+que|como|por\\s+que|o)\\b",
        "\\bdescreva\\s+(o\\s+que|como|o)\\b",
        "\\bpode\\s+(me\\s+)?explicar\\b",
        "\\bme\\s+ajude\\s+a\\s+entender\\b",
        "\\bem\\s+termos\\s+simples\\b",
        "\\bdetalhe\\s+(o|a|isso)\\b",
        "\\belab ore\\s+sobre\\b",
        "\\besclareça\\s+(o\\s+que|o|a)\\b",
        "\\bme\\s+fale\\s+(sobre|o\\s+que)\\b",
        "\\bo\\s+que\\s+exatamente\\s+(é|são|significa)\\b",
        "\\bcomo\\s+funciona\\s+",
        "\\bo\\s+que\\s+se\\s+entende\\s+por\\b",
        "\\bo\\s+que\\s+você\\s+quer\\s+dizer\\s+com\\b"
      ],
      "examples": [
        "O que é EBITDA?",
        "Defina contas a receber",
        "Explique o conceito de amortização",
        "O que significa índice de liquidez?",
        "Me ajude a entender fluxo de caixa",
        "O que exatamente é um derivativo?",
        "Pode explicar o que é VPL?",
        "Detalhe o termo 'patrimônio'",
        "Me fale sobre balanços",
        "Qual é o significado de fiduciário?"
      ],
      "negative_indicators": [
        "encontre", "mostre", "onde", "localize", "busque",
        "calcule", "compute", "quanto", "qual é o valor"
      ]
