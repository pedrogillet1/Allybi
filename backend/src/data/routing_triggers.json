  "meta": {
    "priority_order": ["compute", "extract", "locate", "compare", "audit", "list", "define", "summarize"],
    "default_fallback": "documents",
    "confidence_threshold": 0.6,
    "notes": [
      "Operators with higher priority take precedence when multiple patterns match",
      "compute is highest (90) because math queries should always route to calculator",
      "extract is high (85) because data extraction is core RAG functionality",
      "summarize is lowest (65) because it's a catch-all for document understanding"
    ]
