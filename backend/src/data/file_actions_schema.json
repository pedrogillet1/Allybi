{
  "_meta": {
    "type": "file_actions_schema",
    "version": "1.0.0",
    "description": "FILE_ACTIONS controls physical file & folder operations. UI-intent first, not semantic reasoning.",
    "priority": "HIGHEST - Always wins over extraction, reasoning, domains, edit, memory for navigation queries",
    "layer": "Layer 0 - Beginner/Navigation",
    "createdAt": "2024-12-18T00:00:00.000Z"
  },

  "states": {
    "description": "What is the current file context?",
    "values": [
      "no_file_context",
      "single_file_referenced",
      "multiple_files_referenced",
      "folder_referenced",
      "multiple_folders_referenced",
      "mixed_files_and_folders",
      "file_exists",
      "file_not_found",
      "folder_exists",
      "folder_not_found",
      "ambiguous_file_name",
      "ambiguous_folder_name",
      "permission_allowed",
      "permission_denied",
      "upload_pending",
      "upload_in_progress",
      "upload_completed",
      "upload_failed",
      "delete_pending",
      "delete_completed",
      "move_pending",
      "move_completed",
      "operation_failed"
    ]
  },

  "actions": {
    "description": "What operation is requested?",
    "values": [
      "show_file",
      "preview_file",
      "open_file",
      "download_file",
      "upload_file",
      "create_folder",
      "delete_file",
      "delete_folder",
      "move_file",
      "move_folder",
      "rename_file",
      "rename_folder",
      "list_folder_contents",
      "search_files",
      "resolve_ambiguity",
      "request_confirmation"
    ]
  },

  "scope": {
    "description": "How wide is the operation?",
    "values": [
      "single_file",
      "multiple_files",
      "single_folder",
      "multiple_folders",
      "entire_workspace",
      "current_folder_only",
      "recursive_folders",
      "user_root",
      "shared_space",
      "restricted_space"
    ]
  },

  "depth": {
    "description": "How complex is the action?",
    "levels": {
      "D1": "simple navigation (show/open/list)",
      "D2": "upload or download",
      "D3": "create, rename, move",
      "D4": "bulk operations (multi-file)",
      "D5": "destructive operations with confirmation"
    }
  },

  "evidence_controls": {
    "description": "Trust & safety rules",
    "rules": [
      "never_assume_file_exists",
      "explicit_path_resolution_required",
      "show_file_metadata_before_action",
      "confirm_destructive_actions",
      "never_delete_without_confirmation",
      "display_operation_result",
      "show_error_reason",
      "no_silent_failures",
      "log_all_actions",
      "undo_supported_if_available"
    ]
  },

  "output_controls": {
    "description": "UX output requirements",
    "show": [
      "file_card_required",
      "file_name",
      "file_type",
      "file_size",
      "last_modified",
      "location_path",
      "primary_action_button",
      "secondary_actions",
      "preview_if_supported"
    ],
    "buttons": [
      "open",
      "preview",
      "download",
      "move",
      "rename",
      "delete",
      "cancel"
    ],
    "confirmation": [
      "explicit_yes_no",
      "show_affected_items",
      "warn_irreversible"
    ],
    "errors": [
      "human_readable",
      "actionable_next_step"
    ]
  },

  "memory_elements": {
    "description": "What persists across turns?",
    "values": [
      "last_active_file",
      "last_active_folder",
      "recent_uploads",
      "recent_deletions",
      "last_search_query",
      "last_destination_folder",
      "undo_stack_reference",
      "user_confirmation_preference"
    ]
  },

  "failure_modes": {
    "description": "What can go wrong?",
    "values": [
      "file_not_found",
      "folder_not_found",
      "ambiguous_name",
      "permission_denied",
      "upload_interrupted",
      "unsupported_file_type",
      "file_too_large",
      "duplicate_name_conflict",
      "delete_cancelled",
      "move_target_missing",
      "read_only_location",
      "network_error",
      "timeout",
      "unknown_error"
    ]
  },

  "routing_rules": {
    "description": "BEGINNER_OVERRIDE - Navigation phrases always win",
    "triggers": {
      "STRONG": [
        "where is",
        "show me file",
        "open file",
        "find file",
        "upload",
        "download",
        "delete file",
        "move file",
        "create folder",
        "search files",
        "list files",
        "my files",
        "recent uploads"
      ],
      "NEGATIVE_FOR_OTHER_INTENTS": [
        "extract",
        "analyze",
        "what does it mean",
        "implications",
        "interpret",
        "summarize"
      ]
    },
    "override_rule": {
      "condition": "query contains navigation verb AND references file/folder/document",
      "action": "FORCE FILE_ACTIONS",
      "blocked_intents": ["EXTRACTION", "REASONING", "EDIT", "MEMORY", "PREFERENCES"],
      "blocked_domains": ["LEGAL", "MEDICAL", "FINANCE", "ENGINEERING", "EXCEL"]
    }
  },

  "response_schema": {
    "description": "Standard response payload for FILE_ACTIONS",
    "example": {
      "type": "file_action",
      "action": "show_file",
      "file": {
        "id": "uuid",
        "name": "Contract.pdf",
        "type": "pdf",
        "size": "2.1 MB",
        "path": "/Legal/Contracts",
        "preview_supported": true,
        "last_modified": "2024-12-17T10:30:00Z"
      },
      "ui": {
        "primary_button": "Open",
        "secondary_buttons": ["Preview", "Download", "Move", "Delete"]
      },
      "next_suggestions": [
        "Show me section 3",
        "What does the termination clause say?",
        "Extract the payment terms"
      ]
    },
    "upload_completed": {
      "action": "upload_completed",
      "file": {
        "name": "invoice.pdf",
        "location": "/Uploads"
      },
      "next_suggestions": [
        "Open file",
        "Extract data",
        "Ask questions about this file"
      ]
    },
    "delete_confirmation": {
      "action": "request_confirmation",
      "operation": "delete",
      "affected_items": ["filename.pdf"],
      "warning": "This action cannot be undone.",
      "buttons": ["Yes, delete", "Cancel"]
    }
  }
}
