{
  "_meta": {
    "type": "domain_classification_labels",
    "description": "Multi-label domain head - allows zero or multiple domains per query",
    "version": "1.0",
    "usage": "ML model output labels for domain detection"
  },

  "labels": {
    "LEGAL": {
      "id": 0,
      "name": "LEGAL",
      "description": "Legal documents, contracts, regulatory compliance",
      "tier": 0,
      "high_stakes": true,
      "examples": [
        "What does the indemnification clause say?",
        "Review this NDA",
        "Find the termination provisions",
        "What are our obligations under this contract?"
      ]
    },
    "MEDICAL": {
      "id": 1,
      "name": "MEDICAL",
      "description": "Medical records, clinical documents, healthcare",
      "tier": 0,
      "high_stakes": true,
      "examples": [
        "What are the lab results?",
        "List the medications",
        "What was the diagnosis?",
        "Extract the vital signs"
      ]
    },
    "FINANCE": {
      "id": 2,
      "name": "FINANCE",
      "description": "Financial reports, statements, accounting",
      "tier": 1,
      "high_stakes": true,
      "examples": [
        "What is the total revenue?",
        "Show the balance sheet",
        "Calculate the profit margin",
        "Extract quarterly earnings"
      ]
    },
    "ENGINEERING": {
      "id": 3,
      "name": "ENGINEERING",
      "description": "Technical specifications, CAD, engineering documents",
      "tier": 1,
      "high_stakes": false,
      "examples": [
        "What are the dimensions?",
        "List the materials",
        "Find the tolerances",
        "What standards apply?"
      ]
    },
    "EXCEL": {
      "id": 4,
      "name": "EXCEL",
      "description": "Spreadsheet operations, Excel-specific queries",
      "tier": 2,
      "high_stakes": false,
      "examples": [
        "Sum column B",
        "Create a VLOOKUP formula",
        "Filter by date",
        "What's in cell A1?"
      ]
    },
    "GENERAL": {
      "id": 5,
      "name": "GENERAL",
      "description": "No specific domain detected",
      "tier": 3,
      "high_stakes": false,
      "fallback": true,
      "examples": [
        "What's in this document?",
        "Summarize this",
        "Find the date",
        "Who wrote this?"
      ]
    }
  },

  "label_constraints": {
    "mutually_exclusive": false,
    "max_labels_per_query": 2,
    "allow_no_domain": true,
    "fallback_label": "GENERAL",
    "mutual_exclusions": [
      ["LEGAL", "MEDICAL"],
      ["EXCEL", "ENGINEERING"]
    ]
  },

  "confidence_thresholds": {
    "single_domain": 0.7,
    "multi_domain": 0.5,
    "fallback_threshold": 0.3
  },

  "training_notes": {
    "multi_label": "Use sigmoid outputs, not softmax",
    "class_weights": "Weight high_stakes domains higher",
    "negative_mining": "Use negative triggers for hard negatives"
  }
}
