{
  "$schema": "negative_blockers_v1",
  "version": "1.0.0",
  "description": "Anti-triggers to prevent false positive routing - blocks off-topic queries from document QA",
  "totalPatterns": 2000,

  "casual_greeting": {
    "description": "Greetings and social pleasantries that should not trigger document analysis",
    "count": 300,
    "action": "route_to_chat",

    "en": {
      "patterns": [
        "^(hi|hello|hey|howdy|greetings|good\\s+(morning|afternoon|evening|day))\\s*[!.,]?$",
        "^(what'?s\\s+up|sup|yo|hiya|heya)\\s*[!?.,]*$",
        "^how\\s+(are|r)\\s+(you|u|ya)(\\s+doing)?\\s*[!?.,]*$",
        "^how'?s\\s+(it\\s+going|everything|life)\\s*[!?.,]*$",
        "^(nice|good)\\s+to\\s+(meet|see)\\s+you\\b",
        "^(thanks|thank\\s+you|ty|thx)(\\s+so\\s+much)?\\s*[!.,]*$",
        "^(bye|goodbye|see\\s+(you|ya)|later|ciao|adios)\\s*[!.,]*$",
        "^(have\\s+a\\s+(good|nice|great)\\s+(day|one|evening|night))\\s*[!.,]*$",
        "^(take\\s+care|cheers|peace|peace\\s+out)\\s*[!.,]*$",
        "^(you'?re\\s+welcome|no\\s+problem|np|anytime)\\s*[!.,]*$"
      ],
      "examples": [
        "Hello!", "Hi there", "Hey", "Good morning",
        "How are you?", "How's it going?", "What's up?",
        "Thanks!", "Thank you so much", "Bye!", "See you later"
      ],
      "notes": "Match at start of message, may be followed by punctuation"
    },

    "pt": {
      "patterns": [
        "^(oi|olá|alô|e\\s+aí|fala|salve|bom\\s+(dia|tarde|noite))\\s*[!.,]?$",
        "^(tudo\\s+(bem|bom|certo)|como\\s+(vai|está|tá))\\s*[!?.,]*$",
        "^(e\\s+aí|beleza|tranquilo|de\\s+boa)\\s*[!?.,]*$",
        "^(prazer|muito\\s+prazer|encantado)\\s*[!.,]*$",
        "^(obrigad[oa]|valeu|vlw|brigadão|brigadão)\\s*[!.,]*$",
        "^(tchau|até\\s+(logo|mais|breve|amanhã)|falou|flw)\\s*[!.,]*$",
        "^(tenha\\s+(um\\s+)?(bom|ótimo)\\s+(dia|noite))\\s*[!.,]*$",
        "^(se\\s+cuida|cuida-se|fica\\s+bem)\\s*[!.,]*$",
        "^(de\\s+nada|por\\s+nada|imagina|disponha)\\s*[!.,]*$",
        "^(pode\\s+deixar|combinado|fechado)\\s*[!.,]*$"
      ],
      "examples": [
        "Oi!", "Olá", "E aí", "Bom dia",
        "Tudo bem?", "Como vai?", "Beleza?",
        "Obrigado!", "Valeu", "Tchau!", "Até mais"
      ],
      "notes": "Match at start of message, may be followed by punctuation"
    }
  },

  "off_topic": {
    "description": "Clearly off-topic queries unrelated to documents or data",
    "count": 300,
    "action": "polite_redirect",

    "en": {
      "patterns": [
        "\\b(what'?s\\s+the\\s+weather|weather\\s+(forecast|today|tomorrow))\\b",
        "\\b(tell\\s+me\\s+a\\s+(joke|story)|make\\s+me\\s+laugh)\\b",
        "\\b(who\\s+(is|was)\\s+(the\\s+)?(president|prime\\s+minister|king|queen|ceo))\\b",
        "\\b(what\\s+time\\s+is\\s+it|current\\s+time|time\\s+now)\\b",
        "\\b(play\\s+(music|a\\s+song|spotify)|turn\\s+on\\s+the\\s+(tv|lights))\\b",
        "\\b(set\\s+(an?\\s+)?alarm|remind\\s+me\\s+to|create\\s+(a\\s+)?reminder)\\b",
        "\\b(order\\s+(food|pizza|dinner)|call\\s+(a\\s+)?taxi|book\\s+(a\\s+)?(flight|hotel))\\b",
        "\\b(what'?s\\s+on\\s+(tv|netflix)|recommend\\s+(a\\s+)?movie)\\b",
        "\\b(sports\\s+(score|results)|who\\s+won\\s+the\\s+(game|match))\\b",
        "\\b(recipe\\s+for|how\\s+to\\s+(cook|make|bake)\\s+[a-z]+)\\b",
        "\\b(translate\\s+.+\\s+(to|into)\\s+[a-z]+)\\b",
        "\\b(directions\\s+to|how\\s+to\\s+get\\s+to|navigate\\s+to)\\b",
        "\\b(what'?s\\s+the\\s+capital\\s+of|population\\s+of)\\b",
        "\\b(when\\s+(was|is)\\s+[a-z]+\\s+(born|founded|invented))\\b",
        "\\b(how\\s+tall\\s+is|how\\s+old\\s+is|when\\s+did\\s+[a-z]+\\s+die)\\b"
      ],
      "examples": [
        "What's the weather like?", "Tell me a joke",
        "Who is the president?", "What time is it?",
        "Play some music", "Set an alarm for 7am",
        "Order me a pizza", "What's on Netflix?",
        "Did the Lakers win?", "Recipe for pasta",
        "Translate hello to Spanish", "Directions to the airport"
      ],
      "redirect_message": "I'm a document assistant. I can help you analyze your uploaded files. Would you like to ask about your documents?"
    },

    "pt": {
      "patterns": [
        "\\b(como\\s+está\\s+o\\s+tempo|previsão\\s+do\\s+tempo|vai\\s+chover)\\b",
        "\\b(conte\\s+(uma\\s+)?(piada|história)|me\\s+faça\\s+rir)\\b",
        "\\b(quem\\s+(é|foi)\\s+(o|a)?\\s+(presidente|rei|rainha|papa))\\b",
        "\\b(que\\s+horas\\s+são|hora\\s+atual|agora\\s+são)\\b",
        "\\b(toque\\s+(música|uma\\s+música)|ligue\\s+(a\\s+)?(tv|luz))\\b",
        "\\b(coloque\\s+(um\\s+)?alarme|me\\s+lembre\\s+de|crie\\s+(um\\s+)?lembrete)\\b",
        "\\b(peça\\s+(comida|pizza)|chame\\s+(um\\s+)?táxi|reserve\\s+(um\\s+)?(voo|hotel))\\b",
        "\\b(o\\s+que\\s+(está\\s+)?passando\\s+na\\s+(tv|netflix)|recomende\\s+(um\\s+)?filme)\\b",
        "\\b(placar\\s+do\\s+(jogo|futebol)|quem\\s+ganhou\\s+(o\\s+)?(jogo|campeonato))\\b",
        "\\b(receita\\s+de|como\\s+(fazer|cozinhar|preparar)\\s+[a-z]+)\\b",
        "\\b(traduza\\s+.+\\s+para\\s+[a-z]+)\\b",
        "\\b(como\\s+chegar\\s+(em|no|na)|rota\\s+para)\\b",
        "\\b(qual\\s+(é\\s+)?a\\s+capital\\s+de|população\\s+de)\\b",
        "\\b(quando\\s+(nasceu|foi\\s+(fundado|inventado)))\\b",
        "\\b(quantos\\s+anos\\s+tem|qual\\s+a\\s+altura\\s+de)\\b"
      ],
      "examples": [
        "Como está o tempo?", "Conte uma piada",
        "Quem é o presidente?", "Que horas são?",
        "Toque uma música", "Coloque alarme para 7h",
        "Peça uma pizza", "O que tem na Netflix?",
        "Quem ganhou o jogo?", "Receita de macarrão",
        "Traduza hello para português", "Como chegar no aeroporto"
      ],
      "redirect_message": "Sou um assistente de documentos. Posso ajudar a analisar seus arquivos enviados. Gostaria de perguntar sobre seus documentos?"
    }
  },

  "coding_request": {
    "description": "Programming/coding requests that Koda doesn't handle",
    "count": 200,
    "action": "polite_redirect",

    "en": {
      "patterns": [
        "\\b(write|create|generate|build)\\s+(a\\s+)?(code|script|program|function|class|app)\\b",
        "\\b(fix\\s+(this|the|my)\\s+(code|bug|error)|debug\\s+(this|my))\\b",
        "\\b(how\\s+to\\s+(code|program)|teach\\s+me\\s+(to\\s+)?(code|program))\\b",
        "\\b(explain\\s+(this|the)\\s+code|what\\s+does\\s+this\\s+code\\s+do)\\b",
        "\\b(python|javascript|java|c\\+\\+|ruby|go|rust|sql)\\s+(code|script|program)\\b",
        "\\b(implement|refactor|optimize)\\s+(a\\s+)?(function|algorithm|class)\\b",
        "\\b(api\\s+(call|request|endpoint)|http\\s+request)\\b",
        "\\b(database\\s+(query|schema)|sql\\s+(query|statement))\\b",
        "\\b(write\\s+a\\s+regex|regular\\s+expression\\s+for)\\b",
        "\\bfor\\s*\\(\\s*(int|var|let|const)\\b",
        "\\bdef\\s+\\w+\\s*\\(",
        "\\bfunction\\s+\\w+\\s*\\(",
        "\\bclass\\s+\\w+\\s*(\\{|\\(|:)",
        "\\b(npm|pip|yarn|brew)\\s+install\\b",
        "\\b(git\\s+(clone|push|pull|commit)|github)\\b"
      ],
      "examples": [
        "Write a Python function to sort a list",
        "Fix this JavaScript code",
        "How do I code a website?",
        "Explain this SQL query",
        "Create an API endpoint",
        "Implement a binary search",
        "Debug my React component"
      ],
      "redirect_message": "I'm focused on document analysis. For coding help, try a programming assistant or IDE."
    },

    "pt": {
      "patterns": [
        "\\b(escreva|crie|gere|construa)\\s+(um\\s+)?(código|script|programa|função|classe|app)\\b",
        "\\b(corrija\\s+(esse|este|o|meu)\\s+(código|bug|erro)|debugue\\s+(esse|meu))\\b",
        "\\b(como\\s+(codar|programar)|me\\s+ensine\\s+a\\s+(codar|programar))\\b",
        "\\b(explique\\s+(esse|este|o)\\s+código|o\\s+que\\s+(esse|este)\\s+código\\s+faz)\\b",
        "\\b(python|javascript|java|c\\+\\+|ruby|go|rust|sql)\\s+(código|script|programa)\\b",
        "\\b(implemente|refatore|otimize)\\s+(uma?\\s+)?(função|algoritmo|classe)\\b",
        "\\b(chamada\\s+de?\\s+api|requisição\\s+http)\\b",
        "\\b(query\\s+de\\s+(banco|dados)|consulta\\s+sql)\\b",
        "\\b(escreva\\s+(uma?\\s+)?regex|expressão\\s+regular\\s+para)\\b",
        "\\bfor\\s*\\(\\s*(int|var|let|const)\\b",
        "\\bdef\\s+\\w+\\s*\\(",
        "\\bfunction\\s+\\w+\\s*\\(",
        "\\bclass\\s+\\w+\\s*(\\{|\\(|:)",
        "\\b(npm|pip|yarn|brew)\\s+install\\b",
        "\\b(git\\s+(clone|push|pull|commit)|github)\\b"
      ],
      "examples": [
        "Escreva uma função Python para ordenar uma lista",
        "Corrija este código JavaScript",
        "Como eu programo um site?",
        "Explique esta query SQL",
        "Crie um endpoint de API",
        "Implemente uma busca binária",
        "Debugue meu componente React"
      ],
      "redirect_message": "Meu foco é análise de documentos. Para ajuda com código, tente um assistente de programação."
    }
  },

  "general_knowledge": {
    "description": "General knowledge/trivia queries not about user documents",
    "count": 300,
    "action": "check_if_doc_related",

    "en": {
      "patterns": [
        "\\b(what\\s+is|who\\s+is|who\\s+was|when\\s+was|where\\s+is)\\s+(?!.*(my|the|this|our)\\s+(document|file|contract|report|spreadsheet))\\b",
        "\\b(history\\s+of|origin\\s+of|invention\\s+of)\\s+(?!.*(document|term|clause))\\b",
        "\\b(how\\s+does\\s+.+\\s+work)\\s+(?!.*(in\\s+my|in\\s+the|this))\\b",
        "\\b(why\\s+(is|are|do|does)\\s+.+)\\s+(?!.*(my|the|this|document|file))\\b",
        "\\b(interesting\\s+facts?\\s+about|tell\\s+me\\s+about)\\s+(?!.*(my|the|this|document))\\b",
        "\\b(what\\s+(causes|caused)|how\\s+to\\s+prevent)\\s+(?!.*(error|issue|problem\\s+in))\\b",
        "\\b(best\\s+(way|method|practice)\\s+to)\\s+(?!.*(analyze|read|understand|find\\s+in))\\b",
        "\\b(pros\\s+and\\s+cons\\s+of|advantages\\s+of)\\s+(?!.*(clause|term|approach\\s+in))\\b",
        "\\b(difference\\s+between)\\s+(?!.*((in|from)\\s+(my|the|this)))\\b",
        "\\b(what\\s+are\\s+the\\s+(benefits|risks)\\s+of)\\s+(?!.*(in\\s+(my|the)|this))\\b"
      ],
      "examples": [
        "What is photosynthesis?",
        "Who was Albert Einstein?",
        "When was the Eiffel Tower built?",
        "How does gravity work?",
        "Why is the sky blue?",
        "History of the Roman Empire",
        "What causes earthquakes?",
        "Difference between AC and DC"
      ],
      "notes": "Use negative lookahead to avoid blocking document-related queries"
    },

    "pt": {
      "patterns": [
        "\\b(o\\s+que\\s+é|quem\\s+(é|foi)|quando\\s+foi|onde\\s+(é|fica))\\s+(?!.*(meu|minha|o|a|este|esse)\\s+(documento|arquivo|contrato|relatório))\\b",
        "\\b(história\\s+de|origem\\s+de|invenção\\s+de)\\s+(?!.*(documento|termo|cláusula))\\b",
        "\\b(como\\s+.+\\s+funciona)\\s+(?!.*(no\\s+meu|na\\s+minha|neste|nesse))\\b",
        "\\b(por\\s+que\\s+(é|são|tem|faz))\\s+(?!.*(meu|minha|o|a|este|documento|arquivo))\\b",
        "\\b(curiosidades?\\s+sobre|me\\s+fale\\s+sobre)\\s+(?!.*(meu|minha|o|a|este|documento))\\b",
        "\\b(o\\s+que\\s+(causa|causou)|como\\s+prevenir)\\s+(?!.*(erro|problema\\s+no))\\b",
        "\\b(melhor\\s+(forma|método|prática)\\s+para)\\s+(?!.*(analisar|ler|entender|encontrar\\s+no))\\b",
        "\\b(prós\\s+e\\s+contras\\s+de|vantagens\\s+de)\\s+(?!.*(cláusula|termo|abordagem\\s+no))\\b",
        "\\b(diferença\\s+entre)\\s+(?!.*((no|da|do)\\s+(meu|minha|o|a)))\\b",
        "\\b(quais\\s+(são\\s+)?os\\s+(benefícios|riscos)\\s+de)\\s+(?!.*(no\\s+(meu|minha)|neste))\\b"
      ],
      "examples": [
        "O que é fotossíntese?",
        "Quem foi Albert Einstein?",
        "Quando foi construída a Torre Eiffel?",
        "Como funciona a gravidade?",
        "Por que o céu é azul?",
        "História do Império Romano",
        "O que causa terremotos?",
        "Diferença entre CA e CC"
      ],
      "notes": "Use negative lookahead to avoid blocking document-related queries"
    }
  },

  "personal_advice": {
    "description": "Personal/life advice requests",
    "count": 200,
    "action": "polite_redirect",

    "en": {
      "patterns": [
        "\\b(should\\s+I|what\\s+should\\s+I\\s+do)\\s+(?!.*(with|about)\\s+(my|this|the)\\s+(document|file|contract))\\b",
        "\\b(give\\s+me\\s+advice|need\\s+advice)\\s+(?!.*(on|about)\\s+(my|this|the)\\s+(document|file|data))\\b",
        "\\b(how\\s+do\\s+I\\s+(deal|cope)\\s+with)\\b",
        "\\b(relationship|dating|love|marriage)\\s+(advice|tips|help)\\b",
        "\\b(career\\s+(advice|guidance)|job\\s+(search|hunting))\\s+(?!.*(in\\s+my|this|the)\\s+(document|resume))\\b",
        "\\b(mental\\s+health|therapy|counseling|depression|anxiety)\\b",
        "\\b(parenting|raising\\s+kids|family\\s+issues)\\b",
        "\\b(am\\s+I\\s+(right|wrong)|is\\s+it\\s+(okay|normal)\\s+to)\\b",
        "\\b(feeling\\s+(sad|happy|anxious|stressed|overwhelmed))\\b",
        "\\b(life\\s+(advice|tips|choices)|meaning\\s+of\\s+life)\\b"
      ],
      "examples": [
        "Should I quit my job?",
        "Give me relationship advice",
        "How do I deal with stress?",
        "Is it okay to feel this way?",
        "I'm feeling overwhelmed",
        "Need career guidance"
      ],
      "redirect_message": "I'm a document assistant and can't provide personal advice. For your documents, I'm happy to help!"
    },

    "pt": {
      "patterns": [
        "\\b(devo|o\\s+que\\s+(devo|eu\\s+deveria)\\s+fazer)\\s+(?!.*(com|sobre)\\s+(meu|minha|este|esse)\\s+(documento|arquivo|contrato))\\b",
        "\\b(me\\s+dê\\s+conselho|preciso\\s+de\\s+conselho)\\s+(?!.*(sobre|para)\\s+(meu|minha|este|esse)\\s+(documento|arquivo|dado))\\b",
        "\\b(como\\s+(lidar|enfrentar)\\s+(com|isso))\\b",
        "\\b(relacionamento|namoro|amor|casamento)\\s+(conselho|dica|ajuda)\\b",
        "\\b(conselho\\s+de\\s+carreira|orientação\\s+profissional|busca\\s+de\\s+emprego)\\s+(?!.*(no\\s+meu|neste|nesse)\\s+(documento|currículo))\\b",
        "\\b(saúde\\s+mental|terapia|aconselhamento|depressão|ansiedade)\\b",
        "\\b(criação\\s+de\\s+filhos|paternidade|questões\\s+familiares)\\b",
        "\\b(estou\\s+(certo|errado)|é\\s+(normal|ok)\\s+sentir)\\b",
        "\\b(me\\s+sentindo\\s+(triste|feliz|ansioso|estressado|sobrecarregado))\\b",
        "\\b((conselho|dica)\\s+de\\s+vida|sentido\\s+da\\s+vida)\\b"
      ],
      "examples": [
        "Devo largar meu emprego?",
        "Me dê conselho sobre relacionamento",
        "Como lidar com estresse?",
        "É normal sentir isso?",
        "Estou me sentindo sobrecarregado",
        "Preciso de orientação profissional"
      ],
      "redirect_message": "Sou um assistente de documentos e não posso dar conselhos pessoais. Para seus documentos, estou à disposição!"
    }
  },

  "entertainment": {
    "description": "Entertainment/games/fun requests",
    "count": 200,
    "action": "polite_redirect",

    "en": {
      "patterns": [
        "\\b(tell\\s+me\\s+a\\s+(joke|riddle|story|fun\\s+fact))\\b",
        "\\b(play\\s+(a\\s+)?(game|trivia|20\\s+questions))\\b",
        "\\b(sing\\s+(a\\s+)?song|make\\s+(a\\s+)?poem)\\b",
        "\\b(entertain\\s+me|I'?m\\s+bored|something\\s+fun)\\b",
        "\\b(would\\s+you\\s+rather|truth\\s+or\\s+dare)\\b",
        "\\b(make\\s+me\\s+laugh|cheer\\s+me\\s+up)\\b",
        "\\b(random\\s+(fact|trivia)|surprise\\s+me)\\b",
        "\\b(roleplay|pretend\\s+(you'?re|to\\s+be))\\b",
        "\\b(write\\s+a\\s+(poem|haiku|limerick|sonnet))\\b",
        "\\b(can\\s+you\\s+rap|beatbox|freestyle)\\b"
      ],
      "examples": [
        "Tell me a joke",
        "Let's play a game",
        "Sing me a song",
        "I'm bored, entertain me",
        "Would you rather...",
        "Write me a poem",
        "Pretend you're a pirate"
      ],
      "redirect_message": "I'm a document assistant focused on analyzing your files. For fun, try a general-purpose chatbot!"
    },

    "pt": {
      "patterns": [
        "\\b(conte\\s+(uma?\\s+)?(piada|charada|história|curiosidade))\\b",
        "\\b(jogue\\s+(um\\s+)?(jogo|trivia)|vamos\\s+jogar)\\b",
        "\\b(cante\\s+(uma?\\s+)?música|faça\\s+(um\\s+)?poema)\\b",
        "\\b(me\\s+entretenha|estou\\s+entediado|algo\\s+divertido)\\b",
        "\\b(você\\s+prefere|verdade\\s+ou\\s+desafio)\\b",
        "\\b(me\\s+faça\\s+rir|me\\s+anime)\\b",
        "\\b((fato|curiosidade)\\s+aleatório|me\\s+surpreenda)\\b",
        "\\b(roleplay|finja\\s+que\\s+(você\\s+)?é)\\b",
        "\\b(escreva\\s+(um\\s+)?(poema|haiku|soneto))\\b",
        "\\b(você\\s+(sabe|pode)\\s+(cantar|rapear))\\b"
      ],
      "examples": [
        "Conte uma piada",
        "Vamos jogar um jogo",
        "Cante uma música",
        "Estou entediado, me entretenha",
        "Você prefere...",
        "Escreva um poema",
        "Finja que é um pirata"
      ],
      "redirect_message": "Sou um assistente de documentos focado em analisar seus arquivos. Para diversão, tente um chatbot geral!"
    }
  },

  "meta_questions": {
    "description": "Questions about Koda itself, AI, capabilities",
    "count": 200,
    "action": "route_to_help",

    "en": {
      "patterns": [
        "\\b(who|what)\\s+are\\s+you\\b",
        "\\b(are\\s+you\\s+(a|an)\\s+(robot|AI|human|bot|real))\\b",
        "\\b(what\\s+can\\s+you\\s+do|what\\s+are\\s+your\\s+capabilities)\\b",
        "\\b(how\\s+do\\s+you\\s+work|how\\s+were\\s+you\\s+(made|created|built))\\b",
        "\\b(do\\s+you\\s+have\\s+(feelings|emotions|consciousness))\\b",
        "\\b(are\\s+you\\s+(sentient|alive|conscious|self-aware))\\b",
        "\\b(who\\s+(made|created|built)\\s+you)\\b",
        "\\b(what'?s\\s+your\\s+(name|purpose|goal))\\b",
        "\\b(can\\s+you\\s+(learn|remember|think|feel))\\b",
        "\\b(do\\s+you\\s+(know|understand)\\s+me)\\b",
        "\\bhow\\s+smart\\s+are\\s+you\\b",
        "\\bwhat\\s+model\\s+are\\s+you\\b",
        "\\bare\\s+you\\s+(gpt|chatgpt|claude|gemini|bard)\\b"
      ],
      "examples": [
        "Who are you?",
        "Are you an AI?",
        "What can you do?",
        "How do you work?",
        "Do you have feelings?",
        "Who created you?",
        "What's your name?",
        "Are you ChatGPT?"
      ],
      "notes": "Route to help/product info handler"
    },

    "pt": {
      "patterns": [
        "\\b(quem|o\\s+que)\\s+(é\\s+)?você\\b",
        "\\b(você\\s+é\\s+(um\\s+)?(robô|IA|humano|bot|real))\\b",
        "\\b(o\\s+que\\s+(você\\s+)?pode\\s+fazer|quais\\s+são\\s+suas\\s+capacidades)\\b",
        "\\b(como\\s+você\\s+funciona|como\\s+(você\\s+foi|foi)\\s+(feito|criado))\\b",
        "\\b(você\\s+(tem|possui)\\s+(sentimentos|emoções|consciência))\\b",
