{
  "_meta": {
    "type": "audit_report_schema",
    "description": "Standardizes audit output - prevents fixing instead of reporting",
    "version": "1.0"
  },

  "report_structure": {
    "header": {
      "audit_id": {
        "type": "string",
        "format": "uuid",
        "required": true
      },
      "timestamp": {
        "type": "string",
        "format": "ISO8601",
        "required": true
      },
      "auditor": {
        "type": "string",
        "description": "Who/what performed the audit",
        "required": true
      },
      "files_audited": {
        "type": "array",
        "items": "string",
        "required": true
      }
    },

    "summary": {
      "overall_score": {
        "type": "number",
        "min": 0,
        "max": 100,
        "required": true
      },
      "status": {
        "type": "enum",
        "values": ["PASS", "WARN", "FAIL", "CRITICAL"],
        "required": true
      },
      "critical_issues": {
        "type": "number",
        "required": true
      },
      "warnings": {
        "type": "number",
        "required": true
      },
      "recommendations": {
        "type": "number",
        "required": true
      }
    },

    "findings": {
      "type": "array",
      "items": {
        "finding_id": "string",
        "severity": {
          "type": "enum",
          "values": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
        },
        "category": {
          "type": "enum",
          "values": ["STRUCTURE", "CONTENT", "CONSISTENCY", "COMPLETENESS", "SAFETY"]
        },
        "file": "string",
        "location": "string",
        "description": "string",
        "evidence": "string",
        "recommendation": "string",
        "auto_fixable": "boolean"
      }
    }
  },

  "severity_definitions": {
    "CRITICAL": {
      "description": "System will not function correctly",
      "requires_immediate_action": true,
      "blocks_deployment": true
    },
    "HIGH": {
      "description": "Significant functionality impacted",
      "requires_action": true,
      "blocks_deployment": false
    },
    "MEDIUM": {
      "description": "Suboptimal but functional",
      "requires_action": false,
      "recommended_fix": true
    },
    "LOW": {
      "description": "Minor issue",
      "informational": true
    },
    "INFO": {
      "description": "Observation only",
      "informational": true
    }
  },

  "audit_categories": {
    "STRUCTURE": {
      "checks": [
        "required_keys_present",
        "schema_compliance",
        "valid_json"
      ]
    },
    "CONTENT": {
      "checks": [
        "no_empty_arrays",
        "no_placeholder_values",
        "values_in_valid_range"
      ]
    },
    "CONSISTENCY": {
      "checks": [
        "cross_file_references_valid",
        "no_contradictions",
        "naming_conventions"
      ]
    },
    "COMPLETENESS": {
      "checks": [
        "all_intents_defined",
        "all_domains_defined",
        "all_languages_covered"
      ]
    },
    "SAFETY": {
      "checks": [
        "no_pii_in_examples",
        "disclaimers_present",
        "high_stakes_guardrails"
      ]
    }
  },

  "output_rules": {
    "report_only": {
      "description": "Audit MUST only report findings, never auto-fix",
      "enforcement": "strict"
    },
    "evidence_required": {
      "description": "Every finding must include evidence",
      "enforcement": "strict"
    },
    "actionable_recommendations": {
      "description": "Recommendations must be specific and actionable",
      "enforcement": "recommended"
    }
  },

  "example_finding": {
    "finding_id": "F001",
    "severity": "HIGH",
    "category": "STRUCTURE",
    "file": "intent_patterns.json",
    "location": "intents.DOCUMENTS",
    "description": "Missing _meta key in intent patterns file",
    "evidence": "File does not contain _meta at root level",
    "recommendation": "Add _meta with type='intent_surface_forms_only' and protection flags",
    "auto_fixable": true
  }
}
