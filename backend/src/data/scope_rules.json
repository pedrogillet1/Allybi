  "scope_detection_rules": {
    "priority_order": [
      "single_document",
      "named_document",
      "multi_document_comparison",
      "folder_scope",
      "document_type",
      "recent_documents",
      "all_documents",
      "no_document_scope"
    ],

    "disambiguation_rules": [
      {
        "condition": "filename_extension_present",
        "boost": "named_document",
        "boost_amount": 0.25
      },
      {
        "condition": "demonstrative_pronoun",
        "patterns": ["this", "that", "este", "esse", "esta", "essa"],
        "boost": "single_document",
        "boost_amount": 0.30
      },
      {
        "condition": "comparison_operator",
        "boost": "multi_document_comparison",
        "boost_amount": 0.35
      },
      {
        "condition": "plural_documents",
        "patterns": ["documents", "files", "all", "every", "documentos", "arquivos", "todos", "todas"],
        "boost": "all_documents",
        "boost_amount": 0.20
      },
      {
        "condition": "time_reference",
        "patterns": ["recent", "latest", "today", "yesterday", "recente", "último", "hoje", "ontem"],
        "boost": "recent_documents",
        "boost_amount": 0.25
      },
      {
        "condition": "folder_reference",
        "patterns": ["folder", "directory", "pasta", "diretório"],
        "boost": "folder_scope",
        "boost_amount": 0.30
      }
    ],

    "conflict_resolution": {
      "single_vs_named": {
        "rule": "If filename is detected, prefer named_document over single_document",
        "action": "select_named_document"
      },
      "all_vs_type": {
        "rule": "If specific file type mentioned with 'all', use document_type scope",
        "action": "select_document_type"
      },
      "comparison_vs_all": {
        "rule": "If comparison keywords present, always use multi_document_comparison",
        "action": "select_multi_document_comparison"
      }
    }
  },

  "cross_contamination_prevention": {
    "description": "Rules to prevent mixing data from unrelated documents",
    "rules": [
      {
        "id": "single_doc_isolation",
        "scope": "single_document",
        "rule": "When scope is single_document, only include chunks from the specified document",
        "enforcement": "strict"
      },
      {
        "id": "named_doc_isolation",
        "scope": "named_document",
        "rule": "When filename is specified, filter chunks to only that document",
        "enforcement": "strict"
      },
      {
        "id": "folder_boundary",
        "scope": "folder_scope",
        "rule": "When folder is specified, include only documents from that folder and subfolders",
        "enforcement": "strict"
      },
      {
        "id": "type_filter",
        "scope": "document_type",
        "rule": "When type is specified, filter to only matching MIME types",
        "enforcement": "strict"
      },
      {
        "id": "comparison_pairing",
        "scope": "multi_document_comparison",
        "rule": "When comparing, clearly separate and label data from each document",
        "enforcement": "strict"
      },
      {
        "id": "recent_time_bound",
        "scope": "recent_documents",
        "rule": "Apply time filter based on detected time indicator",
        "enforcement": "moderate"
      }
    ]
  },

