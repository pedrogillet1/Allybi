{
  "_meta": {
    "type": "intent_classification_labels",
    "description": "Single source of truth for intent classes - NO domains here",
    "version": "1.0",
    "usage": "ML model output labels"
  },

  "labels": {
    "DOCUMENTS": {
      "id": 0,
      "name": "DOCUMENTS",
      "description": "Document-level operations: navigation, structure, TOC, search",
      "tier": 0,
      "examples": [
        "What's in this document?",
        "Show me the table of contents",
        "Go to section 3",
        "Find all mentions of termination"
      ]
    },
    "EXTRACTION": {
      "id": 1,
      "name": "EXTRACTION",
      "description": "Data extraction: pull specific values, fields, tables",
      "tier": 0,
      "examples": [
        "What is the contract value?",
        "Extract all parties mentioned",
        "Pull the payment terms",
        "Get the effective date"
      ]
    },
    "REASONING": {
      "id": 2,
      "name": "REASONING",
      "description": "Analysis, comparison, inference, decision support",
      "tier": 0,
      "examples": [
        "Compare these two clauses",
        "What are the risks in this agreement?",
        "Analyze the liability terms",
        "Is this contract favorable?"
      ]
    },
    "EDIT": {
      "id": 3,
      "name": "EDIT",
      "description": "Document modification: draft, revise, redline",
      "tier": 1,
      "examples": [
        "Suggest a revision to this clause",
        "Draft a response",
        "Rewrite this in simpler terms",
        "Make this more formal"
      ]
    },
    "HELP": {
      "id": 4,
      "name": "HELP",
      "description": "Product help, onboarding, feature explanation",
      "tier": 1,
      "examples": [
        "How do I upload a document?",
        "What can you do?",
        "Help me get started",
        "Show me the features"
      ]
    },
    "CONVERSATION": {
      "id": 5,
      "name": "CONVERSATION",
      "description": "General chat, greetings, non-document queries",
      "tier": 1,
      "examples": [
        "Hello",
        "Thank you",
        "Good morning",
        "That's helpful"
      ]
    },
    "MEMORY": {
      "id": 6,
      "name": "MEMORY",
      "description": "Context recall, session history",
      "tier": 2,
      "examples": [
        "What did I ask before?",
        "Remember this",
        "Forget that",
        "What documents have we looked at?"
      ]
    },
    "PREFERENCES": {
      "id": 7,
      "name": "PREFERENCES",
      "description": "User settings, personalization",
      "tier": 2,
      "examples": [
        "Change my language to Portuguese",
        "Make responses shorter",
        "Always show citations",
        "What are my current settings?"
      ]
    },
    "FILE_ACTIONS": {
      "id": 8,
      "name": "FILE_ACTIONS",
      "description": "File operations: upload, download, convert",
      "tier": 2,
      "examples": [
        "Upload this file",
        "Download as PDF",
        "Convert to Word",
        "Delete this document"
      ]
    },
    "ERROR": {
      "id": 9,
      "name": "ERROR",
      "description": "Error handling, recovery",
      "tier": 2,
      "examples": [
        "Something went wrong",
        "That didn't work",
        "Try again",
        "What happened?"
      ]
    }
  },

  "label_constraints": {
    "mutually_exclusive": false,
    "max_labels_per_query": 2,
    "primary_secondary_allowed": true,
    "fallback_label": "CONVERSATION"
  },

  "training_notes": {
    "balance": "Oversample TIER-2 intents during training",
    "augmentation": "Use paraphrase augmentation for low-frequency intents",
    "negative_sampling": "Include domain-specific negatives"
  }
}
