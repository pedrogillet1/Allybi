  "_meta": {
    "type": "domain_activation_6_layer",
    "description": "6-layer domain activation system - keywords detect signals, gates decide activation",
    "version": "2.0",
    "do_not_prune": true,
    "architecture": [
      "LAYER 1: Strong Anchors (artifact-based, must have >=1)",
      "LAYER 2: Structural Signals (format-based, must have >=1)",
      "LAYER 3: Reinforcement Keywords (weighted, not decisive)",
      "LAYER 4: Negative Blockers (absolute overrides)",
      "LAYER 5: Tie-Breaker Patterns (collision resolution only)",
      "LAYER 6: Activation Threshold (final decision)"
    ],
    "core_rule": "A domain activates ONLY when: >=1 anchor + >=1 structure + reinforcement_score >= threshold + no blockers + tie-breakers resolve",
