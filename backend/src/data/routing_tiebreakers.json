        "rationale": "PT: Value extraction"
      },
      {
        "id": "TB022",
        "if_contains": ["mostrar", "página", "seção"],
        "route_to": "DOCUMENTS",
        "rationale": "PT: Navigation"
      },
      {
        "id": "TB023",
        "if_contains": ["analisar", "implicações", "cláusula"],
        "route_to": "REASONING",
        "rationale": "PT: Legal analysis"
      },
      {
        "id": "TB024",
        "if_contains": ["extraer", "valor", "documento"],
        "route_to": "EXTRACTION",
        "rationale": "ES: Value extraction"
      },
      {
        "id": "TB025",
        "if_contains": ["mostrar", "página", "sección"],
        "route_to": "DOCUMENTS",
        "rationale": "ES: Navigation"
      },
      {
        "id": "TB026",
        "if_contains": ["analizar", "implicaciones", "cláusula"],
        "route_to": "REASONING",
        "rationale": "ES: Legal analysis"
      },
      {
        "id": "TB027",
        "if_contains": ["editar", "texto", "modificar"],
