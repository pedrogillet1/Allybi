        "if_contains": ["lembrar", "preferência", "sempre"],
        "route_to": "PREFERENCES",
        "rationale": "PT: Preference setting"
      },
      {
        "id": "TB029",
        "if_contains": ["recordar", "preferencia", "siempre"],
        "route_to": "PREFERENCES",
        "rationale": "ES: Preference setting"
      },
      {
        "id": "TB030",
        "if_contains": ["erro", "falhou", "não funciona"],
        "route_to": "ERROR",
        "rationale": "PT: Error report"
      }
    ]
  },

  "fallback_rules": {
    "description": "When no explicit tiebreaker matches, use these rules",

    "same_tier_conflict": {
      "rule": "Use precedence_order - first match wins",
      "example": "If EXTRACTION and DOCUMENTS both have STRONG match, EXTRACTION wins (higher in precedence)"
    },

    "different_tier_conflict": {
      "rule": "Higher tier always wins regardless of precedence",
      "example": "STRONG CONVERSATION beats MEDIUM EXTRACTION"
    },

    "no_strong_match": {
      "rule": "Require at least one MEDIUM match + context confirmation",
      "fallback": "CONVERSATION"
    },

    "ambiguous_after_tiebreakers": {
      "rule": "Log for manual review, route to higher precedence intent",
      "log_path": "routing_ambiguity_log"
    }
  },

  "validation": {
    "all_intents_covered": true,
    "multilingual_support": ["en", "pt", "es"],
    "total_explicit_rules": 30,
    "last_updated": "2025-01-01T00:00:00.000Z"
  }
}
