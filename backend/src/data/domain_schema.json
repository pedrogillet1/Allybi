{
  "_meta": {
    "type": "domain_structural_definitions",
    "description": "Domain logic definitions - SEPARATE from intents",
    "do_not_add_keywords": true,
    "do_not_add_patterns": true,
    "related_files": {
      "keywords_patterns": "domain_layers.json",
      "routing_priority": "routing_priority.json"
    }
  },

  "LEGAL": {
    "description": "Legal documents, contracts, regulatory compliance",
    "tier": 0,
    "activation_gates": {
      "document_types": ["contract", "agreement", "nda", "terms", "policy", "compliance", "regulatory"],
      "content_signals": ["clause", "party", "obligation", "liability", "indemnification"],
      "min_confidence": 0.7
    },
    "hard_blockers": {
      "prohibited_outputs": ["legal_advice", "binding_interpretation", "liability_assessment"],
      "disclaimer_required": true
    },
    "output_baselines": {
      "quote_first": true,
      "citation_required": true,
      "section_references": true,
      "confidence_disclosure": true
    },
    "precision_rules": {
      "exact_language": true,
      "no_paraphrase_for_definitions": true,
      "preserve_legal_terms": true
    },
    "disclaimers": {
      "standard": "This is not legal advice. Consult a qualified attorney.",
      "interpretation": "This analysis is for informational purposes only.",
      "binding": "Only the original document language is legally binding."
    },
    "risk_modifiers": {
      "high_stakes": ["liability_clause", "indemnification", "termination", "penalty"],
      "requires_confirmation": ["delete_clause", "modify_term", "waive_right"]
    }
  },

  "MEDICAL": {
    "description": "Medical records, clinical documents, healthcare content",
    "tier": 0,
    "activation_gates": {
      "document_types": ["medical_record", "clinical_note", "lab_report", "prescription", "discharge_summary"],
      "content_signals": ["diagnosis", "treatment", "medication", "symptom", "prognosis"],
      "min_confidence": 0.8
    },
    "hard_blockers": {
      "prohibited_outputs": ["diagnosis", "treatment_recommendation", "medication_change", "prognosis"],
      "disclaimer_required": true,
      "hipaa_consideration": true
    },
    "output_baselines": {
      "quote_first": true,
      "citation_required": true,
      "uncertainty_explicit": true,
      "no_clinical_judgment": true
    },
    "precision_rules": {
      "exact_values": true,
      "units_required": true,
      "no_interpolation": true,
      "reference_ranges_verbatim": true
    },
    "disclaimers": {
      "standard": "This is not medical advice. Consult a healthcare professional.",
      "clinical": "This information is extracted from documents and should not guide clinical decisions.",
      "emergency": "If this is a medical emergency, contact emergency services immediately."
    },
    "risk_modifiers": {
      "high_stakes": ["allergy", "contraindication", "critical_value", "emergency"],
      "requires_confirmation": ["medication_info", "dosage", "clinical_finding"]
    }
  },

  "FINANCE": {
    "description": "Financial reports, statements, accounting, investment content",
    "tier": 1,
    "activation_gates": {
      "document_types": ["financial_statement", "annual_report", "balance_sheet", "income_statement", "10k", "10q"],
      "content_signals": ["revenue", "expense", "asset", "liability", "equity", "ratio"],
      "min_confidence": 0.7
    },
    "hard_blockers": {
      "prohibited_outputs": ["investment_advice", "buy_sell_recommendation", "valuation_opinion"],
      "disclaimer_required": true
    },
    "output_baselines": {
      "precision_required": true,
      "currency_explicit": true,
      "period_explicit": true,
      "source_citation": true
    },
    "precision_rules": {
      "decimal_places": "as_stated",
      "currency_symbol": true,
      "thousands_separator": true,
      "percentage_format": true
    },
    "disclaimers": {
      "standard": "This is not financial advice. Consult a qualified financial advisor.",
      "investment": "Past performance does not guarantee future results.",
      "accuracy": "Verify all figures against original source documents."
    },
    "risk_modifiers": {
      "high_stakes": ["material_change", "restatement", "audit_opinion", "going_concern"],
      "requires_confirmation": ["calculation", "ratio_derivation", "period_comparison"]
    }
  },

  "ENGINEERING": {
    "description": "Technical specifications, CAD, engineering documents",
    "tier": 1,
    "activation_gates": {
      "document_types": ["specification", "drawing", "bom", "test_report", "design_doc", "requirements"],
      "content_signals": ["tolerance", "dimension", "material", "assembly", "component"],
      "min_confidence": 0.7
    },
    "hard_blockers": {
      "prohibited_outputs": ["safety_certification", "compliance_approval", "structural_sign_off"],
      "disclaimer_required": true
    },
    "output_baselines": {
      "units_explicit": true,
      "tolerances_preserved": true,
      "standards_referenced": true,
      "revision_tracked": true
    },
    "precision_rules": {
      "units_mandatory": true,
      "significant_figures": "preserve",
      "tolerance_format": "as_stated",
      "coordinate_system": "explicit"
    },
    "disclaimers": {
      "standard": "This is extracted information. Verify against official specifications.",
      "safety": "Safety-critical dimensions must be verified by qualified engineer.",
      "compliance": "Compliance with standards must be confirmed by authorized personnel."
    },
    "risk_modifiers": {
      "high_stakes": ["safety_critical", "load_bearing", "pressure_rated", "electrical_rating"],
      "requires_confirmation": ["dimension_change", "material_substitution", "tolerance_modification"]
    }
  },

  "_EXCEL_REMOVED": {
    "_comment": "EXCEL REMOVED AS DOMAIN - Now handled as FILE_ACTIONS.excel intent",
    "_reason": "Excel is HOW data is accessed, not WHAT kind of knowledge. Domains answer what kind of knowledge.",
    "_migration_date": "2025-12-18",
    "_see_instead": "intent_schema.json -> FILE_ACTIONS.sub_intents.excel"
  }
}
