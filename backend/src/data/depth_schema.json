{
  "_meta": {
    "type": "depth_semantic_definitions",
    "description": "Depth level semantics - ORTHOGONAL to intent and domain",
    "version": "1.0",
    "related_files": {
      "intent_schema": "intent_schema.json",
      "domain_schema": "domain_schema.json"
    }
  },

  "depth_levels": {
    "D1": {
      "name": "Surface",
      "description": "Quick, surface-level response",
      "triggers": ["quick", "brief", "short", "just", "simply", "basic"],
      "minimum_output": {
        "sentences": 1,
        "max_sentences": 3,
        "evidence_required": false
      },
      "allowed_behaviors": ["direct_answer", "yes_no", "single_value", "quick_summary"],
      "forbidden_behaviors": ["deep_analysis", "multi_source_synthesis", "caveats"],
      "example": "What is the contract value? → '$50,000'"
    },

    "D2": {
      "name": "Standard",
      "description": "Typical response with context",
      "triggers": ["tell me", "what is", "explain", "describe", "show me"],
      "minimum_output": {
        "sentences": 2,
        "max_sentences": 6,
        "evidence_required": true
      },
      "allowed_behaviors": ["explanation", "context", "single_source_citation", "basic_reasoning"],
      "forbidden_behaviors": ["exhaustive_analysis", "speculation", "multi_document_synthesis"],
      "example": "What is the contract value? → 'The contract value is $50,000 as stated in Section 3.1 (Compensation).'"
    },

    "D3": {
      "name": "Detailed",
      "description": "Comprehensive response with analysis",
      "triggers": ["detail", "explain fully", "analyze", "break down", "elaborate", "comprehensive"],
      "minimum_output": {
        "sentences": 5,
        "max_sentences": 15,
        "evidence_required": true,
        "multiple_citations": true
      },
      "allowed_behaviors": ["detailed_explanation", "multi_source_citation", "reasoning_chain", "related_context"],
      "forbidden_behaviors": ["speculation_without_evidence", "off-topic_tangents"],
      "example": "Analyze the contract value → Multiple sections referenced, payment terms, conditions, etc."
    },

    "D4": {
      "name": "Expert",
      "description": "Expert-level analysis with cross-references",
      "triggers": ["thorough", "complete analysis", "expert review", "due diligence", "comprehensive review"],
      "minimum_output": {
        "sentences": 10,
        "max_sentences": 30,
        "evidence_required": true,
        "cross_document_ok": true,
        "caveats_required": true
      },
      "allowed_behaviors": ["cross_document_analysis", "comparative_analysis", "gap_identification", "risk_assessment"],
      "forbidden_behaviors": ["definitive_conclusions_without_evidence", "legal_medical_advice"],
      "example": "Comprehensive contract review → Full analysis across all sections with risk flags"
    },

    "D5": {
      "name": "Exhaustive",
      "description": "Maximum depth - forensic level analysis",
      "triggers": ["exhaustive", "forensic", "leave nothing out", "every detail", "complete audit"],
      "minimum_output": {
        "sentences": 20,
        "max_sentences": null,
        "evidence_required": true,
        "all_sources_cited": true,
        "uncertainty_explicit": true
      },
      "allowed_behaviors": ["exhaustive_enumeration", "all_relevant_sections", "uncertainty_quantification", "alternative_interpretations"],
      "forbidden_behaviors": ["omission_without_explanation"],
      "example": "Forensic contract analysis → Every relevant clause, all interpretations, all risks"
    }
  },

  "depth_escalation_rules": {
    "description": "When to automatically adjust depth",
    "rules": [
      {
        "condition": "ambiguous_query",
        "action": "default_to_D2"
      },
      {
        "condition": "multiple_questions",
        "action": "match_complexity"
      },
      {
        "condition": "high_stakes_domain",
        "action": "minimum_D3"
      },
      {
        "condition": "explicit_quick",
        "action": "honor_D1_request"
      }
    ]
  },

  "depth_domain_overrides": {
    "LEGAL": {
      "min_depth": "D2",
      "reason": "Legal queries require context and citation"
    },
    "MEDICAL": {
      "min_depth": "D2",
      "reason": "Medical queries require source attribution"
    },
    "FINANCE": {
      "min_depth": "D2",
      "reason": "Financial data requires precision context"
    }
  }
}
