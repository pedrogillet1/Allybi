# Server Configuration
PORT=5000
NODE_ENV=development

# Database - Local Postgres (use docker-compose.dev.yml)
DATABASE_URL="postgresql://koda:koda@localhost:5432/koda_dev?schema=public"
DIRECT_DATABASE_URL="postgresql://koda:koda@localhost:5432/koda_dev?schema=public"

# Storage (Google Cloud Storage)
STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# JWT Secrets
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/apple/callback

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Backend URL
BACKEND_URL=http://localhost:5000

# Encryption (AES-256 — 64 hex chars = 256 bits)
ENCRYPTION_KEY=

# Google Cloud Vision API
ENABLE_GOOGLE_CLOUD_VISION=true

# Mistral API
MISTRAL_API_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Redis URL for BullMQ
REDIS_URL=

# Worker Configuration
WORKER_CONCURRENCY=2

# Email & SMS (Infobip)
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
EMAIL_FROM=info@getkoda.ai

# Gemini AI API
GEMINI_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# Google Custom Search API
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Pinecone (Vector Database)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# CloudConvert (PPTX → PDF conversion)
CLOUDCONVERT_API_KEY=

# Google Drive (for future Google Slides API integration)
GOOGLE_DRIVE_FOLDER_ID=
