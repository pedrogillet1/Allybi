# Server Configuration
PORT=5000
NODE_ENV=development

# Database - Local Postgres (use docker-compose.dev.yml)
# docker-compose.dev.yml maps container 5432 -> localhost 5433
DATABASE_URL="postgresql://koda:koda@localhost:5433/koda_dev?schema=public"
DIRECT_DATABASE_URL="postgresql://koda:koda@localhost:5433/koda_dev?schema=public"

# Storage (Google Cloud Storage)
STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# JWT Secrets
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# Gmail connector OAuth (optional; defaults to GOOGLE_* above)
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_CALLBACK_URL=http://localhost:5000/api/integrations/gmail/callback
GOOGLE_GMAIL_CALLBACK_URLS=http://localhost:5000/api/integrations/gmail/callback

# Microsoft Outlook connector OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/integrations/outlook/callback
# For single-tenant apps use your tenant ID; for multi-tenant use "common"
MICROSOFT_TENANT_ID=common

# Slack connector OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:5000/api/integrations/slack/callback
SLACK_REDIRECT_URIS=http://localhost:5000/api/integrations/slack/callback,https://allybi.co/api/integrations/slack/callback
SLACK_SIGNING_SECRET=

# Connector security/runtime flags
CONNECTOR_OAUTH_STATE_SECRET=
CONNECTOR_ACTION_SECRET=
CONNECTOR_TOKEN_STORAGE=file
CONNECTOR_TOKEN_VAULT_FAIL_CLOSED=false
# Chat-time connector operation timeout in milliseconds (clamped 1000-120000)
CONNECTOR_CHAT_OP_TIMEOUT_MS=15000
CONNECTORS_INGEST_AS_DOCUMENTS=false

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/apple/callback

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Backend URL
BACKEND_URL=http://localhost:5000

# Encryption (AES-256 — 64 hex chars = 256 bits)
ENCRYPTION_KEY=

# Google Cloud Vision API
ENABLE_GOOGLE_CLOUD_VISION=true

# Mistral API
MISTRAL_API_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Redis URL for BullMQ
REDIS_URL=

# Worker Configuration
WORKER_CONCURRENCY=2
STORAGE_DOWNLOAD_CONCURRENCY=8

# Email & SMS (Infobip)
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
EMAIL_FROM=info@allybi.co

# Gemini AI API
GEMINI_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# Google Custom Search API
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Pinecone (Vector Database)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Retrieval/Indexing Runtime Selectors
RETRIEVAL_V2_ENGINE=false
RETRIEVAL_V2_PRISMA_ADAPTERS=false
RETRIEVAL_V2_VECTOR_EMBEDDING=false

# Retrieval Behavior Flags
RETRIEVAL_SEMANTIC_PINECONE_PRIMARY=true
RETRIEVAL_SEMANTIC_DB_FALLBACK=true
RETRIEVAL_LEXICAL_FROM_EMBEDDINGS=false

# Indexing/Embedding Safety Flags
INDEXING_ENCRYPTED_CHUNKS_ONLY=true
INDEXING_STRICT_FAIL_CLOSED=true
EMBEDDING_FAILCLOSE_V1=true

# CloudConvert (PPTX → PDF conversion)
CLOUDCONVERT_API_KEY=

# Google Drive (for future Google Slides API integration)
GOOGLE_DRIVE_FOLDER_ID=

# ---------------------------------------------------------------------------
# Slides / Deck Generation (Google Slides + Templates + Visuals)
# ---------------------------------------------------------------------------
# Template presentations must contain archetype slides tagged with a tiny element whose
# description is "koda:layout:<LAYOUT_NAME>" (e.g. koda:layout:TITLE_AND_BODY).
KODA_SLIDES_TEMPLATE_BUSINESS_ID=
KODA_SLIDES_TEMPLATE_LEGAL_ID=
KODA_SLIDES_TEMPLATE_STATS_ID=
KODA_SLIDES_TEMPLATE_MEDICAL_ID=
KODA_SLIDES_TEMPLATE_BOOK_ID=
KODA_SLIDES_TEMPLATE_SCRIPT_ID=

# Optional: allow multiple template libraries per domain (comma-separated).
# Use this to build a "vast design library" and let Koda pick a variant per deck.
KODA_SLIDES_TEMPLATE_BUSINESS_IDS=
KODA_SLIDES_TEMPLATE_LEGAL_IDS=
KODA_SLIDES_TEMPLATE_STATS_IDS=
KODA_SLIDES_TEMPLATE_MEDICAL_IDS=
KODA_SLIDES_TEMPLATE_BOOK_IDS=
KODA_SLIDES_TEMPLATE_SCRIPT_IDS=

# stable|random|first|best (default: stable)
# best = scores layout variants per slide (prefers correct visual frames + stronger tag coverage)
KODA_SLIDES_TEMPLATE_VARIANT_MODE=stable

# To compile the built-in agency pack templates into Google Slides libraries:
#   cd backend && npm run compile:templates:agency
# Then copy the printed `KODA_SLIDES_TEMPLATE_*_IDS=...` into your env and restart the backend.

# Enable Nano Banana visuals for generated decks (cover/section headers, etc).
# Requires GEMINI_API_KEY. For local dev with STORAGE_PROVIDER=local, Koda will upload visuals to Drive
# temporarily so Slides can fetch them via HTTPS.
KODA_SLIDES_ENABLE_VISUALS=false

# If true, generate visuals even for legal/medical/stats slides that don't include an explicit visual prompt.
# Use with care for conservative domains.
KODA_SLIDES_VISUALS_FORCE=false

# If true, delete temporary Drive assets after inserting into Slides.
# Leave false while tuning templates/visuals to avoid intermittent missing-image issues.
KODA_SLIDES_DELETE_TEMP_ASSETS=false

# Optional brand label injected into creative prompts.
KODA_BRAND_NAME=Koda

# Optional override for the Imagen model name.
NANO_BANANA_MODEL=nano-banana-pro-preview

# Editing: save mode (overwrite | revision). Default: overwrite.
KODA_EDITING_SAVE_MODE=overwrite
# Keep undo history for overwrite edits. Default: true.
KODA_EDITING_KEEP_UNDO_HISTORY=true
