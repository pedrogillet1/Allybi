{
  "name": "@koda/dataset-generator",
  "version": "1.0.0",
  "description": "Dataset generator for KODA intent patterns, tests, and fallbacks using Claude API",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "koda-gen": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "generate": "tsx src/cli.ts generate",
    "validate": "tsx src/cli.ts validate",
    "ingest": "tsx src/cli.ts ingest",
    "gen:patterns": "tsx src/cli.ts generate --type patterns",
    "gen:tests": "tsx src/cli.ts generate --type tests",
    "gen:fallbacks": "tsx src/cli.ts generate --type fallbacks",
    "pipeline": "tsx src/cli.ts generate && tsx src/cli.ts validate && tsx src/cli.ts ingest",
    "clean:staging": "rimraf staging/*",
    "clean:validated": "rimraf validated/*"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.2.3",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
