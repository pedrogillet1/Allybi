{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --ignore 'logs/*' --ignore 'dist/*' --ignore '*.log' --ignore 'src/generated/*' --ignore 'node_modules/*' --ignore '*.test.ts' --ignore 'test-*.ts' --ignore 'check-*.ts' --ignore 'cleanup-*.ts' --ignore 'delete-*.ts' --ignore 'reprocess-*.ts' --exec ts-node --transpile-only src/server.ts",
    "predev": "prisma generate",
    "build": "prisma generate && tsc && cp -r src/data_banks dist/",
    "eval:retrieval": "ts-node --transpile-only scripts/eval/retrieval_eval.ts",
    "eval:retrieval:gate": "ts-node --transpile-only scripts/eval/retrieval_eval_gate.ts --mode=real_banks",
    "eval:document-understanding:strict": "ts-node --transpile-only scripts/eval/document_understanding_eval.ts --strict",
    "docint:verify:banks:strict": "npm run eval:document-understanding:strict",
    "docint:all": "ts-node --transpile-only scripts/run-script-suite.ts docint",
    "start": "node dist/server.js",
    "start:api": "KODA_RUNTIME_ROLE=api node dist/server.js",
    "start:worker:document": "KODA_RUNTIME_ROLE=worker-document node dist/server.js",
    "start:worker:connectors": "KODA_RUNTIME_ROLE=worker-connectors node dist/server.js",
    "start:worker:edit": "KODA_RUNTIME_ROLE=worker-edit node dist/server.js",
    "start:scheduler": "KODA_RUNTIME_ROLE=scheduler node dist/server.js",
    "start:pubsub": "node dist/workers/gcp-pubsub-worker.js",
    "start:pubsub:fanout": "node dist/workers/gcp-pubsub-fanout-worker.js",
    "worker": "ts-node --transpile-only src/workers/document-worker.ts",
    "worker:dev": "nodemon --exec ts-node src/workers/document-worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "jest --config jest.config.cjs",
    "test:benchmarks": "ts-node --transpile-only scripts/certification/run-jest-suite.ts benchmarks",
    "test:docint": "ts-node --transpile-only scripts/certification/run-jest-suite.ts docint",
    "test:retrieval:doclock": "ts-node --transpile-only scripts/certification/run-jest-suite.ts doclock",
    "test:cert:retrieval": "ts-node --transpile-only scripts/certification/run-jest-suite.ts retrieval",
    "test:cert:runtime": "ts-node --transpile-only scripts/certification/run-jest-suite.ts runtime",
    "test:cert:editing": "ts-node --transpile-only scripts/certification/run-jest-suite.ts editing",
    "test:cert:security": "ts-node --transpile-only scripts/certification/run-jest-suite.ts security",
    "test:cert:composition": "ts-node --transpile-only scripts/certification/run-jest-suite.ts composition",
    "test:cert:strict": "ts-node --transpile-only scripts/run-script-suite.ts cert:strict",
    "test:orchestrator-certification": "ts-node --transpile-only scripts/certification/run-orchestrator-certification.ts",
    "policy:cert:strict": "ts-node --transpile-only scripts/policy/run-certification.ts --strict",
    "policy:a-grade:assert": "ts-node --transpile-only scripts/policy/assert-a-grade.ts",
    "policy:audit:any": "ts-node --transpile-only scripts/policy/audit-production-any.ts",
    "policy:audit:env": "ts-node --transpile-only scripts/policy/audit-env-boundaries.ts",
    "policy:audit:file-caps": "ts-node --transpile-only scripts/policy/audit-file-caps.ts",
    "policy:composition:a-plus:assert": "ts-node --transpile-only scripts/policy/assert-composition-a-plus.ts",
    "security:scan": "./scripts/security/run-all.sh",
    "security:backfill-encrypt-plaintext": "npx ts-node --transpile-only scripts/security/backfill-encrypt-plaintext.ts",
    "security:backfill-doc-encryption": "npx ts-node scripts/security/backfill-document-encryption.ts",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint \"src/**/*.{ts,tsx,js,cjs}\" \"scripts/**/*.{ts,js,cjs}\" \"tools/**/*.{ts,js,cjs}\" \"*.{js,cjs,ts}\" --config eslint.config.cjs",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,cjs}\" \"scripts/**/*.{ts,js,cjs}\" \"tools/**/*.{ts,js,cjs}\" \"*.{js,cjs,ts}\" --config eslint.config.cjs --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "chat:module:file-caps": "ts-node --transpile-only scripts/chat-module/enforce-chat-file-caps.ts",
    "chat:module:no-any": "ts-node --transpile-only scripts/chat-module/detect-chat-any.ts",
    "chat:module:fix-env": "ts-node --transpile-only scripts/chat-module/split-runtime-env-reads.ts",
    "typecheck:chat": "tsc --noEmit src/controllers/chat.controller.ts src/controllers/rag.controller.ts src/services/chat.service.ts src/services/rag.service.ts",
    "audit:retrieval": "ts-node --transpile-only scripts/run-script-suite.ts audit:retrieval",
    "audit:editing": "ts-node --transpile-only scripts/run-script-suite.ts audit:editing",
    "audit:memory:strict": "npx ts-node --transpile-only scripts/memory-semantic-grade.ts --strict",
    "audit:routing": "ts-node --transpile-only scripts/audit-routing-alignment.ts",
    "check:all": "ts-node --transpile-only scripts/run-script-suite.ts check:all",
    "fix:all": "npm run lint:fix && npm run format",
    "prepare": "husky",
    "audit:operators:a-plus": "ts-node --transpile-only scripts/run-script-suite.ts audit:operators"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix --max-warnings=50",
      "prettier --write"
    ]
  },
  "keywords": [],
