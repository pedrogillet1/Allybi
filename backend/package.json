    "security:routes": "npx ts-node scripts/security/scan-unprotected-routes.ts",
    "security:plaintext": "npx ts-node scripts/security/scan-plaintext.ts",
    "security:backfill-doc-encryption": "npx ts-node scripts/security/backfill-document-encryption.ts",
