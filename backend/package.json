    "editing:validate-banks": "node scripts/editing/validate-editing-banks.mjs",
    "editing:validate-banks:ci": "node scripts/editing/validate-editing-banks.mjs --strict",
    "build:runtime-patterns": "ts-node --transpile-only tools/build/compile_runtime_patterns.ts",
    "build:win": "prisma generate && tsc && xcopy /E /I /Y src\\data dist\\data",
    "build:ignore-errors": "tsc --skipLibCheck --noEmitOnError false",
    "start": "node dist/server.js",
    "worker": "ts-node --transpile-only src/workers/document-worker.ts",
    "worker:dev": "nodemon --exec ts-node src/workers/document-worker.ts",
    "worker:prod": "node dist/workers/document-worker.js",
