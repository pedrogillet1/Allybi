    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:runtime-wiring": "jest --config jest.config.cjs --runTestsByPath src/controllers/rag.controller.test.ts src/services/chat/turnRouter.service.test.ts src/services/chat/guardrails/editorMode.guard.test.ts src/services/core/banks/runtimeWiringIntegrity.service.test.ts",
