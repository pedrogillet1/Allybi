    "test:cert:editing-roundtrip": "jest --config jest.config.cjs --runTestsByPath src/tests/certification/editing-roundtrip.cert.test.ts --runInBand",
    "test:cert:enforcer-failclosed": "jest --config jest.config.cjs --runTestsByPath src/tests/certification/enforcer-failclosed.cert.test.ts --runInBand",
    "test:cert:evidence-fidelity": "jest --config jest.config.cjs --runTestsByPath src/tests/certification/evidence-fidelity.cert.test.ts --runInBand",
    "test:cert:turn-debug-packet": "jest --config jest.config.cjs --runTestsByPath src/tests/certification/turn-debug-packet.cert.test.ts --runInBand",
    "test:cert:security-auth": "jest --config jest.config.cjs --runTestsByPath src/tests/certification/security-auth.cert.test.ts --runInBand",
