# KODA Backend - Local Development Environment
#
# Copy this to .env and adjust as needed:
#   cp .env.example.local .env
#
# Prerequisites:
#   docker compose -f ../docker-compose.local.yml up -d
#
# Then run:
#   npm run dev

# Server Configuration
PORT=5000
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE - Local PostgreSQL via Docker
# ═══════════════════════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://koda:koda_local_password@localhost:5432/koda_db?schema=public"
DIRECT_DATABASE_URL="postgresql://koda:koda_local_password@localhost:5432/koda_db?schema=public"

# ═══════════════════════════════════════════════════════════════════════════════
# AWS S3 - Using MinIO locally
# ═══════════════════════════════════════════════════════════════════════════════
# MinIO runs as local S3-compatible storage
# Console: http://localhost:9001 (minioadmin:minioadmin123)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=koda-local-uploads

# LOCAL S3 EMULATOR CONFIGURATION
# Set this to enable path-style URLs for MinIO/LocalStack
# Without this, presigned URLs won't work locally!
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true

# ═══════════════════════════════════════════════════════════════════════════════
# JWT SECRETS - Generate your own for production!
# ═══════════════════════════════════════════════════════════════════════════════
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-change-in-production
JWT_REFRESH_SECRET=local-dev-jwt-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ═══════════════════════════════════════════════════════════════════════════════
# CORS & URLs
# ═══════════════════════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ═══════════════════════════════════════════════════════════════════════════════
# ENCRYPTION - Generate a 64-char hex key for production!
# ═══════════════════════════════════════════════════════════════════════════════
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS - Local Docker Redis
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: External APIs (leave empty if not needed for upload testing)
# ═══════════════════════════════════════════════════════════════════════════════
# Google Cloud Vision (for OCR)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GCS_KEY_FILE=
GOOGLE_APPLICATION_CREDENTIALS=
ENABLE_GOOGLE_CLOUD_VISION=false

# OpenAI (for chat)
OPENAI_API_KEY=

# Gemini (for embeddings)
GEMINI_API_KEY=

# Pinecone (for vector search)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
