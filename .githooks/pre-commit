#!/bin/bash
# Pre-commit hook to detect secrets and sshpass usage

echo "🔍 Running secret detection..."

# Check for sshpass
if git diff --cached --name-only | xargs grep -l 'sshpass' 2>/dev/null; then
  echo "❌ ERROR: sshpass usage detected in staged files!"
  echo "   Use SSH keys instead of password-based authentication."
  exit 1
fi

# Check for hardcoded passwords (common patterns)
if git diff --cached | grep -E '(password|passwd|pwd)\s*[=:]\s*["'\'''][^"'\'']+["'\''']' 2>/dev/null; then
  echo "❌ ERROR: Hardcoded password pattern detected!"
  echo "   Use environment variables or secrets management."
  exit 1
fi

# Check for AWS keys
if git diff --cached | grep -E 'AKIA[A-Z0-9]{16}' 2>/dev/null; then
  echo "❌ ERROR: AWS Access Key detected!"
  exit 1
fi

# Check for private keys
if git diff --cached | grep -E '-----BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----' 2>/dev/null; then
  echo "❌ ERROR: Private key detected!"
  exit 1
fi

# Check for JWT secrets
if git diff --cached | grep -E 'JWT_SECRET\s*=\s*["'\'''][^"'\'']+["'\''']' 2>/dev/null; then
  echo "❌ ERROR: JWT secret detected in code!"
  exit 1
fi

echo "✅ No secrets detected in staged files."
exit 0
