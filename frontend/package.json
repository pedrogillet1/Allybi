{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@clerk/clerk-react": "^5.49.1",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.91.0",
    "axios": "^1.12.2",
    "framer-motion": "^12.29.2",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.11.0",
    "p-limit": "^7.2.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-i18next": "^16.3.5",
    "react-is": "^19.2.0",
    "react-markdown": "^9.0.1",
    "react-pdf": "^10.2.0",
    "react-phone-number-input": "^3.4.12",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.2.1",
    "rehype-raw": "^7.0.0",
    "remark-emoji": "^4.0.1",
    "remark-gfm": "^4.0.0",
    "socket.io-client": "^4.8.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:e2e": "npx playwright test",
    "test:e2e:harness": "npx playwright test -c playwright.harness.config.ts",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:harness:headed": "npx playwright test -c playwright.harness.config.ts --headed",
    "reports:hygiene:prepare": "node e2e/grading/report-hygiene.mjs --prepare",
    "reports:hygiene:prepare:reset": "node e2e/grading/report-hygiene.mjs --prepare --reset-latest",
    "reports:hygiene:prepare:force-reset": "node e2e/grading/report-hygiene.mjs --prepare --reset-latest --force-reset-latest",
    "reports:hygiene:check": "node e2e/grading/report-hygiene.mjs --check",
    "reports:lineage:bootstrap": "node e2e/grading/bootstrap-report-lineage.mjs",
    "reports:lineage:bootstrap:strict": "node e2e/grading/bootstrap-report-lineage.mjs --strict",
    "reports:lineage:check": "node e2e/grading/validate-report-lineage.mjs",
    "audit:a11y:semantic-click": "node e2e/grading/a11y-semantic-click-audit.mjs --max-violations 225",
    "grade:harsh": "node e2e/grading/run-harsh-rubric.mjs",
    "test:preflight:frontend-queries": "node e2e/grading/preflight-queries.mjs",
    "test:preflight:frontend-queries:full": "node e2e/grading/preflight-queries.mjs --run-100"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": "off",
      "react-hooks/exhaustive-deps": "off",
      "import/no-anonymous-default-export": "off",
      "no-useless-escape": "off",
      "no-loop-func": "off",
      "jsx-a11y/alt-text": "off",
      "jsx-a11y/role-supports-aria-props": "off",
      "jsx-a11y/anchor-is-valid": "off",
      "default-case": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.2.3"
  }
}
